{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"GINT64_FORMAT"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some platforms do not support scanning and printing 64-bit integers,"},{"type":"text","text":" "},{"type":"text","text":"even though the types are supported. On such platforms "},{"type":"codeVoice","code":"G_GINT64_FORMAT"},{"type":"text","text":" "},{"type":"text","text":"is not defined. Note that "},{"type":"codeVoice","code":"scanf()"},{"type":"text","text":" may not support 64-bit integers, even"},{"type":"text","text":" "},{"type":"text","text":"if "},{"type":"codeVoice","code":"G_GINT64_FORMAT"},{"type":"text","text":" is defined. Due to its weak error handling, "},{"type":"codeVoice","code":"scanf()"},{"type":"text","text":" "},{"type":"text","text":"is not recommended for parsing anyway; consider using "},{"type":"codeVoice","code":"g_ascii_strtoull()"},{"type":"text","text":" "},{"type":"text","text":"instead."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is not necessarily the correct format for printing and scanning"},{"type":"text","text":" "},{"type":"codeVoice","code":"int64_t"},{"type":"text","text":" values, even though the in-memory representation is the same."},{"type":"text","text":" "},{"type":"text","text":"Standard C macros like "},{"type":"codeVoice","code":"PRID64"},{"type":"text","text":" and "},{"type":"codeVoice","code":"SCNd64"},{"type":"text","text":" should be used for "},{"type":"codeVoice","code":"int64_t"},{"type":"text","text":"."}]}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"variants":[{"paths":["\/documentat
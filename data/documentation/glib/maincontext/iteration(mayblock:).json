{"metadata":{"extendedModule":"GLib","roleHeading":"Instance Method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"iteration","kind":"identifier"},{"text":"(","kind":"text"},{"text":"mayBlock","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"symbolKind":"method","externalID":"s:4GLib19MainContextProtocolPAAE9iteration8mayBlockS2b_tF::SYNTHESIZED::s:4GLib11MainContextC","role":"symbol","title":"iteration(mayBlock:)","modules":[{"name":"GLib"}]},"variants":[{"paths":["\/documentation\/glib\/maincontext\/iteration(mayblock:)"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/MainContext","doc:\/\/GLib\/documentation\/GLib\/MainContext\/MainContextProtocol-Implementations"]]},"abstract":[{"text":"Runs a single iteration for the given main loop.","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/MainContext\/iteration(mayBlock:)"},"kind":"symbol","primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"iteration","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"mayBlock"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"text":") -> ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"inlineContent":[{"text":"This involves","type":"text"},{"type":"text","text":" "},{"type":"text","text":"checking to see if any event sources are ready to be processed,"},{"text":" ","type":"text"},{"type":"text","text":"then if no events sources are ready and "},{"type":"codeVoice","code":"mayBlock"},{"type":"text","text":" is true, waiting"},{"type":"text","text":" "},{"type":"text","text":"for a source to become ready, then dispatching the highest priority"},{"type":"text","text":" "},{"text":"events sources that are ready. Otherwise, if ","type":"text"},{"type":"codeVoice","code":"mayBlock"},{"text":" is false,","type":"text"},{"text":" ","type":"text"},{"text":"this function does not wait for sources to become ready, and only the highest","type":"text"},{"type":"text","text":" "},{"type":"text","text":"priority sources which are already ready (if any) will be dispatched."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that even when "},{"type":"codeVoice","code":"mayBlock"},{"text":" is true, it is still possible for","type":"text"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.MainContext.iteration"},{"text":"] to return false, since the wait may","type":"text"},{"type":"text","text":" "},{"type":"text","text":"be interrupted for other reasons than an event source becoming ready."}]}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://GLib/documentation/GLib/MainContext/MainContextProtocol-Implementations":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext\/MainContextProtocol-Implementations","url":"\/documentation\/glib\/maincontext\/maincontextprotocol-implementations","role":"collectionGroup","type":"topic","abstract":[],"kind":"article","title":"MainContextProtocol Implementations"},"doc://GLib/documentation/GLib/MainContext/iteration(mayBlock:)":{"role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext\/iteration(mayBlock:)","title":"iteration(mayBlock:)","type":"topic","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"iteration"},{"kind":"text"
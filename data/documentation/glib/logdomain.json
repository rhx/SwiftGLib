{"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"title":"logDomain","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"logDomain","kind":"identifier"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"role":"symbol","externalID":"s:4GLib9logDomainSivp","roleHeading":"Global Variable","symbolKind":"var","modules":[{"name":"GLib"}]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/logdomain"]}],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/logDomain"},"abstract":[{"type":"text","text":"Defines the log domain. See "},{"type":"reference","identifier":"#log-domains","isActive":true},{"text":".","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"text":"logDomain","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"Libraries should define this so that any messages","type":"text"},{"type":"text","text":" "},{"type":"text","text":"which they log can be differentiated from messages from other"},{"text":" ","type":"text"},{"text":"libraries and application code. But be careful not to define","type":"text"},{"type":"text","text":" "},{"type":"text","text":"it in any public header files."}]},{"type":"paragraph","inlineContent":[{"text":"Log domains must be unique, and it is recommended that they are the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"application or library name, optionally followed by a hyphen and a sub-domain"},{"text":" ","type":"text"},{"text":"name. For example, ","type":"text"},{"code":"bloatpad","type":"codeVoice"},{"type":"text","text":" or "},{"code":"bloatpad-io","type":"codeVoice"},{"text":".","type":"text"}]},{"inlineContent":[{"type":"text","text":"If undefined, it defaults to the default "},{"type":"codeVoice","code":"nil"},{"text":" (or ","type":"text"},{"type":"codeVoice","code":"\"\""},{"type":"text","text":") log domain; this is"},{"text":" ","type":"text"},{"text":"not advisable, as it cannot be filtered against using the ","type":"text"},{"code":"G_MESSAGES_DEBUG","type":"codeVoice"},{"type":"text","text":" "},{"text":"environment variable.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example, GTK uses this in its "},{"type":"codeVoice","code":"Makefile.am"},{"type":"text","text":":"}]},{"syntax":null,"code":["AM_CPPFLAGS = -DG_LOG_DOMAIN=\\\"Gtk\\\""],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"Applications can choose to leave it as the default ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" (or ","type":"text"},{"code":"\"\"","type":"codeVoice"},{"text":")","type":"text"},{"text":" ","type":"text"},{"text":"domain. However, defining the domain offers the same advantages as","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"above."}]}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"sections":[],"references":{"doc://GLib/documentation/GLib/logDomain":{"type":"topic","url":"\/documentation\/glib\/logdomain","title":"logDomain","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/logDomain","fragments":[{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"text":"logDomain","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}],"abstract":[{"type":"text","text":"Defines the log domain. See "},{"type":"reference","isActive":true,"identifier":"#log-domains"},{"type":"text","text":"."}],"role":"symbol"},"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"#log-domains":{"title":"Log Domains","titleInlineContent":[{"text":"Log Domains","type":"text"}],"url":"#log-domains","identifier":"#log-domains","type":"link"}}}
{"kind":"symbol","sections":[],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo\/isPartialMatch","interfaceLanguage":"swift"},"abstract":[{"text":"Usually if the string passed to g_regex_match*() matches as far as","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"it goes, but is too short to match the entire pattern, "},{"code":"false","type":"codeVoice"},{"text":" is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"returned. There are circumstances where it might be helpful to"},{"text":" ","type":"text"},{"type":"text","text":"distinguish this case from other cases in which there is no match."}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/MatchInfo","doc:\/\/GLib\/documentation\/GLib\/MatchInfo\/MatchInfoProtocol-Implementations"]]},"variants":[{"paths":["\/documentation\/glib\/matchinfo\/ispartialmatch"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"isPartialMatch","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"text":" { ","kind":"text"},{"kind":"keyword","text":"get"},{"text":" }","kind":"text"}]}]},{"content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Consider, for example, an application where a human is required to"},{"type":"text","text":" "},{"type":"text","text":"type in data for a field with specific formatting requirements. An"},{"type":"text","text":" "},{"type":"text","text":"example might be a date in the form ddmmmyy, defined by the pattern"},{"type":"text","text":" "},{"type":"codeVoice","code":"\"^\\d?\\d(jan|feb|mar|apr|may|jun|jul|aug|sep|oct|nov|dec)"},{"text":"\\d\\d$”.","type":"text"},{"type":"text","text":" "},{"text":"If the application sees the user’s keystrokes one by one, and can","type":"text"},{"type":"text","text":" "},{"text":"check that what has been typed so far is potentially valid, it is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"able to raise an error as soon as a mistake is made."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"GRegex supports the concept of partial matching by means of the"},{"text":" ","type":"text"},{"code":"partialSoft","type":"codeVoice"},{"type":"text","text":" and "},{"code":"partialHard","type":"codeVoice"},{"type":"text","text":" flags."},{"text":" ","type":"text"},{"type":"text","text":"When they are used, the return code for"},{"type":"text","text":" "},{"code":"g_regex_match()","type":"codeVoice"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"g_regex_match_full()"},{"text":" is, as usual, ","type":"text"},{"type":"codeVoice","code":"true"},{"text":" ","type":"text"},{"type":"text","text":"for a complete match, "},{"type":"codeVoice","code":"false"},{"type":"text","text":" otherwise. But, when these functions"},{"type":"text","text":" "},{"text":"return ","type":"text"},{"type":"codeVoice","code":"false"},{"text":", you can check if the match was partial calling","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_match_info_is_partial_match()"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The difference between "},{"type":"codeVoice","code":"partialSoft"},{"type":"text","text":" and"},{"type":"text","text":" "},{"code":"partialHard","type":"codeVoice"},{"text":" is that when a partial match is encountered","type":"text"},{"type":"text","text":" "},{"text":"with ","type":"text"},{"type":"codeVoice","code":"partialSoft"},{"text":", matching continues to search for a","type":"text"},{"text":" ","type":"text"},{"text":"possible complete match, while with ","type":"text"},{"type":"codeVoice","code":"partialHard"},{"type":"text","text":" matching"},{"text":" ","type":"text"},{"type":"text","text":"stops at the partial match."},{"text":" ","type":"text"},{"text":"When both ","type":"text"},{"type":"codeVoice","code":"partialSoft"},{"type":"text","text":" and "},{"code":"partialHard","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"are set, the latter takes precedence."}]},{"type":"paragraph","inlineContent":[{"text":"There were formerly some restrictions on the pattern for partial matching.","type":"text"},{"type":"text","text":" "},{"text":"The restrictions no longer apply.","type":"text"}]},{"inlineContent":[{"text":"See ","type":"text"},{"code":"pcrepartial(3)","type":"codeVoice"},{"type":"text","text":" for more information on partial matching."}],"type":"paragraph"}],"kind":"content"}],"metadata":{"externalID":"s:4GLib17MatchInfoProtocolPAAE09isPartialB0Sbvp::SYNTHESIZED::s:4GLib9MatchInfoC","modules":[{"name":"GLib"}],"title":"isPartialMatch","extendedModule":"GLib","symbolKind":"property","role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"isPartialMatch","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"roleHeading":"Instance Property"},"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://GLib/documentation/GLib/MatchInfo/MatchInfoProtocol-Implementations":{"kind":"article","title":"MatchInfoProtocol Implementations","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo\/MatchInfoProtocol-Implementations","type":"topic","role":"collectionGroup","url":"\/documentation\/glib\/matchinfo\/matchinfoprotocol-implementations"},"doc://GLib/documentation/GLib/MatchInfo":{"type":"topic","kind":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"MatchInfo","kind":"identifier"}],"url":"\/documentation\/glib\/matchinfo","navigatorTitle":[{"text":"MatchInfo","kind":"identifier"}],"abstract":[{"type":"text","text":"A GMatchInfo is an opaque struct used to return information about"},{"text":" ","type":"text"},{"type":"text","text":"matches."}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo","title":"MatchInfo","role":"symbol"},"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"doc://GLib/documentation/GLib/MatchInfo/isPartialMatch":{"fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"isPartialMatch","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"title":"isPartialMatch","url":"\/documentation\/glib\/matchinfo\/ispartialmatch","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo\/isPartialMatch","abstract":[{"type":"text","text":"Usually if the string passed to g_regex_match*() matches as far as"},{"text":" ","type":"text"},{"type":"text","text":"it goes, but is too short to match the entire pattern, "},{"type":"codeVoice","code":"false"},{"text":" is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"returned. There are circumstances where it might be helpful to"},{"type":"text","text":" "},{"text":"distinguish this case from other cases in which there is no match.","type":"text"}],"type":"topic","role":"symbol"}}}
{"abstract":[{"type":"text","text":"Sets a source to be dispatched when the given monotonic time is"},{"type":"text","text":" "},{"text":"reached (or passed).","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/Source\/set(readyTime:)"},"sections":[],"kind":"symbol","schemaVersion":{"minor":3,"patch":0,"major":0},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/Source","doc:\/\/GLib\/documentation\/GLib\/Source\/SourceProtocol-Implementations"]]},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"set"},{"kind":"text","text":"("},{"kind":"externalParam","text":"readyTime"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@gint64","kind":"typeIdentifier","text":"gint64"},{"kind":"text","text":")"}]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the monotonic time is in the past (as it"},{"type":"text","text":" "},{"type":"text","text":"always will be if "},{"code":"readyTime","type":"codeVoice"},{"text":" is ","type":"text"},{"type":"codeVoice","code":"0"},{"type":"text","text":") then the source will be"},{"text":" ","type":"text"},{"type":"text","text":"dispatched immediately."}]},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"readyTime"},{"text":" is ","type":"text"},{"code":"-1","type":"codeVoice"},{"text":" then the source is never woken up on the basis","type":"text"},{"type":"text","text":" "},{"type":"text","text":"of the passage of time."}],"type":"paragraph"},{"inlineContent":[{"text":"Dispatching the source does not reset the ready time.  You should do","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"so yourself, from the source dispatch function."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Note that if you have a pair of sources where the ready time of one","type":"text"},{"text":" ","type":"text"},{"text":"suggests that it will be delivered first but the priority for the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"other suggests that it would be delivered first, and the ready time"},{"text":" ","type":"text"},{"text":"for both sources is reached during the same main context iteration,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"then the order of dispatch is undefined."}]},{"inlineContent":[{"text":"It is a no-op to call this function on a [struct","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Source","type":"reference"},{"type":"text","text":"] which has"},{"type":"text","text":" "},{"text":"already been destroyed with [method","type":"text"},{"type":"codeVoice","code":"GLib.Source.destroy"},{"text":"].","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"This API is only intended to be used by implementations of [struct","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Source","isActive":true},{"type":"text","text":"]."},{"text":" ","type":"text"},{"type":"text","text":"Do not call this API on a [struct"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Source","isActive":true,"type":"reference"},{"text":"] that you did not create.","type":"text"}]}]}],"metadata":{"modules":[{"name":"GLib"}],"role":"symbol","title":"set(readyTime:)","symbolKind":"method","roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"set","kind":"identifier"},{"kind":"text","text":"("},{"text":"readyTime","kind":"externalParam"},{"kind":"text","text":": "},{"text":"gint64","kind":"typeIdentifier","preciseIdentifier":"c:@T@gint64"},{"kind":"text","text":")"}],"externalID":"s:4GLib14SourceProtocolPAAE3se
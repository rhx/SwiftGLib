{"topicSections":[{"anchor":"Initializers","generated":true,"identifiers":["doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef\/init(_:)-23tja","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef\/init(_:)-34spm","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef\/init(_:)-5mqz7","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef\/init(_:)-92aql","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef\/init(_:)-eq03","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef\/init(cPointer:)","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef\/init(constPointer:)","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef\/init(gconstpointer:)","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef\/init(gpointer:)","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef\/init(mutating:)","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef\/init(opaquePointer:)"],"title":"Initializers"},{"title":"Instance Properties","generated":true,"identifiers":["doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef\/ptr"],"anchor":"Instance-Properties"},{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef\/new(full:userData:itemFreeFunc:maxThreads:exclusive:)"],"generated":true,"title":"Type Methods","anchor":"Type-Methods"},{"anchor":"Default-Implementations","generated":true,"identifiers":["doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef\/PointerWrapper-Implementations","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef\/ThreadPoolProtocol-Implementations"],"title":"Default Implementations"}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef","interfaceLanguage":"swift"},"metadata":{"title":"ThreadPoolRef","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"ThreadPoolRef","kind":"identifier"}],"symbolKind":"struct","navigatorTitle":[{"text":"ThreadPoolRef","kind":"identifier"}],"modules":[{"name":"GLib"}],"role":"symbol","roleHeading":"Structure","externalID":"s:4GLib13ThreadPoolRefV"},"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"abstract":[{"type":"text","text":"The "},{"code":"GThreadPool","type":"codeVoice"},{"type":"text","text":" struct represents a thread pool."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/threadpoolref"]}],"kind":"symbol","primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ThreadPoolRef"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"overview","level":2,"text":"Overview","type":"heading"},{"inlineContent":[{"text":"A thread pool is useful when you wish to asynchronously fork out the execution of work","type":"text"},{"type":"text","text":" "},{"text":"and continue working in your own thread. If that will happen often, the overhead of starting","type":"text"},{"text":" ","type":"text"},{"text":"and destroying a thread each time might be too high. In such cases reusing already started","type":"text"},{"type":"text","text":" "},{"text":"threads seems like a good idea. And it indeed is, but implementing this can be tedious","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and error-prone."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Therefore GLib provides thread pools for your convenience. An added advantage is, that the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"threads can be shared between the different subsystems of your program, when they are using GLib."}]},{"inlineContent":[{"type":"text","text":"To create a new thread pool, you use [func"},{"type":"codeVoice","code":"GLib.ThreadPool.new"},{"type":"text","text":"]."},{"type":"text","text":" "},{"type":"text","text":"It is destroyed by [method"},{"type":"codeVoice","code":"GLib.ThreadPool.free"},{"text":"].","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you want to execute a certain task within a thread pool, use [method"},{"type":"codeVoice","code":"GLib.ThreadPool.push"},{"type":"text","text":"]."}]},{"inlineContent":[{"text":"To get the current number of running threads you call [method","type":"text"},{"code":"GLib.ThreadPool.get_num_threads","type":"codeVoice"},{"type":"text","text":"]."},{"type":"text","text":" "},{"text":"To get the number of still unprocessed tasks you call [method","type":"text"},{"code":"GLib.ThreadPool.unprocessed","type":"codeVoice"},{"text":"].","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"To control the maximum number of threads for a thread pool, you use"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.ThreadPool.get_max_threads"},{"text":"]. and [method","type":"text"},{"type":"codeVoice","code":"GLib.ThreadPool.set_max_threads"},{"type":"text","text":"]."}],"type":"paragraph"},{"inlineContent":[{"text":"Finally you can control the number of unused threads, that are kept alive by GLib for future use.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"The current number can be fetched with [func"},{"code":"GLib.ThreadPool.get_num_unused_threads","type":"codeVoice"},{"text":"].","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"The maximum number can be controlled by [func"},{"code":"GLib.ThreadPool.get_max_unused_threads","type":"codeVoice"},{"type":"text","text":"] and"},{"type":"text","text":" "},{"type":"text","text":"[func"},{"code":"GLib.ThreadPool.set_max_unused_threads","type":"codeVoice"},{"type":"text","text":"]. All currently unused threads"},{"text":" ","type":"text"},{"type":"text","text":"can be stopped by calling [func"},{"code":"GLib.ThreadPool.stop_unused_threads","type":"codeVoice"},{"type":"text","text":"]."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef","type":"reference","isActive":true},{"type":"text","text":" type acts as a lightweight Swift reference to an underlying "},{"type":"codeVoice","code":"GThreadPool"},{"text":" instance.","type":"text"},{"text":" ","type":"text"},{"text":"It exposes methods that can operate on this data type through ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol"},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"text":"Use ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef","isActive":true},{"type":"text","text":" only as an "},{"type":"codeVoice","code":"unowned"},{"type":"text","text":" reference to an existing "},{"code":"GThreadPool","type":"codeVoice"},{"type":"text","text":" instance."}]},{"name":"Note","style":"note","type":"aside","content":[{"inlineContent":[{"type":"text","text":"Use "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/ThreadPool","type":"reference"},{"type":"text","text":" (instead of "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef","isActive":true},{"text":") if you want to use Automatic Reference Counting for memory management of the underlying ","type":"text"},{"code":"GThreadPool","type":"codeVoice"},{"text":" instance.","type":"text"}],"type":"paragraph"}]}]}],"sections":[],"relationshipsSections":[{"title":"Conforms To","kind":"relationships","identifiers":["doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol"],"type":"conformsTo"}],"references":{"doc://GLib/documentation/GLib/ThreadPoolRef/init(opaquePointer:)":{"kind":"symbol","title":"init(opaquePointer:)","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"text":"opaquePointer","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:s13OpaquePointerV","text":"OpaquePointer","kind":"typeIdentifier"},{"kind":"text","text":")"}],"url":"\
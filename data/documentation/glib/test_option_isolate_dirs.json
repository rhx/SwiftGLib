{"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TEST_OPTION_ISOLATE_DIRS","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"}]}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Creates a unique temporary directory for each unit test and uses sets"},{"text":" ","type":"text"},{"text":"XDG directories to point into subdirectories of it for the duration of","type":"text"},{"text":" ","type":"text"},{"text":"the unit test. The directory tree is cleaned up after the test finishes","type":"text"},{"type":"text","text":" "},{"text":"successfully.","type":"text"}]},{"inlineContent":[{"text":"Note that this doesn’t take effect until [func","type":"text"},{"type":"codeVoice","code":"GLib.test_run"},{"text":"] is called,","type":"text"},{"text":" ","type":"text"},{"text":"so calls to (for example) [func","type":"text"},{"type":"codeVoice","code":"GLib.get_home_dir"},{"text":"] will return the","type":"text"},{"type":"text","text":" "},{"text":"system-wide value when made in a test program’s ","type":"text"},{"type":"codeVoice","code":"main()"},{"type":"text","text":" function."}],"type":"paragraph"},{"inlineContent":[{"text":"The following functions will return subdirectories of the temporary directory","type":"text"},{"type":"text","text":" "},{"text":"when this option is used. The specific subdirectory paths in use are not","type":"text"},{"type":"text","text":" "},{"text":"guaranteed to be stable API — always use a getter function to retrieve them.","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"[func"},{"type":"codeVoice","code":"GLib.get_home_dir"},{"type":"text","text":"]"}]}]},{"content":[{"inlineContent":[{"text":"[func","type":"text"},{"type":"codeVoice","code":"GLib.get_user_cache_dir"},{"text":"]","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"[func"},{"type":"codeVoice","code":"GLib.get_system_config_dirs"},{"text":"]","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"[func","type":"text"},{"code":"GLib.get_user_config_dir","type":"codeVoice"},{"type":"text","text":"]"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"[func"},{"code":"GLib.get_system_data_dirs","type":"codeVoice"},{"type":"text","text":"]"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"[func"},{"type":"codeVoice","code":"GLib.get_user_data_dir"},{"text":"]","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"[func"},{"code":"GLib.get_user_state_dir","type":"codeVoice"},{"text":"]","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"[func"},{"code":"GLib.get_user_runtime_dir","type":"codeVoice"},{"type":"text","text":"]"}],"type":"paragraph"}]}]},{"inlineContent":[{"text":"The subdirectories may not be created by the test harness; as with normal","type":"text"},{"text":" ","type":"text"},{"text":"calls to functions like [func","type":"text"},{"code":"GLib.get_user_cache_dir","type":"codeVoice"},{"type":"text","text":"], the caller must"},{"text":" ","type":"text"},{"type":"text","text":"be prepared to create the directory if it doesn’t exist."},{"type":"text","text":" "},{"inlineContent":[{"text":"TEST_OPTION_ISOLATE_DIRS is deprecated:","type":"text"}],"type":"strong"},{"text":" ","type":"text"},{"type":"text","text":"Use "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/testOptionIsolateDirs","type":"reference"},{"type":"text","text":" instead."}],"type":"paragraph"}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"
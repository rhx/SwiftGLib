{"sections":[],"abstract":[{"text":"Sets a function to be called at regular intervals, with ","type":"text"},{"type":"codeVoice","code":"priority"},{"type":"text","text":"."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/timeoutAddSecondsFull(priority:interval:function:data:notify:)"},"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"title":"timeoutAddSecondsFull(priority:interval:function:data:notify:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"timeoutAddSecondsFull"},{"text":"(","kind":"text"},{"text":"priority","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"interval","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"function","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GSourceFunc","text":"GSourceFunc"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"data"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"gpointer","preciseIdentifier":"c:@T@gpointer"},{"text":"?, ","kind":"text"},{"text":"notify","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GDestroyNotify","text":"GDestroyNotify"},{"kind":"text","text":"?) -> "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"symbolKind":"func","modules":[{"name":"GLib"}],"role":"symbol","roleHeading":"Function","externalID":"s:4GLib21timeoutAddSecondsFull8priority8interval8function4data6notifyS2i_Sis5Int32VSvSgXCSgAJyAJXCSgtF"},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"timeoutAddSecondsFull","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"priority"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"interval","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"function","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"GSourceFunc","kind":"typeIdentifier","preciseIdentifier":"c:@T@GSourceFunc"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"data"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@gpointer","kind":"typeIdentifier","text":"gpointer"},{"text":"? = nil, ","kind":"text"},{"kind":"externalParam","text":"notify"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GDestroyNotify","text":"GDestroyNotify"},{"text":"? = nil) -> ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The function is called repeatedly until it returns [const"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/sourceRemove","isActive":true},{"type":"text","text":"],"},{"text":" ","type":"text"},{"type":"text","text":"at which point the timeout is automatically destroyed and"},{"type":"text","text":" "},{"type":"text","text":"the function will not be called again."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Unlike [func"},{"type":"codeVoice","code":"GLib.timeout_add"},{"type":"text","text":"], this function operates at whole second"},{"text":" ","type":"text"},{"type":"text","text":"granularity. The initial starting point of the timer is determined by the"},{"text":" ","type":"text"},{"type":"text","text":"implementation and the implementation is expected to group multiple timers"},{"text":" ","type":"text"},{"type":"text","text":"together so that they fire all at the same time. To allow this grouping,"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"type":"codeVoice","code":"interval"},{"type":"text","text":" to the first timer is rounded and can deviate up to one second"},{"text":" ","type":"text"},{"type":"text","text":"from the specified interval. Subsequent timer iterations will generally run"},{"text":" ","type":"text"},{"type":"text","text":"at the specified interval."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that timeout functions may be delayed, due to the processing of other"},{"type":"text","text":" "},{"type":"text","text":"event sources. Thus they should not be relied on for precise timing."},{"text":" ","type":"text"},{"type":"text","text":"After each call to the timeout function, the time of the next"},{"type":"text","text":" "},{"text":"timeout is recalculated based on the current time and the given ","type":"text"},{"code":"interval","type":"codeVoice"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"identifier":"main-loop.html#memory-management-of-sources","isActive":true,"type":"reference"},{"type":"text","text":" for details"},{"type":"text","text":" "},{"text":"on how to handle the return value and memory management of ","type":"text"},{"code":"data","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you want timing more precise than whole seconds, use"},{"type":"text","text":" "},{"text":"[func","type":"text"},{"type":"codeVoice","code":"GLib.timeout_add"},{"text":"] instead.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The grouping of timers to fire at the same time results in a more power"},{"type":"text","text":" "},{"text":"and CPU efficient behavior so if your timer is in multiples of seconds","type":"text"},{"text":" ","type":"text"},{"text":"and you don’t require the first timer exactly one second from now, the","type":"text"},{"text":" ","type":"text"},{"text":"use of [func","type":"text"},{"type":"codeVoice","code":"GLib.timeout_add_seconds"},{"type":"text","text":"] is preferred over"},{"text":" ","type":"text"},{"type":"text","text":"[func"},{"type":"codeVoice","code":"GLib.timeout_add"},{"type":"text","text":"]."}]},{"type":"paragraph","inlineContent":[{"text":"This internally creates a main loop source using","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[func"},{"code":"GLib.timeout_source_new_seconds","type":"codeVoice"},{"type":"text","text":"] and attaches it to the main loop"},{"type":"text","text":" "},{"type":"text","text":"context using [method"},{"type":"codeVoice","code":"GLib.Source.attach"},{"text":"]. You can do these steps manually","type":"text"},{"type":"text","text":" "},{"text":"if you need greater control.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"It is safe to call this function from any thread.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The interval given is in terms of monotonic time, not wall clock"},{"text":" ","type":"text"},{"type":"text","text":"time. See [func"},{"code":"GLib.get_monotonic_time","type":"codeVoice"},{"text":"].","type":"text"}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/timeoutaddsecondsfull(priority:interval:function:data:notify:)"]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"kind":"symbol","references":{"doc://GLib/documentation/GLib/timeoutAddSecondsFull(priority:interval:function:data:notify:)":{"url":"\/documentation\/glib\/timeoutaddsecondsfull(priority:interval:function:data:notify:)","identifier":"doc:\/\/GLib\/documentation\/GLib\/timeoutAddSecondsFull(priority:interval:function:data:notify:)","title":"timeoutAddSecondsFull(priority:interval:function:data:notify:)","abstract":[{"text":"Sets a function to be called at regular interv
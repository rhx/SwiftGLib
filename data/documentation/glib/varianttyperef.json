{"metadata":{"navigatorTitle":[{"kind":"identifier","text":"VariantTypeRef"}],"modules":[{"name":"GLib"}],"roleHeading":"Structure","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"VariantTypeRef"}],"symbolKind":"struct","title":"VariantTypeRef","externalID":"s:4GLib14VariantTypeRefV"},"schemaVersion":{"major":0,"patch":0,"minor":3},"sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"relationshipsSections":[{"kind":"relationships","title":"Conforms To","type":"conformsTo","identifiers":["doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","doc:\/\/GLib\/documentation\/GLib\/VariantTypeProtocol"]}],"variants":[{"paths":["\/documentation\/glib\/varianttyperef"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"text":"A type in the [type","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"type":"text","text":"] type system."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"VariantTypeRef"}]}]},{"kind":"content","content":[{"level":2,"text":"Overview","anchor":"overview","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"[Type"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","type":"reference","isActive":true},{"type":"text","text":"] types are represented as strings, but have a strict"},{"text":" ","type":"text"},{"type":"text","text":"syntax described below. All [type"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantType"},{"text":"]s passed to GLib must be","type":"text"},{"type":"text","text":" "},{"text":"valid, and they are typically expected to be static (i.e. not provided by","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"user input) as they determine how binary [type"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","type":"reference","isActive":true},{"type":"text","text":"] data is"},{"text":" ","type":"text"},{"type":"text","text":"interpreted."}]},{"inlineContent":[{"text":"To convert a static string to a [type","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantType","isActive":true,"type":"reference"},{"text":"] in C, use the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[func"},{"type":"codeVoice","code":"GLib.VARIANT_TYPE"},{"type":"text","text":"] casting macro. When GLib is compiled with checks"},{"type":"text","text":" "},{"type":"text","text":"enabled, it will validate the type. To check if an arbitrary string is a"},{"text":" ","type":"text"},{"type":"text","text":"valid [type"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantType"},{"type":"text","text":"], use [func"},{"code":"GLib.VariantType.string_is_valid","type":"codeVoice"},{"type":"text","text":"]."}],"type":"paragraph"},{"level":2,"anchor":"GVariant-Type-System","text":"GVariant Type System","type":"heading"},{"inlineContent":[{"type":"text","text":"This section introduces the [type"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","type":"reference","isActive":true},{"type":"text","text":"] type system. It is based, in"},{"type":"text","text":" "},{"type":"text","text":"large part, on the D-Bus type system, with two major changes and"},{"type":"text","text":" "},{"type":"text","text":"some minor lifting of restrictions. The"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"http:\/\/dbus.freedesktop.org\/doc\/dbus-specification.html"},{"type":"text","text":","},{"text":" ","type":"text"},{"text":"therefore, provides a significant amount of","type":"text"},{"type":"text","text":" "},{"text":"information that is useful when working with [type","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"text":"].","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The first major change with respect to the D-Bus type system is the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"introduction of maybe (or ‘nullable’) types.  Any type in [type"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true,"type":"reference"},{"text":"]","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"can be converted to a maybe type, in which case, "},{"type":"codeVoice","code":"nothing"},{"type":"text","text":" (or "},{"code":"null","type":"codeVoice"},{"text":")","type":"text"},{"text":" ","type":"text"},{"text":"becomes a valid value.  Maybe types have been added by introducing the","type":"text"},{"type":"text","text":" "},{"text":"character ","type":"text"},{"code":"m","type":"codeVoice"},{"type":"text","text":" to type strings."}]},{"inlineContent":[{"type":"text","text":"The second major change is that the [type"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","type":"reference"},{"type":"text","text":"] type system supports"},{"type":"text","text":" "},{"text":"the concept of ‘indefinite types’ — types that are less specific than","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the normal types found in D-Bus.  For example, it is possible to speak"},{"type":"text","text":" "},{"type":"text","text":"of ‘an array of any type’ in [type"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true},{"text":"], where the D-Bus type system","type":"text"},{"type":"text","text":" "},{"text":"would require you to speak of ‘an array of integers’ or ‘an array of","type":"text"},{"text":" ","type":"text"},{"text":"strings’.  Indefinite types have been added by introducing the","type":"text"},{"type":"text","text":" "},{"text":"characters ","type":"text"},{"type":"codeVoice","code":"*"},{"text":", ","type":"text"},{"type":"codeVoice","code":"?"},{"text":" and ","type":"text"},{"code":"r","type":"codeVoice"},{"type":"text","text":" to type strings."}],"type":"paragraph"},{"inlineContent":[{"text":"Finally, all arbitrary restrictions relating to the complexity of","type":"text"},{"text":" ","type":"text"},{"text":"types are lifted along with the restriction that dictionary entries","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"may only appear nested inside of arrays."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Just as in D-Bus, [type"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"type":"text","text":"] types are described with strings (‘type"},{"text":" ","type":"text"},{"type":"text","text":"strings’).  Subject to the differences mentioned above, these strings"},{"text":" ","type":"text"},{"text":"are of the same form as those found in D-Bus.  Note, however: D-Bus","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"always works in terms of messages and therefore individual type"},{"type":"text","text":" "},{"text":"strings appear nowhere in its interface.  Instead, ‘signatures’","type":"text"},{"type":"text","text":" "},{"type":"text","text":"are a concatenation of the strings of the type of each argument in a"},{"text":" ","type":"text"},{"text":"message.  [type","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true},{"text":"] deals with single values directly so","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[type"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","type":"reference"},{"text":"] type strings always describe the type of exactly one","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"value.  This means that a D-Bus signature string is generally not a valid"},{"type":"text","text":" "},{"type":"text","text":"[type"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true},{"type":"text","text":"] type string — except in the case that it is the signature"},{"text":" ","type":"text"},{"type":"text","text":"of a message containing exactly one argument."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"An indefinite type is similar in spirit to what may be called an"},{"type":"text","text":" "},{"text":"abstract type in other type systems.  No value can exist that has an","type":"text"},{"type":"text","text":" "},{"type":"text","text":"indefinite type as its type, but values can exist that have types"},{"text":" ","type":"text"},{"type":"text","text":"that are subtypes of indefinite types.  That is to say,"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GLib.Variant.get_type"},{"type":"text","text":"] will never return an indefinite type, but"},{"type":"text","text":" "},{"type":"text","text":"calling [method"},{"type":"codeVoice","code":"GLib.Variant.is_of_type"},{"text":"] with an indefinite type may return","type":"text"},{"type":"text","text":" "},{"text":"true.  For example, you cannot have a value that represents ‘an","type":"text"},{"type":"text","text":" "},{"type":"text","text":"array of no particular type’, but you can have an ‘array of integers’"},{"type":"text","text":" "},{"type":"text","text":"which certainly matches the type of ‘an array of no particular type’,"},{"text":" ","type":"text"},{"type":"text","text":"since ‘array of integers’ is a subtype of ‘array of no particular"},{"text":" ","type":"text"},{"text":"type’.","type":"text"}]},{"inlineContent":[{"type":"text","text":"This is similar to how instances of abstract classes may not"},{"text":" ","type":"text"},{"text":"directly exist in other type systems, but instances of their","type":"text"},{"text":" ","type":"text"},{"text":"non-abstract subtypes may.  For example, in GTK, no object that has","type":"text"},{"type":"text","text":" "},{"text":"the type of ","type":"text"},{"identifier":"https:\/\/docs.gtk.org\/gtk4\/class.Widget.html","isActive":true,"type":"reference"},{"text":" can","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"exist (since "},{"type":"codeVoice","code":"GtkWidget"},{"type":"text","text":" is an abstract class), but a "},{"type":"reference","isActive":true,"identifier":"https:\/\/docs.gtk.org\/gtk4\/class.Window.html"},{"type":"text","text":" "},{"type":"text","text":"can certainly be instantiated, and you would say that a "},{"code":"GtkWindow","type":"codeVoice"},{"text":" is a","type":"text"},{"type":"text","text":" "},{"code":"GtkWidget","type":"codeVoice"},{"text":" (since ","type":"text"},{"type":"codeVoice","code":"GtkWindow"},{"type":"text","text":" is a subclass of "},{"code":"GtkWidget","type":"codeVoice"},{"type":"text","text":")."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Two types may not be compared by value; use [method"},{"code":"GLib.VariantType.equal","type":"codeVoice"},{"text":"]","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"or [method"},{"code":"GLib.VariantType.is_subtype_of","type":"codeVoice"},{"text":"]  May be copied using","type":"text"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"code":"GLib.VariantType.copy","type":"codeVoice"},{"type":"text","text":"] and freed using [method"},{"type":"codeVoice","code":"GLib.VariantType.free"},{"type":"text","text":"]."}]},{"anchor":"GVariant-Type-Strings","type":"heading","text":"GVariant Type Strings","level":2},{"inlineContent":[{"text":"A [type","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true},{"text":"] type string can be any of the following:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"any basic type string (listed below)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"v","type":"codeVoice"},{"text":", ","type":"text"},{"code":"r","type":"codeVoice"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"*"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"one of the characters ","type":"text"},{"code":"a","type":"codeVoice"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"m"},{"text":", followed by another type string","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"the character "},{"type":"codeVoice","code":"("},{"type":"text","text":", followed by a concatenation of zero or more other"},{"text":" ","type":"text"},{"type":"text","text":"type strings, followed by the character "},{"type":"codeVoice","code":")"}]}]},{"content":[{"inlineContent":[{"text":"the character ","type":"text"},{"code":"{","type":"codeVoice"},{"text":", followed by a basic type string (see below),","type":"text"},{"type":"text","text":" "},{"text":"followed by another type string, followed by the character ","type":"text"},{"code":"}","type":"codeVoice"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A basic type string describes a basic type (as per"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"code":"GLib.VariantType.is_basic","type":"codeVoice"},{"text":"]) and is always a single character in","type":"text"},{"type":"text","text":" "},{"type":"text","text":"length. The valid basic type strings are "},{"code":"b","type":"codeVoice"},{"text":", ","type":"text"},{"code":"y","type":"codeVoice"},{"type":"text","text":", "},{"code":"n","type":"codeVoice"},{"text":", ","type":"text"},{"type":"codeVoice","code":"q"},{"type":"text","text":", "},{"type":"codeVoice","code":"i"},{"text":", ","type":"text"},{"code":"u","type":"codeVoice"},{"text":", ","type":"text"},{"code":"x","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"t","type":"codeVoice"},{"type":"text","text":", "},{"code":"h","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"d"},{"type":"text","text":", "},{"code":"s","type":"codeVoice"},{"type":"text","text":", "},{"code":"o","type":"codeVoice"},{"type":"text","text":", "},{"code":"g","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"?"},{"text":".","type":"text"}]},{"inlineContent":[{"text":"The above definition is recursive to arbitrary depth. ","type":"text"},{"type":"codeVoice","code":"aaaaai"},{"type":"text","text":" and"},{"text":" ","type":"text"},{"code":"(","type":"codeVoice"},{"text":"ui(nq((y)","type":"text"},{"type":"codeVoice","code":"))s)"},{"text":" are both valid type strings, as is","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"a(aa(ui)`(qna{`ya(yd)`}))`. In order to not hit memory limits, [type"},{"type":"text","text":"Variant``] imposes a limit on recursion depth of 65 nested"},{"text":" ","type":"text"},{"text":"containers. This is the limit in the D-Bus specification (64) plus one to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"allow a "},{"type":"reference","isActive":true,"identifier":"..\/gio\/class.DBusMessage.html"},{"type":"text","text":" to be nested in"},{"type":"text","text":" "},{"text":"a top-level tuple.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The meaning of each of the characters is as follows:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"b"},{"text":": the type string of ","type":"text"},{"code":"G_VARIANT_TYPE_BOOLEAN","type":"codeVoice"},{"type":"text","text":"; a boolean value."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"y","type":"codeVoice"},{"text":": the type string of ","type":"text"},{"code":"G_VARIANT_TYPE_BYTE","type":"codeVoice"},{"type":"text","text":"; a byte."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"n"},{"text":": the type string of ","type":"text"},{"code":"G_VARIANT_TYPE_INT16","type":"codeVoice"},{"type":"text","text":"; a signed 16 bit integer."}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"q"},{"type":"text","text":": the type string of "},{"code":"G_VARIANT_TYPE_UINT16","type":"codeVoice"},{"type":"text","text":"; an unsigned 16 bit integer."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"i"},{"type":"text","text":": the type string of "},{"code":"G_VARIANT_TYPE_INT32","type":"codeVoice"},{"type":"text","text":"; a signed 32 bit integer."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"u"},{"type":"text","text":": the type string of "},{"type":"codeVoice","code":"G_VARIANT_TYPE_UINT32"},{"type":"text","text":"; an unsigned 32 bit integer."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"x"},{"text":": the type string of ","type":"text"},{"type":"codeVoice","code":"G_VARIANT_TYPE_INT64"},{"type":"text","text":"; a signed 64 bit integer."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"t","type":"codeVoice"},{"text":": the type string of ","type":"text"},{"code":"G_VARIANT_TYPE_UINT64","type":"codeVoice"},{"type":"text","text":"; an unsigned 64 bit integer."}]}]},{"content":[{"inlineContent":[{"code":"h","type":"codeVoice"},{"text":": the type string of ","type":"text"},{"code":"G_VARIANT_TYPE_HANDLE","type":"codeVoice"},{"type":"text","text":"; a signed 32 bit value"},{"text":" ","type":"text"},{"type":"text","text":"that, by convention, is used as an index into an array of file"},{"type":"text","text":" "},{"text":"descriptors that are sent alongside a D-Bus message.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"d"},{"type":"text","text":": the type string of "},{"code":"G_VARIANT_TYPE_DOUBLE","type":"codeVoice"},{"text":"; a double precision","type":"text"},{"text":" ","type":"text"},{"text":"floating point value.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"s"},{"type":"text","text":": the type string of "},{"type":"codeVoice","code":"G_VARIANT_TYPE_STRING"},{"type":"text","text":"; a string."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"o","type":"codeVoice"},{"text":": the type string of ","type":"text"},{"code":"G_VARIANT_TYPE_OBJECT_PATH","type":"codeVoice"},{"type":"text","text":"; a string in the form"},{"type":"text","text":" "},{"type":"text","text":"of a D-Bus object path."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"g","type":"codeVoice"},{"type":"text","text":": the type string of "},{"type":"codeVoice","code":"G_VARIANT_TYPE_SIGNATURE"},{"text":"; a string in the form of","type":"text"},{"type":"text","text":" "},{"text":"a D-Bus type signature.","type":"text"}]}]},{"content":[{"inlineContent":[{"code":"?","type":"codeVoice"},{"type":"text","text":": the type string of "},{"type":"codeVoice","code":"G_VARIANT_TYPE_BASIC"},{"type":"text","text":"; an indefinite type that"},{"type":"text","text":" "},{"type":"text","text":"is a supertype of any of the basic types."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"v","type":"codeVoice"},{"text":": the type string of ","type":"text"},{"type":"codeVoice","code":"G_VARIANT_TYPE_VARIANT"},{"type":"text","text":"; a container type that"},{"text":" ","type":"text"},{"text":"contain any other type of value.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"a"},{"type":"text","text":": used as a prefix on another type string to mean an array of that"},{"text":" ","type":"text"},{"text":"type; the type string ","type":"text"},{"type":"codeVoice","code":"ai"},{"text":", for example, is the type of an array of","type":"text"},{"text":" ","type":"text"},{"text":"signed 32-bit integers.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"m"},{"text":": used as a prefix on another type string to mean a ‘maybe’, or","type":"text"},{"type":"text","text":" "},{"type":"text","text":"‘nullable’, version of that type; the type string "},{"code":"ms","type":"codeVoice"},{"type":"text","text":", for example,"},{"text":" ","type":"text"},{"type":"text","text":"is the type of a value that maybe contains a string, or maybe contains"},{"text":" ","type":"text"},{"type":"text","text":"nothing."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"()","type":"codeVoice"},{"type":"text","text":": used to enclose zero or more other concatenated type strings to"},{"type":"text","text":" "},{"text":"create a tuple type; the type string ","type":"text"},{"type":"codeVoice","code":"(is)"},{"type":"text","text":", for example, is the type of"},{"type":"text","text":" "},{"type":"text","text":"a pair of an integer and a string."}]}]},{"content":[{"inlineContent":[{"code":"r","type":"codeVoice"},{"type":"text","text":": the type string of "},{"code":"G_VARIANT_TYPE_TUPLE","type":"codeVoice"},{"type":"text","text":"; an indefinite type that is"},{"type":"text","text":" "},{"type":"text","text":"a supertype of any tuple type, regardless of the number of items."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"{}","type":"codeVoice"},{"type":"text","text":": used to enclose a basic type string concatenated with another type"},{"text":" ","type":"text"},{"type":"text","text":"string to create a dictionary entry type, which usually appears inside of"},{"type":"text","text":" "},{"text":"an array to form a dictionary; the type string ","type":"text"},{"code":"a{sd}","type":"codeVoice"},{"text":", for example, is","type":"text"},{"type":"text","text":" "},{"text":"the type of a dictionary that maps strings to double precision floating","type":"text"},{"type":"text","text":" "},{"type":"text","text":"point values."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The first type (the basic type) is the key type and the second type is"},{"type":"text","text":" "},{"text":"the value type. The reason that the first type is restricted to being a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"basic type is so that it can easily be hashed."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"*"},{"text":": the type string of ","type":"text"},{"code":"G_VARIANT_TYPE_ANY","type":"codeVoice"},{"type":"text","text":"; the indefinite type that is"},{"type":"text","text":" "},{"text":"a supertype of all types.  Note that, as with all type strings, this","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"character represents exactly one type. It cannot be used inside of tuples"},{"text":" ","type":"text"},{"type":"text","text":"to mean ‘any number of items’."}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Any type string of a container that contains an indefinite type is,"},{"text":" ","type":"text"},{"text":"itself, an indefinite type. For example, the type string ","type":"text"},{"type":"codeVoice","code":"a*"},{"type":"text","text":" "},{"type":"text","text":"(corresponding to "},{"code":"G_VARIANT_TYPE_ARRAY","type":"codeVoice"},{"type":"text","text":") is an indefinite type"},{"text":" ","type":"text"},{"text":"that is a supertype of every array type. ","type":"text"},{"type":"codeVoice","code":"(*s)"},{"type":"text","text":" is a supertype"},{"type":"text","text":" "},{"type":"text","text":"of all tuples that contain exactly two items where the second"},{"type":"text","text":" "},{"type":"text","text":"item is a string."}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"a{?*}"},{"text":" is an indefinite type that is a supertype of all arrays","type":"text"},{"type":"text","text":" "},{"text":"containing dictionary entries where the key is any basic type and","type":"text"},{"text":" ","type":"text"},{"text":"the value is any type at all.  This is, by definition, a dictionary,","type":"text"},{"type":"text","text":" "},{"text":"so this type string corresponds to ","type":"text"},{"type":"codeVoice","code":"G_VARIANT_TYPE_DICTIONARY"},{"type":"text","text":". Note"},{"text":" ","type":"text"},{"type":"text","text":"that, due to the restriction that the key of a dictionary entry must"},{"type":"text","text":" "},{"type":"text","text":"be a basic type, "},{"type":"codeVoice","code":"{**}"},{"text":" is not a valid type string.","type":"text"}]},{"inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantTypeRef","isActive":true,"type":"reference"},{"type":"text","text":" type acts as a lightweight Swift reference to an underlying "},{"type":"codeVoice","code":"GVariantType"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"type":"text","text":"It exposes methods that can operate on this data type through "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantTypeProtocol","type":"reference"},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantTypeRef","isActive":true},{"text":" only as an ","type":"text"},{"code":"unowned","type":"codeVoice"},{"type":"text","text":" reference to an existing "},{"type":"codeVoice","code":"GVariantType"},{"text":" instance.","type":"text"}],"type":"paragraph"},{"type":"aside","name":"Note","content":[{"inlineContent":[{"text":"Use ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantType","isActive":true,"type":"reference"},{"text":" (instead of ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantTypeRef","isActive":true,"type":"reference"},{"type":"text","text":") if you want to use Automatic Reference Counting for memory management of the underlying "},{"type":"codeVoice","code":"GVariantType"},{"type":"text","text":" instance."}],"type":"paragraph"}],"style":"note"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/VariantTypeRef"},"kind":"symbol","topicSections":[{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/VariantTypeRef\/init(_:)-1262e","doc:\/\/GLib\/documentation\/GLib\/VariantTypeRef\/init(_:)-1cp1y","doc:\/\/GLib\/documentation\/GLib\/VariantTypeRef\/init(_:)-3bbhv","doc:\/\/GLib\/documentation\/GLib\/VariantTypeRef\/init(_:)-3or3","doc:\/\/GLib\/documentation\/GLib\/VariantTypeRef\/init(_:)-yp1o","doc:\/\/GLib\/documentation\/GLib\/VariantTypeRef\/init(cPointer:)","doc:\/\/GLib\/documentation\/GLib\/VariantTypeRef\/init(constPointer:)","doc:\/\/GLib\/documentation\/GLib\/VariantTypeRef\/init(gconstpointer:)","doc:\/\/GLib\/documentation\/GLib\/VariantTypeRef\/init(gpointer:)","doc:\/\/GLib\/documentation\/GLib\/VariantTypeRef\/init(mutating:)","doc:\/\/GLib\/documentation\/GLib\/VariantTypeRef\/init(opaquePointer:)","doc:\/\/GLib\/documentation\/GLib\/VariantTypeRef\/init(typeString:)"],"generated":true,"anchor":"Initializers","title":"Initializers"},{"generated":true,"identifiers":["doc:\/\/GLib\/documentation\/GLib\/VariantTypeRef\/ptr"],"anchor":"Instance-Properties","title":"Instance Properties"},{"generated":true,"title":"Type Methods","identifiers":["doc:\/\/GLib\/documentation\/GLib\/VariantTypeRef\/checked(typeString:)"],"anchor":"Type-Methods"},{"anchor":"Default-Implementations","identifiers":["doc:\/\/GLib\/documentation\/GLib\/VariantTypeRef\/PointerWrapper-Implementations","doc:\/\/GLib\/documentation\/GLib\/VariantTypeRef\/VariantTypeProtocol-Implementations"],"title":"Default Implementations","generated":true}],"references":{"doc://GLib/documentation/GLib/Variant":{"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","kind":"symbol","navigatorTitle":[{"tex
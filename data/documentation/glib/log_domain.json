{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"LOG_DOMAIN","kind":"identifier"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Log domains must be unique, and it is recommended that they are the"},{"type":"text","text":" "},{"text":"application or library name, optionally followed by a hyphen and a sub-domain","type":"text"},{"text":" ","type":"text"},{"text":"name. For example, ","type":"text"},{"code":"bloatpad","type":"codeVoice"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"bloatpad-io"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"If undefined, it defaults to the default ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" (or ","type":"text"},{"type":"codeVoice","code":"\"\""},{"type":"text","text":") log domain; this is"},{"type":"text","text":" "},{"text":"not advisable, as it cannot be filtered against using the ","type":"text"},{"code":"G_MESSAGES_DEBUG","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"environment variable."}]},{"inlineContent":[{"type":"text","text":"For example, GTK uses this in its "},{"code":"Makefile.am","type":"codeVoice"},{"type":"text","text":":"}],"type":"paragraph"},{"type":"codeListing","code":["AM_CPPFLAGS = -DG_LOG_DOMAIN=\\\"Gtk\\\""],"syntax":null},{"inlineContent":[{"text":"Applications can choose to leave it as the default ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" (or ","type":"text"},{"code":"\"\"","type":"codeVoice"},{"type":"text","text":")"},{"type":"text","text":" "},{"type":"text","text":"domain. However, defining the domain offers the same advantages as"},{"type":"text","text":" "},{"type":"text","text":"above."}],"type":"paragraph"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/documentation\/glib\/log_domain"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/LOG_DOMAIN","interfaceLanguage":"swift"},"metadata":{"fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"LOG_DOMAIN","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}],"title":"LOG_DOMAIN","externalID":"s:4GLib10LOG_DOMAINSivp","symbolKind":"var","modules":[{"name":"GLib"}],"role":"symbol","platforms":[],"roleHeading":"Global Variable"},"kind":"symbol","abstract":[{"text":"Libraries should define this so that any messages","type":"text"},{"type":"text","text":" "},{"type":"text","text":"which they log can be differentiated from messages from other"},{"type":"text","text":" "},{"type":"text","text":"libraries and application code. But be careful not to define"},{"type":"text","text":" "},{"type":"text","text":"it in any public header files."}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"sections":[],"references":{"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"doc://GLib/documentation/GLib/LOG_DOMAIN":{"fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"text":"LOG_DOMAIN","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"title":"LOG_DOMAIN","deprecated":true,"url":"\/documentation\/glib\/log_domain","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/LOG_DOMAIN","abstract":[{"type":"text","text":"Libraries should define this so that any messages"},{"type":"text","text":" "},{"type":"text","text":"which they log can be differentiated from messages from other"},{"type":"text","text":" "},{"type":"text","text":"libraries and application code. But be careful not to define"},{"type":"text","text":" "},{"text":"it in any public header files.","type":"text"}],"type":"topic","role":"symbol"}}}
type":"text","text":" "},{"type":"text","text":"for "},{"type":"codeVoice","code":"uri"},{"type":"text","text":",  "},{"code":"false","type":"codeVoice"},{"text":" is returned and error is set to","type":"text"},{"type":"text","text":" "},{"code":"appNotRegistered","type":"codeVoice"},{"text":".  Otherwise, if no bookmark","type":"text"},{"type":"text","text":" "},{"type":"text","text":"for "},{"type":"codeVoice","code":"uri"},{"type":"text","text":" is found, one is created."}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"set_app_info is deprecated:"}],"type":"strong"},{"type":"text","text":" "},{"text":"Use g_bookmark_file_set_application_info() instead, as","type":"text"},{"text":" ","type":"text"},{"code":"time_t","type":"codeVoice"},{"type":"text","text":" is deprecated due to the year 2038 problem."}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/bookmarkfileref\/setappinfo(uri:name:exec:count:stamp:)"]}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/setAppInfo(uri:name:exec:count:stamp:)","interfaceLanguage":"swift"},"abstract":[{"text":"Sets the meta-data of application ","type":"text"},{"code":"name","type":"codeVoice"},{"type":"text","text":" inside the list of"},{"type":"text","text":" "},{"text":"applications that have registered a bookmark for ","type":"text"},{"type":"codeVoice","code":"uri"},{"type":"text","text":" inside"},{"text":" ","type":"text"},{"code":"bookmark","type":"codeVoice"},{"text":".","type":"text"}],"sections":[],"references":{"doc://GLib/documentation/GLib/BookmarkFileRef/BookmarkFileProtocol-Implementations":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/BookmarkFileProtocol-Implementations","title":"BookmarkFileProtocol Implementations","url":"\/documentation\/glib\/bookmarkfileref\/bookmarkfileprotocol-implementations","type":"topic","role":"collectionGroup","abstract":[],"kind":"article"
{"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/CondRef","doc:\/\/GLib\/documentation\/GLib\/CondRef\/CondProtocol-Implementations"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"waitUntil","kind":"identifier"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"MutexT"},{"kind":"text","text":">("},{"text":"mutex","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"MutexT"},{"text":", ","kind":"text"},{"text":"endTime","kind":"externalParam"},{"kind":"text","text":": "},{"text":"gint64","preciseIdentifier":"c:@T@gint64","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"},{"text":" ","kind":"text"},{"text":"where","kind":"keyword"},{"kind":"text","text":" "},{"text":"MutexT","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:4GLib13MutexProtocolP","text":"MutexProtocol","identifier":"doc:\/\/GLib\/documentation\/GLib\/MutexProtocol","kind":"typeIdentifier"}]}]},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"As with ","type":"text"},{"type":"codeVoice","code":"g_cond_wait()"},{"text":" it is possible that a spurious or stolen wakeup","type":"text"},{"type":"text","text":" "},{"text":"could occur.  For that reason, waiting on a condition variable should","type":"text"},{"type":"text","text":" "},{"type":"text","text":"always be in a loop, based on an explicitly-checked predicate."}]},{"inlineContent":[{"code":"true","type":"codeVoice"},{"text":" is returned if the condition variable was signalled (or in the","type":"text"},{"type":"text","text":" "},{"text":"case of a spurious wakeup).  ","type":"text"},{"code":"false","type":"codeVoice"},{"type":"text","text":" is returned if "},{"code":"endTime","type":"codeVoice"},{"text":" has","type":"text"},{"type":"text","text":" "},{"type":"text","text":"passed."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The following code shows how to correctly perform a timed wait on a"},{"text":" ","type":"text"},{"type":"text","text":"condition variable (extending the example presented in the"},{"type":"text","text":" "},{"text":"documentation for ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond"},{"text":"):","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"type":"codeListing","syntax":"C","code":["gpointer","pop_data_timed (void)","{","  gint64 end_time;","  gpointer data;","","  g_mutex_lock (&data_mutex);","","  end_time = g_get_monotonic_time () + 5 * G_TIME_SPAN_SECOND;","  while (!current_data)","    if (!g_cond_wait_until (&data_cond, &data_mutex, end_time))","      {","        \/\/ timeout has passed.","        g_mutex_unlock (&data_mutex);","        return NULL;","      }","","  \/\/ there is data for us","  data = current_data;","  current_data = NULL;","","  g_mutex_unlock (&data_mutex);","","  return data;","}"]},{"type":"paragraph","inlineContent":[{"text":"Notice that the end time is calculated once, before entering the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"loop and reused.  This is the motivation behind the use of absolute"},{"type":"text","text":" "},{"text":"time on this API – if a relative time of 5 seconds were passed","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"directly to the call and a spurious wakeup occurred, the program would"},{"text":" ","type":"text"},{"text":"have to start over waiting again (which would lead to a total wait","type":"text"},{"type":"text","text":" "},{"type":"text","text":"time of more than 5 seconds)."}]}],"kind":"content"}],"abstract":[{"type":"text","text":"Waits until either "},{"type":"codeVoice","code":"cond"},{"text":" is signalled or ","type":"text"},{"type":"codeVoice","code":"endTime"},{"text":" has passed.","type":"text"}],"variants":[{"paths":["\/documentation\/glib\/condref\/waituntil(mutex:endtime:)"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/CondRef\/waitUntil(mutex:endTime:)","interfaceLanguage":"swift"},"metadata":{"extendedModule":"GLib","roleHeading":"Instance Method","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"waitUntil","kind":"identifier"},{"text":"<","kind":"text"},{"text":"MutexT","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"mutex","kind":"externalParam"},{"kind":"text","text":": "},{"text":"MutexT","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"endTime","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@gint64","text":"gint64","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"symbolKind":"method","externalID":"s:4GLib12CondProtocolPAAE9waitUntil5mutex7endTimeSbqd___s5Int64VtAA05MutexC0Rd__lF::SYNTHESIZED::s:4GLib7CondRefV","modules":[{"name":"GLib"}],"title":"waitUntil(mutex:endTime:)"},"sections":[],"references":{"doc://GLib/documentation/GLib/Mutex":{"url":"\/documentation\/glib\/mutex","role":"symbol","navigatorTitle":[{"text":"Mutex","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","type":"topic","abstract":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","isActive":true},{"text":" struct is an opaque data structure to represent a mutex","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"(mutual exclusion). It can be used to protect data against shared"},{"text":" ","type":"text"},{"type":"text","text":"access."}],"kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Mutex"}],"title":"Mutex"},"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"doc://GLib/documentation/GLib/CondRef/waitUntil(mutex:endTime:)":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/CondRef\/waitUntil(mutex:endTime:)","kind":"symbol","title":"waitUntil(mutex:endTime:)","role":"symbol","abstract":[{"type":"text","text":"Waits until either "},{"type":"codeVoice","code":"cond"},{"text":" is signalled or ","type":"text"},{"code":"endTime","type":"codeVoice"},{"type":"text","text":" has passed."}],"url":"\/documentation\/glib\/condref\/waituntil(mutex:endtime:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"waitUntil"},{"text":"<","kind":"text"},{"text":"MutexT","kind":"genericParameter"},{"kind":"text","text":">("},{"kind":"externalParam","text":"mutex"},{"kind":"text","text":": "},{"text":"MutexT","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"endTime","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@gint64","kind":"typeIdentifier","text":"gint64"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"type":"topic"},"doc://GLib/documentation/GLib/CondRef/CondProtocol-Implementations":{"type":"topic","role":"collectionGroup","url":"\/documentation\/glib\/condref\/condprotocol-implementations","kind":"article","identifier":"doc:\/\/GLib\/documentation\/GLib\/CondRef\/CondProtocol-Implementations","title":"CondProtocol Implementations","abstract":[]},"doc://GLib/documentation/GLib/Cond":{"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Cond"}],"url":"\/documentation\/glib\/cond","navigatorTitle":[{"kind":"identifier","text":"Cond"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","role":"symbol","abstract":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","type":"reference","isActive":true},{"type":"text","text":" struct is an opaque data structure that represents a"},{"text":" ","type":"text"},{"text":"condition. Threads can block on a ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","isActive":true},{"text":" if they find a certain","type":"text"},{"type":"text","text":" "},{"type":"text","text":"condition to be false. If other threads change the state of this"},{"type":"text","text":" "},{"type":"text","text":"condition they signal the "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","isActive":true},{"type":"text","text":", and that causes the waiting"},{"type":"text","text":" "},{"type":"text","text":"threads to be woken up."}],"type":"topic","title":"Cond","kind":"symbol"},"doc://GLib/documentation/GLib/MutexProtocol":{"title":"MutexProtocol","abstract":[{"text":"The ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","type":"reference"},{"type":"text","text":" struct is an opaque data structure to represent a mutex"},{"text":" ","type":"text"},{"text":"(mutual exclusion). It can be used to protect data against shared","type":"text"},{"type":"text","text":" "},{"text":"access.","type":"text"}],"kind":"symbol","url":"\/documentation\/glib\/mutexprotocol","identifier":"doc:\/\/GLib\/documentation\/GLib\/MutexProtocol","type":"topic","role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"MutexProtocol"}],"navigatorTitle":[{"kind":"identifier","text":"MutexProtocol"}]},"doc://GLib/documentation/GLib/CondRef":{"type":"topic","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/CondRef","role":"symbol
n returns, "},{"type":"codeVoice","code":"mutex"},{"type":"text","text":" is locked again and owned by the"},{"type":"text","text":" "},{"type":"text","text":"calling thread."}],"url":"\/documentation\/glib\/condref\/wait(mutex:)"},"doc://GLib/documentation/GLib/Cond":{"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Cond"}],"url":"\/documentation\/glib\/cond","navigatorTitle":[{"kind":"identifier","text":"Cond"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","role":"symbol","abstract":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","type":"reference","isActive":true},{"type":"text","text":" struct is an opaque data structure that represents a"},{"text":" ","type":"text"},{"text":"condition. Threads can block on a ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","isActive":true},{"text":" if they find a certain","type":"text"},{"type":"text","text":" "},{"type":"text","text":"condition to be false. If other threads change the state of this"},{"type":"text","text":" "},{"type":"text","text":"condition they signal the "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","isActive":true},{"type":"text","text":", and that causes the waiting"},{"type":"text","text":" "},{"type":"text","text":"threads to be woken up."}],"type":"topic","title":"Cond","kind":"symbol"},"doc://GLib/documentation/GLib/MutexProtocol":{"title":"MutexProtocol","abstract":[{"text":"The ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","type":"reference"},{"type":"text","text":" struct is an opaque data structure to represent a mutex"},{"text":" ","type":"text"},{"text":"(mutual exclusion). It can be used to protect data against shared","type":"text"},{"type":"text","text":" "},{"text":"access.","type":"text"}],"kind":"symbol","url":"\/documentation\/glib\/mutexprotocol","identifier":"doc:\/\
{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"RWLockRef","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"anchor":"overview","text":"Overview","type":"heading"},{"inlineContent":[{"text":"The difference to a mutex is that a reader-writer lock discriminates","type":"text"},{"type":"text","text":" "},{"type":"text","text":"between read-only (‘reader’) and full (‘writer’) access. While only"},{"type":"text","text":" "},{"type":"text","text":"one thread at a time is allowed write access (by holding the ‘writer’"},{"text":" ","type":"text"},{"text":"lock via ","type":"text"},{"type":"codeVoice","code":"g_rw_lock_writer_lock()"},{"text":"), multiple threads can gain","type":"text"},{"text":" ","type":"text"},{"text":"simultaneous read-only access (by holding the ‘reader’ lock via","type":"text"},{"text":" ","type":"text"},{"code":"g_rw_lock_reader_lock()","type":"codeVoice"},{"type":"text","text":")."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"It is unspecified whether readers or writers have priority in acquiring the"},{"type":"text","text":" "},{"text":"lock when a reader already holds the lock and a writer is queued to acquire","type":"text"},{"type":"text","text":" "},{"text":"it.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Here is an example for an array with access functions:"},{"type":"text","text":" "},{"type":"text","text":"(C Language Example):"}]},{"code":["  GRWLock lock;","  GPtrArray *array;","","  gpointer","  my_array_get (guint index)","  {","    gpointer retval = NULL;","","    if (!array)","      return NULL;","","    g_rw_lock_reader_lock (&lock);","    if (index < array->len)","      retval = g_ptr_array_index (array, index);","    g_rw_lock_reader_unlock (&lock);","","    return retval;","  }","","  void","  my_array_set (guint index, gpointer data)","  {","    g_rw_lock_writer_lock (&lock);","","    if (!array)","      array = g_ptr_array_new ();","","    if (index >= array->len)","      g_ptr_array_set_size (array, index+1);","    g_ptr_array_index (array, index) = data;","","    g_rw_lock_writer_unlock (&lock);","  }"," "],"syntax":"C","type":"codeListing"},{"inlineContent":[{"type":"text","text":"This example shows an array which can be accessed by many readers"},{"text":" ","type":"text"},{"type":"text","text":"(the "},{"code":"my_array_get()","type":"codeVoice"},{"type":"text","text":" function) simultaneously, whereas the writers"},{"text":" ","type":"text"},{"text":"(the ","type":"text"},{"type":"codeVoice","code":"my_array_set()"},{"type":"text","text":" function) will only be allowed one at a time"},{"type":"text","text":" "},{"type":"text","text":"and only if no readers currently access the array. This is because"},{"type":"text","text":" "},{"text":"of the potentially dangerous resizing of the array. Using these","type":"text"},{"type":"text","text":" "},{"text":"functions is fully multi-thread safe now.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If a ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLock","isActive":true},{"text":" is allocated in static storage then it can be used","type":"text"},{"text":" ","type":"text"},{"text":"without initialisation.  Otherwise, you should call","type":"text"},{"text":" ","type":"text"},{"code":"g_rw_lock_init()","type":"codeVoice"},{"type":"text","text":" on it and "},{"type":"codeVoice","code":"g_rw_lock_clear()"},{"type":"text","text":" when done."}],"type":"paragraph"},{"inlineContent":[{"text":"A GRWLock should only be accessed with the g_rw_lock_ functions.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockRef","type":"reference"},{"type":"text","text":" type acts as a lightweight Swift reference to an underlying "},{"type":"codeVoice","code":"GRWLock"},{"text":" instance.","type":"text"},{"type":"text","text":" "},{"text":"It exposes methods that can operate on this data type through ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockProtocol","isActive":true},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"text":"Use ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockRef","isActive":true},{"type":"text","text":" only as an "},{"code":"unowned","type":"codeVoice"},{"type":"text","text":" reference to an existing "},{"code":"GRWLock","type":"codeVoice"},{"text":" instance.","type":"text"}]},{"style":"note","name":"Note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLock","isActive":true,"type":"reference"},{"text":" (instead of ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockRef","isActive":true},{"text":") if you want to use Automatic Reference Counting for memory management of the underlying ","type":"text"},{"type":"codeVoice","code":"GRWLock"},{"text":" instance.","type":"text"}]}]}]}],"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/rwlockref"]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"metadata":{"title":"RWLockRef","modules":[{"name":"GLib"}],"symbolKind":"struct","roleHeading":"Structure","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"RWLockRef","kind":"identifier"}],"role":"symbol","externalID":"s:4GLib9RWLockRefV","navigatorTitle":[{"text":"RWLockRef","kind":"identifier"}]},"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/RWLockRef"},"abstract":
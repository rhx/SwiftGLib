{"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"VariantDict","kind":"identifier"}],"languages":["swift"]}]},{"content":[{"anchor":"overview","level":2,"type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"It can be used for doing a sequence of dictionary lookups in an","type":"text"},{"type":"text","text":" "},{"text":"efficient way on an existing ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"text":" dictionary or it can be used","type":"text"},{"type":"text","text":" "},{"text":"to construct new dictionaries with a hashtable-like interface.  It","type":"text"},{"type":"text","text":" "},{"text":"can also be used for taking existing dictionaries and modifying them","type":"text"},{"type":"text","text":" "},{"text":"in order to create new ones.","type":"text"}]},{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict"},{"type":"text","text":" can only be used with "},{"code":"G_VARIANT_TYPE_VARDICT","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"dictionaries."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is possible to use "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","isActive":true},{"text":" allocated on the stack or on the","type":"text"},{"type":"text","text":" "},{"text":"heap.  When using a stack-allocated ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict"},{"text":", you begin with a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"call to "},{"type":"codeVoice","code":"g_variant_dict_init()"},{"type":"text","text":" and free the resources with a call to"},{"text":" ","type":"text"},{"code":"g_variant_dict_clear()","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Heap-allocated "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","type":"reference","isActive":true},{"type":"text","text":" follows normal refcounting rules: you"},{"text":" ","type":"text"},{"text":"allocate it with ","type":"text"},{"code":"g_variant_dict_new()","type":"codeVoice"},{"type":"text","text":" and use "},{"code":"g_variant_dict_ref()","type":"codeVoice"},{"type":"text","text":" "},{"text":"and ","type":"text"},{"type":"codeVoice","code":"g_variant_dict_unref()"},{"type":"text","text":"."}]},{"inlineContent":[{"code":"g_variant_dict_end()","type":"codeVoice"},{"type":"text","text":" is used to convert the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict"},{"type":"text","text":" back into a"},{"type":"text","text":" "},{"type":"text","text":"dictionary-type "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true},{"text":".  When used with stack-allocated instances,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"this also implicitly frees all associated memory, but for"},{"type":"text","text":" "},{"type":"text","text":"heap-allocated instances, you must still call "},{"code":"g_variant_dict_unref()","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"afterwards."}],"type":"paragraph"},{"inlineContent":[{"text":"You will typically want to use a heap-allocated ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict"},{"text":" when","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"you expose it as part of an API.  For most other uses, the"},{"type":"text","text":" "},{"text":"stack-allocated form will be more convenient.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Consider the following two examples that do the same thing in each"},{"text":" ","type":"text"},{"type":"text","text":"style: take an existing dictionary and look up the “count” uint32"},{"type":"text","text":" "},{"type":"text","text":"key, adding 1 to it if it is found, or returning an error if the"},{"text":" ","type":"text"},{"text":"key is not found.  Each returns the new dictionary as a floating","type":"text"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"text":".","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Using-a-stack-allocated-GVariantDict","type":"heading","text":"Using a stack-allocated GVariantDict"},{"inlineContent":[{"type":"text","text":"(C Language Example):"}],"type":"paragraph"},{"code":["  GVariant *","  add_to_count (GVariant  *orig,","                GError   **error)","  {","    GVariantDict dict;","    guint32 count;","","    g_variant_dict_init (&dict, orig);","    if (!g_variant_dict_lookup (&dict, \"count\", \"u\", &count))","      {","        g_set_error (...);","        g_variant_dict_clear (&dict);","        return NULL;","      }","","    g_variant_dict_insert (&dict, \"count\", \"u\", count + 1);","","    return g_variant_dict_end (&dict);","  }"],"type":"codeListing","syntax":"C"},{"type":"heading","level":2,"text":"Using heap-allocated GVariantDict","anchor":"Using-heap-allocated-GVariantDict"},{"inlineContent":[{"type":"text","text":"(C Language Example):"}],"type":"paragraph"},{"code":["  GVariant *","  add_to_count (GVariant  *orig,","                GError   **error)","  {","    GVariantDict *dict;","    GVariant *result;","    guint32 count;","","    dict = g_variant_dict_new (orig);","","    if (g_variant_dict_lookup (dict, \"count\", \"u\", &count))","      {","        g_variant_dict_insert (dict, \"count\", \"u\", count + 1);","        result = g_variant_dict_end (dict);","      }","    else","      {","        g_set_error (...);","        result = NULL;","      }","","    g_variant_dict_unref (dict);","","    return result;","  }"],"type":"codeListing","syntax":"C"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","type":"reference","isActive":true},{"type":"text","text":" type acts as a reference-counted owner of an underlying "},{"code":"GVariantDict","type":"codeVoice"},{"type":"text","text":" instance."},{"text":" ","type":"text"},{"type":"text","text":"It provides the methods that can operate on this data type through "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDictProtocol","isActive":true},{"text":" conformance.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Use "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","isActive":true,"type":"reference"},{"type":"text","text":" as a strong reference or owner of a "},{"code":"GVariantDict","type":"codeVoice"},{"text":" instance.","type":"text"}]},{"type":"aside","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDictRef"},{"text":" (instead of ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","type":"reference"},{"type":"text","text":") for a lightweight Swift reference to an underlying "},{"type":"codeVoice","code":"GVariantDict"},{"text":" instance.","type":"text"}]}],"style":"note"}],"kind":"content"}],"relationshipsSections":[{"title":"Conforms To","type":"conformsTo","identifiers":["doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","doc:\/\/GLib\/documentation\/GLib\/VariantDictProtocol"],"kind":"relationships"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/variantdict"]}],"metadata":{"navigatorTitle":[{"kind":"identifier","text":"VariantDict"}],"symbolKind":"class","roleHeading":"Clas
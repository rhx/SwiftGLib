{"sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"roleHeading":"Function","role":"symbol","symbolKind":"func","externalID":"s:4GLib17testExpectMessage9logDomain0E5Level7patternySPys4Int8VGSg_AA03LogG5FlagsVAItF","title":"testExpectMessage(logDomain:logLevel:pattern:)","modules":[{"name":"GLib"}],"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"testExpectMessage","kind":"identifier"},{"kind":"text","text":"("},{"text":"logDomain","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier","text":"gchar"},{"text":">?, ","kind":"text"},{"text":"logLevel","kind":"externalParam"},{"kind":"text","text":": "},{"text":"LogLevelFlags","preciseIdentifier":"s:4GLib13LogLevelFlagsV","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"pattern","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier","text":"gchar"},{"kind":"text","text":">!)"}]},"abstract":[{"text":"Indicates that a message with the given ","type":"text"},{"type":"codeVoice","code":"logDomain"},{"text":" and ","type":"text"},{"code":"logLevel","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"with text matching ","type":"text"},{"type":"codeVoice","code":"pattern"},{"text":", is expected to be logged.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"testExpectMessage"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"logDomain"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"gchar","preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier"},{"kind":"text","text":">? = nil, "},{"text":"logLevel","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:4GLib13LogLevelFlagsV","identifier":"doc:\/\/GLib\/documentation\/GLib\/LogLevelFlags","kind":"typeIdentifier","text":"LogLevelFlags"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"pattern"},{"text":": ","kind":"text"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">!)"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"inlineContent":[{"text":"When this message is logged, it will not be printed, and the test case will","type":"text"},{"type":"text","text":" "},{"text":"not abort.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This API may only be used with the old logging API ([func"},{"type":"codeVoice","code":"GLib.log"},{"type":"text","text":"] without"},{"text":" ","type":"text"},{"code":"G_LOG_USE_STRUCTURED","type":"codeVoice"},{"type":"text","text":" defined). It will not work with the structured logging"},{"type":"text","text":" "},{"type":"text","text":"API. See "},{"identifier":"logging.html#testing-for-messages","type":"reference","isActive":true},{"text":".","type":"text"}]},{"inlineContent":[{"type":"text","text":"Use [func"},{"code":"GLib.test_assert_expected_messages","type":"codeVoice"},{"type":"text","text":"] to assert that all"},{"type":"text","text":" "},{"type":"text","text":"previously-expected messages have been seen and suppressed."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can call this multiple times in a row, if multiple messages are"},{"text":" ","type":"text"},{"text":"expected as a result of a single call. (The messages must appear in","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the same order as the calls to [func"},{"code":"GLib.test_expect_message","type":"codeVoice"},{"type":"text","text":"].)"}]},{"inlineContent":[{"type":"text","text":"For example:"}],"type":"paragraph"},{"syntax":"c","code":["\/\/ `g_main_context_push_thread_default()` should fail if the","\/\/ context is already owned by another thread.","g_test_expect_message (G_LOG_DOMAIN,","                       G_LOG_LEVEL_CRITICAL,","                       \"assertion*acquired_context*failed\");","g_main_context_push_thread_default (bad_context);","g_test_assert_expected_messages ();"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Note that you cannot use this to test [func"},{"type":"codeVoice","code":"GLib.error"},{"text":"] messages, since","type":"text"},{"type":"text","text":" "},{"text":"[func","type":"text"},{"type":"codeVoice","code":"GLib.error"},{"text":"] intentionally never returns even if the program doesn’t","type":"text"},{"type":"text","text":" "},{"text":"abort; use [func","type":"text"},{"code":"GLib.test_trap_subprocess","type":"codeVoice"},{"type":"text","text":"] in this case."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If messages at [flags","type":"text"},{"type":"codeVoice","code":"GLib.LogLevelFlags.LEVEL_DEBUG"},{"type":"text","text":"] are emitted, but not explicitly"},{"text":" ","type":"text"},{"text":"expected via [func","type":"text"},{"type":"codeVoice","code":"GLib.test_expect_message"},{"type":"text","text":"] then they will be ignored."}]}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/testExpectMessage(logDomain:logLevel:pattern:)"},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/testexpectmessage(logdomain:loglevel:pattern:)"]}],"refere
{"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Sets a function to be called at regular intervals, with the default"},{"type":"text","text":" "},{"type":"text","text":"priority, [const"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/priorityDefault","isActive":true,"type":"reference"},{"text":"].","type":"text"}],"sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/timeoutAdd(interval:function:data:)"},"metadata":{"roleHeading":"Function","role":"symbol","title":"timeoutAdd(interval:function:data:)","externalID":"s:4GLib10timeoutAdd8interval8function4dataS2i_s5Int32VSvSgXCSgAHtF","symbolKind":"func","modules":[{"name":"GLib"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"timeoutAdd"},{"kind":"text","text":"("},{"text":"interval","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"function","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GSourceFunc","text":"GSourceFunc"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"data"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gpointer","text":"gpointer"},{"text":"?) -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/timeoutadd(interval:function:data:)"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"timeoutAdd","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"interval"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":", "},{"text":"function","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@GSourceFunc","text":"GSourceFunc","kind":"typeIdentifier"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"data"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@gpointer","text":"gpointer","kind":"typeIdentifier"},{"kind":"text","text":"? = nil) -> "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The given ","type":"text"},{"type":"codeVoice","code":"function"},{"text":" is called repeatedly until it returns","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[const"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/sourceRemove","isActive":true},{"text":"], at which point the timeout is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"automatically destroyed and the function will not be called again. The first"},{"text":" ","type":"text"},{"text":"call to the function will be at the end of the first ","type":"text"},{"type":"codeVoice","code":"interval"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that timeout functions may be delayed, due to the processing of other"},{"text":" ","type":"text"},{"text":"event sources. Thus they should not be relied on for precise timing.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"After each call to the timeout function, the time of the next"},{"type":"text","text":" "},{"text":"timeout is recalculated based on the current time and the given interval","type":"text"},{"type":"text","text":" "},{"text":"(it does not try to ‘catch up’ time lost in delays).","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"type":"reference","isActive":true,"identifier":"main-loop.html#memory-management-of-sources"},{"type":"text","text":" for details"},{"text":" ","type":"text"},{"type":"text","text":"on how to handle the return value and memory management of "},{"code":"data","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If you want to have a timer in the ‘seconds’ range and do not care","type":"text"},{"type":"text","text":" "},{"text":"about the exact time of the first call of the timer, use the","type":"text"},{"text":" ","type":"text"},{"text":"[func","type":"text"},{"code":"GLib.timeout_add_seconds","type":"codeVoice"},{"type":"text","text":"] function; this function allows for more"},{"text":" ","type":"text"},{"text":"optimizations and more efficient system power usage.","type":"text"}]},{"inlineContent":[{"text":"This internally creates a main loop source using","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[func"},{"type":"codeVoice","code":"GLib.timeout_source_new"},{"text":"] and attaches it to the global","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[struct"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","isActive":true},{"type":"text","text":"] using [method"},{"code":"GLib.Source.attach","type":"codeVoice"},{"type":"text","text":"], so the callback"},{"text":" ","type":"text"},{"text":"will be invoked in whichever thread is running that main context. You can do","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"these steps manually if you need greater control or to use a custom main"},{"type":"text","text":" "},{"type":"text","text":"context."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is safe to call this function from any thread."}]},{"type":"paragraph","inlineContent":[{"text":"The interval given is in terms of monotonic time, not wall clock","type":"text"},{"type":"text","text":" "},{"type":"text","text":"time. See [func"},{"type":"codeVoice","code":"GLib.get_monotonic_time"},{"type":"text","text":"]."}]}]}],"kind":"symbol","references":{"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"doc://GLib/documentation/GLib/priorityDefault":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/priorityDefault","url":"\/documentation\/glib\/prioritydefault","role":"symbol","type":"topic","abstract":[{"text":"Use this for default priority event sources.","type":"text"}],"kind":"symbol","title":"priorityDefault","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"priorityDefault"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:s5Int32V","text":"Int32"}]},"main-loop.html#memory-management-of-sources":{"identifier":"main-loop.html#memory-management-of-sources","title":"main loop memory management","url":"main-loop.html#memory-management-of-sources","titleInlineContent":[{"type":"text","text":"main loop memory management"}],"type":"link"},"doc://GLib/documentation/GLib/MainContext":{"navigatorTitle":[{"text":"MainContext","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/glib\/maincontext","role":"symbol","type":"topic","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MainContext","kind":"identifier"}],"abstract":[{"type":"text","text":"The "},{"code":"GMainContext","type":"codeVoice"},{"text":" struct is an opaque data","type":"text"},{"type":"text","text":" "},{"type":"text","text":"type representing a set of sources to be handled in a main loop."}],"title":"MainContext","identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext"},"doc://GLib/documentation/GLib/Source":{"abstract":[{"type":"text","text":"The "},{"code":"GSource","type":"codeVoice"},{"type":"text","text":" struct is an opaque data type"},{"text":" ","type":"tex
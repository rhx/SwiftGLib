{"abstract":[{"type":"text","text":"Sets strict POSIX mode."}],"sections":[],"metadata":{"modules":[{"name":"GLib"}],"externalID":"s:4GLib21OptionContextProtocolPAAE3set11strictPosixySb_tF::SYNTHESIZED::s:4GLib13OptionContextC","roleHeading":"Instance Method","title":"set(strictPosix:)","symbolKind":"method","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"set"},{"kind":"text","text":"("},{"text":"strictPosix","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"kind":"text","text":")"}],"extendedModule":"GLib"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/OptionContext","doc:\/\/GLib\/documentation\/GLib\/OptionContext\/OptionContextProtocol-Implementations"]]},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/OptionContext\/set(strictPosix:)","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/optioncontext\/set(strictposix:)"]}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"set","kind":"identifier"},{"text":"(","kind":"text"},{"text":"strictPosix","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"text":")","kind":"text"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"inlineContent":[{"type":"text","text":"By default, this mode is disabled."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In strict POSIX mode, the first non-argument parameter encountered"},{"text":" ","type":"text"},{"type":"text","text":"(eg: filename) terminates argument processing.  Remaining arguments"},{"text":" ","type":"text"},{"type":"text","text":"are treated as non-options and are not attempted to be parsed."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If strict POSIX mode is disabled then parsing is done in the GNU way"},{"type":"text","text":" "},{"text":"where option arguments can be freely mixed with non-options.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"As an example, consider “ls foo -l”.  With GNU style parsing, this"},{"text":" ","type":"text"},{"text":"will list “foo” in long mode.  In strict POSIX style, this will list","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the files named “foo” and “-l”."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"It may be useful to force strict POSIX mode when creating “verb","type":"text"},{"text":" ","type":"text"},{"text":"style” command line tools.  For example, the “gsettings” command line","type":"text"},{"type":"text","text":" "},{"text":"tool supports the global option “–schemadir” as well as many","type":"text"},{"type":"text","text":" "},{"text":"subcommands (“get”, “set”, etc.) which each have their own set of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"arguments.  Using strict POSIX mode will allow parsing the global"},{"text":" ","type":"text"},{"type":"text","text":"options up to the verb name while leaving the remaining options to be"},{"text":" ","type":"text"},{"type":"text","text":"parsed by the relevant subcommand (which can be determined by"},{"text":" ","type":"text"},{"type":"text","text":"examining the verb name, which should be present in argv[1] after"},{"type":"text","text":" "},{"type":"text","text":"parsing)."}]}]}],"kind":"symbol","references":{"doc://GLib/documentation/GLib/OptionContext/OptionContextProtocol-Implementations":{"kind":"article","title":"OptionContextProtocol Implementations","url":"\/documentation\/glib\/optioncontext\/optioncontextprotocol-implementations","identifier":"doc:\/\/GLib\/documentation\/GLib\/OptionContext\/OptionContextProtocol-Implementations","abstract":[],"role":"collectionGroup","type":"topic"},"doc://GLib/documentation/GLib/OptionContext":{"kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"OptionContext"}],"title":"OptionContext","url":"\/documentation\/glib\/optioncontext","identifier":"doc:\/\/GLib\/documentation\/GLib\/OptionContext","abstract":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"GOptionContext"},{"type":"text","text":" struct defines which options"},{"type":"text","text":" "},{"type":"text","text":"are accepted by the commandline option parser. The struct has only private"},{"type":"text","text":" "},{"text":"fields and should not be directly accessed.","type":"text"}],"role":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"OptionContext"}]},"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"doc://GLib/documentation/GLib/OptionContext/set(strictPosix:)":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/OptionContext\/set(strictPosix:)","kind":"symbol","type":"topic","url":"\/documentation\/glib\/optioncontext\/set(strictposix:)","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"set"},{"text":"(","kind":"text"},{"text":"strictPosix","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"text":")","kind":"text"}],"title":"set(strictPosix:)","abstract":[{"type":"text","text":"Sets strict POSIX mode."}]}}}
{"abstract":[{"text":"The ","type":"text"},{"code":"GIOChannel","type":"codeVoice"},{"type":"text","text":" data type aims to provide a portable method for"},{"text":" ","type":"text"},{"type":"text","text":"using file descriptors, pipes, and sockets, and integrating them"},{"type":"text","text":" "},{"text":"into the main event loop (see [struct","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","isActive":true,"type":"reference"},{"text":"]). Currently,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"full support is available on UNIX platforms; support for Windows"},{"text":" ","type":"text"},{"type":"text","text":"is only partially complete."}],"variants":[{"paths":["\/documentation\/glib\/iochannel"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"IOChannel","kind":"identifier"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"level":2,"text":"Overview","anchor":"overview","type":"heading"},{"inlineContent":[{"text":"To create a new ","type":"text"},{"type":"codeVoice","code":"GIOChannel"},{"type":"text","text":" on UNIX systems use"},{"text":" ","type":"text"},{"type":"text","text":"[ctor"},{"code":"GLib.IOChannel.unix_new","type":"codeVoice"},{"text":"]. This works for plain file descriptors,","type":"text"},{"text":" ","type":"text"},{"text":"pipes and sockets. Alternatively, a channel can be created for a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"file in a system independent manner using [ctor"},{"type":"codeVoice","code":"GLib.IOChannel.new_file"},{"type":"text","text":"]."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Once a "},{"type":"codeVoice","code":"GIOChannel"},{"type":"text","text":" has been created, it can be used in a generic"},{"type":"text","text":" "},{"type":"text","text":"manner with the functions [method"},{"type":"codeVoice","code":"GLib.IOChannel.read_chars"},{"text":"],","type":"text"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.IOChannel.write_chars"},{"type":"text","text":"], [method"},{"type":"codeVoice","code":"GLib.IOChannel.seek_position"},{"text":"],","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and [method"},{"code":"GLib.IOChannel.shutdown","type":"codeVoice"},{"text":"].","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"To add a ","type":"text"},{"type":"codeVoice","code":"GIOChannel"},{"text":" to the main event loop, use [func","type":"text"},{"type":"codeVoice","code":"GLib.io_add_watch"},{"type":"text","text":"] or"},{"type":"text","text":" "},{"type":"text","text":"[func"},{"type":"codeVoice","code":"GLib.io_add_watch_full"},{"text":"]. Here you specify which events you are","type":"text"},{"type":"text","text":" "},{"text":"interested in on the ","type":"text"},{"type":"codeVoice","code":"GIOChannel"},{"text":", and provide a function to be called","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"whenever these events occur."}]},{"inlineContent":[{"type":"codeVoice","code":"GIOChannel"},{"type":"text","text":" instances are created with an initial reference count of 1."},{"type":"text","text":" "},{"text":"[method","type":"text"},{"code":"GLib.IOChannel.ref","type":"codeVoice"},{"type":"text","text":"] and [method"},{"type":"codeVoice","code":"GLib.IOChannel.unref"},{"text":"] can be used to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"increment or decrement the reference count respectively. When the"},{"text":" ","type":"text"},{"text":"reference count falls to 0, the ","type":"text"},{"code":"GIOChannel","type":"codeVoice"},{"text":" is freed. (Though it","type":"text"},{"text":" ","type":"text"},{"
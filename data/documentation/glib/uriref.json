{"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/URIRef","interfaceLanguage":"swift"},"schemaVersion":{"patch":0,"minor":3,"major":0},"topicSections":[{"generated":true,"identifiers":["doc:\/\/GLib\/documentation\/GLib\/URIRef\/init(_:)-1m0g3","doc:\/\/GLib\/documentation\/GLib\/URIRef\/init(_:)-2ctpq","doc:\/\/GLib\/documentation\/GLib\/URIRef\/init(_:)-4kx37","doc:\/\/GLib\/documentation\/GLib\/URIRef\/init(_:)-5ugyq","doc:\/\/GLib\/documentation\/GLib\/URIRef\/init(_:)-86fph","doc:\/\/GLib\/documentation\/GLib\/URIRef\/init(cPointer:)","doc:\/\/GLib\/documentation\/GLib\/URIRef\/init(constPointer:)","doc:\/\/GLib\/documentation\/GLib\/URIRef\/init(gconstpointer:)","doc:\/\/GLib\/documentation\/GLib\/URIRef\/init(gpointer:)","doc:\/\/GLib\/documentation\/GLib\/URIRef\/init(mutating:)","doc:\/\/GLib\/documentation\/GLib\/URIRef\/init(opaquePointer:)"],"anchor":"Initializers","title":"Initializers"},{"title":"Instance Properties","generated":true,"identifiers":["doc:\/\/GLib\/documentation\/GLib\/URIRef\/ptr"],"anchor":"Instance-Properties"},{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/URIRef\/build(flags:scheme:userinfo:host:port:path:query:fragment:)","doc:\/\/GLib\/documentation\/GLib\/URIRef\/buildWith(user:scheme:user:password:authParams:host:port:path:query:fragment:)","doc:\/\/GLib\/documentation\/GLib\/URIRef\/parse(uriString:flags:)"],"anchor":"Type-Methods","title":"Type Methods","generated":true},{"title":"Default Implementations","generated":true,"anchor":"Default-Implementations","identifiers":["doc:\/\/GLib\/documentation\/GLib\/URIRef\/PointerWrapper-Implementations","doc:\/\/GLib\/documentation\/GLib\/URIRef\/URIProtocol-Implementations"]}],"relationshipsSections":[{"kind":"relationships","identifiers":["doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","doc:\/\/GLib\/documentation\/GLib\/URIProtocol"],"type":"conformsTo","title":"Conforms To"}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"sections":[],"metadata":{"roleHeading":"Structure","role":"symbol","navigatorTitle":[{"text":"URIRef","kind":"identifier"}],"symbolKind":"struct","modules":[{"name":"GLib"}],"title":"URIRef","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"URIRef","kind":"identifier"}],"externalID":"s:4GLib6URIRefV"},"abstract":[{"type":"text","text":"The "},{"code":"GUri","type":"codeVoice"},{"text":" type and related functions can be used to parse URIs into","type":"text"},{"type":"text","text":" "},{"text":"their components, and build valid URIs from individual components.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"URIRef"}],"platforms":["macOS"]}]},{"content":[{"type":"heading","text":"Overview","level":2,"anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Since "},{"type":"codeVoice","code":"GUri"},{"type":"text","text":" only represents absolute URIs, all "},{"type":"codeVoice","code":"GUri"},{"text":"s will have a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"URI scheme, so [method"},{"code":"GLib.URI.get_scheme","type":"codeVoice"},{"text":"] will always return a non-","type":"text"},{"type":"codeVoice","code":"NULL"},{"type":"text","text":" "},{"text":"answer. Likewise, by definition, all URIs have a path component, so","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GLib.URI.get_path"},{"type":"text","text":"] will always return a non-"},{"type":"codeVoice","code":"NULL"},{"text":" string (which may","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"be empty)."}]},{"type":"paragraph","inlineContent":[{"text":"If the URI string has an","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"https:\/\/tools.ietf.org\/html\/rfc3986#section-3","isActive":true},{"text":" (that","type":"text"},{"text":" ","type":"text"},{"text":"is, if the scheme is followed by ","type":"text"},{"code":":\/\/","type":"codeVoice"},{"text":" rather than just ","type":"text"},{"type":"codeVoice","code":":"},{"text":"), then the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"GUri"},{"type":"text","text":" will contain a hostname, and possibly a port and ‘userinfo’."},{"type":"text","text":" "},{"text":"Additionally, depending on how the ","type":"text"},{"code":"GUri","type":"codeVoice"},{"text":" was constructed\/parsed (for example,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"using the "},{"code":"G_URI_FLAGS_HAS_PASSWORD","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"G_URI_FLAGS_HAS_AUTH_PARAMS"},{"type":"text","text":" flags),"},{"type":"text","text":" "},{"text":"the userinfo may be split out into a username, password, and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"additional authorization-related parameters."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Normally, the components of a "},{"code":"GUri","type":"codeVoice"},{"type":"text","text":" will have all "},{"type":"codeVoice","code":"-encoded characters decoded. However, if you construct\/parse a `GUri` with `G_URI_FLAGS_ENCODED`, then the "},{"text":"-encoding will be preserved instead in","type":"text"},{"type":"text","text":" "},{"text":"the userinfo, path, and query fields (and in the host field if also","type":"text"},{"type":"text","text":" "},{"type":"text","text":"created with "},{"code":"G_URI_FLAGS_NON_DNS","type":"codeVoice"},{"type":"text","text":"). In particular, this is necessary if"},{"text":" ","type":"text"},{"text":"the URI may contain binary data or non-UTF-8 text, or if decoding","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the components might change the interpretation of the URI."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example, with the encoded flag:"}]},{"type":"codeListing","syntax":"c","code":["`g_autoptr(GUri)` uri = g_uri_parse (\"http:\/\/host\/path?query=http`3A``2F``2Fhost``2Fpath``3Fparam``3Dvalue`\", G_URI_FLAGS_ENCODED, &err);","g_assert_cmpstr (g_uri_get_query (uri), ==, \"query=http`3A``2F``2Fhost``2Fpath``3Fparam``3Dvalue`\");"]},{"inlineContent":[{"text":"While the default ````-decoding behaviour would give:","type":"text"}],"type":"paragraph"},{"code":["`g_autoptr(GUri)` uri = g_uri_parse (\"http:\/\/host\/path?query=http`3A``2F``2Fhost``2Fpath``3Fparam``3Dvalue`\", G_URI_FLAGS_NONE, &err);","g_assert_cmpstr (g_uri_get_query (uri), ==, \"query=http:\/\/host\/path?param=value\");"],"type":"codeListing","syntax":"c"},{"inlineContent":[{"type":"text","text":"During decoding, if an invalid UTF-8 string is encountered, parsing will fail"},{"type":"text","text":" "},{"text":"with an error indicating the bad string location:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["`g_autoptr(GUri)` uri = g_uri_parse (\"http:\/\/host\/path?query=http`3A``2F``2Fhost``2Fpath``3Fbad``3D``00alue`\", G_URI_FLAGS_NONE, &err);","g_assert_error (err, G_URI_ERROR, G_URI_ERROR_BAD_QUERY);"],"syntax":"c"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You should pass "},{"type":"codeVoice","code":"G_URI_FLAGS_ENCODED"},{"type":"text","text":" or "},{"type":"codeVoice","code":"G_URI_FLAGS_ENCODED_QUERY"},{"type":"text","text":" if you"},{"type":"text","text":" "},{"text":"need to handle that case manually. In particular, if the query string","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"contains "},{"code":"=","type":"codeVoice"},{"text":" characters that are ````-encoded, you should let","type":"text"},{"text":" ","type":"text"},{"text":"[func","type":"text"},{"type":"codeVoice","code":"GLib.URI.parse_params"},{"type":"text","text":"] do the decoding once of the query."}]},{"inlineContent":[{"code":"GUri","type":"codeVoice"},{"text":" is immutable once constructed, and can safely be accessed from","type":"text"},{"type":"text","text":" "},{"text":"multiple threads. Its reference counting is atomic.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Note that the scope of "},{"type":"codeVoice","code":"GUri"},{"text":" is to help manipulate URIs in various applications,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"following "},{"type":"reference","identifier":"https:\/\/tools.ietf.org\/html\/rfc3986","isActive":true},{"type":"text","text":". In particular,"},{"type":"text","text":" "},{"type":"text","text":"it doesn’t intend to cover web browser needs, and doesn’t implement the"},{"type":"text","text":" "},{"identifier":"https:\/\/url.spec.whatwg.org\/","isActive":true,"type":"reference"},{"type":"text","text":" standard. No APIs are provided to"},{"type":"text","text":" "},{"type":"text","text":"help prevent"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/en.wikipedia.org\/wiki\/IDN_homograph_attack","isActive":true},{"type":"text","text":", so"},{"type":"text","text":" "},{"type":"codeVoice","code":"GUri"},{"type":"text","text":" is not suitable for formatting URIs for display to the user for making"},{"text":" ","type":"text"},{"text":"security-sensitive decisions.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Relative-and-absolute-URIs","text":"Relative and absolute URIs","type":"heading"},{"inlineContent":[{"text":"As defined in ","type":"text"},{"type":"reference","identifier":"https:\/\/tools.ietf.org\/html\/rfc3986#section-4","isActive":true},{"type":"text","text":", the"},{"type":"text","text":" "},{"type":"text","text":"hierarchical nature of URIs means that they can either be ‘relative"},{"type":"text","text":" "},{"type":"text","text":"references’ (sometimes referred to as ‘relative URIs’) or ‘URIs’ (for"},{"type":"text","text":" "},{"text":"clarity, ‘URIs’ are referred to in this documentation as","type":"text"},{"text":" ","type":"text"},{"text":"‘absolute URIs’ — although","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/tools.ietf.org\/html\/rfc3986#section-4.3"},{"text":",","type":"text"},{"type":"text","text":" "},{"type":"text","text":"fragment identifiers are always allowed)."}],"type":"paragraph"},{"inlineContent":[{"text":"Relative references have one or more components of the URI missing. In","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"particular, they have no scheme. Any other component, such as hostname,"},{"type":"text","text":" "},{"text":"query, etc. may be missing, apart from a path, which has to be specified (but","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"may be empty). The path may be relative, starting with "},{"code":".\/","type":"codeVoice"},{"text":" rather than ","type":"text"},{"type":"codeVoice","code":"\/"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"For example, a valid relative reference is ","type":"text"},{"type":"codeVoice","code":".\/path?query"},{"type":"text","text":","},{"text":" ","type":"text"},{"type":"codeVoice","code":"\/?query"},{"type":"text","text":"fragment`` or "},{"type":"codeVoice","code":"\/\/example.com"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Absolute URIs have a scheme specified. Any other components of the URI which"},{"type":"text","text":" "},{"type":"text","text":"are missing are specified as explicitly unset in the URI, rather than being"},{"text":" ","type":"text"},{"type":"text","text":"resolved relative to a base URI using [method"},{"code":"GLib.URI.parse_relative","type":"codeVoice"},{"text":"].","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"For example, a valid absolute URI is ","type":"text"},{"code":"file:\/\/\/home\/bob","type":"codeVoice"},{"text":" or","type":"text"},{"type":"text","text":" "},{"code":"https:\/\/search.com?query=string","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"GUri"},{"type":"text","text":" instance is always an absolute URI. A string may be an absolute URI"},{"text":" ","type":"text"},{"type":"text","text":"or a relative reference; see the documentation for individual functions as to"},{"type":"text","text":" "},{"text":"what forms they accept.","type":"text"}]},{"level":2,"text":"Parsing URIs","anchor":"Parsing-URIs","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The most minimalist APIs for parsing URIs are [func","type":"text"},{"type":"codeVoice","code":"GLib.URI.split"},{"type":"text","text":"] and"},{"text":" ","type":"text"},{"type":"text","text":"[func"},{"code":"GLib.URI.split_with_user","type":"codeVoice"},{"type":"text","text":"]. These split a URI into its component"},{"text":" ","type":"text"},{"text":"parts, and return the parts; the difference between the two is that","type":"text"},{"text":" ","type":"text"},{"text":"[func","type":"text"},{"code":"GLib.URI.split","type":"codeVoice"},{"type":"text","text":"] treats the ‘userinfo’ component of the URI as a"},{"type":"text","text":" "},{"text":"single element, while [func","type":"text"},{"code":"GLib.URI.split_with_user","type":"codeVoice"},{"type":"text","text":"] can (depending on the"},{"type":"text","text":" "},{"type":"text","text":"[flags"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/URIFlags","type":"reference"},{"type":"text","text":"] you pass) treat it as containing a username, password,"},{"text":" ","type":"text"},{"text":"and authentication parameters. Alternatively, [func","type":"text"},{"code":"GLib.URI.split_network","type":"codeVoice"},{"text":"]","type":"text"},{"text":" ","type":"text"},{"text":"can be used when you are only interested in the components that are","type":"text"},{"type":"text","text":" "},{"text":"needed to initiate a network connection to the service (scheme,","type":"text"},{"text":" ","type":"text"},{"text":"host, and port).","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"[func"},{"type":"codeVoice","code":"GLib.URI.parse"},{"type":"text","text":"] is similar to [func"},{"code":"GLib.URI.split","type":"codeVoice"},{"text":"], but instead of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"returning individual strings, it returns a "},{"type":"codeVoice","code":"GUri"},{"type":"text","text":" structure (and it requires"},{"type":"text","text":" "},{"type":"text","text":"that the URI be an absolute URI)."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"[func"},{"type":"codeVoice","code":"GLib.URI.resolve_relative"},{"text":"] and [method","type":"text"},{"type":"codeVoice","code":"GLib.URI.parse_relative"},{"text":"] allow","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"you to resolve a relative URI relative to a base URI."},{"type":"text","text":" "},{"text":"[func","type":"text"},{"code":"GLib.URI.resolve_relative","type":"codeVoice"},{"type":"text","text":"] takes two strings and returns a string,"},{"text":" ","type":"text"},{"type":"text","text":"and [method"},{"type":"codeVoice","code":"GLib.URI.parse_relative"},{"type":"text","text":"] takes a "},{"type":"codeVoice","code":"GUri"},{"text":" and a string and returns a","type":"text"},{"type":"text","text":" "},{"code":"GUri","type":"codeVoice"},{"text":".","type":"text"}]},{"inlineContent":[{"text":"All of the parsing functions take a [flags","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/URIFlags"},{"text":"] argument describing","type":"text"},{"type":"text","text":" "},{"type":"text","text":"exactly how to parse the URI; see the documentation for that type"},{"type":"text","text":" "},{"type":"text","text":"for more details on the specific flags that you can pass. If you"},{"type":"text","text":" "},{"text":"need to choose different flags based on the type of URI, you can","type":"text"},{"type":"text","text":" "},{"type":"text","text":"use [func"},{"type":"codeVoice","code":"GLib.URI.peek_scheme"},{"type":"text","text":"] on the URI string to check the scheme"},{"type":"text","text":" "},{"type":"text","text":"first, and use that to decide what flags to parse it with."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example, you might want to use "},{"type":"codeVoice","code":"G_URI_PARAMS_WWW_FORM"},{"text":" when parsing the","type":"text"},{"text":" ","type":"text"},{"text":"params for a web URI, so compare the result of [func","type":"text"},{"type":"codeVoice","code":"GLib.URI.peek_scheme"},{"text":"]","type":"text"},{"text":" ","type":"text"},{"text":"against ","type":"text"},{"type":"codeVoice","code":"http"},{"type":"text","text":" and "},{"type":"codeVoice","code":"https"},{"text":".","type":"text"}]},{"level":2,"type":"heading","text":"Building URIs","anchor":"Building-URIs"},{"inlineContent":[{"type":"text","text":"[func"},{"type":"codeVoice","code":"GLib.URI.join"},{"text":"] and [func","type":"text"},{"type":"codeVoice","code":"GLib.URI.join_with_user"},{"type":"text","text":"] can be used to construct"},{"type":"text","text":" "},{"type":"text","text":"valid URI strings from a set of component strings. They are the"},{"text":" ","type":"text"},{"type":"text","text":"inverse of [func"},{"type":"codeVoice","code":"GLib.URI.split"},{"type":"text","text":"] and [func"},{"type":"codeVoice","code":"GLib.URI.split_with_user"},{"type":"text","text":"]."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Similarly, [func"},{"type":"codeVoice","code":"GLib.URI.build"},{"text":"] and [func","type":"text"},{"code":"GLib.URI.build_with_user","type":"codeVoice"},{"type":"text","text":"] can be"},{"type":"text","text":" "},{"type":"text","text":"used to construct a "},{"type":"codeVoice","code":"GUri"},{"type":"text","text":" from a set of component strings."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"As with the parsing functions, the building functions take a"},{"type":"text","text":" "},{"text":"[flags","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/URIFlags","type":"reference"},{"type":"text","text":"] argument. In particular, it is important to keep in mind"},{"type":"text","text":" "},{"type":"text","text":"whether the URI components you are using are already ````-encoded. If so,"},{"type":"text","text":" "},{"type":"text","text":"you must pass the "},{"code":"G_URI_FLAGS_ENCODED","type":"codeVoice"},{"text":" flag.","type":"text"}],"type":"paragraph"},{"text":"`file:\/\/` URIs","level":2,"type":"heading","anchor":"file-URIs"},{"inlineContent":[{"text":"Note that Windows and Unix both define special rules for parsing","type":"text"},{"type":"text","text":" "},{"code":"file:\/\/","type":"codeVoice"},{"type":"text","text":" URIs (involving non-UTF-8 character sets on Unix, and the"},{"text":" ","type":"text"},{"type":"text","text":"interpretation of path separators on Windows). "},{"type":"codeVoice","code":"GUri"},{"text":" does not","type":"text"},{"type":"text","text":" "},{"type":"text","text":"implement these rules. Use [func"},{"type":"codeVoice","code":"GLib.filename_from_uri"},{"type":"text","text":"] and"},{"text":" ","type":"text"},{"text":"[func","type":"text"},{"type":"codeVoice","code":"GLib.filename_to_uri"},{"type":"text","text":"] if you want to properly convert between"},{"text":" ","type":"text"},{"code":"file:\/\/","type":"codeVoice"},{"type":"text","text":" URIs and local filenames."}],"type":"paragraph"},{"type":"heading","anchor":"URI-Equality","text":"URI Equality","level":2},{"inlineContent":[{"type":"text","text":"Note that there is no "},{"type":"codeVoice","code":"g_uri_equal ()"},{"text":" function, because comparing","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"URIs usefully requires scheme-specific knowledge that "},{"type":"codeVoice","code":"GUri"},{"text":" does","type":"text"},{"type":"text","text":" "},{"text":"not have. ","type":"text"},{"type":"codeVoice","code":"GUri"},{"text":" can help with normalization if you use the various","type":"text"},{"type":"text","text":" "},{"text":"encoded [flags","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/URIFlags","isActive":true,"type":"reference"},{"type":"text","text":"] as well as "},{"type":"codeVoice","code":"G_URI_FLAGS_SCHEME_NORMALIZE"},{"text":" ","type":"text"},{"type":"text","text":"however it is not comprehensive."},{"text":" ","type":"text"},{"type":"text","text":"For example, "},{"type":"codeVoice","code":"data:,foo"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"data:;base64,Zm9v"},{"type":"text","text":" resolve to the same"},{"type":"text","text":" "},{"text":"thing according to the ","type":"text"},{"code":"data:","type":"codeVoice"},{"text":" URI specification which GLib does not","type":"text"},{"text":" ","type":"text"},{"text":"handle.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/URIRef","isActive":true},{"type":"text","text":" type acts as a lightweight Swift reference to an underlying "},{"type":"codeVoice","code":"GUri"},{"type":"text","text":" instance."},{"text":" ","type":"text"},{"type":"text","text":"It exposes methods that can operate on this data type through "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/URIProtocol"},{"type":"text","text":" conformance."},{"text":" ","type":"text"},{"type":"text","text":"Use "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/URIRef","type":"reference","isActive":true},{"type":"text","text":" only as an "},{"code":"unowned","type":"codeVoice"},{"text":" reference to an existing "
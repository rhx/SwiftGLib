renthesis that is not","type":"text"},{"type":"text","text":" "},{"text":"followed by “?” behaves as if it were followed by “?:” but named","type":"text"},{"type":"text","text":" "},{"type":"text","text":"parentheses can still be used for capturing (and they acquire numbers"},{"text":" ","type":"text"},{"type":"text","text":"in the usual way)."}],"role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexCompileFlags\/noAutoCapture","title":"noAutoCapture"},"doc://GLib/documentation/GLib/RegexCompileFlags/firstline":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexCompileFlags\/firstline","type":"topic","abstract":[{"type":"text","text":"Limits an unanchored pattern to match before (or at) the"},{"type":"text","text":" "},{"text":"first newline. Since: 2.34","type":"text"}],"url":"\/documentation\/glib\/regexcompileflags\/firstline","kind":"symbol","title":"firstline","role":"symbol","fragments":[{"text":"static","kind":"keyword"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"text":" ","kind":"text"},{"kind":"identifier","text":"firstline"},{"text":": ","kind":"text"},{"text":"RegexCompileFlags","kind":"typeIdentifier","preciseIdentifier":"s:4GLib17RegexCompileFlagsV"}]},"doc://GLib/documentation/GLib/RegexCompileFlags/newlineAnycrlf":{"title":"newlineAnycrlf","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexCompileFlags\/newlineAnycrlf","url":"\/documentation\/glib\/regexcompileflags\/newlineanycrlf","role":"symbol","fragments":[{"kind":"keyword","text":"static"},{"text":" ","kind":"text"},{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"newlineAnycrlf"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:4GLib17RegexCompileFlagsV","kind":"typeIdentifier","text":"RegexCompileFlags"}],"abstract":[{"text":"Usually any newline character or character sequence","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is recognized. If this option is set, the only recogniz
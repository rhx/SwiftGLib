larEndonly","isActive":true},{"text":" is set). When","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexCompileFlags\/multiline","isActive":true,"type":"reference"},{"text":" is set, the “start of line” and “end of line”","type":"text"},{"type":"text","text":" "},{"text":"constructs match immediately following or immediately before any","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"newline in the string, respectively, as well as at the very start"},{"text":" ","type":"text"},{"text":"and end. This can be changed within a pattern by a “(?m)” option","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"setting."}],"type":"topic","fragments":[{"kind":"keyword","text":"static"},{"text":" ","kind":"text"},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"multiline"},{"kind":"text","text":": "},{"preciseIdentifier":"s:4GLib17RegexCompileFlagsV","kind":"typeIdentifier","text":"RegexCompileFlags"}]},"doc://GLib/s9OptionSetP":{"title":"Swift.OptionSet","type":"unresolvable","identifier":"doc:\/\/GLib\/s9OptionSetP"},"doc://GLib/SY":{"title":"Swift.RawRepresentable","type":"unresolvable","identifier":"doc:\/\/GLib\/SY"},"doc://GLib/documentation/GLib/RegexCompileFlags/ungreedy":{"url":"\/documentation\/glib\/regexcompileflags\/ungreedy","type":"topic","title":"ungreedy","role":"symbol","fragments":[{"text":"static","kind":"keyword"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"text":" ","kind":"text"},{"text":"ungreedy","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib17RegexCompileFlagsV","text":"RegexCompileFlags"}],"kind":"symbol","abstract":[{"type":"text","text":"Inverts the “greediness” of the quantifiers so that"},{"type":"text","text":" "},{"type":"text","text":"they are not greedy by default, but become greedy if followed by “?”."},{"type":"text","text":" "},{"type":"text","text":"It c
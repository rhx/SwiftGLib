{"abstract":[{"type":"text","text":"Matches a string against a compiled pattern."}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/PatternSpecRef","doc:\/\/GLib\/documentation\/GLib\/PatternSpecRef\/PatternSpecProtocol-Implementations"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/patternspecref\/patternmatch(stringlength:string:stringreversed:)"]}],"kind":"symbol","sections":[],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/PatternSpecRef\/patternMatch(stringLength:string:stringReversed:)","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"patternMatch"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"stringLength"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"text":"string","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier","text":"gchar"},{"text":">!, ","kind":"text"},{"text":"stringReversed","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">? = nil) -> ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Passing the correct","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"length of the string given is mandatory. The reversed string can be"},{"text":" ","type":"text"},{"text":"omitted by passing ","type":"text"},{"type":"codeVoice","code":"NULL"},{"text":", this is more efficient if the reversed","type":"text"},{"type":"text","text":" "},{"text":"version of the string to be matched is not at hand, as","type":"text"},{"text":" ","type":"text"},{"code":"g_pattern_match()","type":"codeVoice"},{"text":" will only construct it if the compiled pattern","type":"text"},{"text":" ","type":"text"},{"text":"requires reverse matches.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Note that, if the user code will (possibly) match a string against a"},{"text":" ","type":"text"},{"text":"multitude of patterns containing wildcards, chances are high that","type":"text"},{"text":" ","type":"text"},{"text":"some patterns will require a reversed string. In this case, it’s","type":"text"},{"type":"text","text":" "},{"type":"text","text":"more efficient to provide the reversed string to avoid multiple"},{"text":" ","type":"text"},{"text":"constructions thereof in the various calls to ","type":"text"},{"type":"codeVoice","code":"g_pattern_match()"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Note also that the reverse of a UTF-8 encoded string can in general","type":"text"},{"type":"text","text":" "},{"text":"not be obtained by [func","type":"text"},{"type":"codeVoice","code":"GLib.strreverse"},{"text":"]. This works only if the string","type":"text"},{"text":" ","type":"text"},{"text":"does not contain any multibyte characters. GLib offers the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[func"},{"type":"codeVoice","code":"GLib.utf8_strreverse"},{"type":"text","text":"] function to reverse UTF-8 encoded strings."}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"pattern_match is deprecated:","type":"text"}],"type":"strong"},{"type":"text","text":" "},{"type":"text","text":"Use [method@GLib.PatternSpec.match] instead"}]}],"kind":"content"}],"schemaVersion"
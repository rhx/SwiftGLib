{"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"modules":[{"name":"GLib"}],"roleHeading":"Structure","symbolKind":"struct","externalID":"s:4GLib14VariantDictRefV","role":"symbol","title":"VariantDictRef","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"VariantDictRef","kind":"identifier"}],"navigatorTitle":[{"text":"VariantDictRef","kind":"identifier"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"VariantDictRef","kind":"identifier"}]}]},{"kind":"content","content":[{"anchor":"overview","type":"heading","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It can be used for doing a sequence of dictionary lookups in an"},{"type":"text","text":" "},{"type":"text","text":"efficient way on an existing "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true,"type":"reference"},{"text":" dictionary or it can be used","type":"text"},{"type":"text","text":" "},{"text":"to construct new dictionaries with a hashtable-like interface.  It","type":"text"},{"type":"text","text":" "},{"text":"can also be used for taking existing dictionaries and modifying them","type":"text"},{"type":"text","text":" "},{"text":"in order to create new ones.","type":"text"}]},{"inlineContent":[{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","isActive":true,"type":"reference"},{"text":" can only be used with ","type":"text"},{"type":"codeVoice","code":"G_VARIANT_TYPE_VARDICT"},{"text":" ","type":"text"},{"text":"dictionaries.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is possible to use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict"},{"text":" allocated on the stack or on the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"heap.  When using a stack-allocated "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict"},{"type":"text","text":", you begin with a"},{"text":" ","type":"text"},{"type":"text","text":"call to "},{"type":"codeVoice","code":"g_variant_dict_init()"},{"text":" and free the resources with a call to","type":"text"},{"text":" ","type":"text"},{"code":"g_variant_dict_clear()","type":"codeVoice"},{"type":"text","text":"."}]},{"inlineContent":[{"text":"Heap-allocated ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict"},{"type":"text","text":" follows normal refcounting rules: you"},{"type":"text","text":" "},{"type":"text","text":"allocate it with "},{"type":"codeVoice","code":"g_variant_dict_new()"},{"text":" and use ","type":"text"},{"code":"g_variant_dict_ref()","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"and "},{"type":"codeVoice","code":"g_variant_dict_unref()"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"g_variant_dict_end()"},{"type":"text","text":" is used to convert the "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","type":"reference"},{"text":" back into a","type":"text"},{"type":"text","text":" "},{"text":"dictionary-type ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"text":".  When used with stack-allocated instances,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"this also implicitly frees all associated memory, but for"},{"type":"text","text":" "},{"type":"text","text":"heap-allocated instances, you must still call "},{"type":"codeVoice","code":"g_variant_dict_unref()"},{"text":" ","type":"text"},{"type":"text","text":"afterwards."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You will typically want to use a heap-allocated "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","isActive":true,"type":"reference"},{"type":"text","text":" when"},{"type":"text","text":" "},{"type":"text","text":"you expose it as part of an API.  For most other uses, the"},{"type":"text","text":" "},{"text":"stack-allocated form will be more convenient.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Consider the following two examples that do the same thing in each","type":"text"},{"type":"text","text":" "},{"type":"text","text":"style: take an existing dictionary and look up the “count” uint32"},{"type":"text","text":" "},{"type":"text","text":"key, adding 1 to it if it is found, or returning an error if the"},{"type":"text","text":" "},{"type":"text","text":"key is not found.  Each returns the new dictionary as a floating"},{"text":" ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true,"type":"reference"},{"type":"text","text":"."}],"type":"paragraph"},{"text":"Using a stack-allocated GVariantDict","anchor":"Using-a-stack-allocated-GVariantDict","level":2,"type":"heading"},{"inlineContent":[{"text":"(C Language Example):","type":"text"}],"type":"paragraph"},{"syntax":"C","type":"codeListing","code":["  GVariant *","  add_to_count (GVariant  *orig,","                GError   **error)","  {","    GVariantDict dict;","    guint32 count;","","    g_variant_dict_init (&dict, orig);","    if (!g_variant_dict_lookup (&dict, \"count\", \"u\", &count))","      {","        g_set_error (...);","        g_variant_dict_clear (&dict);","        return NULL;","      }","","    g_variant_dict_insert (&dict, \"count\", \"u\", count + 1);","","    return g_variant_dict_end (&dict);","  }"]},{"text":"Using heap-allocated GVariantDict","anchor":"Using-heap-allocated-GVariantDict","level":2,"type":"heading"},{"inlineContent":[{"text":"(C Language Example):","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"C","code":["  GVariant *","  add_to_count (GVariant  *orig,","                GError   **error)","  {","    GVariantDict *dict;","    GVariant *result;","    guint32 count;","","    dict = g_variant_dict_new (orig);","","    if (g_variant_dict_lookup (dict, \"count\", \"u\", &count))","      {","        g_variant_dict_insert (dict, \"count\", \"u\", count + 1);","        result = g_variant_dict_end (dict);","      }","    else","      {","        g_set_error (...);","        result = NULL;","      }","","    g_variant_dict_unref (dict);","","    return result;","  }"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDictRef"},{"type":"text","text":" type acts as a lightweight Swift reference to an underlying "},{"type":"codeVoice","code":"GVariantDict"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"type":"text","text":"It exposes methods that can operate on this data type through "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDictProtocol","isActive":true,"type":"reference"},{"text":" conformance.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDictRef"},{"text":" only as an ","type":"text"},{"type":"codeVoice","code":"unowned"},{"text":" reference to an existing ","type":"text"},{"type":"codeVoice","code":"GVariantDict"},{"text":" instance.","type":"text"}]},{"content":[{"inlineContent":[{"type":"text","text":"Use "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","isActive":true},{"text":" (instead of ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDictRef","isActive":true,"type":"reference"},{"type":"text","text":") if you want to use Automatic Reference Counting for memory management of the underlying "},{"code":"GVariantDict","type":"codeVoice"},{"type":"text","text":" instance."}],"type":"paragraph"}],"type":"aside","style":"note","name":"Note"}]}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"relationshipsSections":[{"type":"conformsTo","title":"Conforms To","identifiers":["doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","doc:\/\/GLib\/documentation\/GLib\/VariantDictProtocol"],"kind":"relationships"}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/variantdictref"]}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/VariantDictRef","interfaceLanguage":"swift"},"abstract":[{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantDict","type":"reference","isActive":true},{"type":"text","text":" is a mutable interface to "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"text":" dictionaries.","type":"text"}],"topicSections":[{"title":"Initializers","generated":true,"identifiers":["doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/init(_:)-1m81v","doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/init(_:)-2ionc","doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/init(_:)-32bsf","doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/init(_:)-3gqla","doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/init(_:)-9l5r7","doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/init(asv:)","doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/init(cPointer:)","doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/init(constPointer:)","doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/init(gconstpointer:)","doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/init(gpointer:)","doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/init(mutating:)","doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/init(opaquePointer:)"],"anchor":"Initializers"},{"generated":true,"title":"Instance Properties","identifiers":["doc:\/\/GLib\/documentation\/GLib\/VariantDictRef\/ptr"],"anchor":"Instance-Properties"},{"title":"Default Implementations"
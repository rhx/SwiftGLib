{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/timevalref\/toiso8601()"]}],"metadata":{"externalID":"s:4GLib15TimeValProtocolPAAE9toIso8601SSSgyF::SYNTHESIZED::s:4GLib10TimeValRefV","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"toIso8601","kind":"identifier"},{"kind":"text","text":"() -> "},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"roleHeading":"Instance Method","extendedModule":"GLib","platforms":[],"symbolKind":"method","modules":[{"name":"GLib"}],"title":"toIso8601()"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/TimeValRef\/toIso8601()"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/TimeValRef","doc:\/\/GLib\/documentation\/GLib\/TimeValRef\/TimeValProtocol-Implementations"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"toIso8601"},{"kind":"text","text":"() -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"text":"!","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"ISO 8601 allows a large number of date\/time formats, with or without","type":"text"},{"text":" ","type":"text"},{"text":"punctuation and optional elements. The format returned by this function","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is a complete date and time, with optional punctuation included, the"},{"text":" ","type":"text"},{"text":"UTC time zone represented as “Z”, and the ","type":"text"},{"code":"tv_usec","type":"codeVoice"},{"text":" part included if","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and only if it is nonzero, i.e. either"},{"text":" ","type":"text"},{"type":"text","text":"“YYYY-MM-DDTHH:MM:SSZ” or “YYYY-MM-DDTHH:MM:SS.fffffZ”."}]},{"type":"paragraph","inlineContent":[{"text":"This corresponds to the Internet date\/time format defined by","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/www.ietf.org\/rfc\/rfc3339.txt"},{"type":"text","text":","},{"type":"text","text":" "},{"text":"and to either of the two most-precise formats defined by","type":"text"},{"text":" ","type":"text"},{"text":"the W3C Note","type":"text"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"http:\/\/www.w3.org\/TR\/NOTE-datetime-19980827"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Both of these documents are profiles of ISO 8601.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":"g_date_time_format()"},{"text":" or ","type":"text"},{"code":"g_strdup_printf()","type":"codeVoice"},{"type":"text","text":" if a different"},{"type":"text","text":" "},{"type":"text","text":"variation of ISO 8601 format is required."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"code":"time","type":"codeVoice"},{"text":" represents a date which is too large to fit into a ","type":"text"},{"type":"codeVoice","code":"struct tm"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" will be returned. This is platform dependent. Note also that since"},{"type":"text","text":" "},{"type":"codeVoice","code":"GTimeVal"},{"text":" stores the number of seconds as a ","type":"text"},{"type":"codeVoice","code":"glong"},{"text":", on 32-bit systems it","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is subject to the year 2038 problem. Accordingly, since GLib 2.62, this"},{"type":"text","text":" "},{"text":"function has been deprecated. Equivalent functionality is available using:","type":"text"}],"type":"paragraph"},{"syntax":null,"type":"codeListing","code":["GDateTime *dt = g_date_time_new_from_unix_utc (time_val);","iso8601_string = g_date_time_format_iso8601 (dt);","g_date_time_unref (dt);"]},{"inlineContent":[{"type":"text","text":"The return value of "},{"type":"codeVoice","code":"g_time_val_to_iso8601()"},{"type":"text","text":" has been nullable since GLib"},{"text":" ","type":"text"},{"text":"2.54; before then, GLib would crash under the same conditions.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"to_iso8601 is deprecated:"}],"type":"strong"},{"type":"text","text":" "},{"type":"text","text":"#GTimeVal is not year-2038-safe. Use"},{"type":"text","text":" "},{"type":"text","text":"g_date_time_format_iso8601(dt) instead."}],"type":"paragraph"}],"kind":"content"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"text":"Converts ","type":"text"},{"type":"codeVoice","code":"time"},{"text":" into an RFC 3339 encoded string, relative to the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Coordinated Universal Time (UTC). This is one of the many formats"},{"text":" ","type":"text"},{"type":"text","text":"allowed by ISO 8601."}],"sections":[],"kind":"symbol","references":{"doc://GLib/documentation/GLib/TimeValRef/TimeValProtocol-Implementations":{"abstract":[],"role":"collectionGroup","kind":"article","url":"\/documentation\/glib\/timevalref\/timevalprotocol-implementations","title":"TimeValProtocol Implementations","identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeValRef\/TimeValProtocol-Implementations","type":"topic"},"doc://GLib/documentation/GLib/TimeValRef/toIso8601()":{"url":"\/documentation\/glib\/timevalref\/toiso8601()","type":"topic","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"toIso8601","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"deprecated":true,"role":"symbol","title":"toIso8601()","abstract":[{"type":"text","text":"Converts "},{"type":"codeVoice","code":"time"},{"type":"text","text":" into an RFC 3339 encoded string, relative to the"},{"text":" ","type":"text"},{"type":"text","text":"Coordinated Universal Time (UTC). This is one of the many formats"},{"text":" ","type":"text"},{"text":"allowed by ISO 8601.","type":"text"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeValRef\/toIso8601()"},"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"http://www.w3.org/TR/NOTE-datetime-19980827":{"url":"http:\/\/www.w3.org\/TR\/NOTE-datetime-19980827","titleInlineContent":[{"text":"Date and Time Formats","type":"text"}],"title":"Date and Time Formats","type":"link","identifier":"http:\/\/www.w3.org\/TR\/NOTE-datetime-19980827"},"https://www.ietf.org/rfc/rfc3339.txt":{"url":"https:\/\/www.ietf.org\/rfc\/rfc3339.txt","titleInlineContent":[{"text":"RFC 3339","type":"text"}],"title":"RFC 3339","type":"link","identifier":"https:\/\/www.ietf.org\/rfc\/rfc3339.txt"},"doc://GLib/documentation/GLib/TimeValRef":{"url":"\/documentation\/glib\/timevalref","abstract":[{"text":"Represents a precise time, with seconds and microseconds.","type":"text"}],"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"TimeValRef","kind":"identifier"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"TimeValRef"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeValRef","title":"TimeValRef","kind":"symbol","type":"topic"}}}
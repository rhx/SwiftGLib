{"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"title":"MutexRef","symbolKind":"struct","modules":[{"name":"GLib"}],"roleHeading":"Structure","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"MutexRef"}],"role":"symbol","externalID":"s:4GLib8MutexRefV","navigatorTitle":[{"kind":"identifier","text":"MutexRef"}]},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/MutexRef","interfaceLanguage":"swift"},"abstract":[{"text":"The ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","isActive":true},{"type":"text","text":" struct is an opaque data structure to represent a mutex"},{"type":"text","text":" "},{"type":"text","text":"(mutual exclusion). It can be used to protect data against shared"},{"type":"text","text":" "},{"type":"text","text":"access."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"MutexRef"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"overview","text":"Overview"},{"inlineContent":[{"text":"Take for example the following function:","type":"text"},{"text":" ","type":"text"},{"text":"(C Language Example):","type":"text"}],"type":"paragraph"},{"syntax":"C","code":["  int","  give_me_next_number (void)","  {","    static int current_number = 0;","","    \/\/ now do a very complicated calculation to calculate the new","    \/\/ number, this might for example be a random number generator","    current_number = calc_next_number (current_number);","","    return current_number;","  }"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is easy to see that this won’t work in a multi-threaded"},{"type":"text","text":" "},{"text":"application. There current_number must be protected against shared","type":"text"},{"type":"text","text":" "},{"text":"access. A ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","isActive":true},{"text":" can be used as a solution to this problem:","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(C Language Example):"}]},{"type":"codeListing","syntax":"C","code":["  int","  give_me_next_number (void)","  {","    static GMutex mutex;","    static int current_number = 0;","    int ret_val;","","    g_mutex_lock (&mutex);","    ret_val = current_number = calc_next_number (current_number);","    g_mutex_unlock (&mutex);","","    return ret_val;","  }"]},{"inlineContent":[{"type":"text","text":"Notice that the "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","isActive":true},{"type":"text","text":" is not initialised to any particular value."},{"text":" ","type":"text"},{"type":"text","text":"Its placement in static storage ensures that it will be initialised"},{"text":" ","type":"text"},{"type":"text","text":"to all-zeros, which is appropriate."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If a "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","isActive":true,"type":"reference"},{"type":"text","text":" is placed in other contexts (eg: embedded in a struct)"},{"type":"text","text":" "},{"type":"text","text":"then it must be explicitly initialised using "},{"type":"codeVoice","code":"g_mutex_init()"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","isActive":true,"type":"reference"},{"text":" should only be accessed via g_mutex_ functions.","type":"text"}]},{"inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MutexRef","isActive":true,"type":"reference"},{"type":"text","text":" type acts as a lightweight Swift reference to an underlying "},{"type":"codeVoice","code":"GMutex"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"text":"It exposes methods that can operate on this data type through ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MutexProtocol","isActive":true,"type":"reference"},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"text":"Use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/MutexRef"},{"text":" only as an ","type":"text"},{"code":"unowned","type":"codeVoice"},{"type":"text","text":" reference to an existing "},{"type":"codeVoice","code":"GMutex"},{"text":" instance.","type":"text"}],"type":"paragraph"},{"content":[{"inlineContent":[{"type":"text","text":"Use "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","isActive":true,"type":"reference"},{"text":" (instead of ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/MutexRef"},{"text":") if you want to use Automatic Reference Counting for memory management of the underlying ","type":"text"},{"type":"codeVoice","code":"GMutex"},{"type":"text","text":" instance."}],"type":"paragraph"}],"style":"note","type":"aside","name":"Note"}]}],"variants":[{"paths":["\/documentation\/glib\/mutexref"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","sections":[],"topicSections":[{"generated":true,"identifiers":["doc:\/\/GLib\/documentation\/GLib\/MutexRef\/init(_:)-1lz4u","doc:\/\/GLib\/documentation\/GLib\/MutexRef\/init(_:)-39dgq","doc:\/\/GLib\/documentation\/GLib\/MutexRef\/init(_:)-4ul4a","doc:\/\/GLib\/documentation\/GLib\/MutexRef\/init(_:)-7e86y","doc:\/\/GLib\/documentation\/GLib\/MutexRef\/init(_:)-97x4o","doc:\/\/GLib\/documentation\/GLib\/MutexRef\/init(cPointer:)","doc:\/\/GLib\/documentation\/GLib\/MutexRef\/init(constPointer:)","doc:\/\/GLib\/documentation\/GLib\/MutexRef\/init(gconstpointer:)","doc:\/\/GLib\/documentation\/GLib\/MutexRef\/init(gp
ient when adding multiple"},{"text":" ","type":"text"},{"type":"text","text":"elements. A common idiom to avoid the inefficiency is to prepend"},{"type":"text","text":" "},{"type":"text","text":"the elements and reverse the list when all elements have been added."}],"type":"paragraph"},{"inlineContent":[{"text":"(C Language Example):","type":"text"}],"type":"paragraph"},{"syntax":"C","type":"codeListing","code":["\/\/ Notice that these are initialized to the empty list.","GSList *list = NULL, *number_list = NULL;","","\/\/ This is a list of strings.","list = g_slist_append (list, \"first\");","list = g_slist_append (list, \"second\");","","\/\/ This is a list of integers.","number_list = g_slist_append (number_list, GINT_TO_POINTER (27));","number_list = g_slist_append (number_list, GINT_TO_POINTER (14));"]}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/SListRef","doc:\/\/GLib\/documentation\/GLib\/SListRef\/SListProtocol-Implementations"]]},"abstract":[{"type":"text","text":"Adds a new element on to the end of the list."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/slistref\/append(data:)"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/SListRef\/append(data:)"},"references":{"doc://GLib/documentation/GLib/SListRef/SListProtocol-Implementations":{"kind":"article","identifier":"doc:\/\/GLib\/documentation\/GLib\/SListRef\/SListProtocol-Implementations","abstract":[],"url":"\/documentation\/glib\/slistref\/slistprotocol-implementations","type":"topic","role":"collectionGroup","title":"SListProtocol Implementations"},"doc://GLib/documentation/GLib/SListRef/append(data:)":{"kind":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"append","kind":"identifier"},{"kind":"text","text":"("},{"text":"data","kind":"externalParam"},{"kind":"text","text":": "},{"text":"gpointer","kind":"typeI
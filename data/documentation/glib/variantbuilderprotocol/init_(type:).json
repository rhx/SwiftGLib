{"kind":"symbol","sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilderProtocol\/init_(type:)"},"abstract":[{"type":"text","text":"Initialises a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilder"},{"text":" structure.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/VariantBuilderProtocol"]]},"variants":[{"paths":["\/documentation\/glib\/variantbuilderprotocol\/init_(type:)"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"init_"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"VariantTypeT"},{"text":">(","kind":"text"},{"text":"type","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"VariantTypeT","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"VariantTypeT","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"VariantTypeProtocol","kind":"typeIdentifier","preciseIdentifier":"s:4GLib19VariantTypeProtocolP","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantTypeProtocol"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"type"},{"type":"text","text":" must be non-"},{"code":"nil","type":"codeVoice"},{"text":".  It specifies the type of container to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"construct.  It can be an indefinite type such as"},{"text":" ","type":"text"},{"code":"G_VARIANT_TYPE_ARRAY","type":"codeVoice"},{"type":"text","text":" or a definite type such as “as” or “(ii)”."},{"text":" ","type":"text"},{"text":"Maybe, array, tuple, dictionary entry and variant-typed values may be","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"constructed."}]},{"inlineContent":[{"text":"If using a static type such as one of the ","type":"text"},{"type":"codeVoice","code":"G_VARIANT_TYPE_*"},{"type":"text","text":" constants"},{"text":" ","type":"text"},{"text":"or a ","type":"text"},{"type":"codeVoice","code":"G_VARIANT_TYPE (\"(ii)\")"},{"text":" macro, it is more performant to use","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_variant_builder_init_static()"},{"type":"text","text":" rather than "},{"type":"codeVoice","code":"g_variant_builder_init()"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"After the builder is initialised, values are added using","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_variant_builder_add_value()"},{"text":" or ","type":"text"},{"code":"g_variant_builder_add()","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"After all the child values are added, ","type":"text"},{"code":"g_variant_builder_end()","type":"codeVoice"},{"type":"text","text":" frees"},{"text":" ","type":"text"},{"type":"text","text":"the memory associated with the builder and returns the "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true},{"text":" that","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"was created."}]},{"type":"paragraph","inlineContent":[{"text":"This function completely ignores the previous contents of ","type":"text"},{"type":"codeVoice","code":"builder"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"On one hand this means that it is valid to pass in completely","type":"text"},{"type":"text","text":" "},{"type":"text","text":"uninitialised memory.  On the other hand, this means that if you are"},{"type":"text","text":" "},{"type":"text","text":"initialising over top of an existing "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilder","isActive":true},{"type":"text","text":" you need to"},{"type":"text","text":" "},{"text":"first call ","type":"text"},{"code":"g_variant_builder_clear()","type":"codeVoice"},{"text":" in order to avoid leaking","type":"text"},{"text":" ","type":"text"},{"text":"memory.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"You must not call ","type":"text"},{"code":"g_variant_builder_ref()","type":"codeVoice"},{"type":"text","text":" or"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_variant_builder_unref()"},{"text":" on a ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilder","isActive":true,"type":"reference"},{"text":" that was initialised","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"with this function.  If you ever pass a reference to a"},{"type":"text","text":" "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilder","isActive":true,"type":"reference"},{"text":" outside of the control of your own code then you","type":"text"},{"type":"text","text":" "},{"text":"should assume that the person receiving that reference may try to use","type":"text"},{"type":"text","text":" "},{"type":"text","text":"reference counting; you should use "},{"type":"codeVoice","code":"g_variant_builder_new()"},{"type":"text","text":" instead of"},{"type":"text","text":" "},{"text":"this function.","type":"text"}]}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"role":"symbol","extendedModule":"GLib","title":"init_(type:)","modules":[{"name":"GLib"}],"roleHeading":"Instance Method","externalID":"s:4GLib22VariantBuilderProtocolPAAE5init_4typeyqd___tAA0b4TypeD0Rd__lF","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"init_"},{"kind":"text","text":"<"},{"text":"VariantTypeT","kind":"genericParameter"},{"text":">(","
{"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","abstract":[{"type":"text","text":"The "},{"code":"GSourceFuncs","type":"codeVoice"},{"text":" struct contains a table of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"functions used to handle event sources in a generic manner."}],"relationshipsSections":[{"title":"Inherits From","kind":"relationships","type":"inheritsFrom","identifiers":["doc:\/\/GLib\/documentation\/GLib\/PointerWrapper"]},{"type":"conformingTypes","kind":"relationships","identifiers":["doc:\/\/GLib\/documentation\/GLib\/SourceFuncs","doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef"],"title":"Conforming Types"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SourceFuncsProtocol","kind":"identifier"},{"text":" : ","kind":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","text":"PointerWrapper","kind":"typeIdentifier","preciseIdentifier":"s:4GLib14PointerWrapperP"}]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For idle sources, the prepare and check functions always return "},{"code":"true","type":"codeVoice"},{"type":"text","text":" "},{"text":"to indicate that the source is always ready to be processed. The prepare","type":"text"},{"type":"text","text":" "},{"text":"function also returns a timeout value of 0 to ensure that the ","type":"text"},{"code":"poll()","type":"codeVoice"},{"text":" call","type":"text"},{"type":"text","text":" "},{"text":"doesn’t block (since that would be time wasted which could have been spent","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"running the idle function)."}]},{"inlineContent":[{"text":"For timeout sources, the prepare and check functions both return ","type":"text"},{"type":"codeVoice","code":"true"},{"text":" ","type":"text"},{"type":"text","text":"if the timeout interval has expired. The prepare function also returns"},{"type":"text","text":" "},{"text":"a timeout value to ensure that the ","type":"text"},{"type":"codeVoice","code":"poll()"},{"text":" call doesn’t block too long","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and miss the next timeout."}],"type":"paragraph"},{"inlineContent":[{"text":"For file descriptor sources, the prepare function typically returns ","type":"text"},{"code":"false","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"since it must wait until "},{"code":"poll()","type":"codeVoice"},{"text":" has been called before it knows whether","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"any events need to be processed. It sets the returned timeout to -1 to"},{"text":" ","type":"text"},{"text":"indicate that it doesn’t mind how long the ","type":"text"},{"code":"poll()","type":"codeVoice"},{"type":"text","text":" call blocks. In the"},{"text":" ","type":"text"},{"text":"check function, it tests the results of the ","type":"text"},{"type":"codeVoice","code":"poll()"},{"type":"text","text":" call to see if the"},{"type":"text","text":" "},{"text":"required condition has been met, and returns ","type":"text"},{"type":"codeVoice","code":"true"},{"text":" if so.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsProtocol","isActive":true},{"text":" protocol exposes the methods and properties of an underlying ","type":"text"},{"type":"codeVoice","code":"GSourceFuncs"},{"text":" instance.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The default implementation of these can be found in the protocol extension below."},{"text":" ","type":"text"},{"type":"text","text":"For a concrete class that implements these methods and properties, see "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncs","isActive":true,"type":"reference"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Alternatively, use ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef","type":"reference"},{"text":" as a lighweight, ","type":"text"},{"type":"codeVoice","code":"unowned"},{"text":" reference if you already have an instance you just want to use.","type":"text"}],"type":"paragraph"}]}],"topicSections":[{"generated":true,"identifiers":["doc:\/\/GLib\/documentation\/GLib\/SourceFuncsProtocol\/check","doc:\/\/GLib\/documentation\/GLib\/SourceFuncsProtocol\/dispatch","doc:\/\/GLib\/documentation\/GLib\/SourceFuncsProtocol\/finalize","doc:\/\/GLib\/documentation\/GLib\/SourceFuncsProtocol\/prepare"],"title":"Instance Properties","anchor":"Instance-Properties"},{"title":"Instance Methods","anchor":"Instance-Methods","identifiers":["doc:\/\/GLib\/documentation\/GLib\/SourceFuncsProtocol\/sourceRemoveByFuncs(userData:)"],"generated":true}],"variants":[{"paths":["\/documentation\/glib\/sourcefuncsprotocol"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsProtocol","interfaceLanguage":"swift"},"metadata":{"modules":[{"name":"GLib"}],"role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"text":"SourceFuncsProtocol","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"SourceFuncsProtocol"}],"title":"SourceFuncsProtocol","roleHeading":"Protocol","externalID":"s:4GLib19SourceFuncsProtocolP","symbolKind":"protocol"},"sections":[],"references":{"doc://GLib/documentation/GLib/SourceFuncsProtocol/check":{"title":"check","role":"symbol","kind":"symbol","type":"topic","abstract":[{"type":"text","text":"Called after all the file descriptors are polled. The"},{"type":"text","text":" "},{"text":"source should return ","type":"text"},{"type":"codeVoice","code":"true"},{"type":"text","text":" if it is ready to be dispatched. Note that"},{"text":" ","type":"text"},{"text":"some time may have passed since the previous prepare function was called,","type":"text"},{"text":" ","type":"text"},{"text":"so the source should be checked again here.  Since 2.36 this may","type":"text"},{"type":"text","text":" "},{"type":"text","text":"be "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", in which case the effect is as if the function always returns"},{"text":" ","type":"text"},{"code":"false","type":"codeVoice"},{"text":".","type":"text"}],"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"check"},{"kind":"text","text":": "},{"preciseIdentifier":"c:@T@GSourceFuncsCheckFunc","text":"GSourceFuncsCheckFunc","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"url":"\/documentation\/glib\/sourcefuncsprotocol\/check","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsProtocol\/check"},"doc://GLib/documentation/GLib/SourceFuncsProtocol/finalize":{"url":"\/documentation\/glib\/sourcefuncsprotocol\/finalize","role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"finalize"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GSourceFuncsFinalizeFunc","text":"GSourceFuncsFinalizeFunc"},{"text":"!","kind":"text"}],"title":"finalize","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsProtocol\/finalize","kind":"symbol","abstract":[{"text":"Called when the source is finalized. At this point,","type":"text"},{"type":"text","text":" "},{"text":"the source will have been destroyed, had its callback cleared, and have","type":"text"},{"type":"text","text":" "},{"type":"text","text":"been removed from its [struct"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","isActive":true},{"text":"], but it will still have","type":"text"},{"text":" ","type":"text"},{"text":"its final reference count, so methods can be called on it from within","type":"text"},{"type":"text","text":" "},{"text":"this function. This may be ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":", in which case the effect is as if the","type":"text"},{"text":" ","type":"text"},{"text":"function does nothing and returns.","type":"text"}],"type":"topic"},"doc://GLib/documentation/GLib/SourceFuncs":{"navigatorTitle":[{"text":"SourceFuncs","kind":"identifier"}],"abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"GSourceFuncs"},{"type":"text","text":" struct contains a table of"},{"text":" ","type":"text"},{"type":"text","text":"functions used to handle event sources in a generic manner."}],"type":"topic","kind":"symbol","url":"\/documentation\/glib\/sourcefuncs","role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncs","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"SourceFuncs"}],"title":"SourceFuncs"},"doc://GLib/documentation/GLib/SourceFuncsProtocol/sourceRemoveByFuncs(userData:)":{"title":"sourceRemoveByFuncs(userData:)","role":"symbol","kind":"symbol","type":"topic","abstract":[{"text":"Removes a source from the default main loop context given the","type":"text"},{"type":"text","text":" "},{"text":"source functions and user data.","type":"text"}],"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"sourceRemoveByFuncs"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"userData"},{"text":": ","kind":"text"},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:@T@gpointer"},{"text":"?) -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"url":"\/documentation\/glib\/sourcefuncsprotocol\/sourceremovebyfuncs(userdata:)","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsProtocol\/sourceRemoveByFuncs(userData:)"},"doc://GLib/documentation/GLib/PointerWrapper":{"fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"PointerWrapper"}],"kind":"symbol","abstract":[{"text":"Protocol for GLib types that wrap pointers.","type":"text"}],"title":"PointerWrapper","url":"\/documentation\/glib\/pointerwrapper","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"PointerWrapper"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","type":"topic"},"doc://GLib/documentation/GLib/SourceFuncsProtocol":{"role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsProtocol","abstract":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"GSourceFuncs"},{"text":" struct contains a table of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"functions used to handle event sources in a generic manner."}],"title":"SourceFuncsProtocol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SourceFuncsProtocol","kind":"identifier"}],"type":"topic","url":"\/documentation\/glib\/sourcefuncsprotocol","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"SourceFuncsProtocol"}]},"doc://GLib/documentation/GLib/sourceRemove":{"title":"sourceRemove","abstract":[{"text":"Use this macro as the return value of a [callback","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFunc","isActive":true,"type":"reference"},{"type":"text","text":"] to remove"},{"text":" ","type":"text"},{"type":"text","text":"the [struct"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Source","type":"reference"},{"text":"] from the main loop.","type":"text"}],"kind":"symbol","role":"symbol","type":"topic","fragments":[{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"sourceRemove"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:s5Int32V","text":"Int32"}],"url":"\/documentation\/glib\/sourceremove","identifier":"doc:\/\/GLib\/documentation\/GLib\/sourceRemove"},"doc://GLib/documentation/GLib/MainContext":{"navigatorTitle":[{"text":"MainContext","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/glib\/maincontext","role":"symbol","type":"topic","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MainContext","kind":"identifier"}],"abstract":[{"type":"text","text":"The "},{"code":"GMainContext","type":"codeVoice"},{"text":" struct is an opaque data","type":"text"},{"type":"text","text":" "},{"type":"text","text":"type representing a set of sources to be handled in a main loop."}],"title":"MainContext","identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext"},"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"doc://GLib/documentation/GLib/SourceFuncsRef":{"url":"\/documentation\/glib\/sourcefuncsref","type":"topic","abstract":[{"type":"text","text":"The "},{"code":"GSourceFuncs","type":"codeVoice"},{"text":" struct contains a table of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"functions used to handle event sources in a generic manner."}],"navigatorTitle":[{"text":"SourceFuncsRef","kind":"identifier"}],"kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SourceFuncsRef","kind":"identifier"}],"role":"symbol","title":"SourceFuncsRef","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef"},"doc://GLib/documentation/GLib/SourceFuncsProtocol/dispatch":{"url":"\/documentation\/glib\/sourcefuncsprotocol\/dispatch","role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"text":"dispatch","kind":"identifier"},{"kind":"text","text":": "},{"text":"GSourceFuncsDispatchFunc","preciseIdentifier":"c:@T@GSourceFuncsDispatchFunc","kind":"typeIdentifier"},{"kind":"text","text":"!"}],"title":"dispatch","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsProtocol\/dispatch","kind":"symbol","abstract":[{"type":"text","text":"Called to dispatch the event source, after it has returned"},{"text":" ","type":"text"},{"code":"true","type":"codeVoice"},{"text":" in either its ","type":"text"},{"code":"prepare","type":"codeVoice"},{"type":"text","text":" or its "},{"code":"check","type":"codeVoice"},{"type":"text","text":" function, or if a ready time"},{"type":"text","text":" "},{"text":"has been reached. The ","type":"text"},{"type":"codeVoice","code":"dispatch"},{"text":" function receives a callback function and","type":"text"},{"type":"text","text":" "},{"text":"user data. The callback function may be ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" if the source was never","type":"text"},{"text":" ","type":"text"},{"text":"connected to a callback using [method","type":"text"},{"type":"codeVoice","code":"GLib.Source.set_callback"},{"type":"text","text":"]. The"},{"type":"text","text":" "},{"code":"dispatch","type":"codeVoice"},{"text":" function should call the callback function with ","type":"text"},{"code":"user_data","type":"codeVoice"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"text":"whatever additional parameters are needed for this type of event source.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"The return value of the "},{"type":"codeVoice","code":"dispatch"},{"type":"text","text":" function should be"},{"type":"text","text":" "},{"text":"[const","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/sourceRemove"},{"text":"] if the source should be removed or","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[const"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/sourceContinue","type":"reference","isActive":true},{"text":"] to keep it.","type":"text"}],"type":"topic"},"doc://GLib/documentation/GLib/sourceContinue":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/sourceContinue","url":"\/documentation\/glib\/sourcecontinue","role":"symbol","type":"topic","abstract":[{"type":"text","text":"Use this macro as the return value of a [callback"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFunc"},{"type":"text","text":"] to leave"},{"text":" ","type":"text"},{"text":"the [struct","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Source","isActive":true},{"type":"text","text":"] in the main loop."}],"kind":"symbol","title":"sourceContinue","fragments":[{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"text":"sourceContinue","kind":"identifier"},{"kind":"text","text":": "},{"text":"gboolean","kind":"typeIdentifier","preciseIdentifier":"c:@T@gboolean"}]},"doc://GLib/documentation/GLib/SourceFuncsProtocol/prepare":{"title":"prepare","role":"symbol","kind":"symbol","type":"topic","abstract":[{"type":"text","text":"Called before all the file descriptors are polled. If"},{"text":" ","type":"text"},{"type":"text","text":"the source can determine that it is ready here (without waiting for the"},{"text":" ","type":"text"},{"text":"results of the ","type":"text"},{"type":"codeVoice","code":"poll()"},{"text":" call) it should return ","type":"text"},{"type":"codeVoice","code":"true"},{"type":"text","text":". It can also return"},{"type":"text","text":" "},{"text":"a ","type":"text"},{"type":"codeVoice","code":"timeout_"},{"text":" value which should be the maximum timeout (in milliseconds)","type":"text"},{"text":" ","type":"text"},{"text":"which should be passed to the ","type":"text"},{"code":"poll()","type":"codeVoice"},{"type":"text","text":" call. The actual timeout used will"},{"type":"text","text":" "},{"text":"be -1 if all sources returned -1, or it will be the minimum of all","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"code":"timeout_","type":"codeVoice"},{"type":"text","text":" values returned which were >= 0.  Since 2.36 this may"},{"text":" ","type":"text"},{"type":"text","text":"be "},{"code":"nil","type":"codeVoice"},{"type":"text","text":", in which case the effect is as if the function always returns"},{"type":"text","text":" "},{"code":"false","type":"codeVoice"},{"text":" with a timeout of -1.  If ","type":"text"},{"type":"codeVoice","code":"prepare"},{"text":" returns a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"timeout and the source also has a ready time set, then the"},{"text":" ","type":"text"},{"text":"lower of the two will be used.","type":"text"}],"fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"prepare"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"GSourceFuncsPrepareFunc","preciseIdentifier":"c:@T@GSourceFuncsPrepareFunc"},{"kind":"text","text":"!"}],"url":"\/documentation\/glib\/sourcefuncsprotocol\/prepare","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsProtocol\/prepare"}}}
{"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"externalID":"s:4GLib26MarkupParseContextProtocolPAAE4push6parser8userDatayqd___SvSgtAA0b6ParserE0Rd__lF","modules":[{"name":"GLib"}],"title":"push(parser:userData:)","extendedModule":"GLib","symbolKind":"method","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"push","kind":"identifier"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"MarkupParserT"},{"text":">(","kind":"text"},{"text":"parser","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"MarkupParserT","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"userData","kind":"externalParam"},{"kind":"text","text":": "},{"text":"gpointer","preciseIdentifier":"c:@T@gpointer","kind":"typeIdentifier"},{"text":"?)","kind":"text"}],"roleHeading":"Instance Method"},"abstract":[{"text":"Temporarily redirects markup data to a sub-parser.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"push"},{"text":"<","kind":"text"},{"text":"MarkupParserT","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"parser","kind":"externalParam"},{"kind":"text","text":": "},{"text":"MarkupParserT","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"userData","kind":"externalParam"},{"kind":"text","text":": "},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:@T@gpointer"},{"text":"? = nil) ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MarkupParserT","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"MarkupParserProtocol","identifier":"doc:\/\/GLib\/documentation\/GLib\/MarkupParserProtocol","kind":"typeIdentifier","preciseIdentifier":"s:4GLib20MarkupParserProtocolP"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"inlineContent":[{"text":"This function may only be called from the start_element handler of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"a "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/MarkupParser","type":"reference"},{"text":". It must be matched with a corresponding call to","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_markup_parse_context_pop()"},{"text":" in the matching end_element handler","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(except in the case that the parser aborts due to an error)."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"All tags, text and other data between the matching tags is"},{"type":"text","text":" "},{"text":"redirected to the subparser given by ","type":"text"},{"code":"parser","type":"codeVoice"},{"type":"text","text":". "},{"code":"userData","type":"codeVoice"},{"type":"text","text":" is used"},{"text":" ","type":"text"},{"type":"text","text":"as the user_data for that parser. "},{"code":"userData","type":"codeVoice"},{"text":" is also passed to the","type":"text"},{"type":"text","text":" "},{"text":"error callback in the event that an error occurs. This includes","type":"text"},{"text":" ","type":"text"},{"text":"errors that occur in subparsers of the subparser.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The end tag matching the start tag for which this call was made is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"handled by the previous parser (which is given its own user_data)"},{"text":" ","type":"text"},{"text":"which is why ","type":"text"},{"type":"codeVoice","code":"g_markup_parse_context_pop()"},{"type":"text","text":" is provided to allow “one"},{"type":"text","text":" "},{"type":"text","text":"last access” to the "},{"type":"codeVoice","code":"userData"},{"type":"text","text":" provided to this function. In the"},{"type":"text","text":" "},{"text":"case of error, the ","type":"text"},{"code":"userData","type":"codeVoice"},{"type":"text","text":" provided here is passed directly to"},{"type":"text","text":" "},{"type":"text","text":"the error callback of the subparser and "},{"code":"g_markup_parse_context_pop()","type":"codeVoice"},{"type":"text","text":" "},{"text":"should not be called. In either case, if ","type":"text"},{"type":"codeVoice","code":"userData"},{"text":" was allocated","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"then it ought to be freed from both of these locations."}]},{"type":"paragraph","inlineContent":[{"text":"This function is not intended to be directly called by users","type":"text"},{"type":"text","text":" "},{"text":"interested in invoking subparsers. Instead, it is intended to be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"used by the subparsers themselves to implement a higher-level"},{"type":"text","text":" "},{"text":"interface.","type":"text"}]},{"inlineContent":[{"type":"text","text":"As an example, see the following implementation of a simple"},{"type":"text","text":" "},{"type":"text","text":"parser that counts the number of tags encountered."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"(C Language Example):"}],"type":"paragraph"},{"syntax":"C","code":["typedef struct","{","  gint tag_count;","} CounterData;","","static void","counter_start_element (GMarkupParseContext  *context,","                       const gchar          *element_name,","                       const gchar         **attribute_names,","                       const gchar         **attribute_values,","                       gpointer              user_data,","                       GError              **error)","{","  CounterData *data = user_data;","","  data->tag_count++;","}","","static void","counter_error (GMarkupParseContext *context,","               GError              *error,","               gpointer             user_data)","{","  CounterData *data = user_data;","","  g_slice_free (CounterData, data);","}","","static GMarkupParser counter_subparser =","{","  counter_start_element,","  NULL,","  NULL,","  NULL,","  counter_error","};"],"type":"codeListing"},{"inlineContent":[{"text":"In order to allow this parser to be easily used as a subparser, the","type":"text"},{"text":" ","type":"text"},{"text":"following interface is provided:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"(C Language Example):","type":"text"}],"type":"paragraph"},{"syntax":"C","type":"codeListing","code":["void","start_counting (GMarkupParseContext *context)","{","  CounterData *data = g_slice_new (CounterData);","","  data->tag_count = 0;","  g_markup_parse_context_push (context, &counter_subparser, data);","}","","gint","end_counting (GMarkupParseContext *context)","{","  CounterData *data = g_markup_parse_context_pop (context);","  int result;","","  result = data->tag_count;","  g_slice_free (CounterData, data);","","  return result;","}"]},{"type":"paragraph","inlineContent":[{"text":"The subparser would then be used as follows:","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"code":["static void start_element (context, element_name, ...)","{","  if (strcmp (element_name, \"count-these\") == 0)","    start_counting (context);","","  \/\/ else, handle other tags...","}","","static void end_element (context, element_name, ...)","{","  if (strcmp (element_name, \"count-these\") == 0)","    g_print (\"Counted %d tags\\n\", end_counting (context));","","  \/\/ else, handle other tags...","}"],"syntax":"C","type":"codeListing"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/MarkupParseContextProtocol"]]},"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/MarkupParseContextProtocol\/push(parser:userData:)"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/markupparsecontextprotocol\/push(parser:userdata:)"]}],"references":{"doc://GLib/documentation/GLib/MarkupParser":{"navigatorTitle":[{"text":"MarkupParser","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/glib\/markupparser","title":"MarkupParser","type":"topic","abstract":[{"type":"text","text":"Any of the fields in "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/MarkupParser","isActive":true},{"text":" can be ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":", in which case they"},{"text":" ","type":"text"},{"text":"will be ignored. Except for the ","type":"text"},{"code":"error","type":"codeVoice"},{"type":"text","text":" function, any of these callbacks"},{"type":"text","text":" "},{"type":"text","text":"can set an error; in particular the "},{"code":"unknownElement","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"codeVoice","code":"unknownAttribute"},{"type":"text","text":", and "},{"code":"invalidContent","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"errors are intended to be set from these callbacks. If you set an error"},{"type":"text","text":" "},{"type":"text","text":"from a callback, "},{"code":"g_markup_parse_context_parse()","type":"codeVoice"},{"type":"text","text":" will report that error"},{"text":" ","type":"text"},{"text":"back to its caller.","type":"text"}],"role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"MarkupParser"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/MarkupParser"},"doc://GLib/documentation/GLib/MarkupParserProtocol":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MarkupParserProtocol","url":"\/documentation\/glib\/markupparserprotocol","type":"topic","role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"text":"MarkupParserProtocol","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"MarkupParserProtocol"}],"abstract":[{"type":"text","text":"Any of the fields in "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/MarkupParser"},{"text":" can be ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":", in which case they"},{"type":"text","text":" "},{"text":"will be ignored. Except for the ","type":"text"},{"type":"codeVoice","code":"error"},{"type":"text","text":" function, any of these callbacks"},{"text":" ","type":"text"},{"text":"can set an error; in particular the ","type":"text"},{"type":"codeVoice","code":"unknownElement"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"codeVoice","code":"unknownAttribute"},{"text":", and ","type":"text"},{"type":"codeVoice","code":"invalidContent"},{"text":" ","type":"text"},{"type":"text","text":"errors are intended to be set from these callbacks. If you set an error"},{"type":"text","text":" "},{"text":"from a callback, ","type":"text"},{"code":"g_markup_parse_context_parse()","type":"codeVoice"},{"text":" will report that error","type":"text"},{"type":"text","text":" "},{"type":"text","text":"back to its caller."}],"title":"MarkupParserProtocol","kind":"symbol"},"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"doc://GLib/documentation/GLib/MarkupParseContextProtocol":{"title":"MarkupParseContextProtocol","role":"symbol","abstract":[{"text":"A parse context is used to parse a stream of bytes that","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"you expect to contain marked-up text."}],"kind":"symbol","type":"topic","navigatorTitle":[{"text":"MarkupParseContextProtocol","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"text":"MarkupParseContextProtocol","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/MarkupParseContextProtocol","url":"\/documentation\/glib\/markupparsecontextprotocol"},"doc://GLib/documentation/GLib/MarkupParseContextProtocol/push(parser:userData:)":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MarkupParseContextProtocol\/push(parser:userData:)","type":"topic","role":"symbol","kind":"symbol","title":"push(parser:userData:)","abstract":[{"text":"Temporarily redirects markup data to a sub-parser.","type":"text"}],"url":"\/documentation\/glib\/markupparsecontextprotocol\/push(parser:userdata:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"push"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"MarkupParserT"},{"kind":"text","text":">("},{"text":"parser","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"MarkupParserT"},{"text":", ","kind":"text"},{"text":"userData","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"gpointer","preciseIdentifier":"c:@T@gpointer"},{"kind":"text","text":"?)"}]}}}
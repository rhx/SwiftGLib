{"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"isPartialMatch","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"externalID":"s:4GLib17MatchInfoProtocolPAAE09isPartialB0Sbvp::SYNTHESIZED::s:4GLib12MatchInfoRefV","extendedModule":"GLib","role":"symbol","title":"isPartialMatch","modules":[{"name":"GLib"}],"symbolKind":"property","roleHeading":"Instance Property"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/matchinforef\/ispartialmatch"]}],"kind":"symbol","identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/MatchInfoRef\/isPartialMatch","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Usually if the string passed to g_regex_match*() matches as far as"},{"type":"text","text":" "},{"text":"it goes, but is too short to match the entire pattern, ","type":"text"},{"type":"codeVoice","code":"false"},{"type":"text","text":" is"},{"type":"text","text":" "},{"text":"returned. There are circumstances where it might be helpful to","type":"text"},{"text":" ","type":"text"},{"text":"distinguish this case from other cases in which there is no match.","type":"text"}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"isPartialMatch","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"kind":"text","text":" }"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"Consider, for example, an application where a human is required to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"type in data for a field with specific formatting requirements. An"},{"type":"text","text":" "},{"type":"text","text":"example might be a date in the form ddmmmyy, defined by the pattern"},{"text":" ","type":"text"},{"code":"\"^\\d?\\d(jan|feb|mar|apr|may|jun|jul|aug|sep|oct|nov|dec)","type":"codeVoice"},{"type":"text","text":"\\d\\d$”."},{"text":" ","type":"text"},{"type":"text","text":"If the application sees the user’s keystrokes one by one, and can"},{"type":"text","text":" "},{"type":"text","text":"check that what has been typed so far is potentially valid, it is"},{"text":" ","type":"text"},{"text":"able to raise an error as soon as a mistake is made.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"GRegex supports the concept of partial matching by means of the"},{"type":"text","text":" "},{"type":"codeVoice","code":"partialSoft"},{"type":"text","text":" and "},{"type":"codeVoice","code":"partialHard"},{"type":"text","text":" flags."},{"type":"text","text":" "},{"type":"text","text":"When they are used, the return code for"},{"type":"text","text":" "},{"code":"g_regex_match()","type":"codeVoice"},{"type":"text","text":" or "},{"code":"g_regex_match_full()","type":"codeVoice"},{"type":"text","text":" is, as usual, "},{"type":"codeVoice","code":"true"},{"text":" ","type":"text"},{"type":"text","text":"for a complete match, "},{"code":"false","type":"codeVoice"},{"text":" otherwise. But, when these functions","type":"text"},{"type":"text","text":" "},{"type":"text","text":"return "},{"code":"false","type":"codeVoice"},{"type":"text","text":", you can check if the match was partial calling"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_match_info_is_partial_match()"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"The difference between "},{"code":"partialSoft","type":"codeVoice"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"codeVoice","code":"partialHard"},{"type":"text","text":" is that when a partial match is encountered"},{"type":"text","text":" "},{"type":"text","text":"with "},{"type":"codeVoice","code":"partialSoft"},{"type":"text","text":", matching continues to search for a"},{"text":" ","type":"text"},{"text":"possible complete match, while with ","type":"text"},{"code":"partialHard","type":"codeVoice"},{"text":" matching","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"stops at the partial match."},{"text":" ","type":"text"},{"type":"text","text":"When both "},{"type":"codeVoice","code":"partialSoft"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"partialHard"},{"type":"text","text":" "},{"type":"text","text":"are set, the latter takes precedence."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"There were formerly some restrictions on the pattern for partial matching."},{"text":" ","type":"text"},{"type":"text","text":"The restrictions no longer apply."}]},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"code":"pcrepartial(3)","type":"codeVoice"},{"text":" for more information on partial matching.","type":"text"}]}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/MatchInfoRef","doc:\/\/GLib\/documentation\/GLib\/MatchInfoRef\/MatchInfoProtocol-Implementations"]]},"sections":[],"references":{"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"doc://GLib/documentation/GLib/MatchInfoRef":{"kind":"symbol","navigatorTitle":[{"text":"MatchInfoRef","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfoRef","abstract":[{"text":"A GMatchInfo is an opaque struct used to return information about","type":"text"},{"type":"text","text":" "},{"type":"text","text":"matches."}],"type":"topic","url":"\/documentation\/glib\/matchinforef","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"MatchInfoRef"}],"title":"MatchInfoRef"},"doc://GLib/documentation/GLib/MatchInfoRef/isPartialMatch":{"fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"isPartialMatch"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"url":"\/documentation\/glib\/matchinforef\/ispartialmatch","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfoRef\/isPartialMatch","title":"isPartialMatch","role":"symbol","type":"topic","abstract":[{"text":"Usually if the string passed to g_regex_match*() matches as far as","type":"text"},{"type":"text","text":" "},{"text":"it goes, but is too short to match the entire pattern, ","type":"text"},{"code":"false","type":"codeVoice"},{"text":" is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"returned. There are circumstances where it might be helpful to"},{"text":" ","type":"text"},{"type":"text","text":"distinguish this case from other cases in which there is no match."}]},"doc://GLib/documentation/GLib/MatchInfoRef/MatchInfoProtocol-Implementations":{"title":"MatchInfoProtocol Implementations","url":"\/documentation\/glib\/matchinforef\/matchinfoprotocol-implementations","kind":"article","identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfoRef\/MatchInfoProtocol-Implementations","abstract":[],"type":"topic","role":"collectionGroup"}}}
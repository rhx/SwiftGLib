{"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Returns the start and end positions (in bytes) of a successfully matching"},{"text":" ","type":"text"},{"type":"text","text":"capture parenthesis."}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/MatchInfoRef","doc:\/\/GLib\/documentation\/GLib\/MatchInfoRef\/MatchInfoProtocol-Implementations"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"fetchPos","kind":"identifier"},{"kind":"text","text":"("},{"text":"matchNum","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"text":"startPos","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"gint","kind":"typeIdentifier","preciseIdentifier":"c:@T@gint"},{"text":">! = nil, ","kind":"text"},{"kind":"externalParam","text":"endPos"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gint","kind":"typeIdentifier","text":"gint"},{"text":">! = nil) -> ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"languages":["swift"]}]},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Valid values for "},{"code":"matchNum","type":"codeVoice"},{"type":"text","text":" are "},{"code":"0","type":"codeVoice"},{"type":"text","text":" for the full text of the match,"},{"text":" ","type":"text"},{"code":"1","type":"codeVoice"},{"text":" for the first paren set, ","type":"text"},{"type":"codeVoice","code":"2"},{"type":"text","text":" for the second, and so on."}]},{"inlineContent":[{"type":"text","text":"As "},{"type":"codeVoice","code":"endPos"},{"type":"text","text":" is set to the byte after the final byte of the match (on success),"},{"text":" ","type":"text"},{"type":"text","text":"the length of the match can be calculated as "},{"code":"end_pos - start_pos","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"As a best practice, initialize ","type":"text"},{"code":"startPos","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"endPos"},{"text":" to identifiable","type":"text"},{"type":"text","text":" "},{"text":"values, such as ","type":"text"},{"type":"codeVoice","code":"G_MAXINT"},{"type":"text","text":", so that you can test if"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_match_info_fetch_pos()"},{"type":"text","text":" actually changed the value for a given"},{"text":" ","type":"text"},{"type":"text","text":"capture parenthesis."}]},{"inlineContent":[{"type":"text","text":"The parameter "},{"code":"matchNum","type":"codeVoice"},{"type":"text","text":" corresponds to a matched capture parenthesis. The"},{"text":" ","type":"text"},{"type":"text","text":"actual value you use for "},{"type":"codeVoice","code":"matchNum"},{"text":" depends on the method used to generate","type":"text"},{"type":"text","text":" "},{"code":"matchInfo","type":"codeVoice"},{"type":"text","text":". The following sections describe those methods."}],"type":"paragraph"},{"type":"heading","anchor":"Methods-Using-Non-deterministic-Finite-Automata-Matching","level":2,"text":"Methods Using Non-deterministic Finite Automata Matching"},{"type":"paragraph","inlineContent":[{"text":"The methods [method","type":"text"},{"type":"codeVoice","code":"GLib.Regex.match"},{"text":"] and [method","type":"text"},{"code":"GLib.Regex.match_full","type":"codeVoice"},{"text":"]","type":"text"},{"type":"text","text":" "},{"text":"return a [struct","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo"},{"text":"] using traditional (greedy) pattern","type":"text"},{"type":"text","text":" "},{"text":"matching, also known as","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/en.wikipedia.org\/wiki\/Nondeterministic_finite_automaton","type":"reference","isActive":true},{"text":" ","type":"text"},{"text":"(NFA) matching. You pass the returned ","type":"text"},{"type":"codeVoice","code":"GMatchInfo"},{"type":"text","text":" from these methods to"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_match_info_fetch_pos()"},{"text":" to determine the start and end positions","type":"text"},{"text":" ","type":"text"},{"text":"of capture parentheses. The values for ","type":"text"},{"type":"codeVoice","code":"matchNum"},{"type":"text","text":" correspond to the capture"},{"text":" ","type":"text"},{"text":"parentheses in order, with ","type":"text"},{"type":"codeVoice","code":"0"},{"text":" corresponding to the entire matched string.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"matchNum"},{"type":"text","text":" can refer to a capture parenthesis with no match. For example,"},{"type":"text","text":" "},{"type":"text","text":"the string "},{"type":"codeVoice","code":"b"},{"type":"text","text":" matches against the pattern "},{"type":"codeVoice","code":"(a)?b"},{"text":", but the capture","type":"text"},{"type":"text","text":" "},{"type":"text","text":"parenthesis "},{"code":"(a)","type":"codeVoice"},{"text":" has no match. In this case, ","type":"text"},{"code":"g_match_info_fetch_pos()","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"returns true and sets "},{"code":"startPos","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"endPos"},{"text":" to ","type":"text"},{"type":"codeVoice","code":"-1"},{"type":"text","text":" when called with"},{"type":"text","text":" "},{"type":"codeVoice","code":"match_num"},{"text":" as ","type":"text"},{"type":"codeVoice","code":"1"},{"text":" (for ","type":"text"},{"code":"(a)","type":"codeVoice"},{"text":").","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For an expanded example, a regex pattern is "},{"type":"codeVoice","code":"(a)?(.*?)the (.*)"},{"text":",","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and a candidate string is "},{"code":"glib regexes are the best","type":"codeVoice"},{"text":". In this scenario","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"there are four capture parentheses numbered 0–3: an implicit one"},{"type":"text","text":" "},{"text":"for the entire string, and three explicitly declared in the regex pattern.","type":"text"}]},{"inlineContent":[{"text":"Given this example, the following table describes the return values","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"from "},{"code":"g_match_info_fetch_pos()","type":"codeVoice"},{"type":"text","text":" for various values of "},{"type":"codeVoice","code":"matchNum"},{"type":"text","text":"."}],"type":"paragraph"},{"rows":[[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"match_num"}]}],[{"type":"paragraph","inlineContent":[{"text":"Contents","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Return value","type":"text"}]}],[{"inlineContent":[{"text":"Returned ","type":"text"},{"type":"codeVoice","code":"start_pos"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Returned "},{"code":"end_pos","type":"codeVoice"}]}]],[[{"inlineContent":[{"text":"0","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Matches entire string","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"True","type":"text"}]}],[{"inlineContent":[{"text":"0","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"25"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"1"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Does not match first character"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"True"}]}],[{"type":"paragraph","inlineContent":[{"text":"-1","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"-1","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"2","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"All text before "},{"type":"codeVoice","code":"the "}]}],[{"inlineContent":[{"type":"text","text":"True"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"0"}]}],[{"type":"paragraph","inlineContent":[{"text":"17","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"3"}]}],[{"inlineContent":[{"type":"text","text":"All text after "},{"code":"the ","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"True"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"21","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"25"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"4"}]}],[{"inlineContent":[{"type":"text","text":"Capture paren out of range"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"False"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Unchanged","type":"text"}]}],[{"inlineContent":[{"text":"Unchanged","type":"text"}],"type":"paragraph"}]]],"type":"table","header":"row"},{"inlineContent":[{"text":"The following code sample and output implements this example.","type":"text"}],"type":"paragraph"},{"syntax":"{ .c }","code":["`include` <glib.h>","","int","main (int argc, char *argv[])","{","  `g_autoptr(GError)` local_error = NULL;","  const char *regex_pattern = \"(a)?(.*?)the (.*)\";","  const char *test_string = \"glib regexes are the best\";","  `g_autoptr(GRegex)` regex = NULL;","","  regex = g_regex_new (regex_pattern,","                       G_REGEX_DEFAULT,","                       G_REGEX_MATCH_DEFAULT,","                       &local_error);","  if (regex == NULL)","    {","      g_printerr (\"Error creating regex: `s`\\n\", local_error->message);","      return 1;","    }","","  `g_autoptr(GMatchInfo)` match_info = NULL;","  g_regex_match (regex, test_string, G_REGEX_MATCH_DEFAULT, &match_info);","","  int n_matched_strings = g_match_info_get_match_count (match_info);","","  \/\/ Print header line","  g_print (\"match_num Contents                  Return value returned start_pos returned end_pos\\n\");","","  \/\/ Iterate over each capture paren, including one that is out of range as a demonstration.","  for (int match_num = 0; match_num <= n_matched_strings; match_num++)","    {","      gboolean found_match;","      g_autofree char *paren_string = NULL;","      int start_pos = G_MAXINT;","      int end_pos = G_MAXINT;","","      found_match = g_match_info_fetch_pos (match_info,","                                            match_num,","                                            &start_pos,","                                            &end_pos);","","      \/\/ If no match, display N\/A as the found string.","      if (start_pos == G_MAXINT || start_pos == -1)","        paren_string = g_strdup (\"N\/A\");","      else","        paren_string = g_strndup (test_string + start_pos, end_pos - start_pos);","","      g_print (\"`-9d` `-25s` `-12d` `-18d` `d`\\n\", match_num, paren_string, found_match, start_pos, end_pos);","    }","","  return 0;","}"],"type":"codeListing"},{"code":["match_num Contents                  Return value returned start_pos returned end_pos","0         glib regexes are the best 1            0                  25","1         N\/A                       1            -1                 -1","2         glib regexes are          1            0                  17","3         best                      1            21                 25","4         N\/A                       0            2147483647         2147483647"],"syntax":null,"type":"codeListing"},{"anchor":"Methods-Using-Deterministic-Finite-Automata-Matching","text":"Methods Using Deterministic Finite Automata Matching","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The methods [method","type":"text"},{"type":"codeVoice","code":"GLib.Regex.match_all"},{"type":"text","text":"] and"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.Regex.match_all_full"},{"text":"]","type":"text"},{"text":" ","type":"text"},{"text":"return a ","type":"text"},{"type":"codeVoice","code":"GMatchInfo"},{"text":" using","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/en.wikipedia.org\/wiki\/Deterministic_finite_automaton","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"type":"text","text":"(DFA) pattern matching. This algorithm detects overlapping matches. You pass"},{"type":"text","text":" "},{"text":"the returned ","type":"text"},{"type":"codeVoice","code":"GMatchInfo"},{"type":"text","text":" from these methods to "},{"type":"codeVoice","code":"g_match_info_fetch_pos()"},{"text":" ","type":"text"},{"type":"text","text":"to determine the start and end positions of each overlapping match. Use the"},{"type":"text","text":" "},{"type":"text","text":"method [method"},{"code":"GLib.MatchInfo.get_match_count","type":"codeVoice"},{"text":"] to determine the number","type":"text"},{"type":"text","text":" "},{"text":"of overlapping matches.","type":"text"}]},{"inlineContent":[{"type":"text","text":"For example, a regex pattern is "},{"type":"codeVoice","code":"<.*>"},{"text":", and a candidate string is","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"<a> <b> <c>"},{"text":". In this scenario there are three implicit capture","type":"text"},{"text":" ","type":"text"},{"text":"parentheses: one for the entire string, one for ","type":"text"},{"code":"<a> <b>","type":"codeVoice"},{"text":", and one for ","type":"text"},{"type":"codeVoice","code":"<a>"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Given this example, the following table describes the return values from"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_match_info_fetch_pos()"},{"type":"text","text":" for various values of "},{"code":"matchNum","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"rows":[[[{"inlineContent":[{"type":"codeVoice","code":"match_num"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Contents"}]}],[{"inlineContent":[{"type":"text","text":"Return value"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Returned "},{"code":"start_pos","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Returned "},{"code":"end_pos","type":"codeVoice"}]}]],[[{"inlineContent":[{"type":"text","text":"0"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Matches entire string"}],"type":"paragraph"}],[{"inlineContent":[{"text":"True","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"0"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"11","type":"text"}]}]],[[{"inlineContent":[{"text":"1","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Matches "},{"code":"<a> <b>","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"True","type":"text"}]}],[{"inlineContent":[{"text":"0","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"7","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"2"}]}],[{"inlineContent":[{"type":"text","text":"Matches "},{"code":"<a>","type":"codeVoice"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"True","type":"text"}]}],[{"inlineContent":[{"type":"text","text":"0"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"3"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"3"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Capture paren out of range"}]}],[{"type":"paragraph","inlineContent":[{"text":"False","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Unchanged"}]}],[{"inlineContent":[{"type":"text","text":"Unchanged"}],"type":"paragraph"}]]],"type":"table","header":"row"},{"inlineContent":[{"text":"The following code sample and output implements this example.","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["`include` <glib.h>","","int","main (int argc, char *argv[])","{","  `g_autoptr(GError)` local_error = NULL;","  const char *regex_pattern = \"<.*>\";","  const char *test_string = \"<a> <b> <c>\";","  `g_autoptr(GRegex)` regex = NULL;","","  regex = g_regex_new (regex_pattern,","                       G_REGEX_DEFAULT,","                       G_REGEX_MATCH_DEFAULT,","                       &local_error);","  if (regex == NULL)","    {","      g_printerr (\"Error creating regex: `s`\\n\", local_error->message);","      return -1;","    }","","  `g_autoptr(GMatchInfo)` match_info = NULL;","  g_regex_match_all (regex, test_string, G_REGEX_MATCH_DEFAULT, &match_info);","","  int n_matched_strings = g_match_info_get_match_count (match_info);","","  \/\/ Print header line","  g_print (\"match_num Contents                  Return value returned start_pos returned end_pos\\n\");","","  \/\/ Iterate over each capture paren, including one that is out of range as a demonstration.","  for (int match_num = 0; match_num <= n_matched_strings; match_num++)","    {","      gboolean found_match;","      g_autofree char *paren_string = NULL;","      int start_pos = G_MAXINT;","      int end_pos = G_MAXINT;","","      found_match = g_match_info_fetch_pos (match_info, match_num, &sta
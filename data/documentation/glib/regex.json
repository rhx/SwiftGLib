{"metadata":{"navigatorTitle":[{"kind":"identifier","text":"Regex"}],"role":"symbol","title":"Regex","externalID":"s:4GLib5RegexC","roleHeading":"Class","symbolKind":"class","modules":[{"name":"GLib"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"Regex","kind":"identifier"}]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/Regex"},"topicSections":[{"generated":true,"identifiers":["doc:\/\/GLib\/documentation\/GLib\/Regex\/init(_:)-14i11","doc:\/\/GLib\/documentation\/GLib\/Regex\/init(_:)-38s23","doc:\/\/GLib\/documentation\/GLib\/Regex\/init(_:)-5mtur","doc:\/\/GLib\/documentation\/GLib\/Regex\/init(_:)-7dwt1","doc:\/\/GLib\/documentation\/GLib\/Regex\/init(_:)-8o1r7","doc:\/\/GLib\/documentation\/GLib\/Regex\/init(cPointer:)","doc:\/\/GLib\/documentation\/GLib\/Regex\/init(gconstpointer:)","doc:\/\/GLib\/documentation\/GLib\/Regex\/init(gpointer:)","doc:\/\/GLib\/documentation\/GLib\/Regex\/init(opaquePointer:)","doc:\/\/GLib\/documentation\/GLib\/Regex\/init(pattern:compileOptions:matchOptions:)","doc:\/\/GLib\/documentation\/GLib\/Regex\/init(raw:)-1y1qf","doc:\/\/GLib\/documentation\/GLib\/Regex\/init(raw:)-4klw6","doc:\/\/GLib\/documentation\/GLib\/Regex\/init(retaining:)","doc:\/\/GLib\/documentation\/GLib\/Regex\/init(retainingCPointer:)","doc:\/\/GLib\/documentation\/GLib\/Regex\/init(retainingOpaquePointer:)","doc:\/\/GLib\/documentation\/GLib\/Regex\/init(retainingRaw:)-1u2ye","doc:\/\/GLib\/documentation\/GLib\/Regex\/init(retainingRaw:)-7yto8"],"title":"Initializers","anchor":"Initializers"},{"generated":true,"title":"Instance Properties","anchor":"Instance-Properties","identifiers":["doc:\/\/GLib\/documentation\/GLib\/Regex\/ptr"]},{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/Regex\/RegexProtocol-Implementations"],"anchor":"Default-Implementations","title":"Default Implementations","generated":true}],"variants":[{"paths":["\/documentation\/glib\/regex"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"sections":[],"abstract":[{"type":"text","text":"A "},{"code":"GRegex","type":"codeVoice"},{"text":" is a compiled form of a regular expression.","type":"text"}],"relationshipsSections":[{"type":"conformsTo","identifiers":["doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","doc:\/\/GLib\/documentation\/GLib\/RegexProtocol"],"kind":"relationships","title":"Conforms To"}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Regex"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"anchor":"overview","type":"heading","text":"Overview"},{"inlineContent":[{"text":"After instantiating a ","type":"text"},{"type":"codeVoice","code":"GRegex"},{"type":"text","text":", you can use its methods to find matches"},{"type":"text","text":" "},{"type":"text","text":"in a string, replace matches within a string, or split the string at matches."}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"GRegex"},{"type":"text","text":" implements regular expression pattern matching using syntax and"},{"text":" ","type":"text"},{"text":"semantics (such as character classes, quantifiers, and capture groups)","type":"text"},{"type":"text","text":" "},{"text":"similar to Perl regular expression. See the","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"man:pcre2pattern(3)","isActive":true},{"text":" for details.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"A typical scenario for regex pattern matching is to check if a string"},{"type":"text","text":" "},{"text":"matches a pattern. The following statements implement this scenario.","type":"text"}],"type":"paragraph"},{"code":["const char *regex_pattern = \".*GLib.*\";","const char *string_to_search = \"You will love the GLib implementation of regex\";","`g_autoptr(GMatchInfo)` match_info = NULL;","`g_autoptr(GRegex)` regex = NULL;","","regex = g_regex_new (regex_pattern, G_REGEX_DEFAULT, G_REGEX_MATCH_DEFAULT, NULL);","g_assert (regex != NULL);","","if (g_regex_match (regex, string_to_search, G_REGEX_MATCH_DEFAULT, &match_info))","  {","    int start_pos, end_pos;","    g_match_info_fetch_pos (match_info, 0, &start_pos, &end_pos);","    g_print (\"Match successful! Overall pattern matches bytes `d` to `d`\\n\", start_pos, end_pos);","  }","else","  {","    g_print (\"No match!\\n\");","  }"],"type":"codeListing","syntax":"{ .c }"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The constructor for "},{"type":"codeVoice","code":"GRegex"},{"type":"text","text":" includes two sets of bitmapped flags:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"[flags"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexCompileFlags","isActive":true,"type":"reference"},{"type":"text","text":"]—These flags"},{"text":" ","type":"text"},{"type":"text","text":"control how GLib compiles the regex. There are options for case"},{"type":"text","text":" "},{"type":"text","text":"sensitivity, multiline, ignoring whitespace, etc."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"[flags"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexMatchFlags","isActive":true,"type":"reference"},{"text":"]—These flags control","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"GRegex"},{"type":"text","text":"’s matching behavior, such as anchoring and customizing definitions"},{"text":" ","type":"text"},{"type":"text","text":"for newline characters."}]}]}]},{"inlineContent":[{"type":"text","text":"Some regex patterns include backslash assertions, such as "},{"code":"\\d","type":"codeVoice"},{"text":" (digit) or","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"\\D"},{"text":" (non-digit). The regex pattern must escape those backslashes. For","type":"text"},{"type":"text","text":" "},{"type":"text","text":"example, the pattern "},{"type":"codeVoice","code":"\"\\\\d\\\\D\""},{"text":" matches a digit followed by a non-digit.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"GLib’s implementation of pattern matching includes a ","type":"text"},{"type":"codeVoice","code":"start_position"},{"text":" ","type":"text"},{"type":"text","text":"argument for some of the match, replace, and split methods. Specifying"},{"type":"text","text":" "},{"text":"a start position provides flexibility when you want to ignore the first","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"n"}],"type":"emphasis"},{"type":"text","text":" characters of a string, but want to incorporate backslash assertions"},{"text":" ","type":"text"},{"text":"at character ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"n"}]},{"type":"text","text":" - 1. For example, a database field contains inconsistent"},{"type":"text","text":" "},{"type":"text","text":"spelling for a job title: "},{"type":"codeVoice","code":"healthcare provider"},{"text":" and ","type":"text"},{"code":"health-care provider","type":"codeVoice"},{"type":"text","text":"."},{"text":" ","type":"text"},{"text":"The database manager wants to make the spelling consistent by adding a","type":"text"},{"type":"text","text":" "},{"text":"hyphen when it is missing. The following regex pattern tests for the string","type":"text"},{"type":"text","text":" "},{"code":"care","type":"codeVoice"},{"text":" preceded by a non-word boundary character (instead of a hyphen)","type":"text"},{"type":"text","text":" "},{"text":"and followed by a space.","type":"text"}]},{"code":["const char *regex_pattern = \"\\\\Bcare\\\\s\";"],"type":"codeListing","syntax":"{ .c }"},{"inlineContent":[{"type":"text","text":"An efficient way to match with this pattern is to start examining at"},{"type":"text","text":" "},{"code":"start_position","type":"codeVoice"},{"type":"text","text":" 6 in the string "},{"code":"healthcare","type":"codeVoice"},{"type":"text","text":" or "},{"code":"health-care","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"code":["const char *regex_pattern = \"\\\\Bcare\\\\s\";","const char *string_to_search = \"healthcare provider\";","`g_autoptr(GMatchInfo)` match_info = NULL;","`g_autoptr(GRegex)` regex = NULL;","","regex = g_regex_new (","  regex_pattern,","  G_REGEX_DEFAULT,","  G_REGEX_MATCH_DEFAULT,","  NULL);","g_assert (regex != NULL);","","g_regex_match_full (","  regex,","  string_to_search,","  -1,","  6, \/\/ position of 'c' in the test string.","  G_REGEX_MATCH_DEFAULT,","  &match_info,","  NULL);"],"type":"codeListing","syntax":"{ .c }"},{"inlineContent":[{"type":"text","text":"The method [method"},{"type":"codeVoice","code":"GLib.Regex.match_full"},{"type":"text","text":"] (and other methods implementing"},{"type":"text","text":" "},{"code":"start_pos","type":"codeVoice"},{"type":"text","text":") allow for lookback before the start position to determine if"},{"type":"text","text":" "},{"type":"text","text":"the previous character satisfies an assertion."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Unless you set the [flags"},{"type":"codeVoice","code":"GLib.RegexCompileFlags.RAW"},{"type":"text","text":"] as one of"},{"type":"text","text":" "},{"text":"the ","type":"text"},{"type":"codeVoice","code":"GRegexCompileFlags"},{"type":"text","text":", all the strings passed to "},{"type":"codeVoice","code":"GRegex"},{"type":"text","text":" methods must"},{"type":"text","text":" "},{"text":"be encoded in UTF-8. The lengths and the positions inside the strings are","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"in bytes and not in characters, so, for instance, "},{"type":"codeVoice","code":"\\xc3\\xa0"},{"type":"text","text":" (i.e., "},{"code":"à","type":"codeVoice"},{"type":"text","text":")"},{"text":" ","type":"text"},{"type":"text","text":"is two bytes long but it is treated as a single character. If you set"},{"text":" ","type":"text"},{"code":"G_REGEX_RAW","type":"codeVoice"},{"text":", the strings can be non-valid UTF-8 strings and a byte is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"treated as a character, so "},{"type":"codeVoice","code":"\\xc3\\xa0"},{"text":" is two bytes and two characters long.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Regarding line endings, "},{"type":"codeVoice","code":"\\n"},{"type":"text","text":" matches a "},{"type":"codeVoice","code":"\\n"},{"type":"text","text":" character, and "},{"code":"\\r","type":"codeVoice"},{"type":"text","text":" matches"},{"text":" ","type":"text"},{"text":"a ","type":"text"},{"type":"codeVoice","code":"\\r"},{"type":"text","text":" character. More generally, "},{"type":"codeVoice","code":"\\R"},{"text":" matches all typical line endings:","type":"text"},{"text":" ","type":"text"},{"text":"CR + LF (","type":"text"},{"code":"\\r\\n","type":"codeVoice"},{"type":"text","text":"), LF (linefeed, U+000A, "},{"code":"\\n","type":"codeVoice"},{"type":"text","text":"), VT (vertical tab, U+000B,"},{"type":"text","text":" "},{"code":"\\v","type":"codeVoice"},{"type":"text","text":"), FF (formfeed, U+000C, "},{"type":"codeVoice","code":"\\f"},{"text":"), CR (carriage return, U+000D, ","type":"text"},{"type":"codeVoice","code":"\\r"},{"text":"),","type":"text"},{"text":" ","type":"text"},{"text":"NEL (next line, U+0085), LS (line separator, U+2028), and PS (paragraph","type":"text"},{"type":"text","text":" "},{"type":"text","text":"separator, U+2029)."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The behaviour of the dot, circumflex, and dollar metacharacters are"},{"type":"text","text":" "},{"type":"text","text":"affected by newline characters. By default, "},{"code":"GRegex","type":"codeVoice"},{"type":"text","text":" matches any newline"},{"type":"text","text":" "},{"text":"character matched by ","type":"text"},{"code":"\\R","type":"codeVoice"},{"type":"text","text":". You can limit the matched newline characters by"},{"text":" ","type":"text"},{"type":"text","text":"specifying the [flags"},{"code":"GLib.RegexMatchFlags.NEWLINE_CR","type":"codeVoice"},{"text":"],","type":"text"},{"type":"text","text":" "},{"text":"[flags","type":"text"},{"type":"codeVoice","code":"GLib.RegexMatchFlags.NEWLINE_LF"},{"type":"text","text":"], and"},{"type":"text","text":" "},{"text":"[flags","type":"text"},{"code":"GLib.RegexMatchFlags.NEWLINE_CRLF","type":"codeVoice"},{"text":"] compile options, and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"with [flags"},{"code":"GLib.RegexMatchFlags.NEWLINE_ANY","type":"codeVoice"},{"type":"text","text":"],"},{"text":" ","type":"text"},{"type":"text","text":"[flags"},{"type":"codeVoice","code":"GLib.RegexMatchFlags.NEWLINE_CR"},{"text":"],","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[flags"},{"type":"codeVoice","code":"GLib.RegexMatchFlags.NEWLINE_LF"},{"type":"text","text":"] and"},{"text":" ","type":"text"},{"type":"text","text":"[flags"},{"type":"codeVoice","code":"GLib.RegexMatchFlags.NEWLINE_CRLF"},{"type":"text","text":"] match options."},{"text":" ","type":"text"},{"type":"text","text":"These settings are also relevant when compiling a pattern if"},{"text":" ","type":"text"},{"text":"[flags","type":"text"},{"code":"GLib.RegexCompileFlags.EXTENDED","type":"codeVoice"},{"text":"] is set and an unescaped","type":"text"},{"type":"text","text":" "},{"code":"#","type":"codeVoice"},{"text":" outside a character class is encountered. This indicates a comment","type":"text"},{"type":"text","text":" "},{"text":"that lasts until after the next newline.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Because ","type":"text"},{"type":"codeVoice","code":"GRegex"},{"type":"text","text":" does not modify its internal state between creation and"},{"type":"text","text":" "},{"type":"text","text":"destruction, you can create and modify the same "},{"code":"GRegex","type":"codeVoice"},{"text":" instance from","type":"text"},{"type":"text","text":" "},{"text":"different threads. In contrast, [struct","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo","type":"reference","isActive":true},{"type":"text","text":"] is not thread safe."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The regular expression low-level functionalities are obtained through"},{"text":" ","type":"text"},{"text":"the excellent ","type":"text"},{"identifier":"http:\/\/www.pcre.org\/","type":"reference","isActive":true},{"type":"text","text":" library written by Philip Hazel."}]},{"inlineContent":[{"text":"The ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Regex","isActive":true},{"type":"text","text":" type acts as a reference-counted owner of an underlying "},{"type":"codeVoice","code":"GRegex"},{"text":" instance.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"It provides the methods that can operate on this data type through "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexProtocol","isActive":true,"type":"reference"},{"type":"text","text":" conformance."},{"text":" ","type":"text"},{"type":"text","text":"Use "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Regex","isActive":true,"type":"reference"},{"type":"text","text":" as a strong reference or owner of a "},{"code":"GRegex","type":"codeVoice"},{"text":" instance.","type":"text"}],"type":"paragraph"},{"type":"aside","name":"Note","style":"note","content":[{"inlineContent":[{"type":"text","text":"Use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexRef"},{"type":"text","text":" (instead of "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Regex","isActive":true,"type":"reference"},{"text":") for a lightweight Swift reference to an underlying ","type":"text"},{"type":"codeVoice","code":"GRegex"},{"type":"text","text":" instance."}],"type":"paragraph"}]}]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"kind":"symbol","references":{"doc://GLib/documentation/GLib/Regex/init(opaquePointer:)":{"role":"symbol","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"opaquePointer","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:s13OpaquePointerV","text":"OpaquePointer"},{"text":")","kind":"text"}],"abstract":[{"type":"text","text":"Unsafe untyped initialiser."},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"Do not use unless you know the underlying data type the pointer points to conforms to "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexProtocol"},{"text":".","type":"text"}],"type":"strong"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/Regex\/init(opaquePointer:)","type":"topic","kind":"symbol","url":"\/documentation\/glib\/regex\/init(opaquepointer:)","title":"init(opaquePointer:)"},"doc://GLib/documentation/GLib/Regex/init(gpointer:)":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Regex\/init(gpointer:)","kind":"symbol","url":"\/documentation\/glib\/regex\/init(gpointer:)","type":"topic","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"!("},{"text":"gpointer","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"gpointer","preciseIdentifier":"c:@T@gpointer","kind":"typeIdentifier"},{"kind":"text","text":"?)"}],"role":"symbol","title":"init(gpointer:)","abstract":[{"text":"Optional initialiser from a non-mutating ","type":"text"},{"code":"gpointer","type":"codeVoice"},{"text":" to","type":"text"},{"text":" ","type":"text"},{"text":"the underlying ","type":"text"},{"type":"codeVoice","code":"C"},{"text":" data type.","type":"te
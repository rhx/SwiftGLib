{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"fileSetContentsFull","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"filename"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"contents"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"length"},{"kind":"text","text":": "},{"text":"gssize","preciseIdentifier":"c:@T@gssize","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"FileSetContentsFlags","kind":"typeIdentifier","identifier":"doc:\/\/GLib\/documentation\/GLib\/FileSetContentsFlags","preciseIdentifier":"s:4GLib20FileSetContentsFlagsV"},{"kind":"text","text":", "},{"kind":"externalParam","text":"mode"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":") ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"inlineContent":[{"type":"codeVoice","code":"flags"},{"text":" control the properties of the write operation: whether it’s atomic,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and what the tradeoff is between returning quickly or being resilient to"},{"type":"text","text":" "},{"text":"system crashes.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"As this function performs file I\/O, it is recommended to not call it anywhere","type":"text"},{"type":"text","text":" "},{"type":"text","text":"where blocking would cause problems, such as in the main loop of a graphical"},{"type":"text","text":" "},{"type":"text","text":"application. In particular, if "},{"code":"flags","type":"codeVoice"},{"type":"text","text":" has any value other than"},{"text":" ","type":"text"},{"type":"codeVoice","code":"none"},{"type":"text","text":" then this function may call "},{"type":"codeVoice","code":"fsync()"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"consistent"},{"text":" is set in ","type":"text"},{"code":"flags","type":"codeVoice"},{"text":", the operation is atomic","type":"text"},{"text":" ","type":"text"},{"text":"in the sense that it is first written to a temporary file which is then","type":"text"},{"type":"text","text":" "},{"text":"renamed to the final name.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Notes:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"On UNIX, if "},{"code":"filename","type":"codeVoice"},{"text":" already exists hard links to ","type":"text"},{"type":"codeVoice","code":"filename"},{"type":"text","text":" will break."},{"text":" ","type":"text"},{"text":"Also since the file is recreated, existing permissions, access control","type":"text"},{"type":"text","text":" "},{"text":"lists, metadata etc. may be lost. If ","type":"text"},{"type":"codeVoice","code":"filename"},{"type":"text","text":" is a symbolic link,"},{"type":"text","text":" "},{"text":"the link itself will be replaced, not the linked file.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"On UNIX, if "},{"type":"codeVoice","code":"filename"},{"type":"text","text":" already exists and is non-empty, and if the system"},{"type":"text","text":" "},{"type":"text","text":"supports it (via a journalling filesystem or equivalent), and if"},{"type":"text","text":" "},{"type":"codeVoice","code":"consistent"},{"text":" is set in ","type":"text"},{"type":"codeVoice","code":"flags"},{"text":", the ","type":"text"},{"type":"codeVoice","code":"fsync()"},{"type":"text","text":" call (or"},{"type":"text","text":" "},{"text":"equivalent) will be used to ensure atomic replacement: ","type":"text"},{"code":"filename","type":"codeVoice"},{"type":"text","text":" "},{"text":"will contain either its old contents or ","type":"text"},{"type":"codeVoice","code":"contents"},{"text":", even in the face of","type":"text"},{"type":"text","text":" "},{"text":"system power loss, the disk being unsafely removed, etc.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"On UNIX, if "},{"code":"filename","type":"codeVoice"},{"type":"text","text":" does not already exist or is empty, there is a"},{"type":"text","text":" "},{"text":"possibility that system power loss etc. after calling this function will","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"leave "},{"type":"codeVoice","code":"filename"},{"type":"text","text":" empty or full of NUL bytes, depending on the underlying"},{"text":" ","type":"text"},{"text":"filesystem, unless ","type":"text"},{"type":"codeVoice","code":"durable"},{"text":" and","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"consistent"},{"text":" are set in ","type":"text"},{"code":"flags","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"On Windows renaming a file will not remove an existing file with the","type":"text"},{"type":"text","text":" "},{"text":"new name, so on Windows there is a race condition between the existing","type":"text"},{"type":"text","text":" "},{"type":"text","text":"file being removed and the temporary file being renamed."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"On Windows there is no way to remove a file that is open to some"},{"type":"text","text":" "},{"text":"process, or mapped into memory. Thus, this function will fail if","type":"text"},{"type":"text","text":" "},{"code":"filename","type":"codeVoice"},{"text":" already exists and is open.","type":"text"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"If the call was successful, it returns ","type":"text"},{"type":"codeVoice","code":"true"},{"type":"text","text":". If the call was not successful,"},{"type":"text","text":" "},{"type":"text","text":"it returns "},{"type":"codeVoice","code":"false"},{"type":"text","text":" and sets "},{"type":"codeVoice","code":"error"},{"type":"text","text":". The error domain is "},{"type":"codeVoice","code":"G_FILE_ERROR"},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"Possible error codes are those in the ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/FileError","isActive":true,"type":"reference"},{"type":"text","text":" enumeration."}]},{"inlineContent":[{"text":"Note that the name for the temporary file is constructed by appending up","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to 7 characters to "},{"type":"codeVoice","code":"filename"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If the file didn’t exist before and is created, it will be given the"},{"type":"text","text":" "},{"type":"text","text":"permissions from "},{"type":"codeVoice","code":"mode"},{"type":"text","text":". Otherwise, the permissions of the existing file will"},{"type":"text","text":" "},{"text":"remain unchanged.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"kind":"symbol","metadata":{"modules":[{"name":"GLib"}],"role":"symbol","title":"fileSetContentsFull(filename:contents:length:flags:mode:)","symbolKind":"func","roleHeading":"Function","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"fileSetContentsFull"},{"kind":"text","text":"("},{"kind":"externalParam","text":"filename"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"contents"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"text":"gchar","preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"text":"length","kind":"externalParam"},{"kind":"text","text":": "},{"text":"gssize","preciseIdentifier":"c:@T@gssize","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"FileSetContentsFlags","preciseIdentifier":"s:4GLib20FileSetContentsFlagsV","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"mode","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"kind":"text","text":") "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"externalID":"s:4GLib19fileSetContentsFull8filename8contents6length5flags4modeSbSPys4Int8VGSg_AKSiAA04FilecD5FlagsVSitKF"},"abstract":[{"text":"Writes all of ","type":"text"},{"type":"codeVoice","code":"contents"},{"text":" to a file named ","type":"text"},{"code":"filename","type":"codeVoice"},{"text":", with good error checking.","type":"text"},{"text":" ","type":"text"},{"text":"If a file called ","type":"text"},{"type":"codeVoice","code":"filename"},{"type":"text","text":" already exists it will be overwritten."}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/fileSetContentsFull(filename:contents:length:flags:mode:)","interfaceLanguage":"swift"},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/filesetcontentsfull(filename:contents:length:flags:mode:)"]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"references":{"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"doc://GLib/documentation/GLib/FileSetContentsFlags":{"title":"FileSetContentsFlags","url":"\/documentation\/glib\/filesetcontentsflags","kind":"symbol","role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/FileSetContentsFlags","type":"topic","navigatorTitle":[{"text":"FileSetContentsFlags","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"FileSetContentsFlags","kind":"identifier"}],"abstract":[{"text":"Flags to pass to ","type":"text"},{"code":"g_file_set_contents_full()","type":"codeVoice"},{"type":"text","text":" to affect its safety and"},{"text":" ","type":"text"},{"type":"text","text":"performance."}]},"doc://GLib/documentation/GLib/FileError":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/FileError","type":"topic","url":"\/documentation\/glib\/fileerror","fragments":[{"kind":"keyword","text":"typealias"},{"text":" ","kind":"text"},{"kind":"identifier","text":"FileError"}],"abstract":[{"type":"text","text":"Values corresponding to "},{"type":"codeVoice","code":"errno"},{"text":" codes returned from file operations","type":"text"},{"type":"text","text":" "},{"type":"text","text":"on UNIX. Unlike "},{"type":"codeVoice","code":"errno"},{"text":" codes, GFileError values are available on","type":"text"},{"type":"text","text":" "},{"text":"all systems, even Windows. The exact meaning of each code depends","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"on what sort of file operation you were performing; the UNIX"},{"text":" ","type":"text"},{"text":"documentation gives more details. The following error code descriptions","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"come from the GNU C Library manual, and are under the copyright"},{"type":"text","text":" "},{"text":"of that manual.","type":"text"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"FileError"}],"title":"FileError","kind":"symbol"},"doc://GLib/documentation/GLib/fileSetContentsFull(filename:contents:length:flags:mode:)":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/fileSetContentsFull(filename:contents:length:flags:mode:)","kind":"symbol","type":"topic","url":"\/documentation\/glib\/filesetcontentsfull(filename:contents:length:flags:mode:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"fileSetContentsFull","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"filename"},{"text":": ","kind":"text"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">!, ","kind":"text"},{"text":"contents","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"length"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gssize","text":"gssize"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"FileSetContentsFlags","preciseIdentifier":"s:4GLib20FileSetContentsFlagsV"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"mode"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"role":"symbol","title":"fileSetContentsFull(filename:contents:length:flags:mode:)","abstract":[{"type":"text","text":"Writes all of "},{"type":"codeVoice","code":"contents"},{"text":" to a file named ","type":"text"},{"code":"filename","type":"codeVoice"},{"text":", with good error checking.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"If a file called "},{"type":"codeVoice","code":"filename"},{"text":" already exists it will be overwritten.","type":"text"}]}}}
{"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"sourceSetNameByID"},{"kind":"text","text":"("},{"text":"tag","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"name","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"text":"CChar","preciseIdentifier":"s:s5CChara","kind":"typeIdentifier"},{"kind":"text","text":">!)"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is a convenience utility to set source names from the return"},{"type":"text","text":" "},{"text":"value of [func","type":"text"},{"type":"codeVoice","code":"GLib.idle_add"},{"text":"], [func","type":"text"},{"type":"codeVoice","code":"GLib.timeout_add"},{"type":"text","text":"], etc."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is a programmer error to attempt to set the name of a non-existent"},{"type":"text","text":" "},{"text":"source.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"More specifically: source IDs can be reissued after a source has been","type":"text"},{"type":"text","text":" "},{"text":"destroyed and therefore it is never valid to use this function with a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"source ID which may have already been removed.  An example is when"},{"text":" ","type":"text"},{"text":"scheduling an idle to run in another thread with [func","type":"text"},{"type":"codeVoice","code":"GLib.idle_add"},{"text":"]: the","type":"text"},{"type":"text","text":" "},{"text":"idle may already have run and been removed by the time this function","type":"text"},{"text":" ","type":"text"},{"text":"is called on its (now invalid) source ID.  This source ID may have","type":"text"},{"text":" ","type":"text"},{"text":"been reissued, leading to the operation being performed against the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"wrong source."}]}],"kind":"content"}],"abstract":[{"type":"text","text":"Sets the name of a source using its ID."}],"variants":[{"paths":["\/documentation\/glib\/sourcesetnamebyid(tag:name:)"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/sourceSetNameByID(tag:name:)","interfaceLanguage":"swift"},"metadata":{"roleHeading":"Function","symbolKind":"func","externalID":"s:4GLib17sourceSetNameByID3tag4nameySi_SPys4Int8VGSgtF","modules":[{"name":"GLib"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sourceSetNameByID","kind":"identifier"},{"text":"(","kind":"text"},{"text":"tag","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":", "},{"text":"name","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"preciseIdentifier":"s:s5CChara","text":"CChar","kind":"typeIdentifier"},{"text":">!)","kind":"text"}],"role":"symbol","title":"sourceSetNameByID(tag:name:)"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"references":{"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"doc://GLib/documentation/GLib/sourceSetNameByID(tag:name:)":{"type":"topic","abstract":[{"type":"text","text":"Sets the name of a source using its ID."}],"url":"\/documentation\/glib\/sourcesetnamebyid(tag:name:)","
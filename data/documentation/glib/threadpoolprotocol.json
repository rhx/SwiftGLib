{"sections":[],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ThreadPoolProtocol"},{"kind":"text","text":" : "},{"text":"PointerWrapper","identifier":"doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","kind":"typeIdentifier","preciseIdentifier":"s:4GLib14PointerWrapperP"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"overview"},{"inlineContent":[{"type":"text","text":"A thread pool is useful when you wish to asynchronously fork out the execution of work"},{"text":" ","type":"text"},{"type":"text","text":"and continue working in your own thread. If that will happen often, the overhead of starting"},{"type":"text","text":" "},{"type":"text","text":"and destroying a thread each time might be too high. In such cases reusing already started"},{"type":"text","text":" "},{"text":"threads seems like a good idea. And it indeed is, but implementing this can be tedious","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and error-prone."}],"type":"paragraph"},{"inlineContent":[{"text":"Therefore GLib provides thread pools for your convenience. An added advantage is, that the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"threads can be shared between the different subsystems of your program, when they are using GLib."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To create a new thread pool, you use [func"},{"code":"GLib.ThreadPool.new","type":"codeVoice"},{"text":"].","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"It is destroyed by [method"},{"type":"codeVoice","code":"GLib.ThreadPool.free"},{"type":"text","text":"]."}]},{"inlineContent":[{"text":"If you want to execute a certain task within a thread pool, use [method","type":"text"},{"type":"codeVoice","code":"GLib.ThreadPool.push"},{"text":"].","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"To get the current number of running threads you call [method","type":"text"},{"type":"codeVoice","code":"GLib.ThreadPool.get_num_threads"},{"type":"text","text":"]."},{"type":"text","text":" "},{"type":"text","text":"To get the number of still unprocessed tasks you call [method"},{"code":"GLib.ThreadPool.unprocessed","type":"codeVoice"},{"type":"text","text":"]."},{"text":" ","type":"text"},{"type":"text","text":"To control the maximum number of threads for a thread pool, you use"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.ThreadPool.get_max_threads"},{"text":"]. and [method","type":"text"},{"code":"GLib.ThreadPool.set_max_threads","type":"codeVoice"},{"text":"].","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Finally you can control the number of unused threads, that are kept alive by GLib for future use."},{"type":"text","text":" "},{"type":"text","text":"The current number can be fetched with [func"},{"type":"codeVoice","code":"GLib.ThreadPool.get_num_unused_threads"},{"text":"].","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"The maximum number can be controlled by [func"},{"type":"codeVoice","code":"GLib.ThreadPool.get_max_unused_threads"},{"type":"text","text":"] and"},{"type":"text","text":" "},{"type":"text","text":"[func"},{"code":"GLib.ThreadPool.set_max_unused_threads","type":"codeVoice"},{"type":"text","text":"]. All currently unused threads"},{"text":" ","type":"text"},{"text":"can be stopped by calling [func","type":"text"},{"code":"GLib.ThreadPool.stop_unused_threads","type":"codeVoice"},{"text":"].","type":"text"}]},{"inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol"},{"type":"text","text":" protocol exposes the methods and properties of an underlying "},{"code":"GThreadPool","type":"codeVoice"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"type":"text","text":"The default implementation of these can be found in the protocol extension below."},{"text":" ","type":"text"},{"type":"text","text":"For a concrete class that implements these methods and properties, see "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/ThreadPool","type":"reference","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"Alternatively, use ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef","isActive":true,"type":"reference"},{"text":" as a lighweight, ","type":"text"},{"type":"codeVoice","code":"unowned"},{"type":"text","text":" reference if you already have an instance you just want to use."}],"type":"paragraph"}],"kind":"content"}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/threadpoolprotocol"]}],"abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"GThreadPool"},{"text":" struct represents a thread pool.","type":"text"}],"relationshipsSections":[{"kind":"relationships","title":"Inherits From","type":"inheritsFrom","identifiers":["doc:\/\/GLib\/documentation\/GLib\/PointerWrapper"]},{"type":"conformingTypes","identifiers":["doc:\/\/GLib\/documentation\/GLib\/ThreadPool","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolRef"],"kind":"relationships","title":"Conforming Types"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"navigatorTitle":[{"text":"ThreadPoolProtocol","kind":"identifier"}],"modules":[{"name":"GLib"}],"roleHeading":"Protocol","role":"symbol","title":"ThreadPoolProtocol","externalID":"s:4GLib18ThreadPoolProtocolP","symbolKind":"protocol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"text":"ThreadPoolProtocol","kind":"identifier"}]},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"topicSections":[{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/exclusive","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/func","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/maxThreads","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/numThreads","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/userData"],"anchor":"Instance-Properties","title":"Instance Properties","generated":true},{"title":"Instance Methods","generated":true,"identifiers":["doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/free(immediate:wait:)","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/getMaxThreads()","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/getNumThreads()","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/moveToFront(data:)","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/push(data:)","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/set(maxThreads:)","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/setSortFunction(func:userData:)","doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/unprocessed()"],"anchor":"Instance-Methods"}],"references":{"doc://GLib/documentation/GLib/PointerWrapper":{"fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"PointerWrapper"}],"kind":"symbol","abstract":[{"text":"Protocol for GLib types that wrap pointers.","type":"text"}],"title":"PointerWrapper","url":"\/documentation\/glib\/pointerwrapper","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"PointerWrapper"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","type":"topic"},"doc://GLib/documentation/GLib/ThreadPoolProtocol/userData":{"url":"\/documentation\/glib\/threadpoolprotocol\/userdata","identifier":"doc:\/\/GLib\/documentation\/GLib\/ThreadPoolProtocol\/userData","kind":"symbol","title":"userData","abstract":[{"type":"text","text":"the user data for the threads 
{"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/TimeVal\/toIso8601()","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"toIso8601","kind":"identifier"},{"kind":"text","text":"() -> "},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"kind":"text","text":"!"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"ISO 8601 allows a large number of date\/time formats, with or without"},{"text":" ","type":"text"},{"type":"text","text":"punctuation and optional elements. The format returned by this function"},{"type":"text","text":" "},{"type":"text","text":"is a complete date and time, with optional punctuation included, the"},{"type":"text","text":" "},{"text":"UTC time zone represented as “Z”, and the ","type":"text"},{"type":"codeVoice","code":"tv_usec"},{"type":"text","text":" part included if"},{"text":" ","type":"text"},{"type":"text","text":"and only if it is nonzero, i.e. either"},{"type":"text","text":" "},{"text":"“YYYY-MM-DDTHH:MM:SSZ” or “YYYY-MM-DDTHH:MM:SS.fffffZ”.","type":"text"}]},{"inlineContent":[{"text":"This corresponds to the Internet date\/time format defined by","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/www.ietf.org\/rfc\/rfc3339.txt"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"and to either of the two most-precise formats defined by","type":"text"},{"type":"text","text":" "},{"text":"the W3C Note","type":"text"},{"text":" ","type":"text"},{"identifier":"http:\/\/www.w3.org\/TR\/NOTE-datetime-19980827","type":"reference","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Both of these documents are profiles of ISO 8601."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":"g_date_time_format()"},{"type":"text","text":" or "},{"type":"codeVoice","code":"g_strdup_printf()"},{"text":" if a different","type":"text"},{"type":"text","text":" "},{"text":"variation of ISO 8601 format is required.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"time"},{"text":" represents a date which is too large to fit into a ","type":"text"},{"type":"codeVoice","code":"struct tm"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" will be returned. This is platform dependent. Note also that since"},{"type":"text","text":" "},{"code":"GTimeVal","type":"codeVoice"},{"text":" stores the number of seconds as a ","type":"text"},{"type":"codeVoice","code":"glong"},{"text":", on 32-bit systems it","type":"text"},{"type":"text","text":" "},{"text":"is subject to the year 2038 problem. Accordingly, since GLib 2.62, this","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"function has been deprecated. Equivalent functionality is available using:"}],"type":"paragraph"},{"type":"codeListing","syntax":null,"code":["GDateTime *dt = g_date_time_new_from_unix_utc (time_val);","iso8601_string = g_date_time_format_iso8601 (dt);","g_date_time_unref (dt);"]},{"type":"paragraph","inlineContent":[{"text":"The return value of ","type":"text"},{"type":"codeVoice","code":"g_time_val_to_iso8601()"},{"type":"text","text":" has been nullable since GLib"},{"text":" ","type":"text"},{"text":"2.54; before then, GLib would crash under the same conditions.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"to_iso8601 is deprecated:","type":"text"}]},{"type":"text","text":" "},{"text":"#GTimeVal is not year-2038-safe. Use","type":"text"},{"text":" ","type":"text"},{"text":"g_date_time_format_iso8601(dt) instead.","type":"text"}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/timeval\/toiso8601()"]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/TimeVal","doc:\/\/GLib\/documentation\/GLib\/TimeVal\/TimeValProtocol-Implementations"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","metadata":{"externalID":"s:4GLib15TimeValProtocolPAAE9toIso8601SSSgyF::SYNTHESIZED::s:4GLib7TimeValC","roleHeading":"Instance Method","title":"toIso8601()","symbolKind":"method","modules":[{"name":"GLib"}],"platforms":[],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"toIso8601","kind":"identifier"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"role":"symbol","extendedModule":"GLib"},"abstract":[{"text":"Converts ","type":"text"},{"type":"codeVoice","code":"time"},{"text":" into an RFC 3339 encoded string, relative to the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Coordinated Universal Time (UTC). This is one of the many formats"},{"type":"text","text":" "},{"text":"allowed by ISO 8601.","type":"text"}],"references":{"https://www.ietf.org/rfc/rfc3339.txt":{"type":"link","identifier":"https:\/\/www.ietf.org\/rfc\/rfc3339.txt","title":"RFC 3339","url":"https:\/\/www.ietf.org\/rfc\/rfc3339.txt","titleInlineContent":[{"type":"text","text":"RFC 3339"}]},"http://www.w3.org/TR/NOTE-datetime-19980827":{"type":"link","identifier":"http:\/\/www.w3.org\/TR\/NOTE-datetime-19980827","title":"Date and Time Formats","url":"http:\/\/www.w3.org\/TR\/NOTE-datetime-19980827","titleInlineContent":[{"type":"text","text":"Date and Time Formats"}]},"doc://GLib/documentation/GLib/TimeVal/toIso8601()":{"url":"\/documentation\/glib\/timeval\/toiso8601()","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"toIso8601","kind":"identifier"},
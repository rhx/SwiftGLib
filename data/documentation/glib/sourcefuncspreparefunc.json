{"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"title":"SourceFuncsPrepareFunc","symbolKind":"typealias","modules":[{"name":"GLib"}],"roleHeading":"Type Alias","fragments":[{"text":"typealias","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"SourceFuncsPrepareFunc"}],"role":"symbol","externalID":"s:4GLib22SourceFuncsPrepareFunca","navigatorTitle":[{"text":"SourceFuncsPrepareFunc","kind":"identifier"}]},"abstract":[{"text":"Checks the source for readiness.","type":"text"}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"kind":"identifier","text":"SourceFuncsPrepareFunc"},{"text":" = ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GSourceFuncsPrepareFunc","text":"GSourceFuncsPrepareFunc"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"inlineContent":[{"text":"Called before all the file descriptors are polled. If the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"source can determine that it is ready here (without waiting for the"},{"text":" ","type":"text"},{"type":"text","text":"results of the poll call) it should return "},{"code":"true","type":"codeVoice"},{"text":". It can also return","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"a "},{"code":"timeout","type":"codeVoice"},{"type":"text","text":" value which should be the maximum timeout (in milliseconds)"},{"type":"text","text":" "},{"type":"text","text":"which should be passed to the poll call. The actual timeout used will"},{"text":" ","type":"text"},{"type":"text","text":"be "},{"type":"codeVoice","code":"-1"},{"text":" if all sources returned ","type":"text"},{"code":"-1","type":"codeVoice"},{"type":"text","text":", or it will be the minimum of all"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"type":"codeVoice","code":"timeout"},{"type":"text","text":" values returned which were greater than or equal to "},{"type":"codeVoice","code":"0"},{"text":".","type":"text"},{"type":"text","text":" "},{"text":"If the prepare function returns a timeout and the source also has a","type":"text"},{"type":"text","text":" "},{"text":"ready time set, then the lower of the two will be used.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Since 2.36 this may be "},{"code":"NULL","type":"codeVoice"},{"type":"text","text":", in which case the effect is as if the"},{"type":"text","text":" "},{"type":"text","text":"function always returns "},{"code":"FALSE","type":"codeVoice"},{"type":"text","text":" with a timeout of "},{"type":"codeVoice","code":"-1"},{"type":"text","text":"."}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"sections":[],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsPrepareFunc","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/glib\/sourcefuncspreparefunc"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://GLib/documentation/GLib/SourceFuncsPrepareFunc":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsPrepareFunc","kind":"symbol","navigatorTitle":[{"text":"SourceFuncsPrepareFunc","kind":"identifier"}],"type":"topic","url":"\/documentation\/glib\/sourcefuncspreparefunc","fragments":[{"text":"typealias","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"SourceFuncsPrepareFunc"}],"role":"symbol","title":"SourceFuncsPrepareFunc","abstract":[{"text":"Checks the source for readiness.","type":"text"}]},"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]}}}
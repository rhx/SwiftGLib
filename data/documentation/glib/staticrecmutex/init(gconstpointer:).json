mentation\/GLib\/StaticRecMutex"},{"text":" has","type":"text"},{"text":" ","type":"text"},{"text":"been deprecated in favor of ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/RecMutex","type":"reference","isActive":true},{"type":"text","text":"."}],"role":"symbol","navigatorTitle":[{"text":"StaticRecMutex","kind":"identifier"}],"title":"StaticRecMutex"},"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"doc://GLib/documentation/GLib/StaticRecMutex/init(gconstpointer:)":{"role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex\/init(gconstpointer:)","kind":"symbol","abstract":[{"text":"Optional initialiser from a non-mutating ","type":"text"},{"code":"gconstpointer","type":"codeVoice"},{"text":" to","type":"text"},{"type":"text","text":" "},{"text":"the underlying ","type":"text"},{"code":"C","type":"codeVoice"},{"text":" data type.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"This creates an instance without performing an unbalanced retain"},{"type":"text","text":" "},{"type":"text","text":"i.e., ownership is transferred to the "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex","isActive":true},{"text":" instance.","type":"text"}],"type":"topic","title":"init(gconstpointer:)","url":"\/documentation\/glib\/staticrecmutex\/init(gconstpointer:)","fragments":[{"text":"init","kind":"identifier"},{"kind":"text","text":"!("},{"kind":"externalParam","text":"gconstpointer"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@gconstpointer","kind":"typeIdentifier","text":"gconstpointer"},{"text":"?)","kind":"text"}]},"doc://GLib/documentation/GLib/RecMutex":{"url":"\/documentation\/glib\/recmutex","abstract":[{"type":"text","text":"The GRecMutex struct is an opaque data structure to represent a"},{"text":" ","type":"text"},{"type":"t
{"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","abstract":[{"type":"text","text":"Tries to lock "},{"type":"codeVoice","code":"mutex"},{"type":"text","text":". If "},{"code":"mutex","type":"codeVoice"},{"text":" is already locked by another thread,","type":"text"},{"type":"text","text":" "},{"text":"it immediately returns ","type":"text"},{"type":"codeVoice","code":"false"},{"type":"text","text":". Otherwise it locks "},{"code":"mutex","type":"codeVoice"},{"text":" and returns","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"true"},{"type":"text","text":". If "},{"code":"mutex","type":"codeVoice"},{"text":" is already locked by the calling thread, this","type":"text"},{"text":" ","type":"text"},{"text":"functions increases the depth of ","type":"text"},{"type":"codeVoice","code":"mutex"},{"text":" and immediately returns","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"true"},{"type":"text","text":"."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"trylock","kind":"identifier"},{"kind":"text","text":"() -> "},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Trylock is deprecated:","type":"text"}]},{"text":" ","type":"text"},{"type":"text","text":"Use g_rec_mutex_trylock()"}],"type":"paragraph"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex\/trylock()"},"metadata":{"role":"symbol","roleHeading":"Instance Method","modules":[{"name":"GLib"}],"title":"trylock()","symbolKind":"method","externalID":"s:4GLib22StaticRecMutexProtocolPAAE7trylockSbyF::SYNTHESIZED::s:4GLib14StaticRecMutexC","extendedModule":"GLib","platforms":[
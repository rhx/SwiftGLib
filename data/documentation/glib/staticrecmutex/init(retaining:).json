{"sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"role":"symbol","roleHeading":"Initializer","symbolKind":"init","modules":[{"name":"GLib"}],"title":"init(retaining:)","externalID":"s:4GLib14StaticRecMutexC9retainingACSpySo08_GStaticcD0VG_tcfc","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"retaining","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"kind":"text","text":"<"},{"text":"GStaticRecMutex","kind":"typeIdentifier"},{"text":">)","kind":"text"}]},"abstract":[{"type":"text","text":"Designated initialiser from the underlying "},{"code":"C","type":"codeVoice"},{"text":" data type.","type":"text"},{"type":"text","text":" "},{"code":"GStaticRecMutex","type":"codeVoice"},{"type":"text","text":" does not allow reference counting, so despite the name no actual retaining will occur."},{"text":" ","type":"text"},{"text":"i.e., ownership is transferred to the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex"},{"text":" instance.","type":"text"}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"init"},{"kind":"text","text":"("},{"text":"retaining","kind":"externalParam"},{"kind":"text","text":" "},{"text":"op","kind":"internalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"GStaticRecMutex","kind":"typeIdentifier"},{"text":">)","kind":"text"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"text":"Pointer to the underlying object","type":"text"}],"type":"paragraph"}],"name":"op"}]}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex\/init(retaining:)","interfaceLanguage":"swift"},"kind":"symbol","variants":[{"paths":["\/documentation\/glib\/staticrecmutex\/init(retaining:)"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://GLib/documentation/GLib/StaticRecMutex/init(retaining:)":{"type":"topic","kind":"symbol","url":"\/documentation\/glib\/staticrecmutex\/init(retaining:)","role":"symbol","title":"init(retaining:)","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex\/init(retaining:)","abstract":[{"type":"text","text":"Designated initialiser from the underlying "},{"type":"codeVoice","code":"C"},{"text":" data type.","type":"text"},{"type":"text","text":" "},{"code":"GStaticRecMutex","type":"codeVoice"},{"text":" does not allow reference counting, so despite the name no actual retaining will occur.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"i.e., ownership is transferred to the "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex","type":"reference"},{"type":"text","text":" instance."}],"fragments":[{"text":"init","kind":"identifier"},{"kind":"text","text":"("},{"text":"retaining","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"GStaticRecMutex","kind":"typeIdentifier"},{"kind":"text","text":">)"}]},"doc://GLib/documentation/GLib/StaticMutex":{"url":"\/documentation\/glib\/staticmutex","abstract":[{"type":"text","text":"A "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex"},{"type":"text","text":" works like a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex"},{"text":".","type":"text"}],"title":"StaticMutex","type":"topic","navigatorTitle":[{"text":"StaticMutex","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"StaticMutex"}],"role":"symbol","kind":"symbol"},"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"doc://GLib/documentation/GLib/RecMutex":{"url":"\/documentation\/glib\/recmutex","abstract":[{"type":"text","text":"The GRecMutex struct is an opaque data structure to represent a"},{"text":" ","type":"text"},{"type":"text","text":"recursive mutex. It is similar to a "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","type":"reference","isActive":true},{"type":"text","text":" with the difference"},{"text":" ","type":"text"},{"text":"that it is possible to lock a GRecMutex multiple times in the same","type":"text"},{"type":"text","text":" "},{"type":"text","text":"thread without deadlock. When doing so, care has to be taken to"},{"type":"text","text":" "},{"type":"text","text":"unlock the recursive mutex as often as it has been locked."}],"title":"RecMutex","type":"topic","navigatorTitle":[{"text":"RecMutex","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/RecMutex","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"RecMutex","kind":"identifier"}],"role":"symbol","kind":"symbol"},"doc://GLib/documentation/GLib/StaticRecMutex":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex","type":"topic","kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"StaticRecMutex","kind":"identifier"}],"url":"\/documentation\/glib\/staticrecmutex","abstract":[{"type":"text","text":"A "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex","isActive":true,"type":"reference"},{"text":" works like a ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex","isActive":true},{"type":"text","text":", but it can be locked"},{"type":"text","text":" "},{"type":"text","text":"multiple times by one thread. If you enter it n times, you have to"},{"type":"text","text":" "},{"text":"unlock it n times again to let other threads lock it. An exception","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is the function "},{"code":"g_static_rec_mutex_unlock_full()","type":"codeVoice"},{"type":"text","text":": that allows you to"},{"text":" ","type":"text"},{"type":"text","text":"unlock a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex"},{"type":"text","text":" completely returning the depth, (i.e. the"},{"type":"text","text":" "},{"text":"number of times this mutex was locked). The depth can later be used","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to restore the state of the "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex","type":"reference","isActive":true},{"type":"text","text":" by calling"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_static_rec_mutex_lock_full()"},{"type":"text","text":". In GLib 2.32, "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex"},{"text":" has","type":"text"},{"text":" ","type":"text"},{"text":"been deprecated in favor of ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/RecMutex","type":"reference","isActive":true},{"type":"text","text":"."}],"role":"symbol","navigatorTitle":[{"text":"StaticRecMutex","kind":"identifier"}],"title":"StaticRecMutex"}}}
e":"collectionGroup","title":"StaticRecMutexProtocol Implementations","type":"topic","kind":"article","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex\/StaticRecMutexProtocol-Implementations","abstract":[],"url":"\/documentation\/glib\/staticrecmutex\/staticrecmutexprotocol-implementations"},"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"doc://GLib/documentation/GLib/StaticRecMutex":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex","type":"topic","kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"StaticRecMutex","kind":"identifier"}],"url":"\/documentation\/glib\/staticrecmutex","abstract":[{"type":"text","text":"A "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex","isActive":true,"type":"reference"},{"text":" works like a ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex","isActive":true},{"type":"text","text":", but it can be locked"},{"type":"text","text":" "},{"type":"text","text":"multiple times by one thread. If you enter it n times, you have to"},{"type":"text","text":" "},{"text":"unlock it n times again to let other threads lock it. An exception","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is the function "},{"code":"g_static_rec_mutex_unlock_full()","type":"codeVoice"},{"type":"text","text":": that allows you to"},{"text":" ","type":"text"},{"type":"text","text":"unlock a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex"},{"type":"text","text":" completely returning the depth, (i.e. the"},{"type":"text","text":" "},{"text":"number of times this mutex was locked). The depth can later be used","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to restore the state of the "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex","type":"reference","isActive":true},{"type":"text","text":" by calling"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_static_rec_mutex_lock_full()"},{"type":"text","text":". In GLib 2.32, "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex"},{"text":" has","type":"text"},{"text":" ","type":"text"},{"text":"been deprecated in favor of ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/RecMutex","type":"reference","isActive":true},{"type":"text","text":"."}],"role":"symbol","navigatorTitle":[{"text":"StaticRecMutex","kind":"identifier"}],"title":"StaticRecMutex"},"doc://GLib/documentation/GLib/StaticRecMutex/init_()":{"url":"\/documentation\/glib\/staticrecmutex\/init_()","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"init_","kind":"identifier"},{"text":"()","kind":"text"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex\/init_()","abstract":[{"type":"text","text":"A "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex","isActive":true,"type":"reference"},{"type":"text","text":" must be initialized with this function before it"},{"text":" ","type":"text"},{"type":"text","text":"can be used. Alternatively you can initialize it with"},{"type":"text","text":" "},{"code":"G_STATIC_REC_MUTEX_INIT","type":"codeVoice"},{"text":".","type":"text"}],"title":"init_()","type":"topic","deprecated":true,"kind":"symbol","role":"symbol"},"doc://GLib/documentation/GLib/RecMutex":{"url":"\/documentation\/glib\/recmutex","abstract":[{"type":"text","text":"The GRecMutex struct is an opaque data structure to represent a"},{"text":" ","type":"text"},{"type":"text","text":"recursive mutex. It is similar to a "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","type":"reference","isActive":true},{"type":"text","text":" with the difference"},{"text":" ","type":"text"},{"text":"that it is possible to lock a GRecMutex multiple times in the same","type":"text"},{"type":"text","text":" "},{"type":"text","text":"thread without deadlock. When doing so, care has to be taken to"},{"type":"text","text":" "},{"type":"text","text":"unlock the recursive mutex as often as it has been locked."}],"title":"RecMutex","type":"topic","navigatorTitle":[{"text":"RecMutex","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/RecMutex","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"RecMutex","kind":"identifier"}],"role":"symbol","kind":"symbol"},"doc://GLib/documentation/GLib/StaticMutex":{"url":"\/documentation\/glib\/staticmutex","abstract":[{"type":"text","text":"A "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex"},{"type":"text","text":" works like a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex"},{"text":".","type":"text"}],"title":"StaticMutex","type":"topic","navigatorTitle":[{"text":"StaticMutex","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"StaticMutex"}],"role":"symbol","kind":"symbol"}}}
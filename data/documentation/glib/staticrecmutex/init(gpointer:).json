{"kind":"symbol","metadata":{"modules":[{"name":"GLib"}],"roleHeading":"Initializer","role":"symbol","title":"init(gpointer:)","externalID":"s:4GLib14StaticRecMutexC8gpointerACSgSvSg_tcfc","symbolKind":"init","fragments":[{"text":"init","kind":"identifier"},{"text":"!(","kind":"text"},{"text":"gpointer","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"c:@T@gpointer","text":"gpointer","kind":"typeIdentifier"},{"text":"?)","kind":"text"}]},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex"]]},"variants":[{"paths":["\/documentation\/glib\/staticrecmutex\/init(gpointer:)"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"text":"Optional initialiser from a non-mutating ","type":"text"},{"code":"gpointer","type":"codeVoice"},{"type":"text","text":" to"},{"type":"text","text":" "},{"text":"the underlying ","type":"text"},{"code":"C","type":"codeVoice"},{"text":" data type.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"This creates an instance without performing an unbalanced retain"},{"type":"text","text":" "},{"text":"i.e., ownership is transferred to the ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRecMutex","isActive":true},{"type":"text","text":" instance."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"init"},{"text":"!(","kind":"text"},{"kind":"externalParam","text":"gpointer"},{"text":" ","kind":"text"},{"kind":"internalParam","text":"op"},{"kind":"text","text":": "},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:@T@gpointer"},{"kind":"text","text":"?)"}]}]},{"parameters":[{"name":"op","content":[{"type":"paragraph","inlineContent":[{"text":"Gpointer to the underlying object","type":"text"}]}]}],"kind":"parameters"}],"sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":
utex","type":"reference","isActive":true},{"type":"text","text":" with the difference"},{"text":" ","type":"text"},{"text":"that it is possible to lock a GRecMutex multiple times in the same","type":"text"},{"type":"text","text":" "},{"type":"text","text":"thread without deadlock. When doing so, care has to be taken to"},{"type":"text","text":" "},{"type":"text","text":"unlock the recursive mutex as often as it has been locked."}],"title":"RecMutex","type":"topic","navigatorTitle":[{"text":"RecMutex","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/RecMutex","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"RecMutex","kind":"identifier"}],"role":"symbol","kind":"symbol"}}}
{"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/VariantProtocol"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/VariantProtocol\/normalForm"},"kind":"symbol","abstract":[{"text":"Gets a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","type":"reference"},{"type":"text","text":" instance that has the same value as "},{"code":"value","type":"codeVoice"},{"type":"text","text":" and is"},{"text":" ","type":"text"},{"type":"text","text":"trusted to be in normal form."}],"metadata":{"modules":[{"name":"GLib"}],"roleHeading":"Instance Property","extendedModule":"GLib","title":"normalForm","role":"symbol","externalID":"s:4GLib15VariantProtocolPAAE10normalFormAA0B3RefVSgvp","symbolKind":"property","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"normalForm"},{"kind":"text","text":": "},{"text":"VariantRef","kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV"},{"text":"!","kind":"text"}]},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"normalForm"},{"text":": ","kind":"text"},{"text":"VariantRef","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef","kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV"},{"text":"! { ","kind":"text"},{"kind":"keyword","text":"get"},{"kind":"text","text":" }"}]}]},{"content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"value"},{"type":"text","text":" is already trusted to be in normal form then a new"},{"type":"text","text":" "},{"type":"text","text":"reference to "},{"code":"value","type":"codeVoice"},{"text":" is returned.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"value"},{"text":" is not already trusted, then it is scanned to check if it","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is in normal form.  If it is found to be in normal form then it is"},{"text":" ","type":"text"},{"text":"marked as trusted and a new reference to it is returned.","type":"text"}]},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"value"},{"type":"text","text":" is found not to be in normal form then a new trusted"},{"type":"text","text":" "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true,"type":"reference"},{"type":"text","text":" is created with the same value as "},{"type":"codeVoice","code":"value"},{"text":". The non-normal parts of","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"value"},{"type":"text","text":" will be replaced with default values which are guaranteed to be in"},{"type":"text","text":" "},{"type":"text","text":"normal form."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"It makes sense to call this function if you’ve received "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true,"type":"reference"},{"type":"text","text":" "},{"text":"data from untrusted sources and you want to ensure your serialized","type":"text"},{"text":" ","type":"text"},{"text":"output is definitely in normal form.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"value","type":"codeVoice"},{"text":" is already in normal form, a new reference will be returned","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(which will be floating if "},{"type":"codeVoice","code":"value"},{"type":"text","text":" is floating). If it is not in normal form,"},{"type":"text","text":" "},{"type":"text","text":"the newly created "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","type":"reference","isActive":true},{"type":"text","text":" will be returned with a single non-floating"},{"text":" ","type":"text"},{"type":"text","text":"reference. Typically, "},{"code":"g_variant_take_ref()","type":"codeVoice"},{"text":" should be called on the return","type":"text"},{"type":"text","text":" "},{"type":"text","text":"value from this function to guarantee ownership of a single non-floating"},{"text":" ","type":"text"},{"type":"text","text":"reference to it."}]}],"kind":"content"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/variantprotocol\/normalform"]}],"references":{"doc://GLib/documentation/GLib/Variant":{"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","kind":"symbol","navigatorTitle":[{"text":"Variant","kind":"identifier"}],"role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Variant","kind":"identifier"}],"url":"\/documentation\/glib\/variant","abstract":[{"type":"codeVoice","code":"GVariant"},{"type":"text","text":" is a variant datatype; it can contain one or more values"},{"type":"text","text":" "},{"text":"along with information about the type of the values.","type":"text"}],"title":"Variant"},"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"doc://GLib/documentation/GLib/VariantProtocol":{"navigatorTitle":[{"text":"VariantProtocol","kind":"identifier"}],"role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantProtocol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"text":"VariantProtocol","kind":"identifier"}],"type":"topic","kind":"symbol","url":"\/documentation\/glib\/variantprotocol","title":"VariantProtocol","abstract":[{"code":"GVariant","type":"codeVoice"},{"type":"t
agraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the array contains a nul terminator character somewhere other than"},{"type":"text","text":" "},{"type":"text","text":"the last byte then the returned string is the string, up to the first"},{"text":" ","type":"text"},{"type":"text","text":"such nul character."}]},{"inlineContent":[{"type":"codeVoice","code":"g_variant_get_fixed_array()"},{"text":" should be used instead if the array contains","type":"text"},{"type":"text","text":" "},{"type":"text","text":"arbitrary data that could not be nul-terminated or could contain nul bytes."}],"type":"paragraph"},{"inlineContent":[{"text":"It is an error to call this function with a ","type":"text"},{"type":"codeVoice","code":"value"},{"text":" that is not an","type":"text"},{"type":"text","text":" "},{"type":"text","text":"array of bytes."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The return value remains valid as long as ","type":"text"},{"code":"value","type":"codeVoice"},{"type":"text","text":" exists."}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/glib\/variantprotocol\/bytestring"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://GLib/documentation/GLib/Variant":{"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","kind":"symbol","navigatorTitle":[{"text":"Variant","kind":"identifier"}],"role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Variant","kind":"identifier"}],"url":"\/documentation\/glib\/variant","abstract":[{"type":"codeVoice","code":"GVariant"},{"type":"text","text":" is a variant datatype; it can contain one or more values"},{"type":"text","text":" "},{"text":"along with information about the type of the values.","type":"text"}],"title":"Variant"},"doc://GLib/documentation/GLib/VariantProtocol":{"navigatorTitle":[{"text":"VariantProtocol","kind":"identifier"}],"role":"symbol","identifier":"doc:\/\/GLib\/document
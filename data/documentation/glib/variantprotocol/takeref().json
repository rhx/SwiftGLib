{"abstract":[{"type":"text","text":"If "},{"code":"value","type":"codeVoice"},{"text":" is floating, sink it.  Otherwise, do nothing.","type":"text"}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"takeRef"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:4GLib10VariantRefV","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef","kind":"typeIdentifier","text":"VariantRef"},{"kind":"text","text":"!"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"text":"Typically you want to use ","type":"text"},{"code":"g_variant_ref_sink()","type":"codeVoice"},{"text":" in order to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"automatically do the correct thing with respect to floating or"},{"text":" ","type":"text"},{"text":"non-floating references, but there is one specific scenario where","type":"text"},{"type":"text","text":" "},{"type":"text","text":"this function is helpful."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The situation where this function is helpful is when creating an API"},{"text":" ","type":"text"},{"type":"text","text":"that allows the user to provide a callback function that returns a"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true},{"text":".  We certainly want to allow the user the flexibility to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"return a non-floating reference from this callback (for the case"},{"type":"text","text":" "},{"text":"where the value that is being returned already exists).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"At the same time, the style of the ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true},{"type":"text","text":" API makes it likely that"},{"text":" ","type":"text"},{"text":"for newly-created ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"text":" instances, the user can be saved some","type":"text"},{"type":"text","text":" "},{"type":"text","text":"typing if they are allowed to return a "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true},{"text":" with a floating","type":"text"},{"type":"text","text":" "},{"text":"reference.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Using this function on the return value of the user’s callback allows"},{"type":"text","text":" "},{"text":"the user to do whichever is more convenient for them.  The caller","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"will always receives exactly one full reference to the value: either"},{"type":"text","text":" "},{"text":"the one that was returned in the first place, or a floating reference","type":"text"},{"type":"text","text":" "},{"text":"that has been converted to a full reference.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function has an odd interaction when combined with"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_variant_ref_sink()"},{"text":" running at the same time in another thread on","type":"text"},{"text":" ","type":"text"},{"text":"the same ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true},{"type":"text","text":" instance.  If "},{"code":"g_variant_ref_sink()","type":"codeVoice"},{"type":"text","text":" runs first then"},{"text":" ","type":"text"},{"type":"text","text":"the result will be that the floating reference is converted to a hard"},{"type":"text","text":" "},{"type":"text","text":"reference.  If "},{"code":"g_variant_take_ref()","type":"codeVoice"},{"text":" runs first then the result will","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"be that the floating reference is converted to a hard reference and"},{"type":"text","text":" "},{"text":"an additional reference on top of that one is added.  It is best to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"avoid this situation."}]}]}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/VariantProtocol\/takeRef()","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/variantprotocol\/takeref()"]}],"sections":[],"metadata":{"extendedModule":"GLib","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"takeRef","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"VariantRef","kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV"},{"text":"!","kind":"text"}],"modules":[{"name":"GLib"}],"externalID":"s:4GLib15VariantProtocolPAAE7takeRefAA0bE0VSgyF","role":"symbol","symbolKind":"method","roleHeading":"Instance Method","title":"takeRef()"},"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/VariantProtocol"]]},"references":{"doc://GLib/documentation/GLib/VariantProtocol/takeRef()":{"type":"topic","role":"symbol","title":"takeRef()","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantProtocol\/takeRef()","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"takeRef","kind":"identifier"},{"kind":"text","text":"() -> "},{"preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"url":"\/documentation\/glib\/variantprotocol\/takeref()","abstract":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"value"},{"text":" is floating, sink it.  Otherwise, do nothing.","type":"text"}]},"doc://GLib/documentation/GLib/VariantProtocol":{"navigatorTitle":[{"text":"VariantProtocol","kind":"identifier"}],"role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantProtocol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"text":"VariantProtocol","kind":"identifier"}],"type":"topic","kind":"symbol","url":"\/documentation\/glib\/variantprotocol","title":"VariantProtocol","abstract":[{"code":"GVariant","type":"codeVoice"},{"type":"text","text":" is a variant datatype; it can contain one or more values"},{"type":"text","text":" "},{"type":"text","text":"along with information about the type of the values."}]},"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"doc://GLib/documentation/GLib/VariantRef":{"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef","kind":"symbol","navigatorTitle":[{"text":"VariantRef","kind":"identifier"}],"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"VariantRef","kind":"identifier"}],"url":"\/documentation\/glib\/variantref","abstract":[{"type":"codeVoice","code":"GVariant"},{"type":"text","text":" is a variant datatype; it can contain one or more values"},{"type":"text","text":" "},{"text":"along with information about the type of the values.","type":"text"}],"title":"VariantRef"},"doc://GLib/documentation/GLib/Variant":{"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","kind":"symbol","navigatorTitle":[{"text":"Variant","kind":"identifier"}],"role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Variant","kind":"identifier"}],"url":"\/documentation\/glib\/variant","abstract":[{"type":"codeVoice","code":"GVariant"},{"type":"text","text":" is a variant datatype; it can contain one or more values"},{"type":"text","text":" "},{"text":"along with information about the type of the values.","type":"text"}],"title":"Variant"}}}
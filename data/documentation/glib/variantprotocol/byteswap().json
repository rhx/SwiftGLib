{"kind":"symbol","schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"text":"Performs a byteswapping operation on the contents of ","type":"text"},{"type":"codeVoice","code":"value"},{"text":".  The","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"result is that all multi-byte numeric data contained in "},{"code":"value","type":"codeVoice"},{"text":" is","type":"text"},{"type":"text","text":" "},{"text":"byteswapped.  That includes 16, 32, and 64bit signed and unsigned","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"integers as well as file handles and double precision floating point"},{"text":" ","type":"text"},{"type":"text","text":"values."}],"metadata":{"title":"byteswap()","externalID":"s:4GLib15VariantProtocolPAAE8byteswapAA0B3RefVSgyF","modules":[{"name":"GLib"}],"extendedModule":"GLib","symbolKind":"method","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"byteswap"},{"kind":"text","text":"() -> "},{"text":"VariantRef","preciseIdentifier":"s:4GLib10VariantRefV","kind":"typeIdentifier"},{"kind":"text","text":"!"}],"roleHeading":"Instance Method"},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/VariantProtocol\/byteswap()","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/VariantProtocol"]]},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/variantprotocol\/byteswap()"]}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"byteswap","kind":"identifier"},{"kind":"text","text":"() -> "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef","text":"VariantRef","kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV"},{"kind":"text","text":"!"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","cont
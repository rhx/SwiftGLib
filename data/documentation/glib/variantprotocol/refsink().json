{"sections":[],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"refSink","kind":"identifier"},{"kind":"text","text":"() -> "},{"preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef","kind":"typeIdentifier","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef"},{"kind":"text","text":"!"}],"languages":["swift"]}]},{"content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"inlineContent":[{"text":"Calling ","type":"text"},{"code":"g_variant_ref_sink()","type":"codeVoice"},{"type":"text","text":" on a "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true,"type":"reference"},{"text":" with a floating reference","type":"text"},{"type":"text","text":" "},{"type":"text","text":"will convert the floating reference into a full reference.  Calling"},{"type":"text","text":" "},{"code":"g_variant_ref_sink()","type":"codeVoice"},{"type":"text","text":" on a non-floating "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true},{"type":"text","text":" results in an"},{"text":" ","type":"text"},{"type":"text","text":"additional normal reference being added."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In other words, if the "},{"code":"value","type":"codeVoice"},{"text":" is floating, then this call “assumes","type":"text"},{"type":"text","text":" "},{"text":"ownership” of the floating reference, converting it to a normal","type":"text"},{"type":"text","text":" "},{"type":"text","text":"reference.  If the "},{"code":"value","type":"codeVoice"},{"text":" is not floating, then this call adds a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"new normal reference increasing the reference count by one."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"All calls that result in a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"text":" instance being inserted into a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"container will call "},{"code":"g_variant_ref_sink()","type":"codeVoice"},{"text":" on the instance.  This means","type":"text"},{"text":" ","type":"text"},{"text":"that if the value was just created (and has only its floating","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"reference) then the container will assume sole ownership of the value"},{"type":"text","text":" "},{"type":"text","text":"at that point and the caller will not need to unreference it.  This"},{"text":" ","type":"text"},{"text":"makes certain common styles of programming much easier while still","type":"text"},{"type":"text","text":" "},{"type":"text","text":"maintaining normal refcounting semantics in situations where values"},{"type":"text","text":" "},{"type":"text","text":"are not floating."}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/variantprotocol\/refsink()"]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/VariantProtocol"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","type":"reference","isActive":true},{"type":"text","text":" uses a floating reference count system.  All functions with"},{"type":"text","text":" "},{"text":"names starting with ","type":"text"},{"type":"codeVoice","code":"g_variant_new_"},{"text":" return floating","type":"text"},{"type":"text","text":" "},{"text":"references.","type":"text"}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/VariantProtocol\/refSink()","interfaceLanguage":"swift"},"metadata":{"extendedModule":"GLib","roleHeading":"Instance Method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"refSink","kind":"ident
{"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/VariantProtocol"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"getChildValue"},{"text":"(","kind":"text"},{"text":"index","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:4GLib10VariantRefV","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef","kind":"typeIdentifier","text":"VariantRef"},{"kind":"text","text":"!"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is an error if "},{"code":"index","type":"codeVoice"},{"type":"text","text":" is greater than the number of child items"},{"text":" ","type":"text"},{"type":"text","text":"in the container.  See "},{"type":"codeVoice","code":"g_variant_n_children()"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The returned value is never floating.  You should free it with","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_variant_unref()"},{"text":" when you’re done with it.","type":"text"}]},{"inlineContent":[{"text":"Note that values borrowed from the returned child are not guaranteed to","type":"text"},{"text":" ","type":"text"},{"text":"still be valid after the child is freed even if you still hold a reference","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to "},{"type":"codeVoice","code":"value"},{"text":", if ","type":"text"},{"type":"codeVoice","code":"value"},{"text":" has not been serialized at the time this function is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"called. To avoid this, you can serialize "},{"type":"codeVoice","code":"value"},{"type":"text","text":" by calling"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_variant_get_data()"},{"text":" and optionally ignoring the return value.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"There may be implementation specific restrictions on deeply nested values,"},{"type":"text","text":" "},{"text":"which would result in the unit tuple being returned as the child value,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"instead of further nested children. "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"text":" is guaranteed to handle","type":"text"},{"text":" ","type":"text"},{"text":"nesting up to at least 64 levels.","type":"text"}]},{"inlineContent":[{"type":"text","text":"This function is "},{"code":"O(1)","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}],"kind":"content"}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/VariantProtocol\/getChildValue(index:)","interfaceLanguage":"swift"},"metadata":{"role":"symbol","roleHeading":"Instance Method","modules":[{"name":"GLib"}],"title":"getChildValue(index:)","symbolKind":"method","externalID":"s:4GLib15VariantProtocolPAAE13getChildValue5indexAA0B3RefVSgSi_tF","extendedModule":"GLib","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"getChildValue","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"index"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"text":") -> ","kind":"text"},{"text":"VariantRef","kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV"},{"text":"!","kind":"text"}]},"abstract":[{"text":"Reads a child item out of a container ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","type":"reference","isActive":true},{"text":" instance.  This","type":"text"},{"text":" ","type":"text"},{"typ
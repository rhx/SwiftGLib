{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/staticrwlock"]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"kind":"symbol","sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLock"},"topicSections":[{"generated":true,"title":"Initializers","identifiers":["doc:\/\/GLib\/documentation\/GLib\/StaticRWLock\/init(_:)-33hto","doc:\/\/GLib\/documentation\/GLib\/StaticRWLock\/init(_:)-3kcsg","doc:\/\/GLib\/documentation\/GLib\/StaticRWLock\/init(_:)-3zz8s","doc:\/\/GLib\/documentation\/GLib\/StaticRWLock\/init(_:)-5u2m3","doc:\/\/GLib\/documentation\/GLib\/StaticRWLock\/init(_:)-8mhsi","doc:\/\/GLib\/documentation\/GLib\/StaticRWLock\/init(cPointer:)","doc:\/\/GLib\/documentation\/GLib\/StaticRWLock\/init(gconstpointer:)","doc:\/\/GLib\/documentation\/GLib\/StaticRWLock\/init(gpointer:)","doc:\/\/GLib\/documentation\/GLib\/StaticRWLock\/init(opaquePointer:)","doc:\/\/GLib\/documentation\/GLib\/StaticRWLock\/init(raw:)-3slj2","doc:\/\/GLib\/documentation\/GLib\/StaticRWLock\/init(raw:)-7ng5h","doc:\/\/GLib\/documentation\/GLib\/StaticRWLock\/init(retaining:)","doc:\/\/GLib\/documentation\/GLib\/StaticRWLock\/init(retainingCPointer:)","doc:\/\/GLib\/documentation\/GLib\/StaticRWLock\/init(retainingOpaquePointer:)","doc:\/\/GLib\/documentation\/GLib\/StaticRWLock\/init(retainingRaw:)-2wn2i","doc:\/\/GLib\/documentation\/GLib\/StaticRWLock\/init(retainingRaw:)-5j6wp"],"anchor":"Initializers"},{"generated":true,"identifiers":["doc:\/\/GLib\/documentation\/GLib\/StaticRWLock\/ptr"],"title":"Instance Properties","anchor":"Instance-Properties"},{"title":"Default Implementations","identifiers":["doc:\/\/GLib\/documentation\/GLib\/StaticRWLock\/StaticRWLockProtocol-Implementations"],"generated":true,"anchor":"Default-Implementations"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"StaticRWLock","kind":"identifier"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"text":"Overview","level":2,"type":"heading","anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Take a look at the following example:"}]},{"type":"codeListing","syntax":null,"code":["  GStaticRWLock rwlock = G_STATIC_RW_LOCK_INIT;","  GPtrArray *array;","","  gpointer","  my_array_get (guint index)","  {","    gpointer retval = NULL;","","    if (!array)","      return NULL;","","    g_static_rw_lock_reader_lock (&rwlock);","    if (index < array->len)","      retval = g_ptr_array_index (array, index);","    g_static_rw_lock_reader_unlock (&rwlock);","","    return retval;","  }","","  void","  my_array_set (guint index, gpointer data)","  {","    g_static_rw_lock_writer_lock (&rwlock);","","    if (!array)","      array = g_ptr_array_new ();","","    if (index >= array->len)","      g_ptr_array_set_size (array, index + 1);","    g_ptr_array_index (array, index) = data;","","    g_static_rw_lock_writer_unlock (&rwlock);","  }"]},{"type":"paragraph","inlineContent":[{"text":"This example shows an array which can be accessed by many readers","type":"text"},{"type":"text","text":" "},{"text":"(the ","type":"text"},{"code":"my_array_get()","type":"codeVoice"},{"type":"text","text":" function) simultaneously, whereas the writers"},{"type":"text","text":" "},{"text":"(the ","type":"text"},{"type":"codeVoice","code":"my_array_set()"},{"text":" function) will only be allowed once at a time","type":"text"},{"type":"text","text":" "},{"text":"and only if no readers currently access the array. This is because","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of the potentially dangerous resizing of the array. Using these"},{"type":"text","text":" "},{"type":"text","text":"functions is fully multi-thread safe now."}]},{"inlineContent":[{"type":"text","text":"Most of the time, writers should have precedence over readers. That"},{"type":"text","text":" "},{"type":"text","text":"means, for this implementation, that as soon as a writer wants to"},{"type":"text","text":" "},{"text":"lock the data, no other reader is allowed to lock the data, whereas,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"of course, the readers that already have locked the data are allowed"},{"type":"text","text":" "},{"text":"to finish their operation. As soon as the last reader unlocks the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"data, the writer will lock it."}],"type":"paragraph"},{"inlineContent":[{"text":"Even though ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLock","type":"reference","isActive":true},{"type":"text","text":" is not opaque, it should only be used"},{"text":" ","type":"text"},{"text":"with the following functions.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"All of the g_static_rw_lock_* functions can be used even if","type":"text"},{"type":"text","text":" "},{"code":"g_thread_init()","type":"codeVoice"},{"type":"text","text":" has not been called. Then they do nothing, apart"},{"text":" ","type":"text"},{"type":"text","text":"from g_static_rw_lock_*_trylock, which does nothing but returning "},{"type":"codeVoice","code":"true"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A read-write lock has a higher overhead than a mutex. For example, both"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_static_rw_lock_reader_lock()"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"g_static_rw_lock_reader_unlock()"},{"text":" have","type":"text"},{"text":" ","type":"text"},{"text":"to lock and unlock a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex"},{"type":"text","text":", so it takes at least twice the time"},{"text":" ","type":"text"},{"type":"text","text":"to lock and unlock a "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLock","isActive":true},{"text":" that it does to lock and unlock a","type":"text"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex"},{"text":". So only data structures that are accessed by multiple","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"readers, and which keep the lock for a considerable time justify a"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLock","isActive":true},{"type":"text","text":". The above example most probably would fare better with a"},{"type":"text","text":" "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex","isActive":true,"type":"reference"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLock","isActive":true,"type":"reference"},{"text":" type acts as an owner of an underlying ","type":"text"},{"type":"codeVoice","code":"GStaticRWLock"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"type":"text","text":"It provides the methods that can operate on this data type through "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLockProtocol"},{"text":" conformance.","type":"text"},{"text":" ","type":"text"},{"text":"Use ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLock","isActive":true},{"text":" as a strong reference or owner of a ","type":"text"},{"type":"codeVoice","code":"GStaticRWLock"},{"type":"text","text":" instance."}],"type":"paragraph"},{"type":"aside","style":"note","name":"Note","content":[{"inlineContent":[{"text":"Use ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLockRef","isActive":true},{"text":" (instead of ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLock"},{"type":"text","text":") for a lightweight Swift reference to an underlying "},{"code":"GStaticRWLock","type":"codeVoice"},{"type":"text","text":" instance."}],"type":"paragraph"}]}]}],"relationshipsSections":[{"type":"conformsTo","identifiers":["doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","doc:\/\/GLib\/documentation\/GLib\/StaticRWLockProtocol"],"title":"Conforms To","kind":"relationships"}],"metadata":{"navigatorTitle":[{"text":"StaticRWLock","kind":"identifier"}],"title":"StaticRWLock","role":"symbol","symbolKind":"class","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"StaticRWLock"}],"roleHeading":"Class","modules":[{"name":"GLib"}],"externalID":"s:4GLib12StaticRWLockC"},"abstract":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLock","isActive":true},{"type":"text","text":" struct represents a read-write lock. A read-write"},{"text":" ","type":"text"},{"text":"lock can be used for protecting data that some portions of code only","type":"text"},{"text":" ","type":"text"},{"text":"read from, while others also write. In such situations it is","type":"text"},{"type":"text","text":" "},{"text":"desirable that several readers can read at once, whereas of course","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"only one writer may write at a time."}],"references":{"doc://GLib/documentation/GLib/StaticRWLock/ptr":{"title":"ptr","abstract":[{"type":"text","text":"Untyped pointer to the underlying "},{"type":"codeVoice","code":"GStaticRWLock"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"type":"text","text":"For type-safe access, use the generated, typed pointer "},{"type":"codeVoice","code":"StaticRWLockProtocol\/_ptr"},{"text":" property instead.","type":"tex
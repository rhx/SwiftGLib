{"topicSections":[{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/DateRef\/init()","doc:\/\/GLib\/documentation\/GLib\/DateRef\/init(_:)-15l2w","doc:\/\/GLib\/documentation\/GLib\/DateRef\/init(_:)-5vh9g","doc:\/\/GLib\/documentation\/GLib\/DateRef\/init(_:)-6v7fp","doc:\/\/GLib\/documentation\/GLib\/DateRef\/init(_:)-7pk3a","doc:\/\/GLib\/documentation\/GLib\/DateRef\/init(_:)-9375e","doc:\/\/GLib\/documentation\/GLib\/DateRef\/init(cPointer:)","doc:\/\/GLib\/documentation\/GLib\/DateRef\/init(constPointer:)","doc:\/\/GLib\/documentation\/GLib\/DateRef\/init(dmy:month:year:)","doc:\/\/GLib\/documentation\/GLib\/DateRef\/init(gconstpointer:)","doc:\/\/GLib\/documentation\/GLib\/DateRef\/init(gpointer:)","doc:\/\/GLib\/documentation\/GLib\/DateRef\/init(julian:)","doc:\/\/GLib\/documentation\/GLib\/DateRef\/init(mutating:)","doc:\/\/GLib\/documentation\/GLib\/DateRef\/init(opaquePointer:)"],"generated":true,"title":"Initializers","anchor":"Initializers"},{"title":"Instance Properties","identifiers":["doc:\/\/GLib\/documentation\/GLib\/DateRef\/ptr"],"generated":true,"anchor":"Instance-Properties"},{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/DateRef\/new(dmy:month:year:)","doc:\/\/GLib\/documentation\/GLib\/DateRef\/new(julian:)"],"generated":true,"title":"Type Methods","anchor":"Type-Methods"},{"generated":true,"anchor":"Default-Implementations","title":"Default Implementations","identifiers":["doc:\/\/GLib\/documentation\/GLib\/DateRef\/DateProtocol-Implementations","doc:\/\/GLib\/documentation\/GLib\/DateRef\/PointerWrapper-Implementations"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/DateRef"},"metadata":{"fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"DateRef","kind":"identifier"}],"role":"symbol","externalID":"s:4GLib7DateRefV","symbolKind":"struct","title":"DateRef","modules":[{"name":"GLib"}],"roleHeading":"Structure","navigatorTitle":[{"kind":"identifier","text":"DateRef"}]},"schemaVersion":{"minor":3,"patch":0,"major":0},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"abstract":[{"code":"GDate","type":"codeVoice"},{"type":"text","text":" is a struct for calendrical calculations."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/dateref"]}],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"DateRef","kind":"identifier"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"text":"Overview","anchor":"overview","level":2,"type":"heading"},{"inlineContent":[{"text":"The ","type":"text"},{"code":"GDate","type":"codeVoice"},{"type":"text","text":" data structure represents a day between January 1, Year 1,"},{"text":" ","type":"text"},{"type":"text","text":"and sometime a few thousand years in the future (right now it will go"},{"text":" ","type":"text"},{"text":"to the year 65535 or so, but [method","type":"text"},{"type":"codeVoice","code":"GLib.Date.set_parse"},{"type":"text","text":"] only parses up to the"},{"type":"text","text":" "},{"text":"year 8000 or so - just count on “a few thousand”). ","type":"text"},{"type":"codeVoice","code":"GDate"},{"text":" is meant to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"represent everyday dates, not astronomical dates or historical dates"},{"type":"text","text":" "},{"type":"text","text":"or ISO timestamps or the like. It extrapolates the current Gregorian"},{"text":" ","type":"text"},{"type":"text","text":"calendar forward and backward in time; there is no attempt to change"},{"text":" ","type":"text"},{"text":"the calendar to match time periods or locations. ","type":"text"},{"type":"codeVoice","code":"GDate"},{"type":"text","text":" does not store"},{"text":" ","type":"text"},{"type":"text","text":"time information; it represents a day."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"GDate","type":"codeVoice"},{"text":" implementation has several nice features; it is only a","type":"text"},{"type":"text","text":" "},{"text":"64-bit struct, so storing large numbers of dates is very efficient. It","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"can keep both a Julian and day-month-year representation of the date,"},{"type":"text","text":" "},{"type":"text","text":"since some calculations are much easier with one representation or the"},{"text":" ","type":"text"},{"type":"text","text":"other. A Julian representation is simply a count of days since some"},{"text":" ","type":"text"},{"text":"fixed day in the past; for ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Date","type":"reference","isActive":true},{"text":" the fixed day is January 1, 1 AD.","type":"text"},{"text":" ","type":"text"},{"text":"(“Julian” dates in the ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Date","isActive":true,"type":"reference"},{"type":"text","text":" API aren’t really Julian dates in the"},{"type":"text","text":" "},{"type":"text","text":"technical sense; technically, Julian dates count from the start of the"},{"type":"text","text":" "},{"type":"text","text":"Julian period, Jan 1, 4713 BC)."}]},{"inlineContent":[{"type":"codeVoice","code":"GDate"},{"type":"text","text":" is simple to use. First you need a “blank” date; you can get a"},{"type":"text","text":" "},{"type":"text","text":"dynamically allocated date from [ctor"},{"type":"codeVoice","code":"GLib.Date.new"},{"text":"], or you can declare an","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"automatic variable or array and initialize it by calling [method"},{"type":"codeVoice","code":"GLib.Date.clear"},{"text":"].","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"A cleared date is safe; it’s safe to call [method"},{"type":"codeVoice","code":"GLib.Date.set_dmy"},{"type":"text","text":"] and the other"},{"type":"text","text":" "},{"type":"text","text":"mutator functions to initialize the value of a cleared date. However, a cleared date"},{"type":"text","text":" "},{"type":"text","text":"is initially invalid, meaning that it doesn’t represent a day that exists."},{"type":"text","text":" "},{"type":"text","text":"It is undefined to call any of the date calculation routines on an invalid date."},{"text":" ","type":"text"},{"type":"text","text":"If you obtain a date from a user or other unpredictable source, you should check"},{"text":" ","type":"text"},{"text":"its validity with the [method","type":"text"},{"code":"GLib.Date.valid","type":"codeVoice"},{"text":"] predicate. [method","type":"text"},{"code":"GLib.Date.valid","type":"codeVoice"},{"text":"]","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is also used to check for errors with [method"},{"type":"codeVoice","code":"GLib.Date.set_parse"},{"text":"] and other functions","type":"text"},{"type":"text","text":" "},{"type":"text","text":"that can fail. Dates can be invalidated by calling [method"},{"code":"GLib.Date.clear","type":"codeVoice"},{"type":"text","text":"] again."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is very important to use the API to access the "},{"code":"GDate","type":"codeVoice"},{"text":" struct. Often only the","type":"text"},{"text":" ","type":"text"},{"text":"day-month-year or only the Julian representation is valid. Sometimes neither is valid.","type":"text"},{"type":"text","text":" "},{"text":"Use the API.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"GLib also features "},{"type":"codeVoice","code":"GDateTime"},{"text":" which represents a precise time.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateRef"},{"text":" type acts as a lightweight Swift reference to an underlying ","type":"text"},{"code":"GDate","type":"codeVoice"},{"type":"text","text":" instance."},{"text":" ","type":"text"},{"type":"text","text":"It exposes methods that can operate on this data type through "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateProtocol"},{"text":" conformance.","type":"text"},{"text":" ","type":"text"},{"text":"Use ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/DateRef","isActive":true},{"text":" only as an ","type":"text"},{"type":"codeVoice","code":"unowned"},{"type":"text","text":" reference to an existing "},{"type":"codeVoice","code":"GDate"},{"text":" instance.","type":"text"}]},{"type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Date","isActive":true},{"type":"text","text":" (instead of "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/DateRef","isActive":true},{"type":"text","text":") if you want to use Automatic Reference Counting for memory management of the underlying "},{"type":"codeVoice","code":"GDate"},{"type":"text","text":" instance."}]}],"name":"Note"}]}],"sections":[],"relationshipsSections":[{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/DateProtocol","doc:\/\/GLib\/documentation\/GLib\/PointerWrapper"],"type":"conformsTo","kind":"relationships","title":"Conforms To"}],"references":{"doc://GLib/documentation/GLib/DateRef/init(_:)-6v7fp":{"title":"init(_:)","type":"topic","abstract":[{"text":"Conditional initialiser from an optional, non-mutable pointer to the underlying ","type":"text"},{"type":"codeVoice","code":"C"},{"text":" data type","type":"text"}],"kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/DateRef\/init(_:)-6v7fp","url":"\/documentation\/glib\/dateref\/init(_:)-6v7fp","fragments":[{"text":"init","kind":"identifier"},{"text":"!(",
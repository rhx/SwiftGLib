{"abstract":[{"text":"Breaks the string on the pattern, and returns an array of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the tokens. If the pattern contains capturing parentheses,"},{"type":"text","text":" "},{"type":"text","text":"then the text for each of the substrings will also be returned."},{"text":" ","type":"text"},{"text":"If the pattern does not match anywhere in the string, then the","type":"text"},{"text":" ","type":"text"},{"text":"whole string is returned as the first token.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/regexsplitsimple(pattern:string:compileoptions:matchoptions:)"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"regexSplitSimple","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"pattern"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"text":"gchar","preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"text":"string","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">!, ","kind":"text"},{"text":"compileOptions","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:4GLib17RegexCompileFlagsV","identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexCompileFlags","text":"RegexCompileFlags","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"matchOptions","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"RegexMatchFlags","identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexMatchFlags","kind":"typeIdentifier","preciseIdentifier":"s:4GLib15RegexMatchFlagsV"},{"text":") -> ","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"kind":"text","text":"<"},{"preciseIdentifier":"s:Sp","kind":"typeIdentifier","text":"UnsafeMutablePointer"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">?>!","kind":"text"}]}],"kind":"declarations"},{"content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"inlineContent":[{"text":"This function is equivalent to ","type":"text"},{"code":"g_regex_split()","type":"codeVoice"},{"type":"text","text":" but it does"},{"text":" ","type":"text"},{"text":"not require to compile the pattern with ","type":"text"},{"type":"codeVoice","code":"g_regex_new()"},{"text":", avoiding","type":"text"},{"text":" ","type":"text"},{"text":"some lines of code when you need just to do a split without","type":"text"},{"type":"text","text":" "},{"text":"extracting substrings, capture counts, and so on.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If this function is to be called on the same "},{"type":"codeVoice","code":"pattern"},{"type":"text","text":" more than"},{"type":"text","text":" "},{"text":"once, it’s more efficient to compile the pattern once with","type":"text"},{"type":"text","text":" "},{"code":"g_regex_new()","type":"codeVoice"},{"type":"text","text":" and then use "},{"code":"g_regex_split()","type":"codeVoice"},{"type":"text","text":"."}]},{"inlineContent":[{"text":"As a special case, the result of splitting the empty string “”","type":"text"},{"text":" ","type":"text"},{"text":"is an empty vector, not a vector containing a single string.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The reason for this special case is that being able to represent"},{"type":"text","text":" "},{"type":"text","text":"an 
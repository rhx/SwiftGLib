{"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"set"},{"kind":"text","text":"("},{"kind":"externalParam","text":"strictPosix"},{"kind":"text","text":": "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"text":")","kind":"text"}],"languages":["swift"]}]},{"kind":"content","content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"By default, this mode is disabled."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In strict POSIX mode, the first non-argument parameter encountered"},{"text":" ","type":"text"},{"text":"(eg: filename) terminates argument processing.  Remaining arguments","type":"text"},{"type":"text","text":" "},{"text":"are treated as non-options and are not attempted to be parsed.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If strict POSIX mode is disabled then parsing is done in the GNU way","type":"text"},{"type":"text","text":" "},{"type":"text","text":"where option arguments can be freely mixed with non-options."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"As an example, consider “ls foo -l”.  With GNU style parsing, this"},{"type":"text","text":" "},{"text":"will list “foo” in long mode.  In strict POSIX style, this will list","type":"text"},{"text":" ","type":"text"},{"text":"the files named “foo” and “-l”.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It may be useful to force strict POSIX mode when creating “verb"},{"type":"text","text":" "},{"text":"style” command line tools.  For example, the “gsettings” command line","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"tool supports the global option “–schemadir” as well as many"},{"type":"text","text":" "},{"type":"text","text":"subcommands (“get”, “set”, etc.) which each have their own set of"},{"type":"text","text":" "},{"type":"text","text":"arguments.  Using strict POSIX mode will allow parsing the global"},{"text":" ","type":"text"},{"type":"text","text":"options up to the verb name while leaving the remaining options to be"},{"type":"text","text":" "},{"type":"text","text":"parsed by the relevant subcommand (which can be determined by"},{"type":"text","text":" "},{"text":"examining the verb name, which should be present in argv[1] after","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"parsing)."}]}]}],"kind":"symbol","identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/OptionContextProtocol\/set(strictPosix:)","interfaceLanguage":"swift"},"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"type":"text","text":"Sets strict POSIX mode."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/optioncontextprotocol\/set(strictposix:)"]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/OptionContextProtocol"]]},"metadata":{"title":"set(strictPosix:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"set"},{"text":"(","kind":"text"},{"text":"strictPosix","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"kind":"text","text":")"}],"extendedModule":"GLib","roleHeading":"Instance Method","modules":[{"name":"GLib"}],"symbolKind":"method","role":"symbol","externalID":"s:4GLib21OptionContextProtocolPAAE3set11strictPosixySb_tF"},"references":{"doc://GLib/documentation/GLib/OptionContextProtocol":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/OptionContextProtocol","url":"\/documentation\/glib\/optioncontextprotocol","abstract":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"GOptionContext"},{"type":"text","text":" struct defines which options"},{"type":"text","text":" "},{"text":"are accepted by the commandline option parser. The struct has only private","type":"text"},{"type":"text","text":" "},{"type":"text","text":"fields and should not be directly accessed."}],"title":"OptionContextProtocol","role":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"OptionContextProtocol"}],"kind":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OptionContextProtocol","kind":"identifier"}]},"doc://GLib/documentation/GLib/OptionContextProtocol/set(strictPosix:)":{"abstract":[{"type":"text","text":"Sets strict POSIX mode."}],"kind":"symbol","role":"symbol","title":"set(strictPosix:)","url":"\/documentation\/glib\/optioncontextprotocol\/set(strictposix:)","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"set","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"strictPosix"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"text":")","kind":"text"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/OptionContextProtocol\/set(strictPosix:)","type":"topic"},"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]}}}
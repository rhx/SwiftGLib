{"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/testTrapSubprocessWithEnvp(testPath:envp:usecTimeout:testFlags:)","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"testTrapSubprocessWithEnvp","kind":"identifier"},{"kind":"text","text":"("},{"text":"testPath","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:s5CChara","text":"CChar"},{"kind":"text","text":">? = nil, "},{"text":"envp","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"text":"<","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"preciseIdentifier":"s:s5CChara","kind":"typeIdentifier","text":"CChar"},{"kind":"text","text":">?>! = nil, "},{"kind":"externalParam","text":"usecTimeout"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"guint64","preciseIdentifier":"c:@T@guint64"},{"text":", ","kind":"text"},{"text":"testFlags","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:4GLib19TestSubprocessFlagsV","kind":"typeIdentifier","identifier":"doc:\/\/GLib\/documentation\/GLib\/TestSubprocessFlags","text":"TestSubprocessFlags"},{"text":")","kind":"text"}]}]},{"kind":"content","content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"inlineContent":[{"type":"text","text":"This can be used for a test case that might not return, or that"},{"text":" ","type":"text"},{"type":"text","text":"might abort."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"testPath","type":"codeVoice"},{"type":"text","text":" is "},{"type":"codeVoice","code":"NULL"},{"text":" then the same test is re-run in a subprocess.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"You can use [func"},{"code":"GLib.test_subprocess","type":"codeVoice"},{"type":"text","text":"] to determine whether the test"},{"type":"text","text":" "},{"text":"is in a subprocess or not.","type":"text"}]},{"type":"paragraph","inlineContent":[{"code":"testPath","type":"codeVoice"},{"text":" can also be the name of the parent test, followed by","type":"text"},{"text":" ","type":"text"},{"text":"“","type":"text"},{"code":"\/subprocess\/","type":"codeVoice"},{"text":"” and then a name for the specific subtest (or just","type":"text"},{"type":"text","text":" "},{"type":"text","text":"ending with “"},{"code":"\/subprocess","type":"codeVoice"},{"type":"text","text":"” if the test only has one child test);"},{"type":"text","text":" "},{"type":"text","text":"tests with names of this form will automatically be skipped in the"},{"text":" ","type":"text"},{"text":"parent process.","type":"text"}]},{"inlineContent":[{"text":"If ","type":"text"},{"code":"envp","type":"codeVoice"},{"text":" is ","type":"text"},{"type":"codeVoice","code":"NULL"},{"text":", the parent process’ environment will be inherited.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"usecTimeout"},{"text":" is non-0, the test subprocess is aborted and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"considered failing if its run time exceeds it."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The subprocess behavior can be configured with [flags"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/TestSubprocessFlags"},{"text":"]","type":"text"},{"type":"text","text":" "},{"type":"text","text":"flags."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use methods such as [func"},{"type":"codeVoice","code":"GLib.test_trap_assert_passed"},{"text":"],","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[func"},{"code":"GLib.test_trap_assert_failed","type":"codeVoice"},{"type":"text","text":"], and [func"},{"code":"GLib.test_trap_assert_stderr","type":"codeVoice"},{"text":"] to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"check the results of the subprocess. (But note that"},{"text":" ","type":"text"},{"text":"[func","type":"text"},{"code":"GLib.test_trap_assert_stdout","type":"codeVoice"},{"type":"text","text":"] and [func"},{"code":"GLib.test_trap_assert_stderr","type":"codeVoice"},{"text":"]","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"cannot be used if "},{"code":"testFlags","type":"codeVoice"},{"type":"text","text":" specifies that the child should"},{"text":" ","type":"text"},{"type":"text","text":"inherit the parent stdout\/stderr.)"}]},{"inlineContent":[{"text":"If your ","type":"text"},{"type":"codeVoice","code":"main ()"},{"text":" needs to behave differently in the subprocess, you can","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"call [func"},{"type":"codeVoice","code":"GLib.test_subprocess"},{"text":"] (after calling [func","type":"text"},{"type":"codeVoice","code":"GLib.test_init"},{"type":"text","text":"])"},{"type":"text","text":" "},{"type":"text","text":"to see whether you are in a subprocess."}],"type":"paragraph"},{"inlineContent":[{"text":"Internally, this function tracks the child process using","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[func"},{"type":"codeVoice","code":"GLib.child_watch_source_new"},{"text":"], so your process must not ignore","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"SIGCHLD"},{"text":", and must not attempt to watch or wait for the child process","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"via another mechanism."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following example tests that calling "},{"code":"my_object_new(1000000)","type":"codeVoice"},{"type":"text","text":" will"},{"type":"text","text":" "},{"text":"abort with an error message.","type":"text"}]},{"type":"codeListing","syntax":"c","code":["  static void","  test_create_large_object (void)","  {","    if (g_test_subprocess ())","      {","        my_object_new (1000000);","        return;","      }","","    \/\/ Reruns this same test in a subprocess","    g_test_trap_subprocess (NULL, 0, G_TEST_SUBPROCESS_DEFAULT);","    g_test_trap_assert_failed ();","    g_test_trap_assert_stderr (\"*ERROR*too large*\");","  }","","  static void","  test_different_username (void)","  {","    if (g_test_subprocess ())","      {","        \/\/ Code under test goes here","        g_message (\"Username is now simulated as `s`\", g_getenv (\"USER\"));","        return;","      }","","    \/\/ Reruns this same test in a subprocess","    `g_auto(GStrv)` envp = g_get_environ ();","    envp = g_environ_setenv (g_steal_pointer (&envp), \"USER\", \"charlie\", TRUE);","    g_test_trap_subprocess_with_envp (NULL, envp, 0, G_TEST_SUBPROCESS_DEFAULT);","    g_test_trap_assert_passed ();","    g_test_trap_assert_stdout (\"Username is now simulated as charlie\");","  }","","  int","  main (int argc, char **argv)","  {","    g_test_init (&argc, &argv, NULL);","","    g_test_add_func (\"\/myobject\/create-large-object\",","                     test_create_large_object);","    g_test_add_func (\"\/myobject\/different-username\",","                     test_different_username);","    return g_test_run ();","  }"]}]}],"metadata":{"role":"symbol","roleHeading":"Function","modules":[{"name":"GLib"}],"externalID":"s:4GLib26testTrapSubprocessWithEnvp0B4Path4envp11usecTimeout0B5FlagsySPys4Int8VGSg_SPyAJGSgs6UInt64VAA04TestdK0VtF","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"testTrapSubprocessWithEnvp","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"testPath"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"kind":"text","text":"<"},{"text":"CChar","preciseIdentifier":"s:s5CChara","kind":"typeIdentifier"},{"text":">?, ","kind":"text"},{"text":"envp","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"text":"<","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"text":"CChar","kind":"typeIdentifier","preciseIdentifier":"s:s5CChara"},{"text":">?>!, ","kind":"text"},{"kind":"externalParam","text":"usecTimeout"},{"text":": ","kind":"text"},{"text":"guint64","kind":"typeIdentifier","preciseIdentifier":"c:@T@guint64"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"testFlags"},{"kind":"text","text":": "},{"text":"TestSubprocessFlags","kind":"typeIdentifier","preciseIdentifier":"s:4GLib19TestSubprocessFlagsV"},{"text":")","kind":"text"}],"title":"testTrapSubprocessWithEnvp(testPath:envp:usecTimeout:testFlags:)","symbolKind":"func"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/testtrapsubprocesswithenvp(testpath:envp:usectimeout:testflags:)"]}],"abstract":[{"type":"text","text":"Respawns the test program to run only "},{"code":"testPath","type":"codeVoice"},{"type":"text","text":" in a subprocess with"},{"text":" ","type":"text"},{"text":"a given environment.","type":"text"}],"kind":"symbol","sections":[],"references":{"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"doc://GLib/documentation/GLib/TestSubprocessFlags":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text
arch 14th 2010 does not exist (due to the leap"},{"type":"text","text":" "},{"type":"text","text":"forward to begin daylight savings time).  -1 is returned in that"},{"type":"text","text":" "},{"type":"text","text":"case."}],"type":"paragraph"}],"kind":"content"}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/TimeZone\/findInterval(type:time:)","interfaceLanguage":"swift"},"references":{"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"doc://GLib/documentation/GLib/TimeZone/TimeZoneProtocol-Implementations":{"role":"collectionGroup","kind":"article","title":"TimeZoneProtocol Implementations","type":"topic","url":"\/documentation\/glib\/timezone\/timezoneprotocol-implementations","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone\/TimeZoneProtocol-Implementations"},"doc://GLib/documentation/GLib/TimeZone":{"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"TimeZone"}],"kind":"symbol","title":"TimeZone","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"TimeZone"}],"url":"\/documentation\/glib\/timezone","abstract":[{"type":"text","text":"A "},{"type":"codeVoice","code":"GTimeZone"},{"text":" represents a time zone, at no particular point in time.","type":"text"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone"},"doc://GLib/documentation/GLib/TimeZone/findInterval(type:time:)":{"url":"\/documentation\/glib\/timezone\/findinterval(type:time:)","kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"findInterval"},{"text":"(","kind":"text"},{"text":"type","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"c:@EA@GTimeType","text":"GTimeType","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"ti
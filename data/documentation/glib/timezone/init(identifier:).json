{"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"init","kind":"keyword"},{"text":"(","kind":"text"},{"text":"identifier","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier","text":"gchar"},{"text":">? = nil)","kind":"text"}]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"code":"identifier","type":"codeVoice"},{"type":"text","text":" can either be an RFC3339\/ISO 8601 time offset or"},{"text":" ","type":"text"},{"text":"something that would pass as a valid value for the ","type":"text"},{"code":"TZ","type":"codeVoice"},{"type":"text","text":" environment"},{"type":"text","text":" "},{"text":"variable (including ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":")."}]},{"inlineContent":[{"type":"text","text":"In Windows, "},{"type":"codeVoice","code":"identifier"},{"type":"text","text":" can also be the unlocalized name of a time"},{"type":"text","text":" "},{"text":"zone for standard time, for example “Pacific Standard Time”.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Valid RFC3339 time offsets are "},{"code":"\"Z\"","type":"codeVoice"},{"type":"text","text":" (for UTC) or"},{"type":"text","text":" "},{"code":"\"±hh:mm\"","type":"codeVoice"},{"type":"text","text":".  ISO 8601 additionally specifies"},{"type":"text","text":" "},{"type":"codeVoice","code":"\"±hhmm\""},{"type":"text","text":" and "},{"code":"\"±hh\"","type":"codeVoice"},{"text":".  Offsets are","type":"text"},{"type":"text","text":" "},{"text":"time values to be added to Coordinated Universal Time (UTC) to get","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the local time."}],"type":"paragraph"},{"inlineContent":[{"text":"In UNIX, the ","type":"text"},{"type":"codeVoice","code":"TZ"},{"type":"text","text":" environment variable typically corresponds"},{"type":"text","text":" "},{"type":"text","text":"to the name of a file in the zoneinfo database, an absolute path to a file"},{"text":" ","type":"text"},{"text":"somewhere else, or a string in","type":"text"},{"type":"text","text":" "},{"type":"text","text":"“std offset [dst [offset],start[\/time],end[\/time]]” (POSIX) format."},{"type":"text","text":" "},{"type":"text","text":"There  are  no spaces in the specification. The name of standard"},{"type":"text","text":" "},{"text":"and daylight savings time zone must be three or more alphabetic","type":"text"},{"type":"text","text":" "},{"text":"characters. Offsets are time values to be added to local time to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"get Coordinated Universal Time (UTC) and should be"},{"text":" ","type":"text"},{"code":"\"[±]hh[[:]mm[:ss]]\"","type":"codeVoice"},{"text":".  Dates are either","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"\"Jn\""},{"type":"text","text":" (Julian day with n between 1 and 365, leap"},{"type":"text","text":" "},{"type":"text","text":"years not counted), "},{"type":"codeVoice","code":"\"n\""},{"type":"text","text":" (zero-based Julian day"},{"type":"text","text":" "},{"type":"text","text":"with n between 0 and 365) or "},{"code":"\"Mm.w.d\"","type":"codeVoice"},{"type":"text","text":" (day d"},{"type":"text","text":" "},{"type":"text","text":"(0 <= d <= 6) of week w (1 <= w <= 5) of month m (1 <= m <= 12), day"},{"text":" ","type":"text"},{"text":"0 is a Sunday).  Times are in local wall clock time, the default is","type":"text"},{"text":" ","type":"text"},{"text":"02:00:00.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In Windows, the “tzn[+|–]hh"},{"identifier":"#dzn","type":"reference","isActive":true},{"text":"” format is used, but also","type":"text"},{"type":"text","text":" "},{"text":"accepts POSIX format.  The Windows format uses US rules for all time","type":"text"},{"type":"text","text":" "},{"text":"zones; daylight savings time is 60 minutes behind the standard time","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"with date and time of change taken from Pacific Standard Time."},{"text":" ","type":"text"},{"text":"Offsets are time values to be added to the local time to get","type":"text"},{"type":"text","text":" "},{"text":"Coordinated Universal Time (UTC).","type":"text"}]},{"inlineContent":[{"code":"g_time_zone_new_local()","type":"codeVoice"},{"text":" calls this function with the value of the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"TZ"},{"type":"text","text":" environment variable. This function itself is independent of"},{"text":" ","type":"text"},{"text":"the value of ","type":"text"},{"type":"codeVoice","code":"TZ"},{"text":", but if ","type":"text"},{"code":"identifier","type":"codeVoice"},{"text":" is ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" then "},{"type":"codeVoice","code":"\/etc\/localtime"},{"text":" ","type":"text"},{"text":"will be consulted to discover the correct time zone on UNIX and the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"registry will be consulted or "},{"code":"GetTimeZoneInformation()","type":"codeVoice"},{"type":"text","text":" will be used"},{"text":" ","type":"text"},{"type":"text","text":"to get the local time zone on Windows."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If intervals are not available, only time zone rules from "},{"code":"TZ","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"environment variable or other means, then they will be computed"},{"text":" ","type":"text"},{"text":"from year 1900 to 2037.  If the maximum year for the rules is","type":"text"},{"text":" ","type":"text"},{"text":"available and it is greater than 2037, then it will followed","type":"text"},{"text":" ","type":"text"},{"text":"instead.","type":"text"}]},{"inlineContent":[{"text":"See","type":"text"},{"type":"text","text":" "},{"identifier":"http:\/\/tools.ietf.org\/html\/rfc3339#section-5.6","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"type":"text","text":"for a precise definition of valid RFC3339 time offsets"},{"type":"text","text":" "},{"type":"text","text":"(the "},{"type":"codeVoice","code":"time-offset"},{"text":" expansion) and ISO 8601 for the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"full list of valid time offsets.  See"},{"type":"text","text":" "},{"type":"reference","identifier":"http:\/\/www.gnu.org\/s\/libc\/manual\/html_node\/TZ-Variable.html","isActive":true},{"text":" ","type":"text"},{"text":"for an explanation of the possible","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"values of the "},{"code":"TZ","type":"codeVoice"},{"type":"text","text":" environment variable. See"},{"text":" ","type":"text"},{"identifier":"http:\/\/msdn.microsoft.com\/en-us\/library\/ms912391%28v=winembedded.11%29.aspx","type":"reference","isActive":true},{"type":"text","text":" "},{"text":"for the list of time zones on Windows.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You should release the return value by calling "},{"type":"codeVoice","code":"g_time_zone_unref()"},{"type":"text","text":" "},{"type":"text","text":"when you are done with it."}],"type":"paragraph"}],"kind":"content"}],"sections":[],"metadata":{"title":"init(identifier:)","modules":[{"name":"GLib"}],"roleHeading":"Initializer","role":"symbol","externalID":"s:4GLib8TimeZoneC10identifierACSPys4Int8VGSg_tcfc","symbolKind":"init","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"identifier"},{"text":": ","kind":"text"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier","text":"gchar"},{"text":">?)","kind":"text"}]},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/TimeZone"]]},"variants":[{"paths":["\/documentation\/glib\/timezone\/init(identifier:)"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","abstract":[{"type":"text","text":"Creates a "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone","type":"reference"},{"text":" corresponding to ","type":"text"},{"code":"identifier","type":"codeVoice"},{"type":"text","text":". If "},{"code":"identifier","type":"codeVoice"},{"type":"text","text":" cannot be"},{"type":"text","text":" "},{"type":"text","text":"parsed or loaded, "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" is returned."}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/TimeZone\/init(identifier:)","interfaceLanguage":"swift"},"references":{"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"http://www.gnu.org/s/libc/manual/html_node/TZ-Variable.html":{"url":"http:\/\/www.gnu.org\/s\/libc\/manual\/html_node\/TZ-Variable.html","titleInlineContent":[{"type":"text","text":"The GNU C Library manual"}],"title":"The GNU C Library manual","type":"link","identifier":"http:\/\/www.gnu.org\/s\/libc\/manual\/html_node\/TZ-Variable.html"},"http://tools.ietf.org/html/rfc3339#section-5.6":{"url":"http:\/\/tools.ietf.org\/html\/rfc3339#section-5.6","titleInlineContent":[{"type":"text","text":"RFC3339 §5.6"}],"title":"RFC3339 §5.6","type":"link","identifier":"http:\/\/tools.ietf.org\/html\/rfc3339#section-5.6"},"doc://GLib/documentation/GLib/TimeZone":{"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"TimeZone"}],"kind":"symbol","title":"TimeZone","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"TimeZone"}],"url":"\/documentation\/glib\/timezone","abstract":[{"type":"text","text":"A "},{"type":"codeVoice","code":"GTimeZone"},{"text":" represents a time zone, at no particular point in time.","type":"text"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone"},"#dzn":{"url":"#dzn","titleInlineContent":[{"type":"text","text":":mm[:ss]"}],"title":":mm[:ss]","type":"link","identifier":"#dzn"},"http://msdn.microsoft.com/en-us/library/ms912391%28v=winembedded.11%29.aspx":{"url":"http:\/\/msdn.microsoft.com\/en-us\/library\/ms912391%28v=winembedded.11%29.aspx","titleInlineContent":[{"type":"text","text":"Microsoft Time Zone Index Values"}],"title":"Microsoft Time Zone Index Values","type":"link","identifier":"http:\/\/msdn.microsoft.com\/en-us\/library\/ms912391%28v=winembedded.11%29.aspx"},"doc://GLib/documentation/GLib/TimeZone/init(identifier:)":{"title":"init(identifier:)","abstract":[{"type":"text","text":"Creates a "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone","type":"reference"},{"type":"text","text":" corresponding to "},{"code":"identifier","type":"codeVoice"},{"type":"text","text":". If "},{"type":"codeVoice","code":"identifier"},{"type":"text","text":" cannot be"},{"text":" ","type":"text"},{"type":"text","text":"parsed or loaded, "},{"type":"codeVoice","code":"nil"},{"text":" is returned.","type":"text"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone\/init(identifier:)","type":"topic","kind":"symbol","role":"symbol","url":"\/documentation\/glib\/timezone\/init(identifier:)","fragments":[{"text":"init","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gchar","
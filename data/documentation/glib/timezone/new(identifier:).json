{"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/TimeZone\/new(identifier:)","interfaceLanguage":"swift"},"sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/TimeZone"]]},"kind":"symbol","metadata":{"title":"new(identifier:)","modules":[{"name":"GLib"}],"externalID":"s:4GLib8TimeZoneC3new10identifierACSgSPys4Int8VGSg_tFZ","roleHeading":"Type Method","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"new","kind":"identifier"},{"text":"(","kind":"text"},{"text":"identifier","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier","text":"gchar"},{"text":">?) -> ","kind":"text"},{"text":"TimeZone","kind":"typeIdentifier","preciseIdentifier":"s:4GLib8TimeZoneC"},{"text":"!","kind":"text"}],"symbolKind":"method","role":"symbol"},"abstract":[{"type":"text","text":"Creates a "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone","type":"reference"},{"text":" corresponding to ","type":"text"},{"type":"codeVoice","code":"identifier"},{"type":"text","text":". If "},{"type":"codeVoice","code":"identifier"},{"type":"text","text":" cannot be"},{"type":"text","text":" "},{"type":"text","text":"parsed or loaded, "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" is returned."}],"schemaVersion":{"patch":0,"minor":3,"major":0},"variants":[{"paths":["\/documentation\/glib\/timezone\/new(identifier:)"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"static","kind":"keyword"},{"kind":"text","text":" "},{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"new"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"identifier"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"text":">? = nil) -> ","kind":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone","kind":"typeIdentifier","preciseIdentifier":"s:4GLib8TimeZoneC","text":"TimeZone"},{"kind":"text","text":"!"}],"platforms":["macOS"]}]},{"content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"inlineContent":[{"type":"codeVoice","code":"identifier"},{"type":"text","text":" can either be an RFC3339\/ISO 8601 time offset or"},{"type":"text","text":" "},{"text":"something that would pass as a valid value for the ","type":"text"},{"type":"codeVoice","code":"TZ"},{"type":"text","text":" environment"},{"text":" ","type":"text"},{"type":"text","text":"variable (including "},{"type":"codeVoice","code":"nil"},{"type":"text","text":")."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In Windows, "},{"type":"codeVoice","code":"identifier"},{"type":"text","text":" can also be the unlocalized name of a time"},{"type":"text","text":" "},{"text":"zone for standard time, for example “Pacific Standard Time”.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Valid RFC3339 time offsets are "},{"code":"\"Z\"","type":"codeVoice"},{"text":" (for UTC) or","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"\"±hh:mm\""},{"type":"text","text":".  ISO 8601 additionally specifies"},{"type":"text","text":" "},{"code":"\"±hhmm\"","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"\"±hh\""},{"type":"text","text":".  Offsets are"},{"text":" ","type":"text"},{"type":"text","text":"time values to be added to Coordinated Universal Time (UTC) to get"},{"type":"text","text":" "},{"type":"text","text":"the local time."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In UNIX, the "},{"code":"TZ","type":"codeVoice"},{"text":" environment variable typically corresponds","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to the name of a file in the zoneinfo database, an absolute path to a file"},{"text":" ","type":"text"},{"type":"text","text":"somewhere else, or a string in"},{"text":" ","type":"text"},{"text":"“std offset [dst [offset],start[\/time],end[\/time]]” (POSIX) format.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"There  are  no spaces in the specification. The name of standard"},{"text":" ","type":"text"},{"type":"text","text":"and daylight savings time zone must be three or more alphabetic"},{"text":" ","type":"text"},{"text":"characters. Offsets are time values to be added to local time to","type":"text"},{"text":" ","type":"text"},{"text":"get Coordinated Universal Time (UTC) and should be","type":"text"},{"type":"text","text":" "},{"code":"\"[±]hh[[:]mm[:ss]]\"","type":"codeVoice"},{"type":"text","text":".  Dates are either"},{"type":"text","text":" "},{"code":"\"Jn\"","type":"codeVoice"},{"text":" (Julian day with n between 1 and 365, leap","type":"text"},{"type":"text","text":" "},{"text":"years not counted), ","type":"text"},{"code":"\"n\"","type":"codeVoice"},{"text":" (zero-based Julian day","type":"text"},{"type":"text","text":" "},{"text":"with n between 0 and 365) or ","type":"text"},{"code":"\"Mm.w.d\"","type":"codeVoice"},{"type":"text","text":" (day d"},{"type":"text","text":" "},{"type":"text","text":"(0 <= d <= 6) of week w (1 <= w <= 5) of month m (1 <= m <= 12), day"},{"type":"text","text":" "},{"text":"0 is a Sunday).  Times are in local wall clock time, the default is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"02:00:00."}]},{"inlineContent":[{"text":"In Windows, the “tzn[+|–]hh","type":"text"},{"identifier":"#dzn","isActive":true,"type":"reference"},{"type":"text","text":"” format is used, but also"},{"text":" ","type":"text"},{"type":"text","text":"accepts POSIX format.  The Windows format uses US rules for all time"},{"type":"text","text":" "},{"text":"zones; daylight savings time is 60 minutes behind the standard time","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"with date and time of change taken from Pacific Standard Time."},{"type":"text","text":" "},{"text":"Offsets are time values to be added to the local time to get","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Coordinated Universal Time (UTC)."}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"g_time_zone_new_local()"},{"text":" calls this function with the value of the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"TZ"},{"type":"text","text":" environment variable. This function itself is independent of"},{"text":" ","type":"text"},{"type":"text","text":"the value of "},{"code":"TZ","type":"codeVoice"},{"type":"text","text":", but if "},{"type":"codeVoice","code":"identifier"},{"text":" is ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" then ","type":"text"},{"type":"codeVoice","code":"\/etc\/localtime"},{"text":" ","type":"text"},{"text":"will be consulted to discover the correct time zone on UNIX and the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"registry will be consulted or "},{"code":"GetTimeZoneInformation()","type":"codeVoice"},{"type":"text","text":" will be used"},{"text":" ","type":"text"},{"type":"text","text":"to get the local time zone on Windows."}],"type":"paragraph"},{"inlineContent":[{"text":"If intervals are not available, only time zone rules from ","type":"text"},{"type":"codeVoice","code":"TZ"},{"text":" ","type":"text"},{"text":"environment variable or other means, then they will be computed","type":"text"},{"type":"text","text":" "},{"type":"text","text":"from year 1900 to 2037.  If the maximum year for the rules is"},{"type":"text","text":" "},{"type":"text","text":"available and it is greater than 2037, then it will followed"},{"type":"text","text":" "},{"type":"text","text":"instead."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"See","type":"text"},{"type":"text","text":" "},{"identifier":"http:\/\/tools.ietf.org\/html\/rfc3339#section-5.6","isActive":true,"type":"reference"},{"type":"text","text":" "},{"text":"for a precise definition of valid RFC3339 time offsets","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(the "},{"code":"time-offset","type":"codeVoice"},{"type":"text","text":" expansion) and ISO 8601 for the"},{"type":"text","text":" "},{"type":"text","text":"full list of valid time offsets.  See"},{"type":"text","text":" "},{"type":"reference","identifier":"http:\/\/www.gnu.org\/s\/libc\/manual\/html_node\/TZ-Variable.html","isActive":true},{"text":" ","type":"text"},{"text":"for an explanation of the possible","type":"text"},{"type":"text","text":" "},{"type":"text","text":"values of the "},{"code":"TZ","type":"codeVoice"},{"text":" environment variable. See","type":"text"},{"type":"text","text":" "},{"type":"reference","identifier":"http:\/\/msdn.microsoft.com\/en-us\/library\/ms912391%28v=winembedded.11%29.aspx","isActive":true},{"type":"text","text":" "},{"text":"for the list of time zones on Windows.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"You should release the return value by calling ","type":"text"},{"code":"g_time_zone_unref()","type":"codeVoice"},{"type":"text","text":" "},{"text":"when you are done with it.","type":"text"}]}],"kind":"content"}],"references":{"doc://GLib/documentation/GLib/TimeZone":{"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"TimeZone"}],"kind":"symbol","title":"TimeZone","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"TimeZone"}],"url":"\/documentation\/glib\/timezone","abstract":[{"type":"text","text":"A "},{"type":"codeVoice","code":"GTimeZone"},{"text":" represents a time zone, at no particular point in time.","type":"text"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone"},"doc://GLib/documentation/GLib/TimeZone/new(identifier:)":{"title":"new(identifier:)","kind":"symbol","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"new","kind":"identifier"},{"text":"(","kind":"text"},{"text":"identifier","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"text":"gchar","preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier"},{"text":">?) -> ","kind":"text"},{"text":"TimeZone","preciseIdentifier":"s:4GLib8TimeZoneC","kind":"typeIdentifier"},{"kind":"text","text":"!"}],"type":"topic","url":"\/documentation\/glib\/timezone\/new(identifier:)","abstract":[{"text":"Creates a ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone","isActive":true,"type":"reference"},{"type":"text","text":" corresponding to "},{"type":"codeVoice","code":"identifier"},{"text":". If ","type":"text"},{"type":"codeVoice","code":"identifier"},{"type":"text","text":" cannot be"},{"type":"text","text":" "},{"type":"text","text":"parsed or loaded, "},{"type":"codeVoice","code":"nil"},{"text":" is returned.","type":"text"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone\/new(identifier:)","role":"symbol"},"#dzn":{"titleInlineContent":[{"type":"text","text":":mm[:ss]"}],"identifier":"#dzn","type":"link","title":":mm[:ss]","url":"#dzn"},"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"http://www.gnu.org/s/libc/manual/html_node/TZ-Variable.html":{"titleInlineContent":[{"type":"text","text":"The GNU C Library manual"}],"identifier":"http:\/\/www.gnu.org\/s\/libc\/manual\/html_node\/TZ-Variable.html","type":"link","title":"The GNU C Library manual","url":"http:\/\/www.gnu.org\/s\/libc\/manual\/html_node\/TZ-Variable.html"},"http://msdn.microsoft.com/en-us/library/ms912391%28v=winembedded.11%29.aspx":{"titleInlineContent":[{"type":"text","text":"Microsoft Time Zone Index Values"}],"identifier":"http:\/\/msdn.microsoft.com\/en-us\/library\/ms912391%28v=winembedded.11%29.aspx","title":"Microsoft Time Zone Index Values","type":"link","url":"http:\/\/msdn.microsoft.com\/en-us\/library\/ms912391%28v=winembedded.11%29.aspx"},"http://tools.ietf.org/html/rfc3339#section-5.6":{"titleInlineContent":[{"type":"text","text":"RFC3339 §5.6"}],"identifier":"http:\/\/tools.ietf.org\/html\/rfc3339#section-5.6","type":"link","title":"RFC3339 §5.6","url":"http:\/\/tools.ietf.org\/html\/rfc3339#section-5.6"}}}
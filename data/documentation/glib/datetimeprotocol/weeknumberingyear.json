{"metadata":{"role":"symbol","roleHeading":"Instance Property","modules":[{"name":"GLib"}],"title":"weekNumberingYear","symbolKind":"property","externalID":"s:4GLib16DateTimeProtocolPAAE17weekNumberingYearSivp","extendedModule":"GLib","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"weekNumberingYear","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}]},"abstract":[{"type":"text","text":"Returns the ISO 8601 week-numbering year in which the week containing"},{"type":"text","text":" "},{"type":"codeVoice","code":"datetime"},{"text":" falls.","type":"text"}],"variants":[{"paths":["\/documentation\/glib\/datetimeprotocol\/weeknumberingyear"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol\/weekNumberingYear","interfaceLanguage":"swift"},"kind":"symbol","primaryContentSections":[{"declarations":[{"tokens":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"weekNumberingYear"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":" { "},{"text":"get","kind":"keyword"},{"kind":"text","text":" }"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"This function, taken together with ","type":"text"},{"code":"g_date_time_get_week_of_year()","type":"codeVoice"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_date_time_get_day_of_week()"},{"type":"text","text":" can be used to determine the full ISO"},{"type":"text","text":" "},{"type":"text","text":"week date on which "},{"code":"datetime","type":"codeVoice"},{"type":"text","text":" falls."}]},{"inlineContent":[{"text":"This is usually equal to the normal Gregorian year (as returned by","type":"text"},{"type":"text","text":" "},{"code":"g_date_time_get_year()","type":"codeVoice"},{"text":"), except as detailed below:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"For Thursday, the week-numbering year is always equal to the usual","type":"text"},{"type":"text","text":" "},{"text":"calendar year.  For other days, the number is such that every day","type":"text"},{"type":"text","text":" "},{"type":"text","text":"within a complete week (Monday to Sunday) is contained within the"},{"text":" ","type":"text"},{"type":"text","text":"same week-numbering year."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For Monday, Tuesday and Wednesday occurring near the end of the year,"},{"type":"text","text":" "},{"text":"this may mean that the week-numbering year is one greater than the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"calendar year (so that these days have the same week-numbering year"},{"text":" ","type":"text"},{"type":"text","text":"as the Thursday occurring early in the next year)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"For Friday, Saturday and Sunday occurring near the start of the year,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"this may mean that the week-numbering year is one less than the"},{"text":" ","type":"text"},{"text":"calendar year (so that these days have the same week-numbering year","type":"text"},{"type":"text","text":" "},{"type":"text","text":"as the Thursday occurring late in the previous year)."}]},{"type":"paragraph","inlineContent":[{"text":"An equivalent description is that the week-numbering year is equal to","type":"text"},{"text":" ","type":"text"},{"text":"the calendar year containing the majority of the days in the current","type":"text"},{"type":"text","text":" "},{"type":"text","text":"week (Monday to Sunday)."}]},{"inlineContent":[{"type":"text","text":"Note that January 1 0001 in the proleptic Gregorian calendar is a"},{"text":" ","type":"text"},{"text":"Monday, so this function never returns 0.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol"]]},"sections":[],"references":{"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"doc://GLib/documentation/GLib/DateTimeProtocol/weekNumberingYear":{"abstract":[{"type":"text","text":"Returns the ISO 8601 week-numbering year in which the week containing"},{"text":" ","type":"text"},{"code":"datetime","type":"codeVoice"},{"text":" falls.","type":"text"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol\/weekNumberingYear","url":"\/documentation\/glib\/datetimeprotocol\/weeknumberingyear","kind":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"weekNumberingYear","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"title":"weekNumberingYear","role":"symbol"},"doc://GLib/documentation/GLib/DateTimeProtocol":{"url":"\/documentation\/glib\/datetimeprotocol","role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DateTimeProtocol","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeProtocol","abstract":[{"type":"codeVoice","code":"GDateTime"},{"text":" is a structure that combines a Gregorian date and time","type":"text"},{"type":"text","text":" "},{"text":"into a single structure.","type":"text"}],"title":"DateTimeProtocol","navigatorTitle":[{"kind":"identifier","text":"DateTimeProtocol"}],"kind":"symbol","type":"topic"}}}
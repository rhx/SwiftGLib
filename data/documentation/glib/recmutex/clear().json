{"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"clear"},{"text":"()","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function should not be used with a "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/RecMutex","type":"reference"},{"type":"text","text":" that has been"},{"text":" ","type":"text"},{"text":"statically allocated.","type":"text"}]},{"inlineContent":[{"text":"Calling ","type":"text"},{"type":"codeVoice","code":"g_rec_mutex_clear()"},{"text":" on a locked recursive mutex leads","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to undefined behaviour."}],"type":"paragraph"}],"kind":"content"}],"sections":[],"variants":[{"paths":["\/documentation\/glib\/recmutex\/clear()"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/RecMutex\/clear()","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Frees the resources allocated to a recursive mutex with"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_rec_mutex_init()"},{"text":".","type":"text"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/RecMutex","doc:\/\/GLib\/documentation\/GLib\/RecMutex\/RecMutexProtocol-Implementations"]]},"metadata":{"title":"clear()","modules":[{"name":"GLib"}],"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"clear","kind":"identifier"},{"text":"()","kind":"text"}],"externalID":"s:4GLib16RecMutexProtocolPAAE5clearyyF::SYNTHESIZED::s:4GLib8RecMutexC","roleHeading":"Instance Method","role":"symbol","symbolKind":"method","extendedModule":"GLib"},"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://GLib/documentation/GLib/Mutex":{"url":"\/documentation\/glib\/mutex","role":"symbol","navigatorTitle":[{"text":"Mutex","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","type":"topic","abstract":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","isActive":true},{"text":" struct is an opaque data structure to represent a mutex","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"(mutual exclusion). It can be used to protect data against shared"},{"text":" ","type":"text"},{"type":"text","text":"access."}],"kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Mutex"}],"title":"Mutex"},"doc://GLib/documentation/GLib/RecMutex":{"url":"\/documentation\/glib\/recmutex","abstract":[{"type":"text","text":"The GRecMutex struct is an opaque data structure to represent a"},{"text":" ","type":"text"},{"type":"text","text":"recursive mutex. It is similar to a "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","type":"reference","isActive":true},{"type":"text","text":" with the difference"},{"text":" ","type":"text"},{"text":"that it is possible to lock a GRecMutex multiple times in the same","type":"text"},{"type":"text","text":" "},{"type":"text","text":"thread without deadlock. When doing so, care has to be taken to"},{"type":"text","text":" "},{"type":"text","text":"unlock the recursive mutex as often as it has been locked."}],"title":"RecMutex","type":"topic","navigatorTitle":[{"text":"RecMutex","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/RecMutex","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"RecMutex","kind":"identifier"}],"role":"symbol","kind":"symbol"},"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"doc://GLib/documentation/GLib/RecMutex/clear()":{"url":"\/documentation\/glib\/recmutex\/clear()","kind":"symbol","type":"topic","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"clear"},{"text":"()","kind":"text"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/RecMutex\/clear()","abstract":[{"text":"Frees the resources allocated to a recursive mutex with","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_rec_mutex_init()"},{"type":"text","text":"."}],"title":"clear()"},"doc://GLib/documentation/GLib/RecMutex/RecMutexProtocol-Implementations":{"title":"RecMutexProtocol Implementations","kind":"article","url":"\/documentation\/glib\/recmutex\/recmutexprotocol-implementations","abstract":[],"role":"collectionGroup","identifier":"doc:\/\/GLib\/documentation\/GLib\/RecMutex\/RecMutexProtocol-Implementations","type":"topic"}}}
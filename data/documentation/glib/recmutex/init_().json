ce","code":"g_rec_mutex_init()"},{"text":" when a recursive mutex","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is no longer needed, use "},{"type":"codeVoice","code":"g_rec_mutex_clear()"},{"text":".","type":"text"}]}]}],"variants":[{"paths":["\/documentation\/glib\/recmutex\/init_()"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/RecMutex\/init_()","interfaceLanguage":"swift"},"metadata":{"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"init_","kind":"identifier"},{"text":"()","kind":"text"}],"title":"init_()","externalID":"s:4GLib16RecMutexProtocolPAAE5init_yyF::SYNTHESIZED::s:4GLib8RecMutexC","symbolKind":"method","extendedModule":"GLib","modules":[{"name":"GLib"}],"role":"symbol","roleHeading":"Instance Method"},"kind":"symbol","references":{"doc://GLib/documentation/GLib/RecMutex/init_()":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"init_","kind":"identifier"},{"text":"()","kind":"text"}],"title":"init_()","url":"\/documentation\/glib\/recmutex\/init_()","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/RecMutex\/init_()","abstract":[{"text":"Initializes a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/RecMutex","type":"reference"},{"type":"text","text":" so that it can be used."}],"type":"topic","role":"symbol"},"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"doc://GLib/documentation/GLib/Mutex":{"url":"\/documentation\/glib\/mutex","role":"symbol","navigatorTitle":[{"text":"Mutex","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","type":"topic","abstract":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","isActive":true},{"text":" struct is an opaque data structure to represent a mutex","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"(mutual exclusion). It can be used to protect data against shared"},{"text":" ","type":"text"},{"type":"text","text":"access."}],"kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Mutex"}],"title":"Mutex"},"doc://GLib/documentation/GLib/RecMutex/RecMutexProtocol-Implementations":{"title":"RecMutexProtocol Implementations","kind":"article","url":"\/documentation\/glib\/recmutex\/recmutexprotocol-implementations","abstract":[],"role":"collectionGroup","identifier":"doc:\/\/GLib\/documentation\/GLib\/RecMutex\/RecMutexProtocol-Implementations","type":"topic"},"doc://GLib/documentation/GLib/RecMutex":{"url":"\/documentation\/glib\/recmutex","abstract":[{"type":"text","text":"The GRecMutex struct is an opaque data structure to represent a"},{"text":" ","type":"text"},{"type":"text","text":"recursive mutex. It is similar to a "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","type":"reference","isActive":true},{"type":"text","text":" with the difference"},{"text":" ","type":"text"},{"text":"that it is possible to lock a GRecMutex multiple times in the same","type":"text"},{"type":"text","text":" "},{"type":"text","text":"thread without deadlock. When doing so, care has to be taken to"},{"type":"text","text":" "},{"type":"text","text":"unlock the recursive mutex as often as it has been locked."}],"title":"RecMutex","type":"topic","navigatorTitle":[{"text":"RecMutex","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/RecMutex","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"RecMutex","kind":"identifier"}],"role":"symbol","kind":"symbol"}}}
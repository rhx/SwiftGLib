{"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/Cond","doc:\/\/GLib\/documentation\/GLib\/Cond\/CondProtocol-Implementations"]]},"metadata":{"roleHeading":"Instance Method","modules":[{"name":"GLib"}],"role":"symbol","title":"waitUntil(mutex:endTime:)","externalID":"s:4GLib12CondProtocolPAAE9waitUntil5mutex7endTimeSbqd___s5Int64VtAA05MutexC0Rd__lF::SYNTHESIZED::s:4GLib4CondC","symbolKind":"method","extendedModule":"GLib","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"waitUntil"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"MutexT"},{"kind":"text","text":">("},{"kind":"externalParam","text":"mutex"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"MutexT"},{"kind":"text","text":", "},{"text":"endTime","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@gint64","text":"gint64","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}]},"sections":[],"variants":[{"paths":["\/documentation\/glib\/cond\/waituntil(mutex:endtime:)"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"Waits until either "},{"code":"cond","type":"codeVoice"},{"type":"text","text":" is signalled or "},{"type":"codeVoice","code":"endTime"},{"type":"text","text":" has passed."}],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"waitUntil"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"MutexT"},{"text":">(","kind":"text"},{"text":"mutex","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"MutexT"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"endTime"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@gint64","kind":"typeIdentifier","text":"gint64"},{"text":") -> ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"text":" ","kind":"text"},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"text":"MutexT","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"kind":"typeIdentifier","text":"MutexProtocol","preciseIdentifier":"s:4GLib13MutexProtocolP","identifier":"doc:\/\/GLib\/documentation\/GLib\/MutexProtocol"}],"platforms":["macOS"]}]},{"content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"inlineContent":[{"text":"As with ","type":"text"},{"code":"g_cond_wait()","type":"codeVoice"},{"type":"text","text":" it is possible that a spurious or stolen wakeup"},{"text":" ","type":"text"},{"type":"text","text":"could occur.  For that reason, waiting on a condition variable should"},{"text":" ","type":"text"},{"text":"always be in a loop, based on an explicitly-checked predicate.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"true"},{"text":" is returned if the condition variable was signalled (or in the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"case of a spurious wakeup).  "},{"type":"codeVoice","code":"false"},{"type":"text","text":" is returned if "},{"type":"codeVoice","code":"endTime"},{"text":" has","type":"text"},{"type":"text","text":" "},{"type":"text","text":"passed."}]},{"inlineContent":[{"type":"text","text":"The following code shows how to correctly perform a timed wait on a"},{"text":" ","type":"text"},{"text":"condition variable (extending the example presented in the","type":"text"},{"text":" ","type":"text"},{"text":"documentation for ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","type":"reference"},{"type":"text","text":"):"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"(C Language Example):","type":"text"}]},{"code":["gpointer","pop_data_timed (void)","{","  gint64 end_time;","  gpointer data;","","  g_mutex_lock (&data_mutex);","","  end_time = g_get_monotonic_time () + 5 * G_TIME_SPAN_SECOND;","  while (!current_data)","    if (!g_cond_wait_until (&data_cond, &data_mutex, end_time))","      {","        \/\/ timeout has passed.","        g_mutex_unlock (&data_mutex);","        return NULL;","      }","","  \/\/ there is data for us","  data = current_data;","  current_data = NULL;","","  g_mutex_unlock (&data_mutex);","","  return data;","}"],"syntax":"C","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Notice that the end time is calculated once, before entering the"},{"text":" ","type":"text"},{"type":"text","text":"loop and reused.  This is the motivation behind the use of absolute"},{"type":"text","text":" "},{"text":"time on this API – if a relative time of 5 seconds were passed","type":"text"},{"type":"text","text":" "},{"type":"text","text":"directly to the call and a spurious wakeup occurred, the program would"},{"text":" ","type":"text"},{"text":"have to start over waiting again (which would lead to a total wait","type":"text"},{"type":"text","text":" "},{"text":"time of more than 5 seconds).","type":"text"}]}],"kind":"content"}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/Cond\/waitUntil(mutex:endTime:)","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://GLib/documentation/GLib/Cond/waitUntil(mutex:endTime:)":{"url":"\/documentation\/glib\/cond\/waituntil(mutex:endtime:)","type":"topic","abstract":[{"type":"text","text":"Waits until either "},{"type":"codeVoice","code":"cond"},{"text":" is signalled or ","type":"text"},{"type":"codeVoice","code":"endTime"},{"text":" has passed.","type":"text"}],"kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"waitUntil"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"MutexT"},{"kind":"text","text":">("},{"text":"mutex","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"MutexT"},{"kind":"text","text":", "},{"text":"endTime","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gint64","text":"gint64"},{"kind":"text","text":") -> "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"role":"symbol","title":"waitUntil(mutex:endTime:)","identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond\/waitUntil(mutex:endTime:)"},"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"doc://GLib/documentation/GLib/Cond/CondProtocol-Implementations":{"title":"CondProtocol Implementations","role":"collectionGroup","kind":"article","abstract":[],"url":"\/documentation\/glib\/cond\/condprotocol-implementations","identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond\/CondProtocol-Implementations","type":"topic"},"doc://GLib/documentation/GLib/Cond":{"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Cond"}],"url":"\/documentation\/glib\/cond","navigatorTitle":[{"kind":"identifier","text":"Cond"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","role":"symbol","abstract":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","type":"reference","isActive":true},{"type":"text","text":" struct is an opaque data structure that represents a"},{"text":" ","type":"text"},{"text":"condition. Threads can block on a ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","isActive":true},{"text":" if they find a certain","type":"text"},{"type":"text","text":" "},{"type":"text","text":"condition to be false. If other threads change the state of this"},{"type":"text","text":" "},{"type":"text","text":"condition they signal the "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","isActive":true},{"type":"text","text":", and that causes the waiting"},{"type":"text","text":" "},{"type":"text","text":"threads to be woken up."}],"type":"topic","title":"Cond","kind":"symbol"},"doc://GLib/documentation/GLib/Mutex":{"url":"\/documentation\/glib\/mutex","role":"symbol","navigatorTitle":[{"text":"Mutex","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","type":"topic","abstract":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","isActive":true},{"text":" struct is an opaque data structure to represent a mutex","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"(mutual exclusion). It can be used to protect data against shared"},{"text":" ","type":"text"},{"type":"text","text":"access."}],"kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Mutex"}],"title":"Mutex"},"doc://GLib/documentation/GLib/MutexProtocol":{"title":"MutexProtocol","abstract":[{"text":"The ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","type":"reference"},{"type":"text","text":" struct is an opaque data structure to represent a mutex"},{"text":" ","type":"text"},{"text":"(mutual exclusion). It can be used to protect data against shared","type":"text"},{"type":"text","text":" "},{"text":"access.","type":"text"}],"kind":"symbol","url":"\/documentation\/glib\/mutexprotocol","identifier":"doc:\/\/GLib\/documentation\/GLib\/MutexProtocol","type":"topic","role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"MutexProtocol"}],"navigatorTitle":[{"kind":"identifier","text":"MutexProtocol"}]}}}
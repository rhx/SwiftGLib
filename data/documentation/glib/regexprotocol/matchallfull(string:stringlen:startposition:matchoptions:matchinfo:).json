xt":"RegexMatchFlags","kind":"typeIdentifier","identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexMatchFlags","preciseIdentifier":"s:4GLib15RegexMatchFlagsV"},{"text":", ","kind":"text"},{"text":"matchInfo","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"GMatchInfo"},{"text":">?>! = nil) ","kind":"text"},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"platforms":["macOS"]}]},{"content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"This function uses a different algorithm (called DFA, i.e. deterministic"},{"text":" ","type":"text"},{"text":"finite automaton), so it can retrieve all the possible matches, all","type":"text"},{"text":" ","type":"text"},{"text":"starting at the same point in the string. For instance matching","type":"text"},{"text":" ","type":"text"},{"code":"\"<a> <b> <c>\"","type":"codeVoice"},{"type":"text","text":" against the pattern "},{"type":"codeVoice","code":"\"<.*>\""},{"type":"text","text":" "},{"text":"you would obtain three matches: ","type":"text"},{"code":"\"<a> <b> <c>\"","type":"codeVoice"},{"text":",","type":"text"},{"type":"text","text":" "},{"code":"\"<a> <b>\"","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"\"<a>\""},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The number of matched strings is retrieved using","type":"text"},{"type":"text","text":" "},{"code":"g_match_info_get_match_count()","type":"codeVoice"},{"type":"text","text":". To obtain the matched strings and"},{"type":"text","text":" "},{"type":"text","text":"their position you can use, respectively, "},{"code":"g_match_info_fetch()","type":"codeVoice"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_match_info_fetch_pos()"},{"type":"text","text":". Note that the strings are returned in"},{"type":"text","text":" "},{"text":"reverse order of length; that is, the longest matching string is","type":"text"},{"type":"text","text":" "},{"text":"given first.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Note that the DFA algorithm is slower than the standard one and it"},{"type":"text","text":" "},{"type":"text","text":"is not able to capture substrings, so backreferences do not work."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Setting "},{"code":"startPosition","type":"codeVoice"},{"text":" differs from just passing over a shortened","type":"text"},{"type":"text","text":" "},{"type":"text","text":"string and setting "},{"code":"notbol","type":"codeVoice"},{"text":" in the case of a pattern","type":"text"},{"text":" ","type":"text"},{"text":"that begins with any kind of lookbehind assertion, such as “\\b”.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Unless ","type":"text"},{"code":"raw","type":"codeVoice"},{"text":" is specified in the options, ","type":"text"},{"code":"string","type":"codeVoice"},{"type":"text","text":" must be valid UTF-8."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo"},{"type":"text","text":" structure, used to get information on the match, is"},{"type":"text","text":" "},{"text":"stored in ","type":"text"},{"code":"matchInfo","type":"codeVoice"},{"type":"text","text":" if not "},{"code":"nil","type":"codeVoice"},{"text":". Note that if ","type":"text"},{"type":"codeVoice","code":"matchInfo"},{"type":"text","text":" is"},{"type":"text","text":" "},{"type":"text","text":"not "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" then it is created even if the function returns "},{"code":"false","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"i.e. you must free it regardless if regular expression actually"},{"text":" ","type":"text"},{"text":"matched.","type":"text"}]},{"inlineContent":[{"code":"string","type":"codeVoice"},{"text":" is not copied and is used in ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo"},{"text":" internally. If","type":"text"},{"type":"text","text":" "},{"text":"you use any ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfo","isActive":true,"type":"reference"},{"type":"text","text":" method (except "},{"code":"g_match_info_free()","type":"codeVoice"},{"type":"text","text":") after"},{"type":"text","text":" "},{"type":"text","text":"freeing or modifying "},{"type":"codeVoice","code":"string"},{"type":"text","text":" then the behaviour is undefined."}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://GLib/documentation/GLib/RegexProtocol/matchAllFull(string:stringLen:startPosition:matchOptions:matchInfo:)":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexProtocol\/matchAllFull(string:stringLen:startPosition:matchOptions:matchInfo:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"matchAllFull","kind":"identifier"},{"kind":"text","text":"("},{"text":"string","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"stringLen"},{"text":": ","kind":"text"},{"text":"gssize","kind":"typeIdentifier","preciseIdentifier":"c:@T@gssize"},{"kind":"text","text":", "},{"text":"startPosition","kind":"externalParam"},{"kind":"text","text":": "},{
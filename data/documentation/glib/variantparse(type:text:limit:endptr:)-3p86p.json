ntTypeT","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:4GLib19VariantTypeProtocolP","kind":"typeIdentifier","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantTypeProtocol","text":"VariantTypeProtocol"}]}]},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"A single ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true,"type":"reference"},{"type":"text","text":" is parsed from the content of "},{"type":"codeVoice","code":"text"},{"text":".","type":"text"}]},{"inlineContent":[{"type":"text","text":"The format is described "},{"identifier":"gvariant-text-format.html","type":"reference","isActive":true},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The memory at ","type":"text"},{"code":"limit","type":"codeVoice"},{"type":"text","text":" will never be accessed and the parser behaves as"},{"text":" ","type":"text"},{"type":"text","text":"if the character at "},{"type":"codeVoice","code":"limit"},{"text":" is the nul terminator.  This has the","type":"text"},{"text":" ","type":"text"},{"text":"effect of bounding ","type":"text"},{"type":"codeVoice","code":"text"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"endptr"},{"text":" is non-","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" then ","type":"text"},{"type":"codeVoice","code":"text"},{"type":"text","text":" is permitted to contain data"},{"type":"text","text":" "},{"text":"following the value that this function parses and ","type":"text"},{"type":"codeVoice","code":"endptr"},{"type":"text","text":" will be"},{"text":" ","type":"text"},{"text":"updated to point to the first character past the end of the text","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"parsed by this function.  If "},{"code":"endptr","type":"codeVoice"},{"text":" is ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" and there is extra data","type":"text"},{"text":" ","type":"text"},{"text":"then an error is returned.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"type"},{"type":"text","text":" is non-"},{"type":"codeVoice","code":"nil"},{"text":" then the value will be parsed to have that","type":"text"},{"type":"text","text":" "},{"type":"text","text":"type.  This may result in additional parse errors (in the case that"},{"text":" ","type":"text"},{"text":"the parsed value doesn’t fit the type) but may also result in fewer","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"errors (in the case that the type would have been ambiguous, such as"},{"text":" ","type":"text"},{"type":"text","text":"with empty arrays)."}]},{"inlineContent":[{"type":"text","text":"In the event that the parsing is successful, the resulting "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"text":" ","type":"text"},{"type":"text","text":"is returned. It is never floating, and must be freed with"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GLib.Variant.unref"},{"type":"text","text":"]."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In case of any error, "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" will be returned.  If "},{"type":"codeVoice","code":"error"},{"text":" is non-","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":" "},{"text":"then it will be set to reflect the error that occurred.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Officially, the language understood by the parser is “any string","type":"text"},{"type":"text","text":" "},{"type":"text","text":"produced by [method"},{"type":"codeVoice","code":"GLib.Variant.print"},{"text":"]”. This explicitly includes","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_variant_print()"},{"type":"text","text":"’s annotated types like "},{"type":"codeVoice","code":"int64 -1000"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"There may be implementation specific restrictions on deeply nested values,"},{"type":"text","text":" "},{"text":"which would result in a ","type":"text"},{"type":"codeVoice","code":"recursion"},{"text":" error. ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true,"type":"reference"},{"text":" is","type":"text"},{"text":" ","type":"text"},{"text":"guaranteed to handle nesting up to at least 64 levels.","type":"text"}],"type":"paragraph"}]}],"variants":[{"paths":["\/documentation\/glib\/variantparse(type:text:limit:endptr:)-3p86p"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/variantParse(type:text:limit:endptr:)-3p86p"},"metadata":{"roleHeading":"Function","symbolKind":"func","externalID":"s:4GLib12variantParse4type4text5limit6endptrAA10VariantRefVSgxSg_SPys4Int8VGSgANSpyANGSgtKAA0H12TypeProtocolRzlF","modules":[{"name":"GLib"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"variantParse"},{"kind":"text","text":"<"},{"text":"VariantTypeT","kind":"genericParameter"},{"kind":"text","text":">("},{"text":"type","kind":"externalParam"},{"kind":"text","text":": "},{"text":"VariantTypeT","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"text"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"limit"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","pr
,"text":"; similarly,"},{"text":" ","type":"text"},{"type":"text","text":"in the event that no application "},{"code":"name","type":"codeVoice"},{"text":" has registered a bookmark","type":"text"},{"type":"text","text":" "},{"text":"for ","type":"text"},{"type":"codeVoice","code":"uri"},{"text":",  ","type":"text"},{"type":"codeVoice","code":"false"},{"text":" is returned and error is set to","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"appNotRegistered"},{"type":"text","text":".  Otherwise, if no bookmark"},{"type":"text","text":" "},{"type":"text","text":"for "},{"type":"codeVoice","code":"uri"},{"type":"text","text":" is found, one is created."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"set_app_info is deprecated:","type":"text"}]},{"type":"text","text":" "},{"text":"Use g_bookmark_file_set_application_info() instead, as","type":"text"},{"type":"text","text":" "},{"code":"time_t","type":"codeVoice"},{"type":"text","text":" is deprecated due to the year 2038 problem."}]}],"kind":"content"}],"abstract":[{"text":"Sets the meta-data of application ","type":"text"},{"type":"codeVoice","code":"name"},{"type":"text","text":" inside the list of"},{"type":"text","text":" "},{"type":"text","text":"applications that have registered a bookmark for "},{"code":"uri","type":"codeVoice"},{"text":" inside","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"bookmark"},{"text":".","type":"text"}],"metadata":{"role":"symbol","symbolKind":"method","modules":[{"name":"GLib"}],"title":"setAppInfo(uri:name:exec:count:stamp:)","extendedModule":"GLib","externalID":"s:4GLib20BookmarkFileProtocolPAAE10setAppInfo3uri4name4exec5count5stampSbSPys4Int8VGSg_A2MS2itKF","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"setAppInfo"},{"kind":"text","text":"("},{"kind":"externalParam","text":"uri"},{"text":": ","kind":"text"},{"kind":"typeIdentifie
{"abstract":[{"text":"Ends the builder process and returns the constructed value.","type":"text"}],"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"end","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"VariantRef","kind":"typeIdentifier","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef","preciseIdentifier":"s:4GLib10VariantRefV"},{"text":"!","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"It is not permissible to use ","type":"text"},{"type":"codeVoice","code":"builder"},{"text":" in any way after this call","type":"text"},{"type":"text","text":" "},{"text":"except for reference counting operations (in the case of a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"heap-allocated "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilder"},{"text":") or by reinitialising it with","type":"text"},{"text":" ","type":"text"},{"code":"g_variant_builder_init()","type":"codeVoice"},{"text":" (in the case of stack-allocated). This","type":"text"},{"type":"text","text":" "},{"type":"text","text":"means that for the stack-allocated builders there is no need to"},{"type":"text","text":" "},{"type":"text","text":"call "},{"type":"codeVoice","code":"g_variant_builder_clear()"},{"type":"text","text":" after the call to"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_variant_builder_end()"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"It is an error to call this function in any way that would create an"},{"type":"text","text":" "},{"type":"text","text":"inconsistent value to be constructed (ie: insufficient number of"},{"type":"text","text":" "},{"type":"text","text":"items added to a container with a specific num
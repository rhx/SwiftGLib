ext"},{"text":"construct.  It can be an indefinite type such as","type":"text"},{"type":"text","text":" "},{"code":"G_VARIANT_TYPE_ARRAY","type":"codeVoice"},{"type":"text","text":" or a definite type such as “as” or “(ii)”."},{"text":" ","type":"text"},{"type":"text","text":"Maybe, array, tuple, dictionary entry and variant-typed values may be"},{"text":" ","type":"text"},{"type":"text","text":"constructed."}]},{"type":"paragraph","inlineContent":[{"text":"If using a static type such as one of the ","type":"text"},{"code":"G_VARIANT_TYPE_*","type":"codeVoice"},{"text":" constants","type":"text"},{"text":" ","type":"text"},{"text":"or a ","type":"text"},{"code":"G_VARIANT_TYPE (\"(ii)\")","type":"codeVoice"},{"text":" macro, it is more performant to use","type":"text"},{"text":" ","type":"text"},{"code":"g_variant_builder_init_static()","type":"codeVoice"},{"type":"text","text":" rather than "},{"code":"g_variant_builder_init()","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"After the builder is initialised, values are added using"},{"type":"text","text":" "},{"code":"g_variant_builder_add_value()","type":"codeVoice"},{"type":"text","text":" or "},{"type":"codeVoice","code":"g_variant_builder_add()"},{"text":".","type":"text"}]},{"inlineContent":[{"type":"text","text":"After all the child values are added, "},{"type":"codeVoice","code":"g_variant_builder_end()"},{"text":" frees","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the memory associated with the builder and returns the "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true,"type":"reference"},{"type":"text","text":" that"},{"text":" ","type":"text"},{"text":"was created.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"This function completely ignores the previous contents of ","type":"text"},{"type":"codeVoice","code":"builder"},{"text":".","type":"text"},{"type":"text","text":" "},{"text":"On one hand this means that it is valid to pass in completely","type":"text"},{"type":"text","text":" "},{"text":"uninitialised memory.  On the other hand, this means that if you are","type":"text"},{"type":"text","text":" "},{"text":"initialising over top of an existing ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilder","type":"reference","isActive":true},{"text":" you need to","type":"text"},{"type":"text","text":" "},{"text":"first call ","type":"text"},{"code":"g_variant_builder_clear()","type":"codeVoice"},{"type":"text","text":" in order to avoid leaking"},{"text":" ","type":"text"},{"type":"text","text":"memory."}]},{"inlineContent":[{"text":"You must not call ","type":"text"},{"type":"codeVoice","code":"g_variant_builder_ref()"},{"type":"text","text":" or"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_variant_builder_unref()"},{"text":" on a ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilder","isActive":true},{"text":" that was initialised","type":"text"},{"type":"text","text":" "},{"text":"with this function.  If you ever pass a reference to a","type":"text"},{"type":"text","text":" "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilder","type":"reference"},{"type":"text","text":" outside of the control of your own code then you"},{"type":"text","text":" "},{"type":"text","text":"should assume that the person receiving that reference may try to use"},{"type":"text","text":" "},{"text":"reference counting; you should use ","type":"text"},{"code":"g_variant_builder_new()","type":"codeVoice"},{"type":"text","text":" instead of"},{"type":"text","text":" "},{"text":"this function.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/VariantBuilderRef","doc:\/\/GLib\/documentation\/GLib\/VariantBuilderRef\/VariantBuilderProt
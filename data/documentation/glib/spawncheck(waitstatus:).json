{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/spawnCheck(waitStatus:)"},"sections":[],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"metadata":{"roleHeading":"Function","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"spawnCheck"},{"kind":"text","text":"("},{"text":"waitStatus","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":") ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"symbolKind":"func","externalID":"s:4GLib10spawnCheck10waitStatusSbSi_tKF","role":"symbol","title":"spawnCheck(waitStatus:)","modules":[{"name":"GLib"}]},"abstract":[{"text":"Set ","type":"text"},{"code":"error","type":"codeVoice"},{"type":"text","text":" if "},{"code":"waitStatus","type":"codeVoice"},{"text":" indicates the child exited abnormally","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"(e.g. with a nonzero exit code, or via a fatal signal)."}],"schemaVersion":{"patch":0,"minor":3,"major":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/spawncheck(waitstatus:)"]}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"spawnCheck","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"waitStatus"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"g_spawn_sync()"},{"type":"text","text":" and "},{"type":"codeVoice","code":"g_child_watch_add()"},{"type":"text","text":" family of APIs return the"},{"type":"text","text":" "},{"type":"text","text":"status of subprocesses encoded in a platform-specific way."},{"text":" ","type":"text"},{"text":"On Unix, this is guaranteed to be in the same format ","type":"text"},{"code":"waitpid()","type":"codeVoice"},{"type":"text","text":" returns,"},{"text":" ","type":"text"},{"type":"text","text":"and on Windows it is guaranteed to be the result of "},{"type":"codeVoice","code":"GetExitCodeProcess()"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Prior to the introduction of this function in GLib 2.34, interpreting"},{"text":" ","type":"text"},{"code":"waitStatus","type":"codeVoice"},{"text":" required use of platform-specific APIs, which is problematic","type":"text"},{"text":" ","type":"text"},{"text":"for software using GLib as a cross-platform layer.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Additionally, many programs simply want to determine whether or not"},{"type":"text","text":" "},{"text":"the child exited successfully, and either propagate a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/GLibError"},{"type":"text","text":" or"},{"type":"text","text":" "},{"type":"text","text":"print a message to standard error. In that common case, this function"},{"text":" ","type":"text"},{"type":"text","text":"can be used. Note that the error message in "},{"type":"codeVoice","code":"error"},{"text":" will contain","type":"text"},{"type":"text","text":" "},{"text":"human-readable information about the wait status.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"domain"},{"type":"text","text":" and "},{"code":"code","type":"codeVoice"},{"type":"text","text":" of "},{"type":"codeVoice","code":"error"},{"text":" have special semantics in the case","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"where the process has an “exit code”, as opposed to being killed by"},{"type":"text","text":" "},{"text":"a signal. On Unix, this happens if ","type":"text"},{"code":"WIFEXITED()","type":"codeVoice"},{"text":" would be true of","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"waitStatus"},{"text":". On Windows, it is always the case.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The special semantics are that the actual exit code will be the"},{"type":"text","text":" "},{"text":"code set in ","type":"text"},{"type":"codeVoice","code":"error"},{"type":"text","text":", and the domain will be "},{"type":"codeVoice","code":"G_SPAWN_EXIT_ERROR"},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"This allows you to differentiate between different exit codes."}]},{"type":"paragraph","inlineContent":[{"text":"If the process was terminated by some means other than an exit","type":"text"},{"text":" ","type":"text"},{"text":"status (for example if it was killed by a signal), the domain will be","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"G_SPAWN_ERROR"},{"type":"text","text":" and the code will be "},{"type":"codeVoice","code":"failed"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"This function just offers convenience; you can of course also check","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the available platform via a macro such as "},{"type":"codeVoice","code":"G_OS_UNIX"},{"text":", and use","type":"text"},{"type":"text","text":" "},{"code":"WIFEXITED()","type":"codeVoice"},{"type":"text","text":" and "},{"code":"WEXITSTATUS()","type":"codeVoice"},{"type":"text","text":" on "},{"code":"waitStatus","type":"codeVoice"},{"type":"text","text":" directly. Do not attempt"},{"type":"text","text":" "},{"text":"to scan or parse the error message string; it may be translated and\/or","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"change in future versions of GLib."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Prior to version 2.70, "},{"code":"g_spawn_check_exit_status()","type":"codeVoice"},{"text":" provides the same","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"functionality, although under a misleading name."}]}]}],"references":{"doc://GLib/documentation/GLib/spawnCheck(waitStatus:)":{"type":"topic","abstract":[{"text":"Set ","type":"text"},{"type":"codeVoice","code":"error"},{"type":"text","text":" if "},{"type":"codeVoice","code":"waitStatus"},{"text":" indicates the child exited abnormally","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(e.g. with a nonzero exit code, or via a fatal signal)."}],"url":"\/documentation\/glib\/spawncheck(waitstatus:)","kind":"symbol","title":"spawnCheck(waitStatus:)","identifier":"doc:\/\/GLib\/documentation\/GLib\/spawnCheck(waitStatus:)","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"spawnCheck","kind":"identifier"},{"kind":"text","text":"("},{"text":"waitStatus","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":") "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}]},"doc://GLib/documentation/GLib/GLibError":{"abstract":[{"text":"The ","type":"text"},{"code":"GError","type":"codeVoice"},{"type":"text","text":" structure contains information about"},{"text":" ","type":"text"},{"type":"text","text":"an error that has occurred."}],"title":"GLibError","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"GLibError"}],"kind":"symbol","url":"\/documentation\/glib\/gliberror","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"GLibError"}],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/GLibError"},"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]}}}
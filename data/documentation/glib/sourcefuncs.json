{"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"SourceFuncs"}]}]},{"content":[{"level":2,"anchor":"overview","type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For idle sources, the prepare and check functions always return "},{"type":"codeVoice","code":"true"},{"text":" ","type":"text"},{"text":"to indicate that the source is always ready to be processed. The prepare","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"function also returns a timeout value of 0 to ensure that the "},{"type":"codeVoice","code":"poll()"},{"type":"text","text":" call"},{"text":" ","type":"text"},{"type":"text","text":"doesn’t block (since that would be time wasted which could have been spent"},{"text":" ","type":"text"},{"type":"text","text":"running the idle function)."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For timeout sources, the prepare and check functions both return "},{"code":"true","type":"codeVoice"},{"text":" ","type":"text"},{"text":"if the timeout interval has expired. The prepare function also returns","type":"text"},{"text":" ","type":"text"},{"text":"a timeout value to ensure that the ","type":"text"},{"type":"codeVoice","code":"poll()"},{"type":"text","text":" call doesn’t block too long"},{"text":" ","type":"text"},{"type":"text","text":"and miss the next timeout."}]},{"inlineContent":[{"type":"text","text":"For file descriptor sources, the prepare function typically returns "},{"type":"codeVoice","code":"false"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"since it must wait until "},{"code":"poll()","type":"codeVoice"},{"type":"text","text":" has been called before it knows whether"},{"type":"text","text":" "},{"type":"text","text":"any events need to be processed. It sets the returned timeout to -1 to"},{"type":"text","text":" "},{"text":"indicate that it doesn’t mind how long the ","type":"text"},{"code":"poll()","type":"codeVoice"},{"text":" call blocks. In the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"check function, it tests the results of the "},{"code":"poll()","type":"codeVoice"},{"text":" call to see if the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"required condition has been met, and returns "},{"code":"true","type":"codeVoice"},{"text":" if so.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncs","isActive":true},{"type":"text","text":" type acts as an owner of an underlying "},{"type":"codeVoice","code":"GSourceFuncs"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"type":"text","text":"It provides the methods that can operate on this data type through "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsProtocol","type":"reference","isActive":true},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"text":"Use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncs"},{"type":"text","text":" as a strong reference or owner of a "},{"type":"codeVoice","code":"GSourceFuncs"},{"text":" instance.","type":"text"}]},{"content":[{"inlineContent":[{"text":"Use ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef","isActive":true},{"type":"text","text":" (instead of "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncs","type":"reference","isActive":true},{"text":") for a lightweight Swift reference to an underlying ","type":"text"},{"code":"GSourceFuncs","type":"codeVoice"},{"text":" instance.","type":"text"}],"type":"paragraph"}],"style":"note","type":"aside","name":"Note"}],"kind":"content"}],"kind":"symbol","sche
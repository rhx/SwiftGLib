{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"logWriterDefaultSet"},{"kind":"text","text":"("},{"text":"useStderr","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"kind":"text","text":")"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The built-in log functions are [func"},{"code":"GLib.log_default_handler","type":"codeVoice"},{"type":"text","text":"] for the"},{"text":" ","type":"text"},{"type":"text","text":"old-style API, and both [func"},{"type":"codeVoice","code":"GLib.log_writer_default"},{"type":"text","text":"] and"},{"text":" ","type":"text"},{"type":"text","text":"[func"},{"type":"codeVoice","code":"GLib.log_writer_standard_streams"},{"type":"text","text":"] for the structured API."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"By default, log messages of levels [flags"},{"code":"GLib.LogLevelFlags.LEVEL_INFO","type":"codeVoice"},{"text":"] and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[flags"},{"code":"GLib.LogLevelFlags.LEVEL_DEBUG","type":"codeVoice"},{"text":"] are sent to ","type":"text"},{"code":"stdout","type":"codeVoice"},{"text":", and other log messages are","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"sent to "},{"type":"codeVoice","code":"stderr"},{"type":"text","text":". This is problematic for applications that intend"},{"type":"text","text":" "},{"type":"text","text":"to reserve "},{"code":"stdout","type":"codeVoice"},{"text":" for structured output such as JSON or XML.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function sets global state. It is not thread-aware, and should be"},{"text":" ","type":"text"},{"text":"called at the very start of a program, before creating any other threads","type":"text"},{"type":"text","text":" "},{"type":"text","text":"or creating objects that could create worker threads of their own."}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/logwriterdefaultset(usestderr:)"]}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/logWriterDefaultSet(useStderr:)","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"abstract":[{"type":"text","text":"Configure whether the built-in log functions will output all log messages to"},{"type":"text","text":" "},{"type":"codeVoice","code":"stderr"},{"text":".","type":"text"}],"metadata":{"role":"symbol","symbolKind":"func","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"logWriterDefaultSet"},{"kind":"text","text":"("},{"kind":"externalParam","text":"useStderr"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"kind":"text","text":")"}],"title":"logWriterDefaultSet(useStderr:)","roleHeading":"Function","modules":[{"name":"GLib"}],"externalID":"s:4GLib19logWriterDefaultSet9useStderrySb_tF"},"sections":[],"schemaVersion":{"patch":0,"minor":3,"major":0},"kind":"symbol","references":{"doc://GLib/documentation/GLib/logWriterDefaultSet(useStderr:)":{"abstract":[{"type":"text","text":"Configure whether the built-in log functions will output all log messages to"},{"text":" ","type":"text"},{"type":"codeVoice","code":"stderr"},{"type":"text","text":"."}],"url":"\/documentation\/glib\/logwriterdefaultset(usestderr:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"logWriterDefaultSet"},{"text":"(","kind":"text"},{"text":"useStderr","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"},{"kind":"text","text
{"sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/OptionContextRef","doc:\/\/GLib\/documentation\/GLib\/OptionContextRef\/OptionContextProtocol-Implementations"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"role":"symbol","roleHeading":"Instance Method","extendedModule":"GLib","modules":[{"name":"GLib"}],"title":"set(strictPosix:)","symbolKind":"method","externalID":"s:4GLib21OptionContextProtocolPAAE3set11strictPosixySb_tF::SYNTHESIZED::s:4GLib16OptionContextRefV","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"set"},{"kind":"text","text":"("},{"text":"strictPosix","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"text":")","kind":"text"}]},"abstract":[{"type":"text","text":"Sets strict POSIX mode."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"set","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"strictPosix"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"},{"text":")","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"text":"By default, this mode is disabled.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In strict POSIX mode, the first non-argument parameter encountered"},{"type":"text","text":" "},{"text":"(eg: filename) terminates argument processing.  Remaining arguments","type":"text"},{"text":" ","type":"text"},{"text":"are treated as non-options and are not attempted to be parsed.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If strict POSIX mode is disabled then parsing is done in the GNU way"},{"type":"text","text":" "},{"type":"text","text":"where option arguments can be freely mixed with non-options."}]},{"type":"paragraph","inlineContent":[{"text":"As an example, consider “ls foo -l”.  With GNU style parsing, this","type":"text"},{"text":" ","type":"text"},{"text":"will list “foo” in long mode.  In strict POSIX style, this will list","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the files named “foo” and “-l”."}]},{"inlineContent":[{"type":"text","text":"It may be useful to force strict POSIX mode when creating “verb"},{"type":"text","text":" "},{"type":"text","text":"style” command line tools.  For example, the “gsettings” command line"},{"type":"text","text":" "},{"type":"text","text":"tool supports the global option “–schemadir” as well as many"},{"type":"text","text":" "},{"type":"text","text":"subcommands (“get”, “set”, etc.) which each have their own set of"},{"text":" ","type":"text"},{"type":"text","text":"arguments.  Using strict POSIX mode will allow parsing the global"},{"text":" ","type":"text"},{"text":"options up to the verb name while leaving the remaining options to be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"parsed by the relevant subcommand (which can be determined by"},{"text":" ","type":"text"},{"type":"text","text":"examining the verb name, which should be present in argv[1] after"},{"type":"text","text":" "},{"type":"text","text":"parsing)."}],"type":"paragraph"}],"kind":"content"}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/OptionContextRef\/set(strictPosix:)","interfaceLanguage":"swift"},"kind":"symbol","variants":[{"paths":["\/documentation\/glib\/optioncontextref\/set(strictposix:)"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://GLib/documentation/GLib/OptionContextRef/OptionContextProtocol-Implementations":{"title":"OptionContextProtocol Implementations","url":"\/documentation\/glib\/optioncontextref\/optioncontextprotocol-implementations","role":"collectionGroup","kind":"article","type":"topic","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib\/OptionContextRef\/OptionContextProtocol-Implementations"},"doc://GLib/documentation/GLib/OptionContextRef":{"title":"OptionContextRef","type":"topic","url":"\/documentation\/glib\/optioncontextref","navigatorTitle":[{"text":"OptionContextRef","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/OptionContextRef","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"OptionContextRef","kind":"identifier"}],"kind":"symbol","role":"symbol","abstract":[{"text":"A ","type":"text"},{"code":"GOptionContext","type":"codeVoice"},{"type":"text","text":" struct defines which options"},{"type":"text","text":" "},{"type":"text","text":"are accepted by the commandline option parser. The struct has only private"},{"text":" ","type":"text"},{"type":"text","text":"fields and should not be directly accessed."}]},"doc://GLib/documentation/GLib/OptionContextRef/set(strictPosix:)":{"type":"topic","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"set"},{"text":"(","kind":"text"},{"text":"strictPosix","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"text":")","kind":"text"}],"url":"\/documentation\/glib\/optioncontextref\/set(strictposix:)","abstract":[{"type":"text","text":"Sets strict POSIX mode."}],"kind":"symbol","title":"set(strictPosix:)","identifier":"doc:\/\/GLib\/documentation\/GLib\/OptionContextRef\/set(strictPosix:)","role":"symbol"},"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]}}}
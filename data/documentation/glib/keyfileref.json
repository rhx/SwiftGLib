{"abstract":[{"type":"codeVoice","code":"GKeyFile"},{"text":" parses .ini-like config files.","type":"text"}],"variants":[{"paths":["\/documentation\/glib\/keyfileref"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"KeyFileRef","kind":"identifier"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"anchor":"overview","text":"Overview"},{"inlineContent":[{"type":"codeVoice","code":"GKeyFile"},{"text":" lets you parse, edit or create files containing groups of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"key-value pairs, which we call ‘key files’ for lack of a better name."},{"text":" ","type":"text"},{"text":"Several freedesktop.org specifications use key files. For example, the","type":"text"},{"type":"text","text":" "},{"identifier":"https:\/\/specifications.freedesktop.org\/desktop-entry-spec\/latest\/","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"and the ","type":"text"},{"identifier":"https:\/\/specifications.freedesktop.org\/icon-theme-spec\/latest\/","isActive":true,"type":"reference"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The syntax of key files is described in detail in the"},{"type":"text","text":" "},{"isActive":true,"overridingTitleInlineContent":[{"type":"text","text":"Desktop Entry Specification"}],"type":"reference","overridingTitle":"Desktop Entry Specification","identifier":"https:\/\/specifications.freedesktop.org\/desktop-entry-spec\/latest\/"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"here is a quick summary: Key files consists of groups of key-value pairs, interspersed"},{"type":"text","text":" "},{"type":"text","text":"with comments."}]},{"syntax":"txt","type":"codeListing","code":["# this is just an example","# there can be comments before the first group","","[First Group]","","Name=Key File Example\\tthis value shows\\nescaping","","# localized strings are stored in multiple key-value pairs","Welcome=Hello","Welcome[de]=Hallo","Welcome[fr_FR]=Bonjour","Welcome[it]=Ciao","","[Another Group]","","Numbers=2;20;-200;0","","Booleans=true;false;true;true"]},{"type":"paragraph","inlineContent":[{"text":"Lines beginning with a ","type":"text"},{"code":"#","type":"codeVoice"},{"text":" and blank lines are considered comments.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Groups are started by a header line containing the group name enclosed"},{"type":"text","text":" "},{"text":"in ","type":"text"},{"code":"[","type":"codeVoice"},{"type":"text","text":" and "},{"code":"]","type":"codeVoice"},{"type":"text","text":", and ended implicitly by the start of the next group or"},{"type":"text","text":" "},{"type":"text","text":"the end of the file. Each key-value pair must be contained in a group."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Key-value pairs generally have the form "},{"type":"codeVoice","code":"key=value"},{"type":"text","text":", with the exception"},{"type":"text","text":" "},{"type":"text","text":"of localized strings, which have the form "},{"type":"codeVoice","code":"key[locale]=value"},{"type":"text","text":", with a"},{"text":" ","type":"text"},{"type":"text","text":"locale identifier of the form "},{"code":"lang_COUNTRY","type":"codeVoice"},{"type":"text","text":"MODIFIER`` where "},{"code":"COUNTRY","type":"codeVoice"},{"text":" ","type":"text"},{"text":"and `MODIFIER` are optional. As a special case, the locale `C` is associated","type":"text"},{"text":" ","type":"text"},{"text":"with the untranslated pair `key=value` (since GLib 2.84). Space before and","type":"text"},{"type":"text","text":" "},{"text":"after the `=` character is ignored. Newline, tab, carriage return and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"backslash characters in value are escaped as `\\n`, `\\t`, `\\r`, and `\\\\`,"},{"text":" ","type":"text"},{"text":"respectively. To preserve leading spaces in values, these can also be escaped","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"as `\\s`."}]},{"type":"paragraph","inlineContent":[{"text":"Key files can store strings (possibly with localized variants), integers,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"booleans and lists of these. Lists are separated by a separator character,"},{"text":" ","type":"text"},{"type":"text","text":"typically "},{"code":";","type":"codeVoice"},{"type":"text","text":" or "},{"type":"codeVoice","code":","},{"text":". To use the list separator character in a value in","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"a list, it has to be escaped by prefixing it with a backslash."}]},{"type":"paragraph","inlineContent":[{"text":"This syntax is obviously inspired by the .ini files commonly met","type":"text"},{"text":" ","type":"text"},{"text":"on Windows, but there are some important differences:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":".ini files use the ","type":"text"},{"code":";","type":"codeVoice"},{"text":" character to begin comments,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"key files use the "},{"code":"#","type":"codeVoice"},{"type":"text","text":" character."}]}]},{"content":[{"inlineContent":[{"text":"Key files do not allow for ungrouped keys meaning only","type":"text"},{"text":" ","type":"text"},{"text":"comments can precede the first group.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Key files are always encoded in UTF-8.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Key and Group names are case-sensitive. For example, a group called","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"[GROUP]"},{"type":"text","text":" is a different from "},{"code":"[group]","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":".ini files don’t have a strongly typed boolean entry type,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"they only have "},{"type":"codeVoice","code":"GetProfileInt()"},{"type":"text","text":". In key files, only"},{"text":" ","type":"text"},{"code":"true","type":"codeVoice"},{"type":"text","text":" and "},{"code":"false","type":"codeVoice"},{"type":"text","text":" (in lower case) are allowed."}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that in contrast to the"},{"text":" ","type":"text"},{"identifier":"https:\/\/specifications.freedesktop.org\/desktop-entry-spec\/latest\/","type":"reference","isActive":true,"overridingTitle":"Desktop Entry Specification","overridingTitleInlineContent":[{"text":"Desktop Entry Specification","type":"text"}]},{"type":"text","text":","},{"type":"text","text":" "},{"text":"groups in key files may contain the same key multiple times; the last entry wins.","type":"text"},{"type":"text","text":" "},{"text":"Key files may also contain multiple groups with the same name; they are merged","type":"text"},{"type":"text","text":" "},{"type":"text","text":"together. Another difference is that keys and group names in key files are not"},{"text":" ","type":"text"},{"text":"restricted to ASCII characters.","type":"text"}]},{"inlineContent":[{"text":"Here is an example of loading a key file and reading a value:","type":"text"}],"type":"paragraph"},{"code":["`g_autoptr(GError)` error = NULL;","`g_autoptr(GKeyFile)` key_file = g_key_file_new ();","","if (!g_key_file_load_from_file (key_file, \"key-file.ini\", flags, &error))","  {","    if (!g_error_matches (error, G_FILE_ERROR, G_FILE_ERROR_NOENT))","      g_warning (\"Error loading key file: `s`\", error->message);","    return;","  }","","g_autofree gchar *val = g_key_file_get_string (key_file, \"Group Name\", \"SomeKey\", &error);","if (val == NULL &&","    !g_error_matches (error, G_KEY_FILE_ERROR, G_KEY_FILE_ERROR_KEY_NOT_FOUND))","  {","    g_warning (\"Error finding key in key file: `s`\", error->message);","    return;","  }","else if (val == NULL)","  {","    \/\/ Fall back to a default value.","    val = g_strdup (\"default-value\");","  }"],"type":"codeListing","syntax":"c"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Here is an example of creating and saving a key file:"}]},{"syntax":"c","code":["`g_autoptr(GKeyFile)` key_file = g_key_file_new ();","const gchar *val = …;","`g_autoptr(GError)` error = NULL;","","g_key_file_set_string (key_file, \"Group Name\", \"SomeKey\", val);","","\/\/ Save as a file.","if (!g_key_file_save_to_file (key_file, \"key-file.ini\", &error))","  {","    g_warning (\"Error saving key file: `s`\", error->message);","    return;","  }","","\/\/ Or store to a GBytes for use elsewhere.","gsize data_len;","g_autofree guint8 *data = (guint8 *) g_key_file_to_data (key_file, &data_len, &error);","if (data == NULL)","  {","    g_warning (\"Error saving key file: `s`\", error->message);","    return;","  }","`g_autoptr(GBytes)` bytes = g_bytes_new_take (g_steal_pointer (&data), data_len);"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/KeyFileRef"},{"type":"text","text":" type acts as a lightweight Swift reference to an underlying "},{"code":"GKeyFile","type":"codeVoice"},{"type":"text","text":" instance."},{"text":" ","type":"text"},{"text":"It exposes methods that can operate on this data type through ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/KeyFileProtocol","isActive":true},{"type":"text","text":" conformance."},{"text":" ","type":"text"},{"text":"Use ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/KeyFileRef","type":"reference","isActive":true},{"text":" only as an ","type":"text"},{"type":"codeVoice","code":"unowned"},{"type":"text","text":" reference to an existing "},{"code":"GKeyFile","type":"codeVoice"},{"text":" instance.","type":"text"}]},{"name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/KeyFile","type":"reference","isActive":true},{"text":" (instead of ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/KeyFileRef","type":"reference"},{"text":") if you want to use Automatic Reference Counting for memory management of the underlying ","type":"text"},{"code":"GKeyFile","type":"codeVoice"},{"text":" instance.","type":"text"}]}],"type":"aside","style":"note"}],"kind":"content"}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/KeyFileRef","interfaceLanguage":"swift"},"kind":"symbol","metadata":{"navigatorTitle":[{"text":"KeyFileRef","kind":"identifier"}],"symbolKind":"struct","roleHeading":"Structure","externalID":"s:4GLib10KeyFileRefV","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"KeyFileRef"}],"role":"symbol","modules":[{"name":"GLib"}],"title":"KeyFileRef"},"relationshipsSections":[{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/KeyFileProtocol","doc:\/\/GLib\/documentation\/GLib\/PointerWrapper"],"type":"conformsTo","title":"Conforms To","kind":"relationships"}],"topicSections":[{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/KeyFileRef\/init()","doc:\/\/GLib\/documentation\/GLib\/KeyFileRef\/init(_:)-5cs5o","doc:\/\/GLib\/documentation\/GLib\/KeyFileRef\/init(_:)-766bl","doc:\/\/GLib\/documentation\/GLib\/KeyFileRef\/init(_:)-776w8","doc:\/\/GLib\/documentation\/GLib\/KeyFileRef\/init(_:)-7qdi8","doc:\/\/G
rces are ready and ","type":"text"},{"type":"codeVoice","code":"mayBlock"},{"type":"text","text":" is true, waiting"},{"type":"text","text":" "},{"text":"for a source to become ready, then dispatching the highest priority","type":"text"},{"text":" ","type":"text"},{"text":"events sources that are ready. Otherwise, if ","type":"text"},{"code":"mayBlock","type":"codeVoice"},{"text":" is false,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"this function does not wait for sources to become ready, and only the highest"},{"type":"text","text":" "},{"type":"text","text":"priority sources which are already ready (if any) will be dispatched."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that even when "},{"code":"mayBlock","type":"codeVoice"},{"text":" is true, it is still possible for","type":"text"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.MainContext.iteration"},{"type":"text","text":"] to return false, since the wait may"},{"text":" ","type":"text"},{"type":"text","text":"be interrupted for other reasons than an event source becoming ready."}]}]}],"references":{"doc://GLib/documentation/GLib/MainContextProtocol":{"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"MainContextProtocol"}],"title":"MainContextProtocol","identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContextProtocol","abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"GMainContext"},{"type":"text","text":" struct is an opaque data"},{"type":"text","text":" "},{"text":"type representing a set of sources to be handled in a main loop.","type":"text"}],"fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"text":"MainContextProtocol","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/glib\/maincontextprotocol","type":"topic"},"doc://GLib/documentation/GLib/MainContextProtocol/iteration(mayBlock:)":{"type":"topic","title":"iteration(mayBlock:)","identi
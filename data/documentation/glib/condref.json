{"kind":"symbol","topicSections":[{"title":"Initializers","identifiers":["doc:\/\/GLib\/documentation\/GLib\/CondRef\/init(_:)-3vuu1","doc:\/\/GLib\/documentation\/GLib\/CondRef\/init(_:)-5lwo4","doc:\/\/GLib\/documentation\/GLib\/CondRef\/init(_:)-64xk6","doc:\/\/GLib\/documentation\/GLib\/CondRef\/init(_:)-858ub","doc:\/\/GLib\/documentation\/GLib\/CondRef\/init(_:)-d6nf","doc:\/\/GLib\/documentation\/GLib\/CondRef\/init(cPointer:)","doc:\/\/GLib\/documentation\/GLib\/CondRef\/init(constPointer:)","doc:\/\/GLib\/documentation\/GLib\/CondRef\/init(gconstpointer:)","doc:\/\/GLib\/documentation\/GLib\/CondRef\/init(gpointer:)","doc:\/\/GLib\/documentation\/GLib\/CondRef\/init(mutating:)","doc:\/\/GLib\/documentation\/GLib\/CondRef\/init(opaquePointer:)"],"generated":true,"anchor":"Initializers"},{"generated":true,"anchor":"Instance-Properties","identifiers":["doc:\/\/GLib\/documentation\/GLib\/CondRef\/ptr"],"title":"Instance Properties"},{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/CondRef\/CondProtocol-Implementations","doc:\/\/GLib\/documentation\/GLib\/CondRef\/PointerWrapper-Implementations"],"anchor":"Default-Implementations","title":"Default Implementations","generated":true}],"relationshipsSections":[{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/CondProtocol","doc:\/\/GLib\/documentation\/GLib\/PointerWrapper"],"kind":"relationships","type":"conformsTo","title":"Conforms To"}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/CondRef"},"abstract":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","type":"reference","isActive":true},{"type":"text","text":" struct is an opaque data structure that represents a"},{"text":" ","type":"text"},{"text":"condition. Threads can block on a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","type":"reference"},{"type":"text","text":" if they find a certain"},{"text":" ","type":"text"},{"text":"condition to be false. If other threads change the state of this","type":"text"},{"type":"text","text":" "},{"type":"text","text":"condition they signal the "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","isActive":true},{"type":"text","text":", and that causes the waiting"},{"text":" ","type":"text"},{"text":"threads to be woken up.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"variants":[{"paths":["\/documentation\/glib\/condref"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CondRef","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"Consider the following example of a shared variable.  One or more","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"threads can wait for data to be published to the variable and when"},{"text":" ","type":"text"},{"type":"text","text":"another thread publishes the data, it can signal one of the waiting"},{"type":"text","text":" "},{"type":"text","text":"threads to wake up to collect the data."}]},{"inlineContent":[{"text":"Here is an example for using GCond to block a thread until a condition","type":"text"},{"text":" ","type":"text"},{"text":"is satisfied:","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(C Language Example):"}],"type":"paragraph"},{"syntax":"C","code":["  gpointer current_data = NULL;","  GMutex data_mutex;","  GCond data_cond;","","  void","  push_data (gpointer data)","  {","    g_mutex_lock (&data_mutex);","    current_data = data;","    g_cond_signal (&data_cond);","    g_mutex_unlock (&data_mutex);","  }","","  gpointer","  pop_data (void)","  {","    gpointer data;","","    g_mutex_lock (&data_mutex);","    while (!current_data)","      g_cond_wait (&data_cond, &data_mutex);","    data = current_data;","    current_data = NULL;","    g_mutex_unlock (&data_mutex);","","    return data;","  }"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Whenever a thread calls "},{"type":"codeVoice","code":"pop_data()"},{"type":"text","text":" now, it will wait until"},{"text":" ","type":"text"},{"text":"current_data is non-","type":"text"},{"code":"nil","type":"codeVoice"},{"text":", i.e. until some other thread","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"has called "},{"type":"codeVoice","code":"push_data()"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"The example shows that use of a condition variable must always be","type":"text"},{"text":" ","type":"text"},{"text":"paired with a mutex.  Without the use of a mutex, there would be a","type":"text"},{"type":"text","text":" "},{"text":"race between the check of ","type":"text"},{"type":"codeVoice","code":"current_data"},{"type":"text","text":" by the while loop in"},{"type":"text","text":" "},{"code":"pop_data()","type":"codeVoice"},{"type":"text","text":" and waiting. Specifically, another thread could set"},{"type":"text","text":" "},{"type":"codeVoice","code":"current_data"},{"type":"text","text":" after the check, and signal the cond (with nobody"},{"text":" ","type":"text"},{"type":"text","text":"waiting on it) before the first thread goes to sleep. "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","isActive":true,"type":"reference"},{"type":"text","text":" is"},{"type":"text","text":" "},{"text":"specifically useful for its ability to release the mutex and go","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to sleep atomically."}]},{"inlineContent":[{"type":"text","text":"It is also important to use the "},{"code":"g_cond_wait()","type":"codeVoice"},{"type":"text","text":" and "},{"code":"g_cond_wait_until()","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"functions only inside a loop which checks for the condition to be"},{"text":" ","type":"text"},{"text":"true.  See ","type":"text"},{"type":"codeVoice","code":"g_cond_wait()"},{"text":" for an explanation of why the condition may","type":"text"},{"text":" ","type":"text"},{"text":"not be true even after it returns.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If a ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","type":"reference","isActive":true},{"text":" is allocated in static storage then it can be used","type":"text"},{"type":"text","text":" "},{"text":"without initialisation.  Otherwise, you should call ","type":"text"},{"code":"g_cond_init()","type":"codeVoice"},{"text":" ","type":"text"},{"text":"on it and ","type":"text"},{"type":"codeVoice","code":"g_cond_clear()"},{"text":" when done.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","isActive":true},{"text":" should only be accessed via the g_cond_ functions.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/CondRef","isActive":true,"type":"reference"},{"text":" type acts as a lightweight Swift reference to an underlying ","type":"text"},{"type":"codeVoice","code":"GCond"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"type":"text","text":"It exposes methods that can operate on this data type through "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/CondProtocol","isActive":true},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"text":"Use ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/CondRef","isActive":true,"type":"reference"},{"type":"text","text":" only as an "},{"type":"codeVoice","code":"unowned"},{"type":"text","text":" reference to an existing "},{"code":"GCond","type":"codeVoice"},{"text":" instance.","type":"text"}]},{"style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","isActive":true,"type":"reference"},{"type":"text","text":" (instead of "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/CondRef","isActive":true},{"type":"text","text":") if you want to use Automatic Reference Counting for memory management of the underlying "},{"type":"codeVoice","code":"GCond"},{"type":"text","text":" instance."}]}],"type":"aside"}]}],"metadata":{"title":"CondRef","externalID":"s:4GLib7CondRefV","symbolKind":"struct","modules":[{"name":"GLib"}],"navigatorTitle":[{"text":"CondRef","kind":"identifier"}],"role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"CondRef"}],"roleHeading":"Structure"},"schemaVersion":{"minor":3,"major":0,"patch":0},"references":{"doc://GLib/documentation/GLib/CondRef/init(gpointer:)":{"url":"\/documentation\/glib\/condref\/init(gpointer:)","title":"init(gpointer:)","identifier":"doc:\/\/GLib\/documentation\/GLib\/CondRef\/init(gpointer:)","abstract":[{"type":"text","text":"Conditional initialiser from an optional "},{"type":"codeVoice","code":"gpointer"}],"role":"symbol","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"!("},{"kind":"externalParam","text":"gpointer"},{"text":": ","kind":"text"},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:@T@gpointer"},{"kind":"text","text":"?)"}],"type":"topic","kind":"symbol"},"doc://GLib/documentation/GLib/CondRef/CondProtocol-Implementations":{"type":"topic","role":"collectionGroup","url":"\/documentation\/glib\/condref\/condprotocol-implementations","kind":"article","identifier":"doc:\/\/GLib\/documentation\/GLib\/CondRef\/CondProtocol-Implementations","title":"CondProtocol Implemen
dentifier"},{"kind":"text","text":"? = nil)"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"inlineContent":[{"type":"text","text":"The use case here is that you are running a test case"},{"type":"text","text":" "},{"type":"text","text":"that depends on particular libraries or circumstances"},{"type":"text","text":" "},{"text":"and cannot prevent certain known critical or warning","type":"text"},{"type":"text","text":" "},{"text":"messages. So you install a handler that compares the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"domain and message to precisely not abort in such a case."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that the handler is reset at the beginning of"},{"text":" ","type":"text"},{"text":"any test case, so you have to set it inside each test","type":"text"},{"text":" ","type":"text"},{"text":"function which needs the special behavior.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This handler has no effect on g_error messages."}]},{"inlineContent":[{"type":"text","text":"This handler also has no effect on structured log messages (using"},{"text":" ","type":"text"},{"type":"text","text":"[func"},{"type":"codeVoice","code":"GLib.log_structured"},{"type":"text","text":"] or [func"},{"code":"GLib.log_structured_array","type":"codeVoice"},{"text":"]). To change the fatal","type":"text"},{"type":"text","text":" "},{"text":"behaviour for specific log messages, programs must install a custom log","type":"text"},{"text":" ","type":"text"},{"text":"writer function using [func","type":"text"},{"code":"GLib.log_set_writer_func","type":"codeVoice"},{"type":"text","text":"].See"},{"type":"text","text":" "},{"type":"reference","identifier":"logging.html#using-structured-logging","isActive":true},{"text":".","type":"text"}],"type":"paragraph"}
{"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/IOChannel","doc:\/\/GLib\/documentation\/GLib\/IOChannel\/IOChannelProtocol-Implementations"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/iochannel\/set(encoding:)"]}],"kind":"symbol","abstract":[{"type":"text","text":"Sets the encoding for the input\/output of the channel."},{"text":" ","type":"text"},{"type":"text","text":"The internal encoding is always UTF-8. The default encoding"},{"type":"text","text":" "},{"text":"for the external file is UTF-8.","type":"text"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"set","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"encoding"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">? = nil) ","kind":"text"},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"text":"GIOStatus","kind":"typeIdentifier","preciseIdentifier":"c:@EA@GIOStatus"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"The encoding ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" is safe to use with binary data."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The encoding can only be set if one of the following conditions"},{"text":" ","type":"text"},{"type":"text","text":"is true:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The channel was just created, and has not been written to or read from yet."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"The channel is write-only."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"The channel is a file, and the file pointer was just repositioned","type":"text"},{"type":"text","text":" "},{"type":"text","text":"by a call to "},{"code":"g_io_channel_seek_position()","type":"codeVoice"},{"type":"text","text":". (This flushes all the"},{"text":" ","type":"text"},{"text":"internal buffers.)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The current encoding is "},{"code":"nil","type":"codeVoice"},{"text":" or UTF-8.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"One of the (new API) read functions has just returned "},{"type":"codeVoice","code":"eof"},{"type":"text","text":" "},{"type":"text","text":"(or, in the case of "},{"type":"codeVoice","code":"g_io_channel_read_to_end()"},{"type":"text","text":", "},{"type":"codeVoice","code":"normal"},{"text":").","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"One of the functions "},{"type":"codeVoice","code":"g_io_channel_read_chars()"},{"text":" or","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_io_channel_read_unichar()"},{"text":" has returned ","type":"text"},{"type":"codeVoice","code":"again"},{"type":"text","text":" or"},{"type":"text","text":" "},{"code":"error","type":"codeVoice"},{"type":"text","text":". This may be useful in the case of"},{"text":" ","type":"text"},{"type":"codeVoice","code":"illegalSequence"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Returning one of these statuses from ","type":"text"},{"type":"codeVoice","code":"g_io_channel_read_line()"},{"text":",","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_io_channel_read_line_string()"},{"text":", or ","type":"text"},{"type":"codeVoice","code":"g_io_channel_read_to_end()"},{"text":" ","type":"text"},{"type":"text","text":"does not guarantee that the encoding can be changed."}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"text":"Channels which do not meet one of the above conditions cannot call","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_io_channel_seek_position()"},{"text":" with an offset of ","type":"text"},{"code":"cur","type":"codeVoice"},{"type":"text","text":", and, if"},{"text":" ","type":"text"},{"text":"they are “seekable”, cannot call ","type":"text"},{"type":"codeVoice","code":"g_io_channel_write_chars()"},{"type":"text","text":" after"},{"text":" ","type":"text"},{"text":"calling one of the API “read” functions.","type":"text"}],"type":"paragraph"}]}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/IOChannel\/set(encoding:)","interfaceLanguage":"swift"},"metadata":{"title":"set(encoding:)","roleHeading":"Instance Method","externalID":"s:4GLib17IOChannelProtocolPAAE3set8encodingSo9GIOStatusaSPys4Int8VGSg_tKF::SYNTHESIZED::s:4GLib9IOChannelC","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"set","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"encoding"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">?) ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"text":"GIOStatus","kind":"typeIdentifier","preciseIdentifier":"c:@EA@GIOStatus"}],"extendedModule":"GLib","modules":[{"name":"GLib"}],"symbolKind":"method"},"references":{"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"doc://GLib/documentation/GLib/IOChannel/IOChannelProtocol-Implementations":{"kind":"article","url":"\/documentation\/gli
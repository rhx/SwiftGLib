{"kind":"symbol","sections":[],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/IOChannel\/set(buffered:)","interfaceLanguage":"swift"},"abstract":[{"text":"The buffering state can only be set if the channel’s encoding","type":"text"},{"type":"text","text":" "},{"text":"is ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":". For any other encoding, the channel must be buffered."}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/IOChannel","doc:\/\/GLib\/documentation\/GLib\/IOChannel\/IOChannelProtocol-Implementations"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/iochannel\/set(buffered:)"]}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"set","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"buffered"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"text":")","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A buffered channel can only be set unbuffered if the channel’s"},{"text":" ","type":"text"},{"text":"internal buffers have been flushed. Newly created channels or","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"channels which have returned "},{"type":"codeVoice","code":"eof"},{"text":" ","type":"text"},{"text":"not require such a flush. For write-only channels, a call to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"g_io_channel_flush () is sufficient. For all other channels,"},{"text":" ","type":"text"},{"type":"text","text":"the buffers may be flushed by a call to g_io_channel_seek_position ()."},{"text":" ","type":"text"},{"text":"This includes the possibility of seeking with seek type ","type":"text"},{"code":"cur","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"and an offset of zero. Note that this means that socket-based"},{"type":"text","text":" "},{"type":"text","text":"channels cannot be set unbuffered once they have had data"},{"text":" ","type":"text"},{"text":"read from them.","type":"text"}]},{"inlineContent":[{"type":"text","text":"On unbuffered channels, it is safe to mix read and write"},{"type":"text","text":" "},{"type":"text","text":"calls from the new and old APIs, if this is necessary for"},{"type":"text","text":" "},{"type":"text","text":"maintaining old code."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The default state of the channel is buffered.","type":"text"}]}],"kind":"content"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"externalID":"s:4GLib17IOChannelProtocolPAAE3set8bufferedySb_tF::SYNTHESIZED::s:4GLib9IOChannelC","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"set","kind":"identifier"},{"text":"(","kind":"text"},{"text":"buffered","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"text":")","kind":"text"}],"title":"set(buffered:)","modules":[{"name":"GLib"}],"roleHeading":"Instance Method","extendedModule":"GLib","role":"symbol"},"references":{"doc://GLib/documentation/GLib/IOChannel/set(buffered:)":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel\/set(buffered:)","role":"symbol","abstract":[{"text":"The buffering state can only be set if the channel’s encoding","type":"text"},{"text":" ","type":"text"},{"text":"is ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":". For any other encoding, the channel must be buffered."}],"type":"topic","url":"\/documentation\/glib\/iochannel\/set(buffered:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"set"},{"kind":"text","text":"("},{"text":"buffered","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"kind":"text","text":")"}],"title":"set(buffered:)","kind":"symbol"},"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"doc://GLib/documentation/GLib/IOChannel":{"kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"IOChannel","kind":"identifier"}],"title":"IOChannel","role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel","abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"GIOChannel"},{"text":" data type aims to provide a portable method for","type":"text"},{"text":" ","type":"text"},{"text":"using file descriptors, pipes, and sockets, and integrating them","type":"text"},{"text":" ","type":"text"},{"text":"into the main event loop (see [struct","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","isActive":true,"type":"reference"},{"type":"text","text":"]). Currently,"},{"type":"text","text":" "},{"type":"text","text":"full support is available on UNIX platforms; support for Windows"},{"type":"text","text":" "},{"type":"text","text":"is only partially complete."}],"navigatorTitle":[{"kind":"identifier","text":"IOChannel"}],"url":"\/documentation\/glib\/iochannel","type":"topic"},"doc://GLib/documentation/GLib/IOChannel/IOChannelProtocol-Implementations":{"kind":"article","url":"\/documentation\/glib\/iochannel\/iochannelprotocol-implementations","role":"collectionGroup","type":"topic","abstract":[],"title":"IOChannelProtocol Implementations","identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel\/IOChannelProtocol-Implementations"},"doc://GLib/documentation/GLib/MainContext":{"navigatorTitle":[{"text":"MainContext","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/glib\/maincontext","role":"symbol","type":"topic","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MainContext","kind":"identifier"}],"abstract":[{"type":"text","text":"The "},{"code":"GMainContext","type":"codeVoice"},{"text":" struct is an opaque data","type":"text"},{"type":"text","text":" "},{"type":"text","text":"type representing a set of sources to be handled in a main loop."}],"title":"MainContext","identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext"}}}
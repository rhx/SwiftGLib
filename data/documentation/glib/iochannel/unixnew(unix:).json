{"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","variants":[{"paths":["\/documentation\/glib\/iochannel\/unixnew(unix:)"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/IOChannel"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/IOChannel\/unixNew(unix:)"},"sections":[],"metadata":{"symbolKind":"method","roleHeading":"Type Method","role":"symbol","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"unixNew","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"unix"},{"kind":"text","text":": "},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:4GLib9IOChannelC","text":"IOChannel","kind":"typeIdentifier"},{"kind":"text","text":"!"}],"externalID":"s:4GLib9IOChannelC7unixNew0C0ACSgSi_tFZ","title":"unixNew(unix:)","modules":[{"name":"GLib"}]},"abstract":[{"type":"text","text":"Creates a new "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel"},{"text":" given a file descriptor. On UNIX systems","type":"text"},{"text":" ","type":"text"},{"text":"this works for plain files, pipes, and sockets.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"static"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"unixNew"},{"kind":"text","text":"("},{"kind":"externalParam","text":"unix"},{"text":" ","kind":"text"},{"text":"fd","kind":"internalParam"},{"kind":"text","text":": "},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel","text":"IOChannel","kind":"typeIdentifier","preciseIdentifier":"s:4GLib9IOChannelC"},{"text":"!","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"The returned "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel","isActive":true},{"text":" has a reference count of 1.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The default encoding for ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel","isActive":true,"type":"reference"},{"text":" is UTF-8. If your application","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is reading output from a command using via pipe, you may need to set"},{"type":"text","text":" "},{"type":"text","text":"the encoding to the encoding of the current locale (see"},{"text":" ","type":"text"},{"code":"g_get_charset()","type":"codeVoice"},{"type":"text","text":") with the "},{"code":"g_io_channel_set_encoding()","type":"codeVoice"},{"type":"text","text":" function."},{"type":"text","text":" "},{"type":"text","text":"By default, the fd passed will not be closed when the final reference"},{"type":"text","text":" "},{"type":"text","text":"to the "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel","isActive":true},{"text":" data structure is dropped.","type":"text"}]},{"inlineContent":[{"type":"text","text":"If you want to read raw binary data without interpretation, then"},{"type":"text","text":" "},{"type":"text","text":"call the "},{"type":"codeVoice","code":"g_io_channel_set_encoding()"},{"type":"text","text":" function with "},{"type":"codeVoice","code":"nil"},{"text":" for the","type":"text"},{"text":" ","type":"text"},{"text":"encoding argument.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function is available in GLib on Windows, too, but you should"},{"type":"text","text":" "},{"text":"avoid using it on Windows. The domain of file descriptors and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"sockets overlap. There is no way for GLib to know which one you mean"},{"type":"text","text":" "},{"type":"text","text":"in case the argument you pass to this function happens to be both a"},{"type":"text","text":" "},{"type":"text","text":"valid file descriptor and socket. If that happens a warning is"},{"type":"text","text":" "},{"text":"issued, and GLib assumes that it is the file descriptor you mean.","type":"text"}]}]}],"references":{"doc://GLib/documentation/GLib/IOChannel/unixNew(unix:)":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel\/unixNew(unix:)","kind":"symbol","abstract":[{"text":"Creates a new ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel","isActive":true},{"text":" given a file descriptor. On UNIX systems","type":"text"},{"type":"text","text":" "},{"type":"text","text":"this works for plain files, pipes, and sockets."}],"type":"topic","role":"symbol","fragments":[{"text":"static","kind":"keyword"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"unixNew"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"unix"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":") -> "},{"text":"IOChannel","kind":"typeIdentifier","preciseIdentifier":"s:4GLib9IOChannelC"},{"kind":"text","text":"!"}],"title":"unixNew(unix:)","url":"\/documentation\/glib\/iochannel\/unixnew(unix:)"},"doc://GLib/documentation/GLib/IOChannel":{"kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"IOChannel","kind":"identifier"}],"title":"IOChannel","role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel","abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"GIOChannel"},{"text":" data type aims to provide a portable method for","type":"text"},{"text":" ","type":"text"},{"text":"using file descriptors, pipes, and sockets, and integrating them","type":"text"},{"text":" ","type":"text"},{"text":"into the main event loop (see [struct","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","isActive":true,"type":"reference"},{"type":"text","text":"]). Currently,"},{"type":"text","text":" "},{"type":"text","text":"full support is available on UNIX platforms; support for Windows"},{"type":"text","text":" "},{"type":"text","text":"is only partially complete."}],"navigatorTitle":[{"kind":"identifier","text":"IOChannel"}],"url":"\/documentation\/glib\/iochannel","type":"topic"},"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"doc://GLib/documentation/GLib/MainContext":{"navigatorTitle":[{"text":"MainContext","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/glib\/maincontext","role":"symbol","type":"topic","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MainContext","kind":"identifier"}],"abstract":[{"type":"text","text":"The "},{"code":"GMainContext","type":"codeVoice"},{"text":" struct is an opaque data","type":"text"},{"type":"text","text":" "},{"type":"text","text":"type representing a set of sources to be handled in a main loop."}],"title":"MainContext","identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext"}}}
{"kind":"symbol","identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFile","interfaceLanguage":"swift"},"schemaVersion":{"patch":0,"major":0,"minor":3},"topicSections":[{"generated":true,"identifiers":["doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init()","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(_:)-12es4","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(_:)-39yvz","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(_:)-5gx5p","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(_:)-638ob","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(_:)-65rhv","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(cPointer:)","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(gconstpointer:)","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(gpointer:)","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(opaquePointer:)","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(raw:)-15cs1","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(raw:)-4ack0","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(retaining:)","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(retainingCPointer:)","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(retainingOpaquePointer:)","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(retainingRaw:)-3hi79","doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/init(retainingRaw:)-8ifug"],"anchor":"Initializers","title":"Initializers"},{"generated":true,"title":"Instance Properties","anchor":"Instance-Properties","identifiers":["doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/ptr"]},{"anchor":"Default-Implementations","generated":true,"title":"Default Implementations","identifiers":["doc:\/\/GLib\/documentation\/GLib\/BookmarkFile\/BookmarkFileProtocol-Implementations"]}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/bookmarkfile"]}],"abstract":[{"type":"codeVoice","code":"GBookmarkFile"},{"type":"text","text":" lets you parse, edit or create files containing bookmarks."}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"BookmarkFile","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Bookmarks refer to a URI, along with some meta-data about the resource"},{"type":"text","text":" "},{"type":"text","text":"pointed by the URI like its MIME type, the application that is registering"},{"text":" ","type":"text"},{"type":"text","text":"the bookmark and the icon that should be used to represent the bookmark."},{"type":"text","text":" "},{"text":"The data is stored using the","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/www.freedesktop.org\/wiki\/Specifications\/desktop-bookmark-spec\/"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"The syntax of the bookmark files is described in detail inside the"},{"type":"text","text":" "},{"type":"text","text":"Desktop Bookmark Specification, here is a quick summary: bookmark"},{"type":"text","text":" "},{"type":"text","text":"files use a sub-class of the XML Bookmark Exchange Language"},{"text":" ","type":"text"},{"type":"text","text":"specification, consisting of valid UTF-8 encoded XML, under the"},{"type":"text","text":" "},{"code":"<xbel>","type":"codeVoice"},{"type":"text","text":" root element; each bookmark is stored inside a"},{"text":" ","type":"text"},{"code":"<bookmark>","type":"codeVoice"},{"type":"text","text":" element, using its URI: no relative paths can"},{"type":"text","text":" "},{"type":"text","text":"be used inside a bookmark file. The bookmark may have a user defined"},{"text":" ","type":"text"},{"type":"text","text":"title and description, to be used instead of the URI. Under the"},{"type":"text","text":" "},{"type":"codeVoice","code":"<metadata>"},{"text":" element, with its owner attribute set to","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"http:\/\/freedesktop.org"},{"type":"text","text":", is stored the meta-data about a resource"},{"text":" ","type":"text"},{"type":"text","text":"pointed by its URI. The meta-data consists of the resource’s MIME"},{"text":" ","type":"text"},{"type":"text","text":"type; the applications that have registered a bookmark; the groups"},{"type":"text","text":" "},{"type":"text","text":"to which a bookmark belongs to; a visibility flag, used to set the"},{"type":"text","text":" "},{"text":"bookmark as “private” to the applications and groups that has it","type":"text"},{"type":"text","text":" "},{"type":"text","text":"registered; the URI and MIME type of an icon, to be used when"},{"type":"text","text":" "},{"type":"text","text":"displaying the bookmark inside a GUI."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Here is an example of a bookmark file:"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/gitlab.gnome.org\/GNOME\/glib\/-\/blob\/HEAD\/glib\/tests\/bookmarks.xbel"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A bookmark file might contain more than one bookmark; each bookmark"},{"type":"text","text":" "},{"text":"is accessed through its URI.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The important caveat of bookmark files is that when you add a new","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"bookmark you must also add the application that is registering it, using"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GLib.BookmarkFile.add_application"},{"text":"] or [method","type":"text"},{"code":"GLib.BookmarkFile.set_application_info","type":"codeVoice"},{"text":"].","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"If a bookmark has no applications then it won’t be dumped when creating"},{"type":"text","text":" "},{"type":"text","text":"the on disk representation, using [method"},{"type":"codeVoice","code":"GLib.BookmarkFile.to_data"},{"text":"] or","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GLib.BookmarkFile.to_file"},{"text":"].","type":"text"}]},{"inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFile","type":"reference","isActive":true},{"type":"text","text":" type acts as an owner of an underlying "},{"type":"codeVoice","code":"GBookmarkFile"},{"text":" instance.","type":"text"},{"text":" ","type":"text"},{"text":"It provides the methods that can operate on this data type through ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFileProtocol","isActive":true},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFile","type":"reference","isActive":true},{"type":"text","text":" as a strong reference or owner of a "},{"type":"codeVoice","code":"GBookmarkFile"},{"text":" instance.","type":"text"}],"type":"paragraph"},{"name":"Note","style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef","type":"reference","isActive":true},{"text":" (instead of ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFile","isActive":true},{"type":"text","text":") for a lightweight Swift reference to an underlying "},{"type":"codeVoice","code":"GBookmarkFile"},{"type":"text","text":" instance."}]}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"relationshipsSections":[{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/BookmarkFileProtocol","doc:\/\
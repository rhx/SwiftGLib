{"topicSections":[{"title":"Initializers","anchor":"Initializers","identifiers":["doc:\/\/GLib\/documentation\/GLib\/RWLock\/init(_:)-187l8","doc:\/\/GLib\/documentation\/GLib\/RWLock\/init(_:)-21sx0","doc:\/\/GLib\/documentation\/GLib\/RWLock\/init(_:)-643cj","doc:\/\/GLib\/documentation\/GLib\/RWLock\/init(_:)-69bry","doc:\/\/GLib\/documentation\/GLib\/RWLock\/init(_:)-9jfa5","doc:\/\/GLib\/documentation\/GLib\/RWLock\/init(cPointer:)","doc:\/\/GLib\/documentation\/GLib\/RWLock\/init(gconstpointer:)","doc:\/\/GLib\/documentation\/GLib\/RWLock\/init(gpointer:)","doc:\/\/GLib\/documentation\/GLib\/RWLock\/init(opaquePointer:)","doc:\/\/GLib\/documentation\/GLib\/RWLock\/init(raw:)-7cuhr","doc:\/\/GLib\/documentation\/GLib\/RWLock\/init(raw:)-9zeby","doc:\/\/GLib\/documentation\/GLib\/RWLock\/init(retaining:)","doc:\/\/GLib\/documentation\/GLib\/RWLock\/init(retainingCPointer:)","doc:\/\/GLib\/documentation\/GLib\/RWLock\/init(retainingOpaquePointer:)","doc:\/\/GLib\/documentation\/GLib\/RWLock\/init(retainingRaw:)-46ai7","doc:\/\/GLib\/documentation\/GLib\/RWLock\/init(retainingRaw:)-4hhp2"],"generated":true},{"generated":true,"title":"Instance Properties","identifiers":["doc:\/\/GLib\/documentation\/GLib\/RWLock\/ptr"],"anchor":"Instance-Properties"},{"title":"Default Implementations","generated":true,"identifiers":["doc:\/\/GLib\/documentation\/GLib\/RWLock\/RWLockProtocol-Implementations"],"anchor":"Default-Implementations"}],"variants":[{"paths":["\/documentation\/glib\/rwlock"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"metadata":{"modules":[{"name":"GLib"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"RWLock","kind":"identifier"}],"roleHeading":"Class","externalID":"s:4GLib6RWLockC","symbolKind":"class","title":"RWLock","role":"symbol","navigatorTitle":[{"text":"RWLock","kind":"identifier"}]},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"RWLock","kind":"identifier"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"anchor":"overview","text":"Overview","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"The difference to a mutex is that a reader-writer lock discriminates"},{"text":" ","type":"text"},{"text":"between read-only (‘reader’) and full (‘writer’) access. While only","type":"text"},{"type":"text","text":" "},{"type":"text","text":"one thread at a time is allowed write access (by holding the ‘writer’"},{"text":" ","type":"text"},{"type":"text","text":"lock via "},{"code":"g_rw_lock_writer_lock()","type":"codeVoice"},{"text":"), multiple threads can gain","type":"text"},{"type":"text","text":" "},{"text":"simultaneous read-only access (by holding the ‘reader’ lock via","type":"text"},{"type":"text","text":" "},{"code":"g_rw_lock_reader_lock()","type":"codeVoice"},{"type":"text","text":")."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"It is unspecified whether readers or writers have priority in acquiring the","type":"text"},{"text":" ","type":"text"},{"text":"lock when a reader already holds the lock and a writer is queued to acquire","type":"text"},{"text":" ","type":"text"},{"text":"it.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Here is an example for an array with access functions:"},{"type":"text","text":" "},{"type":"text","text":"(C Language Example):"}]},{"type":"codeListing","syntax":"C","code":["  GRWLock lock;","  GPtrArray *array;","","  gpointer","  my_array_get (guint index)","  {","    gpointer retval = NULL;","","    if (!array)","      return NULL;","","    g_rw_lock_reader_lock (&lock);","    if (index < array->len)","      retval = g_ptr_array_index (array, index);","    g_rw_lock_reader_unlock (&lock);","","    return retval;","  }","","  void","  my_array_set (guint index, gpointer data)","  {","    g_rw_lock_writer_lock (&lock);","","    if (!array)","      array = g_ptr_array_new ();","","    if (index >= array->len)","      g_ptr_array_set_size (array, index+1);","    g_ptr_array_index (array, index) = data;","","    g_rw_lock_writer_unlock (&lock);","  }"," "]},{"type":"paragraph","inlineContent":[{"text":"This example shows an array which can be accessed by many readers","type":"text"},{"type":"text","text":" "},{"text":"(the ","type":"text"},{"type":"codeVoice","code":"my_array_get()"},{"type":"text","text":" function) simultaneously, whereas the writers"},{"text":" ","type":"text"},{"type":"text","text":"(the "},{"type":"codeVoice","code":"my_array_set()"},{"type":"text","text":" function) will only be allowed one at a time"},{"type":"text","text":" "},{"type":"text","text":"and only if no readers currently access the array. This is because"},{"text":" ","type":"text"},{"text":"of the potentially dangerous resizing of the array. Using these","type":"text"},{"type":"text","text":" "},{"type":"text","text":"functions is fully multi-thread safe now."}]},{"inlineContent":[{"type":"text","text":"If a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLock"},{"type":"text","text":" is allocated in static storage then it can be used"},{"text":" ","type":"text"},{"type":"text","text":"without initialisation.  Otherwise, you should call"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_rw_lock_init()"},{"type":"text","text":" on it and "},{"code":"g_rw_lock_clear()","type":"codeVoice"},{"text":" when done.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A GRWLock should only be accessed with the g_rw_lock_ functions."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLock"},{"text":" type acts as an owner of an underlying ","type":"text"},{"type":"codeVoice","code":"GRWLock"},{"type":"text","text":" instance."},{"text":" ","type":"text"},{"text":"It provides the methods that can operate on this data type through ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockProtocol","isActive":true,"type":"reference"},{"text":" conformance.","type":"text"},{"text":" ","type":"text"},{"text":"Use ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLock","type":"reference"},{"text":" as a strong reference or owner of a ","type":"text"},{"type":"codeVoice","code":"GRWLock"},{"type":"text","text":" instance."}]},{"content":[{"inlineContent":[{"type":"text","text":"Use "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockRef","isActive":true},{"type":"text","text":" (instead of "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLock","type":"reference","isActive":true},{"text":") for a lightweight Swift reference to an underlying ","type":"text"},{"type":"codeVoice","code":"GRWLock"},{"text":" instance.","type":"text"}],"type":"paragraph"}],"name":"Note","type":"aside","style":"note"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"abstract":[{"type":"text","text":"The GRWLock struct is an opaque data structure to represent a"},{"text":" ","type":"text"},{"type":"text","text":"reader-writer lock. It is similar to a "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","isActive":true},{"text":" in that it allows","type":"text"},{"type":"text","text":" "},{"type":"text","text":"multiple threads to coordinate access to a shared resource."}],"relationshipsSections":[{"kind":"relationships","type":"conformsTo","identifiers":["doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","doc:\/\/GLib\/documentation\/GLib\/RWLockProtocol"],"title":"Conforms To"}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/RWLock","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://GLib/documentation/GLib/RWLock/init(
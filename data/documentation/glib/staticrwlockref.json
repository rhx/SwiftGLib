{"topicSections":[{"generated":true,"identifiers":["doc:\/\/GLib\/documentation\/GLib\/StaticRWLockRef\/init(_:)-10mti","doc:\/\/GLib\/documentation\/GLib\/StaticRWLockRef\/init(_:)-37bn","doc:\/\/GLib\/documentation\/GLib\/StaticRWLockRef\/init(_:)-3nxea","doc:\/\/GLib\/documentation\/GLib\/StaticRWLockRef\/init(_:)-56q6n","doc:\/\/GLib\/documentation\/GLib\/StaticRWLockRef\/init(_:)-qfhc","doc:\/\/GLib\/documentation\/GLib\/StaticRWLockRef\/init(cPointer:)","doc:\/\/GLib\/documentation\/GLib\/StaticRWLockRef\/init(constPointer:)","doc:\/\/GLib\/documentation\/GLib\/StaticRWLockRef\/init(gconstpointer:)","doc:\/\/GLib\/documentation\/GLib\/StaticRWLockRef\/init(gpointer:)","doc:\/\/GLib\/documentation\/GLib\/StaticRWLockRef\/init(mutating:)","doc:\/\/GLib\/documentation\/GLib\/StaticRWLockRef\/init(opaquePointer:)"],"anchor":"Initializers","title":"Initializers"},{"title":"Instance Properties","generated":true,"anchor":"Instance-Properties","identifiers":["doc:\/\/GLib\/documentation\/GLib\/StaticRWLockRef\/ptr"]},{"title":"Default Implementations","generated":true,"anchor":"Default-Implementations","identifiers":["doc:\/\/GLib\/documentation\/GLib\/StaticRWLockRef\/PointerWrapper-Implementations","doc:\/\/GLib\/documentation\/GLib\/StaticRWLockRef\/StaticRWLockProtocol-Implementations"]}],"sections":[],"metadata":{"navigatorTitle":[{"text":"StaticRWLockRef","kind":"identifier"}],"externalID":"s:4GLib15StaticRWLockRefV","role":"symbol","modules":[{"name":"GLib"}],"symbolKind":"struct","roleHeading":"Structure","title":"StaticRWLockRef","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"StaticRWLockRef","kind":"identifier"}]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/staticrwlockref"]}],"relationshipsSections":[{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","doc:\/\/GLib\/documentation\/GLib\/StaticRWLockProtocol"],"type":"conformsTo","kind":"relationships","title":"Conforms To"}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"abstract":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLock","isActive":true},{"text":" struct represents a read-write lock. A read-write","type":"text"},{"type":"text","text":" "},{"type":"text","text":"lock can be used for protecting data that some portions of code only"},{"type":"text","text":" "},{"text":"read from, while others also write. In such situations it is","type":"text"},{"type":"text","text":" "},{"text":"desirable that several readers can read at once, whereas of course","type":"text"},{"type":"text","text":" "},{"text":"only one writer may write at a time.","type":"text"}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"StaticRWLockRef","kind":"identifier"}]}],"kind":"declarations"},{"content":[{"anchor":"overview","type":"heading","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"Take a look at the following example:","type":"text"}]},{"syntax":null,"type":"codeListing","code":["  GStaticRWLock rwlock = G_STATIC_RW_LOCK_INIT;","  GPtrArray *array;","","  gpointer","  my_array_get (guint index)","  {","    gpointer retval = NULL;","","    if (!array)","      return NULL;","","    g_static_rw_lock_reader_lock (&rwlock);","    if (index < array->len)","      retval = g_ptr_array_index (array, index);","    g_static_rw_lock_reader_unlock (&rwlock);","","    return retval;","  }","","  void","  my_array_set (guint index, gpointer data)","  {","    g_static_rw_lock_writer_lock (&rwlock);","","    if (!array)","      array = g_ptr_array_new ();","","    if (index >= array->len)","      g_ptr_array_set_size (array, index + 1);","    g_ptr_array_index (array, index) = data;","","    g_static_rw_lock_writer_unlock (&rwlock);","  }"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This example shows an array which can be accessed by many readers"},{"type":"text","text":" "},{"type":"text","text":"(the "},{"code":"my_array_get()","type":"codeVoice"},{"type":"text","text":" function) simultaneously, whereas the writers"},{"type":"text","text":" "},{"text":"(the ","type":"text"},{"type":"codeVoice","code":"my_array_set()"},{"text":" function) will only be allowed once at a time","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and only if no readers currently access the array. This is because"},{"type":"text","text":" "},{"type":"text","text":"of the potentially dangerous resizing of the array. Using these"},{"text":" ","type":"text"},{"text":"functions is fully multi-thread safe now.","type":"text"}]},{"inlineContent":[{"text":"Most of the time, writers should have precedence over readers. That","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"means, for this implementation, that as soon as a writer wants to"},{"type":"text","text":" "},{"type":"text","text":"lock the data, no other reader is allowed to lock the data, whereas,"},{"text":" ","type":"text"},{"text":"of course, the readers that already have locked the data are allowed","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to finish their operation. As soon as the last reader unlocks the"},{"type":"text","text":" "},{"type":"text","text":"data, the writer will lock it."}],"type":"paragraph"},{"inlineContent":[{"text":"Even though ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLock"},{"type":"text","text":" is not opaque, it should only be used"},{"type":"text","text":" "},{"type":"text","text":"with the following functions."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"All of the g_static_rw_lock_* functions can be used even if","type":"text"},{"type":"text","text":" "},{"code":"g_thread_init()","type":"codeVoice"},{"text":" has not been called. Then they do nothing, apart","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"from g_static_rw_lock_*_trylock, which does nothing but returning "},{"type":"codeVoice","code":"true"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A read-write lock has a higher overhead than a mutex. For example, both"},{"type":"text","text":" "},{"code":"g_static_rw_lock_reader_lock()","type":"codeVoice"},{"type":"text","text":" and "},{"code":"g_static_rw_lock_reader_unlock()","type":"codeVoice"},{"text":" have","type":"text"},{"type":"text","text":" "},{"text":"to lock and unlock a ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex","isActive":true,"type":"reference"},{"type":"text","text":", so it takes at least twice the time"},{"text":" ","type":"text"},{"text":"to lock and unlock a ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLock"},{"text":" that it does to lock and unlock a","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex","type":"reference","isActive":true},{"text":". So only data structures that are accessed by multiple","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"readers, and which keep the lock for a considerable time justify a"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLock","isActive":true},{"text":". The above example most probably would fare better with a","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticMutex","isActive":true},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLockRef","isActive":true,"type":"reference"},{"text":" type acts as a lightweight Swift reference to an underlying ","type":"text"},{"code":"GStaticRWLock","type":"codeVoice"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"text":"It exposes methods that can operate on this data type through ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLockProtocol"},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"text":"Use ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLockRef"},{"text":" only as an ","type":"text"},{"type":"codeVoice","code":"unowned"},{"text":" reference to an existing ","type":"text"},{"code":"GStaticRWLock","type":"codeVoice"},{"text":" instance.","type":"text"}]},{"style":"note","type":"aside","name":"Note","content":[{"inlineContent":[{"text":"Use ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLock","isActive":true},{"type":"text","text":" (instead of "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLockRef","isActive":true},{"type":"text","text":") if you want to use Automatic Reference Counting for memory management of the underlying "},{"code":"GStaticRWLock","type":"codeVoice"},{"type":"text","text":" instance."}],"type":"paragraph"}]}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLockRef"},"schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"doc://GLib/documentation/GLib/StaticRWLockRef/ptr":{"abstract":[{"type":"text","text":"Untyped pointer to the underlying "},{"code":"GStaticRWLock","type":"codeVoice"},{"type":"text","text":" instance."},{"text":" ","type":"text"},{"type":"text","text":"For type-safe access, use the generated, typed pointer "},{"type":"codeVoice","code":"StaticRWLockProtocol\/_ptr"},{"type":"text","text":" property instead."}],"type":"topic","fragments":[{"kind":"keyword","text":"let"},{"text":" ","kind":"text"},{"kind":"identifier","
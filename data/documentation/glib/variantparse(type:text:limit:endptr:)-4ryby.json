":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"A single "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"type":"text","text":" is parsed from the content of "},{"code":"text","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The format is described ","type":"text"},{"type":"reference","identifier":"gvariant-text-format.html","isActive":true},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"The memory at ","type":"text"},{"type":"codeVoice","code":"limit"},{"type":"text","text":" will never be accessed and the parser behaves as"},{"text":" ","type":"text"},{"type":"text","text":"if the character at "},{"code":"limit","type":"codeVoice"},{"text":" is the nul terminator.  This has the","type":"text"},{"text":" ","type":"text"},{"text":"effect of bounding ","type":"text"},{"type":"codeVoice","code":"text"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"If "},{"code":"endptr","type":"codeVoice"},{"type":"text","text":" is non-"},{"type":"codeVoice","code":"nil"},{"text":" then ","type":"text"},{"type":"codeVoice","code":"text"},{"text":" is permitted to contain data","type":"text"},{"type":"text","text":" "},{"text":"following the value that this function parses and ","type":"text"},{"code":"endptr","type":"codeVoice"},{"type":"text","text":" will be"},{"text":" ","type":"text"},{"type":"text","text":"updated to point to the first character past the end of the text"},{"text":" ","type":"text"},{"type":"text","text":"parsed by this function.  If "},{"code":"endptr","type":"codeVoice"},{"type":"text","text":" is "},{"type":"codeVoice","code":"nil"},{"text":" and there is extra data","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"then an error is returned."}],"type":
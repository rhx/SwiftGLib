{"kind":"symbol","sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/PatternSpecProtocol\/patternMatch(stringLength:string:stringReversed:)"},"abstract":[{"type":"text","text":"Matches a string against a compiled pattern."}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/PatternSpecProtocol"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/patternspecprotocol\/patternmatch(stringlength:string:stringreversed:)"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"patternMatch","kind":"identifier"},{"kind":"text","text":"("},{"text":"stringLength","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"string","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"text":"stringReversed","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">? = nil) -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"inlineContent":[{"text":"Passing the correct","type":"text"},{"type":"text","text":" "},{"type":"text","text":"length of the string given is mandatory. The reversed string can be"},{"type":"text","text":" "},{"type":"text","text":"omitted by passing "},{"code":"NULL","type":"codeVoice"},{"text":", this is more efficient if the reversed","type":"text"},{"type":"text","text":" "},{"text":"version of the string to be matched is not at hand, as","type":"text"},{"type":"text","text":" "},{"code":"g_pattern_match()","type":"codeVoice"},{"type":"text","text":" will only construct it if the compiled pattern"},{"type":"text","text":" "},{"text":"requires reverse matches.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that, if the user code will (possibly) match a string against a"},{"text":" ","type":"text"},{"type":"text","text":"multitude of patterns containing wildcards, chances are high that"},{"type":"text","text":" "},{"text":"some patterns will require a reversed string. In this case, it’s","type":"text"},{"type":"text","text":" "},{"text":"more efficient to provide the reversed string to avoid multiple","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"constructions thereof in the various calls to "},{"type":"codeVoice","code":"g_pattern_match()"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"Note also that the reverse of a UTF-8 encoded string can in general"},{"type":"text","text":" "},{"text":"not be obtained by [func","type":"text"},{"type":"codeVoice","code":"GLib.strreverse"},{"text":"]. This works only if the string","type":"text"},{"type":"text","text":" "},{"text":"does not contain any multibyte characters. GLib offers the","type":"text"},{"text":" ","type":"text"},{"text":"[func","type":"text"},{"code":"GLib.utf8_strreverse","type":"codeVoice"},{"type":"text","text":"] function to reverse UTF-8 encoded strings."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"pattern_match is deprecated:"}]},{"text":" ","type":"text"},{"text":"Use [method@GLib.PatternSpec.match] instead","type":"text"}]}]}],"metadata":{"role":"symbol","extendedModule":"GLib","title":"patternMatch(stringLength:st
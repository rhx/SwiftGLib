text","text":"initialising over top of an existing "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilder","type":"reference","isActive":true},{"type":"text","text":" you need to"},{"text":" ","type":"text"},{"type":"text","text":"first call "},{"code":"g_variant_builder_clear()","type":"codeVoice"},{"type":"text","text":" in order to avoid leaking"},{"type":"text","text":" "},{"type":"text","text":"memory."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"You must not call ","type":"text"},{"type":"codeVoice","code":"g_variant_builder_ref()"},{"type":"text","text":" or"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_variant_builder_unref()"},{"text":" on a ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilder","isActive":true,"type":"reference"},{"type":"text","text":" that was initialised"},{"type":"text","text":" "},{"text":"with this function.  If you ever pass a reference to a","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantBuilder","isActive":true},{"type":"text","text":" outside of the control of your own code then you"},{"text":" ","type":"text"},{"text":"should assume that the person receiving that reference may try to use","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"reference counting; you should use "},{"type":"codeVoice","code":"g_variant_builder_new()"},{"text":" instead of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"this function."}]}],"kind":"content"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"title":"init_(type:)","modules":[{"name":"GLib"}],"symbolKind":"method","roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"init_","kind":"identifier"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"VariantTypeT"},{"kind":"text","text":">("},{"kind":"externalParam","text":"type"},{"tex
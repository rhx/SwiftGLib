{"kind":"article","schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"title":"SourceFuncsProtocol Implementations","role":"collectionGroup","modules":[{"name":"GLib"}],"roleHeading":"API Collection"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef"]]},"topicSections":[{"anchor":"Instance-Properties","generated":true,"title":"Instance Properties","identifiers":["doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/check","doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/dispatch","doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/finalize","doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/prepare"]},{"title":"Instance Methods","identifiers":["doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/sourceRemoveByFuncs(userData:)"],"generated":true,"anchor":"Instance-Methods"}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/SourceFuncsProtocol-Implementations"},"variants":[{"paths":["\/documentation\/glib\/sourcefuncsref\/sourcefuncsprotocol-implementations"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://GLib/documentation/GLib/SourceFuncsRef/sourceRemoveByFuncs(userData:)":{"title":"sourceRemoveByFuncs(userData:)","abstract":[{"type":"text","text":"Removes a source from the default main loop context given the"},{"type":"text","text":" "},{"type":"text","text":"source functions and user data."}],"kind":"symbol","url":"\/documentation\/glib\/sourcefuncsref\/sourceremovebyfuncs(userdata:)","type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/sourceRemoveByFuncs(userData:)","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sourceRemoveByFuncs","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"userData"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"gpointer","preciseIdentifier":"c:@T@gpointer"},{"kind":"text","text":"?) -> "},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}]},"doc://GLib/documentation/GLib/MainContext":{"navigatorTitle":[{"text":"MainContext","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/glib\/maincontext","role":"symbol","type":"topic","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MainContext","kind":"identifier"}],"abstract":[{"type":"text","text":"The "},{"code":"GMainContext","type":"codeVoice"},{"text":" struct is an opaque data","type":"text"},{"type":"text","text":" "},{"type":"text","text":"type representing a set of sources to be handled in a main loop."}],"title":"MainContext","identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext"},"doc://GLib/documentation/GLib/SourceFuncsRef/dispatch":{"type":"topic","url":"\/documentation\/glib\/sourcefuncsref\/dispatch","title":"dispatch","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/dispatch","kind":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"text":"dispatch","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GSourceFuncsDispatchFunc","text":"GSourceFuncsDispatchFunc"},{"kind":"text","text":"!"}],"abstract":[{"text":"Called to dispatch the event source, after it has returned","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"true"},{"text":" in either its ","type":"text"},{"type":"codeVoice","code":"prepare"},{"text":" or its ","type":"text"},{"code":"check","type":"codeVoice"},{"text":" function, or if a ready time","type":"text"},{"type":"text","text":" "},{"type":"text","text":"has been reached. The "},{"type":"codeVoice","code":"dispatch"},{"type":"text","text":" function receives a callback function and"},{"text":" ","type":"text"},{"type":"text","text":"user data. The callback function may be "},{"code":"nil","type":"codeVoice"},{"text":" if the source was never","type":"text"},{"type":"text","text":" "},{"type":"text","text":"connected to a callback using [method"},{"code":"GLib.Source.set_callback","type":"codeVoice"},{"text":"]. The","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"dispatch"},{"type":"text","text":" function should call the callback function with "},{"code":"user_data","type":"codeVoice"},{"type":"text","text":" and"},{"type":"text","text":" "},{"text":"whatever additional parameters are needed for this type of event source.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The return value of the "},{"code":"dispatch","type":"codeVoice"},{"type":"text","text":" function should be"},{"type":"text","text":" "},{"type":"text","text":"[const"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/sourceRemove","type":"reference","isActive":true},{"type":"text","text":"] if the source should be removed or"},{"type":"text","text":" "},{"type":"text","text":"[const"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/sourceContinue"},{"type":"text","text":"] to keep it."}],"role":"symbol"},"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"doc://GLib/documentation/GLib/SourceFuncsRef/prepare":{"kind":"symbol","url":"\/documentation\/glib\/sourcefuncsref\/prepare","type":"topic","abstract":[{"text":"Called before all the file descriptors are polled. If","type":"text"},{"text":" ","type":"text"},{"text":"the source can determine that it is ready here (without waiting for the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"results of the "},{"type":"codeVoice","code":"poll()"},{"type":"text","text":" call) it should return "},{"type":"codeVoice","code":"true"},{"text":". It can also return","type":"text"},{"type":"text","text":" "},{"type":"text","text":"a "},{"type":"codeVoice","code":"timeout_"},{"type":"text","text":" value which should be the maximum timeout (in milliseconds)"},{"type":"text","text":" "},{"type":"text","text":"which should be passed to the "},{"code":"poll()","type":"codeVoice"},{"text":" call. The actual timeout used will","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"be -1 if all sources returned -1, or it will be the minimum of all"},{"type":"text","text":" "},{"type":"text","text":"the "},{"type":"codeVoice","code":"timeout_"},{"text":" values returned which were >= 0.  Since 2.36 this may","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"be "},{"code":"nil","type":"codeVoice"},{"type":"text","text":", in which case the effect is as if the function always returns"},{"text":" ","type":"text"},{"type":"codeVoice","code":"false"},{"text":" with a timeout of -1.  If ","type":"text"},{"type":"codeVoice","code":"prepare"},{"text":" returns a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"timeout and the source also has a ready time set, then the"},{"type":"text","text":" "},{"text":"lower of the two will be used.","type":"text"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/prepare","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"prepare","kind":"identifier"},{"kind":"text","text":": "},{"preciseIdentifier":"c:@T@GSourceFuncsPrepareFunc","text":"GSourceFuncsPrepareFunc","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"title":"prepare","role":"symbol"},"doc://GLib/documentation/GLib/SourceFuncsRef/finalize":{"role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/finalize","kind":"symbol","abstract":[{"text":"Called when the source is finalized. At this point,","type":"text"},{"type":"text","text":" "},{"text":"the source will have been destroyed, had its callback cleared, and have","type":"text"},{"type":"text","text":" "},{"type":"text","text":"been removed from its [struct"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","type":"reference","isActive":true},{"text":"], but it will still have","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"its final reference count, so methods can be called on it from within"},{"type":"text","text":" "},{"type":"text","text":"this function. This may be "},{"code":"nil","type":"codeVoice"},{"type":"text","text":", in which case the effect is as if the"},{"text":" ","type":"text"},{"text":"function does nothing and returns.","type":"text"}],"type":"topic","title":"finalize","url":"\/documentation\/glib\/sourcefuncsref\/finalize","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"text":"finalize","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@GSourceFuncsFinalizeFunc","text":"GSourceFuncsFinalizeFunc","kind":"typeIdentifier"},{"kind":"text","text":"!"}]},"doc://GLib/documentation/GLib/sourceContinue":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/sourceContinue","url":"\/documentation\/glib\/sourcecontinue","role":"symbol","type":"topic","abstract":[{"type":"text","text":"Use this macro as the return value of a [callback"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFunc"},{"type":"text","text":"] to leave"},{"text":" ","type":"text"},{"text":"the [struct","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Source","isActive":true},{"type":"text","text":"] in the main loop."}],"kind":"symbol","title":"sourceContinue","fragments":[{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"text":"sourceContinue","kind":"identifier"},{"kind":"text","text":": "},{"text":"gboolean","kind":"typeIdentifier","preciseIdentifier":"c:@T@gboolean"}]},"doc://GLib/documentation/GLib/SourceFuncsRef":{"url":"\/documentation\/glib\/sourcefuncsref","type":"topic","abstract":[{"type":"text","text":"The "},{"code":"GSourceFuncs","type":"codeVoice"},{"text":" struct contains a table of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"functions used to handle event sources in a generic manner."}],"navigatorTitle":[{"text":"SourceFuncsRef","kind":"identifier"}],"kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SourceFuncsRef","kind":"identifier"}],"role":"symbol","title":"SourceFuncsRef","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef"},"doc://GLib/documentation/GLib/sourceRemove":{"title":"sourceRemove","abstract":[{"text":"Use this macro as the return value of a [callback","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFunc","isActive":true,"type":"reference"},{"type":"text","text":"] to remove"},{"text":" ","type":"text"},{"type":"text","text":"the [struct"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Source","type":"reference"},{"text":"] from the main loop.","type":"text"}],"kind":"symbol","role":"symbol","type":"topic","fragments":[{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"sourceRemove"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:s5Int32V","text":"Int32"}],"url":"\/documentation\/glib\/sourceremove","identifier":"doc:\/\/GLib\/documentation\/GLib\/sourceRemove"},"doc://GLib/documentation/GLib/SourceFuncsRef/check":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncsRef\/check","role":"symbol","kind":"symbol","type":"topic","url":"\/documentation\/glib\/sourcefuncsref\/check","title":"check","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"check","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"GSourceFuncsCheckFunc","preciseIdentifier":"c:@T@GSourceFuncsCheckFunc"},{"text":"!","kind":"text"}],"abstract":[{"text":"Called after all the file descriptors are polled. The","type":"text"},{"type":"text","text":" "},{"type":"text","text":"source should return "},{"type":"codeVoice","code":"true"},{"type":"text","text":" if it is ready to be dispatched. Note that"},{"type":"text","text":" "},{"text":"some time may have passed since the previous prepare function was called,","type":"text"},{"text":" ","type":"text"},{"text":"so the source should be checked again here.  Since 2.36 this may","type":"text"},{"type":"text","text":" "},{"type":"text","text":"be "},{"code":"nil","type":"codeVoice"},{"text":", in which case the effect is as if the function always returns","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"false"},{"type":"text","text":"."}]}}}
{"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"role":"symbol","symbolKind":"method","roleHeading":"Instance Method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"set","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"clearFunc"},{"kind":"text","text":": "},{"preciseIdentifier":"c:@T@GDestroyNotify","text":"GDestroyNotify","kind":"typeIdentifier"},{"text":"?)","kind":"text"}],"externalID":"s:4GLib13ArrayProtocolPAAE3set9clearFuncyySvSgXCSg_tF::SYNTHESIZED::s:4GLib9ArrayTypeC","extendedModule":"GLib","modules":[{"name":"GLib"}],"title":"set(clearFunc:)"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"set"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"clearFunc"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@GDestroyNotify","kind":"typeIdentifier","text":"GDestroyNotify"},{"text":"? = nil)","kind":"text"}]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"clearFunc"},{"type":"text","text":" will be called when an element in the array"},{"type":"text","text":" "},{"text":"data segment is removed and when the array is freed and data","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"segment is deallocated as well. "},{"type":"codeVoice","code":"clearFunc"},{"text":" will be passed a","type":"text"},{"type":"text","text":" "},{"text":"pointer to the element to clear, rather than the element itself.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that in contrast with other uses of [callback"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/DestroyNotify","type":"reference"},{"type":"text","text":"]"},{"type":"text","text":" "},{"text":"functions, ","type":"text"},{"type":"codeVoice","code":"clearFunc"},{"text":" is expected to clear the contents of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the array element it is given, but not free the element itself."}]},{"code":["typedef struct","{","  gchar *str;","  GObject *obj;","} ArrayElement;","","static void","array_element_clear (ArrayElement *element)","{","  g_clear_pointer (&element->str, g_free);","  g_clear_object (&element->obj);","}","","\/\/ main code","GArray *garray = g_array_new (FALSE, FALSE, sizeof (ArrayElement));","g_array_set_clear_func (garray, (GDestroyNotify) array_element_clear);","\/\/ assign data to the structure","g_array_free (garray, TRUE);"],"syntax":"c","type":"codeListing"}]}],"sections":[],"abstract":[{"text":"Sets a function to clear an element of ","type":"text"},{"code":"array","type":"codeVoice"},{"type":"text","text":"."}],"variants":[{"paths":["\/documentation\/glib\/arraytype\/set(clearfunc:)"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/ArrayType\/set(clearFunc:)","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/ArrayType","doc:\/\/GLib\/documentation\/GLib\/ArrayType\/ArrayProtocol-Implementations"]]},"kind":"symbol","references":{"doc://GLib/documentation/GLib/ArrayType":{"navigatorTitle":[{"text":"ArrayType","kind":"identifier"}],"type":"topic","title":"ArrayType","abstract":[{"type":"text","text":"Contains the public fields of a "},{"code":"GArray","type":"codeVoice"},{"text":".","type":"text"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/ArrayType","kind":"symbol","role":"symbol","url":"\/documentation\/glib\/arraytype","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"ArrayType","kind":"identifier"}]},"doc://GLib/documentation/GLib/DestroyNotify":{"abstract":[{"type":"text","text":"Specifies the type of function which is called when a data element"},{"type":"text","text":" "},{"type":"text","text":"is destroyed. It is passed the pointer to the data element and"},{"text":" ","type":"text"},{"type":"text","text":"should free any memory and resources allocated for it."}],"title":"DestroyNotify","fragments":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DestroyNotify","kind":"identifier"}],"url":"\/documentation\/glib\/destroynotify","kind":"symbol","role":"symbol","navigatorTitle":[{"text":"DestroyNotify","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/DestroyNotify"},"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"doc://GLib/documentation/GLib/ArrayType/set(clearFunc:)":{"type":"topic","kind":"symbol","role":"symbol","abstract":[{"type":"text","text":"Sets a function to clear an element of "},{"type":"codeVoice","code":"array"},{"type":"text","text":"."}],"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"set","kind":"identifier"},{"text":"(","kind":"text"},{"text":"clearFunc","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GDestroyNotify","text":"GDestroyNotify"},{"text":"?)","kind":"text"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/ArrayType\/set(clearFunc:)","url":"\/documentation\/glib\/arraytype\/set(clearfunc:)","title":"set(clearFunc:)"},"doc://GLib/documentation/GLib/ArrayType/ArrayProtocol-Implementations":{"role":"collectionGroup","kind":"article","title":"ArrayProtocol Implementations","type":"topic","url":"\/documentation\/glib\/arraytype\/arrayprotocol-implementations","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib\/ArrayType\/ArrayProtocol-Implementations"}}}
act":[{"text":"Locks ","type":"text"},{"code":"lock","type":"codeVoice"},{"type":"text","text":" for writing. If "},{"code":"lock","type":"codeVoice"},{"type":"text","text":" is already locked for writing or"},{"text":" ","type":"text"},{"type":"text","text":"reading by other threads, this function will block until "},{"type":"codeVoice","code":"lock"},{"type":"text","text":" is"},{"text":" ","type":"text"},{"type":"text","text":"completely unlocked and then lock "},{"type":"codeVoice","code":"lock"},{"type":"text","text":" for writing. While this"},{"text":" ","type":"text"},{"text":"functions waits to lock ","type":"text"},{"type":"codeVoice","code":"lock"},{"type":"text","text":", no other thread can lock "},{"code":"lock","type":"codeVoice"},{"type":"text","text":" for"},{"type":"text","text":" "},{"type":"text","text":"reading. When "},{"code":"lock","type":"codeVoice"},{"text":" is locked for writing, no other thread can lock","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"lock"},{"text":" (neither for reading nor writing). This lock has to be","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"unlocked by "},{"code":"g_static_rw_lock_writer_unlock()","type":"codeVoice"},{"type":"text","text":"."}],"title":"writerLock()","kind":"symbol","type":"topic","role":"symbol","deprecated":true},"doc://GLib/documentation/GLib/StaticRWLockProtocol/readerTrylock()":{"deprecated":true,"type":"topic","url":"\/documentation\/glib\/staticrwlockprotocol\/readertrylock()","title":"readerTrylock()","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLockProtocol\/readerTrylock()","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"readerTrylock"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"abstract":[{"text":"Tries to lock ","type":"text"},{"type":"codeVoice","code":"lock"},{"type":"text","text":" for reading. If "},{"type":"codeVoice","code":"lock"},{"text":" is already locked for","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"writing by another thread or if another thread is already waiting to"},{"text":" ","type":"text"},{"type":"text","text":"lock "},{"code":"lock","type":"codeVoice"},{"text":" for writing, immediately returns ","type":"text"},{"code":"false","type":"codeVoice"},{"text":". Otherwise locks","type":"text"},{"type":"text","text":" "},{"code":"lock","type":"codeVoice"},{"type":"text","text":" for reading and returns "},{"code":"true","type":"codeVoice"},{"type":"text","text":". This lock has to be unlocked by"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_static_rw_lock_reader_unlock()"},{"text":".","type":"text"}],"role":"symbol"},"doc://GLib/documentation/GLib/StaticRWLockRef":{"fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"StaticRWLockRef","kind":"identifier"}],"type":"topic","title":"StaticRWLockRef","url":"\/documentation\/glib\/staticrwlockref","navigatorTitle":[{"text":"StaticRWLockRef","kind":"identifier"}],"kind":"symbol","abstract":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLock","isActive":true,"type":"reference"},{"type":"text","text":" struct represents a read-write lock. A read-write"},{"type":"text","text":" "},{"text":"lock can be used for protecting data that some portions of code only","type":"text"},{"type":"text","text":" "},{"type":"text","text":"read from, while others also write. In such situations it is"},{"text":" ","type":"text"},{"type":"text","text":"desirable that several readers can read at once, whereas of course"},{"text":" ","type":"text"},{"type":"text","text":"only one writer may write at a time."}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLockRef","role":"symbol"},"doc://GLib/documentation/GLib/Mutex":{"url":"\/documentation\/glib\/mutex","role":"symbol","navigatorTitle":[{"text":"Mutex","kind":"id
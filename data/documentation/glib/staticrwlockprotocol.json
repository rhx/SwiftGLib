ier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLockProtocol\/readerLock()","title":"readerLock()","role":"symbol","type":"topic","abstract":[{"text":"Locks ","type":"text"},{"type":"codeVoice","code":"lock"},{"type":"text","text":" for reading. There may be unlimited concurrent locks for"},{"type":"text","text":" "},{"type":"text","text":"reading of a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/StaticRWLock"},{"text":" at the same time.  If ","type":"text"},{"type":"codeVoice","code":"lock"},{"type":"text","text":" is already"},{"text":" ","type":"text"},{"type":"text","text":"locked for writing by another thread or if another thread is already"},{"text":" ","type":"text"},{"text":"waiting to lock ","type":"text"},{"type":"codeVoice","code":"lock"},{"type":"text","text":" for writing, this function will block until"},{"type":"text","text":" "},{"type":"codeVoice","code":"lock"},{"type":"text","text":" is unlocked by the other writing thread and no other writing"},{"text":" ","type":"text"},{"text":"threads want to lock ","type":"text"},{"type":"codeVoice","code":"lock"},{"type":"text","text":". This lock has to be unlocked by"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_static_rw_lock_reader_unlock()"},{"type":"text","text":"."}]},"doc://GLib/documentation/GLib/PointerWrapper":{"fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"PointerWrapper"}],"kind":"symbol","abstract":[{"text":"Protocol for GLib types that wrap pointers.","type":"text"}],"title":"PointerWrapper","url":"\/documentation\/glib\/pointerwrapper","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"PointerWrapper"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","type":"topic"},"doc://GLib/documentation/GLib/StaticRWLockProtocol":{"navigatorTitle":[{"text":"StaticRWLockProtocol","kind":"identifier"}],"type":"topic","title":"StaticRWLockProtocol","abstract":[{"t
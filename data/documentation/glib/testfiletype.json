{"sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"navigatorTitle":[{"kind":"identifier","text":"TestFileType"}],"role":"symbol","symbolKind":"typealias","roleHeading":"Type Alias","modules":[{"name":"GLib"}],"title":"TestFileType","externalID":"s:4GLib12TestFileTypea","fragments":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TestFileType","kind":"identifier"}]},"abstract":[{"type":"text","text":"The type of file to return the filename for, when used with"},{"type":"text","text":" "},{"type":"text","text":"[func"},{"type":"codeVoice","code":"GLib.test_build_filename"},{"type":"text","text":"]."}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"text":"TestFileType","kind":"identifier"},{"text":" = ","kind":"text"},{"kind":"typeIdentifier","text":"GTestFileType","preciseIdentifier":"c:@EA@GTestFileType"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"inlineContent":[{"type":"text","text":"These two options correspond rather directly to the ‘dist’ and"},{"text":" ","type":"text"},{"text":"‘built’ terminology that automake uses and are explicitly used to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"distinguish between the ‘srcdir’ and ‘builddir’ being separate. All"},{"type":"text","text":" "},{"type":"text","text":"files in your project should either be dist (in the "},{"type":"codeVoice","code":"EXTRA_DIST"},{"text":" or","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"dist_schema_DATA"},{"type":"text","text":" sense, in which case they will always be in the"},{"type":"text","text":" "},{"text":"srcdir) or built (in the ","type":"text"},{"type":"codeVoice","code":"BUILT_SOURCES"},{"text":" sense, in which case they","
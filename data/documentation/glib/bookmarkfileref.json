{"variants":[{"paths":["\/documentation\/glib\/bookmarkfileref"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"metadata":{"symbolKind":"struct","externalID":"s:4GLib15BookmarkFileRefV","modules":[{"name":"GLib"}],"roleHeading":"Structure","title":"BookmarkFileRef","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"BookmarkFileRef","kind":"identifier"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"BookmarkFileRef"}]},"topicSections":[{"identifiers":["doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init()","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(_:)-2fawg","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(_:)-2gux1","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(_:)-5l1bm","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(_:)-9fjcb","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(_:)-x28p","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(cPointer:)","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(constPointer:)","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(gconstpointer:)","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(gpointer:)","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(mutating:)","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/init(opaquePointer:)"],"anchor":"Initializers","generated":true,"title":"Initializers"},{"anchor":"Instance-Properties","generated":true,"title":"Instance Properties","identifiers":["doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/ptr"]},{"title":"Default Implementations","identifiers":["doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/BookmarkFileProtocol-Implementations","doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef\/PointerWrapper-Implementations"],"anchor":"Default-Implementations","generated":true}],"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"BookmarkFileRef","kind":"identifier"}]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Overview","anchor":"overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Bookmarks refer to a URI, along with some meta-data about the resource"},{"type":"text","text":" "},{"text":"pointed by the URI like its MIME type, the application that is registering","type":"text"},{"text":" ","type":"text"},{"text":"the bookmark and the icon that should be used to represent the bookmark.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The data is stored using the"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/www.freedesktop.org\/wiki\/Specifications\/desktop-bookmark-spec\/"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The syntax of the bookmark files is described in detail inside the"},{"text":" ","type":"text"},{"type":"text","text":"Desktop Bookmark Specification, here is a quick summary: bookmark"},{"type":"text","text":" "},{"text":"files use a sub-class of the XML Bookmark Exchange Language","type":"text"},{"text":" ","type":"text"},{"text":"specification, consisting of valid UTF-8 encoded XML, under the","type":"text"},{"type":"text","text":" "},{"code":"<xbel>","type":"codeVoice"},{"type":"text","text":" root element; each bookmark is stored inside a"},{"text":" ","type":"text"},{"code":"<bookmark>","type":"codeVoice"},{"text":" element, using its URI: no relative paths can","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"be used inside a bookmark file. The bookmark may have a user defined"},{"text":" ","type":"text"},{"type":"text","text":"title and description, to be used instead of the URI. Under the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"<metadata>"},{"type":"text","text":" element, with its owner attribute set to"},{"type":"text","text":" "},{"type":"codeVoice","code":"http:\/\/freedesktop.org"},{"type":"text","text":", is stored the meta-data about a resource"},{"type":"text","text":" "},{"text":"pointed by its URI. The meta-data consists of the resource’s MIME","type":"text"},{"type":"text","text":" "},{"type":"text","text":"type; the applications that have registered a bookmark; the groups"},{"type":"text","text":" "},{"text":"to which a bookmark belongs to; a visibility flag, used to set the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"bookmark as “private” to the applications and groups that has it"},{"type":"text","text":" "},{"type":"text","text":"registered; the URI and MIME type of an icon, to be used when"},{"text":" ","type":"text"},{"text":"displaying the bookmark inside a GUI.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Here is an example of a bookmark file:","type":"text"},{"type":"text","text":" "},{"identifier":"https:\/\/gitlab.gnome.org\/GNOME\/glib\/-\/blob\/HEAD\/glib\/tests\/bookmarks.xbel","type":"reference","isActive":true}]},{"inlineContent":[{"type":"text","text":"A bookmark file might contain more than one bookmark; each bookmark"},{"type":"text","text":" "},{"type":"text","text":"is accessed through its URI."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The important caveat of bookmark files is that when you add a new","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"bookmark you must also add the application that is registering it, using"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"code":"GLib.BookmarkFile.add_application","type":"codeVoice"},{"text":"] or [method","type":"text"},{"type":"codeVoice","code":"GLib.BookmarkFile.set_application_info"},{"text":"].","type":"text"},{"type":"text","text":" "},{"type":"text","text":"If a bookmark has no applications then it won’t be dumped when creating"},{"text":" ","type":"text"},{"type":"text","text":"the on disk representation, using [method"},{"type":"codeVoice","code":"GLib.BookmarkFile.to_data"},{"text":"] or","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"code":"GLib.BookmarkFile.to_file","type":"codeVoice"},{"type":"text","text":"]."}]},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef","isActive":true},{"type":"text","text":" type acts as a lightweight Swift reference to an underlying "},{"code":"GBookmarkFile","type":"codeVoice"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"type":"text","text":"It exposes methods that can operate on this data type through "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFileProtocol","isActive":true},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef","type":"reference","isActive":true},{"type":"text","text":" only as an "},{"code":"unowned","type":"codeVoice"},{"text":" reference to an existing ","type":"text"},{"type":"codeVoice","code":"GBookmarkFile"},{"text":" instance.","type":"text"}],"type":"paragraph"},{"content":[{"inlineContent":[{"type":"text","text":"Use "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFile","type":"reference"},{"type":"text","text":" (instead of "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef","isActive":true,"type":"reference"},{"text":") if you want to use Automatic Reference Counting for memory management of the underlying ","type":"text"},{"type":"codeVoice","code":"GBookmarkFile"},{"text":" instance.","type":"text"}],"type":"paragraph"}],"name":"Note","type":"aside","style":"note"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/BookmarkFileRef"},"kind":"symbol","abst
{"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"title":"get(filenameCharsets:)","modules":[{"name":"GLib"}],"externalID":"s:4GLib3get16filenameCharsetsSbSpySpySPys4Int8VGSgGSgGSg_tF","symbolKind":"func","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"get"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"filenameCharsets"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"text":"<","kind":"text"},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"text":">?>?>!) -> ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"roleHeading":"Function"},"abstract":[{"type":"text","text":"Determines the preferred character sets used for filenames."},{"text":" ","type":"text"},{"type":"text","text":"The first character set from the "},{"type":"codeVoice","code":"charsets"},{"text":" is the filename encoding, the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"subsequent character sets are used when trying to generate a displayable"},{"text":" ","type":"text"},{"text":"representation of a filename, see ","type":"text"},{"code":"g_filename_display_name()","type":"codeVoice"},{"type":"text","text":"."}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"get"},{"kind":"text","text":"("},{"kind":"externalParam","text":"filenameCharsets"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">?>?>!) -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"On Unix, the character sets are determined by consulting the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"environment variables "},{"type":"codeVoice","code":"G_FILENAME_ENCODING"},{"type":"text","text":" and "},{"type":"codeVoice","code":"G_BROKEN_FILENAMES"},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"On Windows, the character set used in the GLib API is always UTF-8","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and said environment variables have no effect."}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"G_FILENAME_ENCODING"},{"type":"text","text":" may be set to a comma-separated list of"},{"text":" ","type":"text"},{"text":"character set names. The special token ","type":"text"},{"type":"codeVoice","code":"locale"},{"type":"text","text":" is taken to mean the"},{"text":" ","type":"text"},{"text":"character set for the ","type":"text"},{"type":"reference","isActive":true,"identifier":"running.html#locale"},{"type":"text","text":"."},{"text":" ","type":"text"},{"text":"If ","type":"text"},{"type":"codeVoice","code":"G_FILENAME_ENCODING"},{"text":" is not set, but ","type":"text"},{"type":"codeVoice","code":"G_BROKEN_FILENAMES"},{"type":"text","text":" is,"},{"text":" ","type":"text"},{"text":"the character set of the current locale is taken as the filename","type":"text"},{"text":" ","type":"text"},{"text":"encoding. If neither environment variable  is set, UTF-8 is taken","type":"text"},{"text":" ","type":"text"},{"text":"as the filename encoding, but the character set of the current locale","type":"text"},{"type":"text","text":" "},{"text":"is also put in the list of encodings.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The returned ","type":"text"},{"type":"codeVoice","code":"charsets"},{"text":" belong to GLib and must not be freed.","type":"text"}]},{"inlineContent":[{"text":"Note that on Unix, regardless of the locale character set or","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"G_FILENAME_ENCODING"},{"type":"text","text":" value, the actual file names present"},{"type":"text","text":" "},{"text":"on a system might be in any random encoding or just gibberish.","type":"text"}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"sections":[],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/get(filenameCharsets:)","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/get(filenamecharsets:)"]}],"references":{"doc://GLib/documentation/GLib/get(filenameCharsets:)":{"title":"get(filenameCharsets:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"get","kind":"identifier"},{"kind":"text","text":"("},{"text":"filenameCharsets","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"text":"<","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"text":">?>?>!) -> ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"abstract":[{"type":"text","text":"Determines the preferred character se
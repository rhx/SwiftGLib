{"sections":[],"kind":"symbol","primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"getHomeDir"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"},{"text":"!","kind":"text"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"As with most UNIX tools, this function will return the value of the"},{"text":" ","type":"text"},{"code":"HOME","type":"codeVoice"},{"type":"text","text":" environment variable if it is set to an existing absolute path"},{"text":" ","type":"text"},{"type":"text","text":"name, falling back to the "},{"type":"codeVoice","code":"passwd"},{"type":"text","text":" file in the case that it is unset."}]},{"type":"paragraph","inlineContent":[{"text":"If the path given in ","type":"text"},{"code":"HOME","type":"codeVoice"},{"type":"text","text":" is non-absolute, does not exist, or is"},{"type":"text","text":" "},{"type":"text","text":"not a directory, the result is undefined."}]},{"type":"paragraph","inlineContent":[{"text":"Before version 2.36 this function would ignore the ","type":"text"},{"type":"codeVoice","code":"HOME"},{"type":"text","text":" environment"},{"type":"text","text":" "},{"type":"text","text":"variable, taking the value from the "},{"type":"codeVoice","code":"passwd"},{"text":" database instead. This was","type":"text"},{"type":"text","text":" "},{"text":"changed to increase the compatibility of GLib with other programs (and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the XDG basedir specification) and to increase testability of programs"},{"type":"text","text":" "},{"type":"text","text":"based on GLib (by making it easier to run them from test frameworks)."}]},{"inlineContent":[{"type":"text","text":"If your program has a strong requirement for either the new or the"},{"type":"text","text":" "},{"type":"text","text":"old behaviour (and if you don’t wish to increase your GLib"},{"type":"text","text":" "},{"type":"text","text":"dependency to ensure that the new behaviour is in effect) then you"},{"type":"text","text":" "},{"text":"should either directly check the ","type":"text"},{"type":"codeVoice","code":"HOME"},{"text":" environment variable yourself","type":"text"},{"type":"text","text":" "},{"type":"text","text":"or unset it before calling any functions in GLib."}],"type":"paragraph"}]}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/getHomeDir()","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"text":"Gets the current user’s home directory.","type":"text"}],"variants":[{"paths":["\/documentation\/glib\/gethomedir()"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"title":"getHomeDir()","roleHeading":"Function","symbolKind":"func","modules":[{"name":"GLib"}],"role":"symbol","externalID":"s:4GLib10getHomeDirSSSgyF","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"getHomeDir"},{"kind":"text","text":"() -> "},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"text":"!","kind":"text"}]},"references":{"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"doc://GLib/documentation/GLib/getHomeDir()":{"type":"topic","url":"\/documentation\/glib\/gethomedir()","title":"getHomeDir()","identifier":"doc:\/\/GLib\/documentation\/GLib\/getHomeDir()","role":"symbol","kind":"symbol","abstract":[{"type":"text","text":"Gets the current user’s home directory."}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"getHomeDir"},{"text":"() -> ","kind":"text"},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"text":"!","kind":"text"}]}}}
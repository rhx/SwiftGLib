{"abstract":[{"type":"text","text":"A value that can be passed as an option to [func"},{"type":"codeVoice","code":"GLib.test_init"},{"text":"].","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/testoptionisolatedirs"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"testOptionIsolateDirs"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"}]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"inlineContent":[{"text":"Creates a unique temporary directory for each unit test and uses sets","type":"text"},{"type":"text","text":" "},{"type":"text","text":"XDG directories to point into subdirectories of it for the duration of"},{"text":" ","type":"text"},{"type":"text","text":"the unit test. The directory tree is cleaned up after the test finishes"},{"text":" ","type":"text"},{"text":"successfully.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Note that this doesn’t take effect until [func","type":"text"},{"code":"GLib.test_run","type":"codeVoice"},{"text":"] is called,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"so calls to (for example) [func"},{"code":"GLib.get_home_dir","type":"codeVoice"},{"type":"text","text":"] will return the"},{"text":" ","type":"text"},{"text":"system-wide value when made in a test program’s ","type":"text"},{"code":"main()","type":"codeVoice"},{"type":"text","text":" function."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The following functions will return subdirectories of the temporary directory"},{"text":" ","type":"text"},{"type":"text","text":"when this option is used. The specific subdirectory paths in use are not"},{"type":"text","text":" "},{"type":"text","text":"guaranteed to be stable API — always use a getter function to retrieve them."}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"[func","type":"text"},{"code":"GLib.get_home_dir","type":"codeVoice"},{"text":"]","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"[func"},{"type":"codeVoice","code":"GLib.get_user_cache_dir"},{"type":"text","text":"]"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"[func"},{"type":"codeVoice","code":"GLib.get_system_config_dirs"},{"text":"]","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"[func"},{"type":"codeVoice","code":"GLib.get_user_config_dir"},{"type":"text","text":"]"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"[func"},{"type":"codeVoice","code":"GLib.get_system_data_dirs"},{"type":"text","text":"]"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"[func"},{"code":"GLib.get_user_data_dir","type":"codeVoice"},{"type":"text","text":"]"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"[func"},{"type":"codeVoice","code":"GLib.get_user_state_dir"},{"text":"]","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"[func","type":"text"},{"code":"GLib.get_user_runtime_dir","type":"codeVoice"},{"text":"]","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"The subdirectories may not be created by the test harness; as with normal","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"calls to functions like [func"},{"code":"GLib.get_user_cache_dir","type":"codeVoice"},{"type":"text","text":"], the caller must"},{"text":" ","type":"text"},{"text":"be prepared to create the directory if it doesn’t exist.","type":"text"}]}]}],"identifier
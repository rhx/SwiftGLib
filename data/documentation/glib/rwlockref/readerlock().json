{"metadata":{"roleHeading":"Instance Method","extendedModule":"GLib","title":"readerLock()","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"readerLock"},{"kind":"text","text":"()"}],"symbolKind":"method","externalID":"s:4GLib14RWLockProtocolPAAE10readerLockyyF::SYNTHESIZED::s:4GLib9RWLockRefV","modules":[{"name":"GLib"}],"role":"symbol"},"schemaVersion":{"major":0,"patch":0,"minor":3},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/RWLockRef\/readerLock()","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/glib\/rwlockref\/readerlock()"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"Obtain a read lock on "},{"code":"rwLock","type":"codeVoice"},{"text":". If another thread currently holds","type":"text"},{"type":"text","text":" "},{"text":"the write lock on ","type":"text"},{"type":"codeVoice","code":"rwLock"},{"type":"text","text":", the current thread will block until the"},{"text":" ","type":"text"},{"text":"write lock was (held and) released. If another thread does not hold","type":"text"},{"type":"text","text":" "},{"text":"the write lock, but is waiting for it, it is implementation defined","type":"text"},{"text":" ","type":"text"},{"text":"whether the reader or writer will block. Read locks can be taken","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"recursively."}],"sections":[],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/RWLockRef","doc:\/\/GLib\/documentation\/GLib\/RWLockRef\/RWLockProtocol-Implementations"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"readerLock","kind":"identifier"},{"text":"()","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Calling "},{"type":"codeVoice","code":"g_rw_lock_reader_lock()"},{"type":"text","text":" while the current thread already"},{"text":" ","type":"text"},{"text":"owns a write lock leads to undefined behaviour. Read locks however","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"can be taken recursively, in which case you need to make sure to"},{"text":" ","type":"text"},{"type":"text","text":"call "},{"type":"codeVoice","code":"g_rw_lock_reader_unlock()"},{"text":" the same amount of times.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is implementation-defined how many read locks are allowed to be"},{"text":" ","type":"text"},{"type":"text","text":"held on the same lock simultaneously. If the limit is hit,"},{"text":" ","type":"text"},{"text":"or if a deadlock is detected, a critical warning will be emitted.","type":"text"}]}]}],"references":{"doc://GLib/documentation/GLib/RWLockRef/readerLock()":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockRef\/readerLock()","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"readerLock","kind":"identifier"},{"kind":"text","text":"()"}],"abstract":[{"type":"text","text":"Obtain a read lock on "},{"type":"codeVoice","code":"rwLock"},{"text":". If another thread currently holds","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the write lock on "},{"code":"rwLock","type":"codeVoice"},{"type":"text","text":", the current thread will block until the"},{"text":" ","type":"text"},{"text":"write lock was (held and) released. If another thread does not hold","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the write lock, but is waiting for it, it is implementation defined"},{"text":" ","type":"text"},{"type":"text","text":"whether the reader or writer will block. Read locks can be taken"},{"text":" ","type":"text"},{"text":"recursively.","type":"text"}],"url":"\/documentation\/glib\/rwlockref\/readerlock()","kind":"symbol","role":"symbol","type":"topic","title":"readerLock()"},"doc://GLib/documentation/GLib/Mutex":{"url":"\/documentation\/glib\/mutex","role":"symbol","navigatorTitle":[{"text":"Mutex","kind":"identifier"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","type":"topic","abstract":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","isActive":true},{"text":" struct is an opaque data structure to represent a mutex","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"(mutual exclusion). It can be used to protect data against shared"},{"text":" ","type":"text"},{"type":"text","text":"access."}],"kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Mutex"}],"title":"Mutex"},"doc://GLib/documentation/GLib/RWLockRef":{"abstract":[{"type":"text","text":"The GRWLock struct is an opaque data structure to represent a"},{"text":" ","type":"text"},{"type":"text","text":"reader-writer lock. It is similar to a "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Mutex","type":"reference","isActive":true},{"text":" in that it allows","type":"text"},{"type":"text","text":" "},{"text":"multiple threads to coordinate access to a shared resource.","type":"text"}],"title":"RWLockRef","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"RWLockRef","kind":"identifier"}],"role":"symbol","url":"\/documentation\/glib\/rwlockref","identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockRef","navigatorTitle":[{"text":"RWLockRef","kind":"identifier"}],"kind":"symbol"},"doc://GLib/documentation/GLib/RWLockRef/RWLockProtocol-Implementations":{"role":"collectionGroup","identifier":"doc:\/\/GLib\/documentation\/GLib\/RWLockRef\/RWLockProtocol-Implementations","url":"\/documentation\/glib\/rwlockref\/rwlockprotocol-implementations","abstract":[],"type":"topic","title":"RWLockProtocol Implementations","kind":"article"},"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]}}}
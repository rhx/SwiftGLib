buffer, &n_chunks);","for (gsize i = 0; i < n_chunks; i++)","  {","    \/\/ Do something with each chunk here, and then free them, since","    \/\/ `g_ptr_array_steal()` transfers ownership of all the elements and the","    \/\/ array to the caller.","    …","","    g_bytes_unref (chunks[i]);","  }","","g_free (chunks);","","\/\/ After calling `g_ptr_array_steal()`, the pointer array can be reused for the","\/\/ next set of chunks.","g_assert (chunk_buffer->len == 0);"],"type":"codeListing","syntax":"c"}]}],"references":{"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"doc://GLib/documentation/GLib/RefArrayRef":{"abstract":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"RefArrayRef"},{"text":" struct acts as a lightweight, typed wrapper aroundptr ","type":"text"},{"type":"codeVoice","code":"GList"},{"type":"text","text":","},{"text":" ","type":"text"},{"text":"with the associated ","type":"text"},{"type":"codeVoice","code":"Element"},{"type":"text","text":" representing the type of"},{"type":"text","text":" "},{"text":"the elements stored in the list.","type":"text"}],"navigatorTitle":[{"text":"RefArrayRef","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"RefArrayRef","kind":"identifier"}],"kind":"symbol","type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/RefArrayRef","title":"RefArrayRef","url":"\/documentation\/glib\/refarrayref","role":"symbol"},"doc://GLib/documentation/GLib/DestroyNotify":{"abstract":[{"type":"text","text":"Specifies the type of function which is called when a data element"},{"type":"text","text":" "},{"type":"text","text":"is destroyed. It is passed the pointer to the data element and"},{"text":" ","type":"text"},{"type":"text","text":"should free any memory and resources allocated for it."}],"title":"DestroyNotify","frag
{"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"title":"TimeZoneRef","modules":[{"name":"GLib"}],"externalID":"s:4GLib11TimeZoneRefV","symbolKind":"struct","navigatorTitle":[{"text":"TimeZoneRef","kind":"identifier"}],"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TimeZoneRef","kind":"identifier"}],"roleHeading":"Structure"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"A "},{"type":"codeVoice","code":"GTimeZone"},{"type":"text","text":" represents a time zone, at no particular point in time."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"TimeZoneRef","kind":"identifier"}],"languages":["swift"]}]},{"content":[{"anchor":"overview","level":2,"type":"heading","text":"Overview"},{"inlineContent":[{"type":"text","text":"The "},{"code":"GTimeZone","type":"codeVoice"},{"type":"text","text":" struct is refcounted and immutable."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Each time zone has an identifier (for example, ‘Europe\/London’) which is","type":"text"},{"type":"text","text":" "},{"text":"platform dependent. See [ctor","type":"text"},{"code":"GLib.TimeZone.new","type":"codeVoice"},{"text":"] for information on the","type":"text"},{"text":" ","type":"text"},{"text":"identifier formats. The identifier of a time zone can be retrieved using","type":"text"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.TimeZone.get_identifier"},{"text":"].","type":"text"}]},{"inlineContent":[{"text":"A time zone contains a number of intervals. Each interval has an abbreviation","type":"text"},{"text":" ","type":"text"},{"text":"to describe it (for example, ‘PDT’), an offset to UTC and a flag indicating","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"if the daylight savings time is in effect during that interval. A time zone"},{"type":"text","text":" "},{"text":"always has at least one interval — interval 0. Note that interval abbreviations","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"are not the same as time zone identifiers (apart from ‘UTC’), and cannot be"},{"text":" ","type":"text"},{"text":"passed to [ctor","type":"text"},{"type":"codeVoice","code":"GLib.TimeZone.new"},{"text":"].","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Every UTC time is contained within exactly one interval, but a given","type":"text"},{"type":"text","text":" "},{"type":"text","text":"local time may be contained within zero, one or two intervals (due to"},{"text":" ","type":"text"},{"type":"text","text":"incontinuities associated with daylight savings time)."}],"type":"paragraph"},{"inlineContent":[{"text":"An interval may refer to a specific period of time (eg: the duration","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of daylight savings time during 2010) or it may refer to many periods"},{"text":" ","type":"text"},{"text":"of time that share the same properties (eg: all periods of daylight","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"savings time).  It is also possible (usually for political reasons)"},{"type":"text","text":" "},{"text":"that some properties (like the abbreviation) change between intervals","type":"text"},{"text":" ","type":"text"},{"text":"without other properties changing.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef","isActive":true},{"text":" type acts as a lightweight Swift reference to an underlying ","type":"text"},{"type":"codeVoice","code":"GTimeZone"},{"text":" instance.","type":"text"},{"text":" ","type":"text"},{"text":"It exposes methods that can operate on this data type through ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZoneProtocol"},{"text":" conformance.","type":"text"},{"text":" ","type":"text"},{"text":"Use ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef"},{"text":" only as an ","type":"text"},{"code":"unowned","type":"codeVoice"},{"text":" reference to an existing ","type":"text"},{"code":"GTimeZone","type":"codeVoice"},{"type":"text","text":" instance."}]},{"type":"aside","name":"Note","style":"note","content":[{"inlineContent":[{"type":"text","text":"Use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone"},{"text":" (instead of ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef","type":"reference"},{"type":"text","text":") if you want to use Automatic Reference Counting for memory management of the underlying "},{"type":"codeVoice","code":"GTimeZone"},{"type":"text","text":" instance."}],"type":"paragraph"}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/timezoneref"]}],"kind":"symbol","sections":[],"topicSections":[{"title":"Initializers","generated":true,"identifiers":["doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef\/init(_:)-3wi4a","doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef\/init(_:)-5j2y","doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef\/init(_:)-7gvn1","doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef\/init(_:)-8j5ou","doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef\/init(_:)-8m404","doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef\/init(cPointer:)","doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef\/init(constPointer:)","doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef\/init(gconstpointer:)","doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef\/init(gpointer:)","doc:\/\/GLib\/docume
.","type":"text"},{"text":" ","type":"text"},{"text":"Despite the fact that ","type":"text"},{"type":"codeVoice","code":"bytesRead"},{"text":" can return information about partial","type":"text"},{"text":" ","type":"text"},{"text":"characters, the g_convert_… functions are not generally suitable","type":"text"},{"type":"text","text":" "},{"type":"text","text":"for streaming. If the underlying converter maintains internal state,"},{"type":"text","text":" "},{"type":"text","text":"then this won’t be preserved across successive calls to "},{"type":"codeVoice","code":"g_convert()"},{"type":"text","text":","},{"text":" ","type":"text"},{"code":"g_convert_with_iconv()","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"g_convert_with_fallback()","type":"codeVoice"},{"text":". (An example of","type":"text"},{"type":"text","text":" "},{"text":"this is the GNU C converter for CP1255 which does not emit a base","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"character until it knows that the next character is not a mark that"},{"type":"text","text":" "},{"type":"text","text":"could combine with the base character.)"}]},{"type":"paragraph","inlineContent":[{"text":"Characters which are valid in the input character set, but which have no","type":"text"},{"type":"text","text":" "},{"type":"text","text":"representation in the output character set will result in a"},{"type":"text","text":" "},{"code":"illegalSequence","type":"codeVoice"},{"type":"text","text":" error. This is in contrast to the "},{"code":"iconv()","type":"codeVoice"},{"text":" ","type":"text"},{"text":"specification, which leaves this behaviour implementation defined. Note that","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"this is the same error code as is returned for an invalid byte sequence in"},{"text":" ","type":"text"},{"type":"text","text":"the input character set. To get defined behaviour for conversion of"},{"type":"text","text":" "},{"text":"unrepresentable characters, use ","type":"text"},{"type":"codeVoice","code":"g_convert_with_fallback()"},{"type":"text","text":"."}]}]}],"abstract":[{"type":"text","text":"Converts a string from one character set to another."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/convertwithiconv(str:len:converter:bytesread:byteswritten:)"]}],"kind":"symbol","identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/convertWithIconv(str:len:converter:bytesRead:bytesWritten:)","interfaceLanguage":"swift"},"metadata":{"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"convertWithIconv","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"str"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"len"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gssize","text":"gssize"},{"text":", ","kind":"text"},{"text":"converter","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GIConv","text":"GIConv"},{"kind":"text","text":", "},{"text":"bytesRead","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"gsize","preciseIdentifier":"c:@T@gsize"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"bytesWritten"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sp","kind":"typeIdentifier","text":"UnsafeMutablePointer"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gsize","text":"gsize","kind":"typeIdentifier"},{"text":">!) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:SS","text":"String","kind":"typeI
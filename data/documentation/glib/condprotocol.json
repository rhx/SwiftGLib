yword","text":"func"},{"text":" ","kind":"text"},{"text":"clear","kind":"identifier"},{"kind":"text","text":"()"}],"type":"topic","kind":"symbol","title":"clear()","url":"\/documentation\/glib\/condprotocol\/clear()"},"doc://GLib/documentation/GLib/CondProtocol/broadcast()":{"role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/CondProtocol\/broadcast()","type":"topic","abstract":[{"type":"text","text":"If threads are waiting for "},{"type":"codeVoice","code":"cond"},{"text":", all of them are unblocked.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"If no threads are waiting for "},{"type":"codeVoice","code":"cond"},{"text":", this function has no effect.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"It is good practice to lock the same mutex as the waiting threads"},{"type":"text","text":" "},{"type":"text","text":"while calling this function, though not required."}],"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"broadcast"},{"kind":"text","text":"()"}],"url":"\/documentation\/glib\/condprotocol\/broadcast()","kind":"symbol","title":"broadcast()"},"doc://GLib/documentation/GLib/CondProtocol/waitUntil(mutex:endTime:)":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/CondProtocol\/waitUntil(mutex:endTime:)","abstract":[{"type":"text","text":"Waits until either "},{"code":"cond","type":"codeVoice"},{"text":" is signalled or ","type":"text"},{"code":"endTime","type":"codeVoice"},{"type":"text","text":" has passed."}],"role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"waitUntil"},{"kind":"text","text":"<"},{"text":"MutexT","kind":"genericParameter"},{"kind":"text","text":">("},{"kind":"externalParam","text":"mutex"},{"text":": ","kind":"text"},{"text":"MutexT","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"endTime","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdent
ts":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/timezoneprotocol"]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"TimeZoneProtocol"},{"text":" : ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib14PointerWrapperP","identifier":"doc:\/\/GLib\/documentation\/GLib\/PointerWrapper","text":"PointerWrapper"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"GTimeZone"},{"text":" struct is refcounted and immutable.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Each time zone has an identifier (for example, ‘Europe\/London’) which is","type":"text"},{"text":" ","type":"text"},{"text":"platform dependent. See [ctor","type":"text"},{"code":"GLib.TimeZone.new","type":"codeVoice"},{"type":"text","text":"] for information on the"},{"text":" ","type":"text"},{"type":"text","text":"identifier formats. The identifier of a time zone can be retrieved using"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.TimeZone.get_identifier"},{"type":"text","text":"]."}]},{"inlineContent":[{"text":"A time zone contains a number of intervals. Each interval has an abbreviation","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to describe it (for example, ‘PDT’), an offset to UTC and a flag indicating"},{"type":"text","text":" "},{"type":"text","text":"if the daylight savings time is in effect during that interval. A time zone"},{"type":"text","text":" "},{"type":"text","text":"always has at least one interval — interval 0. Note that interval abbreviations"},{"text":" ","type":"text"},{"type":"text","text":"are not the same as time zone identifiers (apart from ‘UTC’), and cannot be"},{"type":"text","text":" "},{"text":"passed to [ctor","type":"text"},{"type":"codeVoice","code":"GLib.TimeZone.new"},{"text":"].","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Every UTC time is contained within exactly one interval, but a given","type":"text"},{"type":"text","text":" "},{"text":"local time may be contained within zero, one or two intervals (due to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"incontinuities associated with daylight savings time)."}]},{"inlineContent":[{"text":"An interval may refer to a specific period of time (eg: the duration","type":"text"},{"type":"text","text":" "},{"type":"text","text":"of daylight savings time during 2010) or it may refer to many periods"},{"type":"text","text":" "},{"text":"of time that share the same properties (eg: all periods of daylight","type":"text"},{"text":" ","type":"text"},{"text":"savings time).  It is also possible (usually for political reasons)","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"that some properties (like the abbreviation) change between intervals"},{"text":" ","type":"text"},{"type":"text","text":"without other properties changing."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZoneProtocol","type":"reference","isActive":true},{"type":"text","text":" protocol exposes the methods and properties of an underlying "},{"code":"GTimeZone","type":"codeVoice"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"text":"The default implementation of these can be found in the protocol extension below.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"For a concrete class that implements these methods and properties, see "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone","type":"reference"},{"text":".","type":"text"},{"
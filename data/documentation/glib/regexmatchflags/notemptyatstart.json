{"abstract":[{"text":"Like ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexMatchFlags\/notempty","isActive":true},{"text":", but only applied to","type":"text"},{"type":"text","text":" "},{"text":"the start of the matched string. For anchored","type":"text"},{"type":"text","text":" "},{"text":"patterns this can only happen for pattern containing “\\K”. Since: 2.34","type":"text"}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/RegexMatchFlags\/notemptyAtstart","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/glib\/regexmatchflags\/notemptyatstart"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"static","kind":"keyword"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"notemptyAtstart"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:4GLib15RegexMatchFlagsV","identifier":"doc:\/\/GLib\/documentation\/GLib\/RegexMatchFlags","text":"RegexMatchFlags","kind":"typeIdentifier"}],"platforms":["macOS"]}]}],"sections":[],"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"roleHeading":"Type Property","fragments":[{"text":"static","kind":"keyword"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"text":" ","kind":"text"},{"text":"notemptyAtstart","kind":"identifier"},{"kind":"text","text":": "},{"preciseIdentifier":"s:4GLib15RegexMatchFlagsV","kind":"typeIdentifier","text":"RegexMatchFlags"}],"role":"symbol","modules":[{"name":"GLib"}],"externalID":"s:4GLib15RegexMatchFlagsV15notemptyAtstartACvpZ","symbolKind":"property","title":"notemptyAtstart"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/RegexMatchFlags"]]},"references":{"doc://GLib/documentation/GLib/RegexMatchFlags/notempty":{"url":"\/documentation\/glib\/regexmatchflags\/notempty","type":"topic
{"sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/SourceRef","doc:\/\/GLib\/documentation\/GLib\/SourceRef\/SourceProtocol-Implementations"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"roleHeading":"Instance Method","role":"symbol","externalID":"s:4GLib14SourceProtocolPAAE18setDisposeFunction7disposeyySpySo8_GSourceVGSgXCSg_tF::SYNTHESIZED::s:4GLib9SourceRefV","extendedModule":"GLib","title":"setDisposeFunction(dispose:)","modules":[{"name":"GLib"}],"symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"setDisposeFunction","kind":"identifier"},{"kind":"text","text":"("},{"text":"dispose","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"c:@T@GSourceDisposeFunc","kind":"typeIdentifier","text":"GSourceDisposeFunc"},{"text":"?)","kind":"text"}]},"abstract":[{"text":"Set ","type":"text"},{"code":"dispose","type":"codeVoice"},{"text":" as dispose function on ","type":"text"},{"type":"codeVoice","code":"source"},{"text":".","type":"text"}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"setDisposeFunction"},{"kind":"text","text":"("},{"text":"dispose","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GSourceDisposeFunc","text":"GSourceDisposeFunc"},{"text":"?)","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"code":"dispose","type":"codeVoice"},{"type":"text","text":" function will be called once the reference count of "},{"type":"codeVoice","code":"source"},{"text":" ","type":"text"},{"text":"reaches zero but before any of the state of the source is freed, especially","type":"text"},{"type":"
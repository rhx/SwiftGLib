paragraph","inlineContent":[{"type":"text","text":"The source name should describe in a human-readable way"},{"text":" ","type":"text"},{"text":"what the source does. For example, ‘X11 event queue’","type":"text"},{"type":"text","text":" "},{"text":"or ‘GTK repaint idle handler’.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"It is permitted to call this function multiple times, but is not","type":"text"},{"type":"text","text":" "},{"type":"text","text":"recommended due to the potential performance impact.  For example,"},{"type":"text","text":" "},{"type":"text","text":"one could change the name in the "},{"type":"codeVoice","code":"check"},{"type":"text","text":" function of a"},{"text":" ","type":"text"},{"text":"[struct","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceFuncs"},{"type":"text","text":"] to include details like the event type in the"},{"text":" ","type":"text"},{"type":"text","text":"source name."}]},{"type":"paragraph","inlineContent":[{"text":"Use caution if changing the name while another thread may be","type":"text"},{"type":"text","text":" "},{"text":"accessing it with [method","type":"text"},{"type":"codeVoice","code":"GLib.Source.get_name"},{"text":"]; that function does not copy","type":"text"},{"type":"text","text":" "},{"text":"the value, and changing the value will free it while the other thread","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"may be attempting to use it."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Also see [method"},{"code":"GLib.Source.set_static_name","type":"codeVoice"},{"type":"text","text":"]."}]}]}],"kind":"symbol","sections":[],"references":{"doc://GLib/documentation/GLib/SourceRef/SourceProtocol-Implementations":{"type":"topic","role":"collectionGroup","kind":"article","url":"\/documentation\/glib\/sourceref\/sourceprotocol-implementations","identifier":"doc:\/\/GLib\/documentation\/GLib\/SourceRef\/Sou
{"kind":"article","sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/Tutorial"},"abstract":[{"text":"This tutorial shows how to use GLib with Swift.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"This is particularly useful if you want to interact"},{"type":"text","text":" "},{"text":"with libraries written in C or other languages that use GLib.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/tutorial"]}],"primaryContentSections":[{"kind":"content","content":[{"text":"What is GLib?","level":2,"type":"heading","anchor":"What-is-GLib"},{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/docs.gtk.org\/glib\/"},{"type":"text","text":" is a low-level,"},{"type":"text","text":" "},{"type":"text","text":"general-purpose software library that provides a set of"},{"text":" ","type":"text"},{"text":"useful data types, string utilities, filesystem abstractions,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"a mainloop abstraction, and similar tools for developing"},{"text":" ","type":"text"},{"type":"text","text":"libraries and applications in different programming languages."},{"text":" ","type":"text"},{"text":"GLIb is mainly used for creating and interacting with","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"low-level data structures and supports features such as"},{"text":" ","type":"text"},{"text":"event-driven programming, memory management, and data","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"type management."},{"type":"text","text":" "},{"text":"GLib is part of the GNOME project, but works with different","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Operating Systems, including Linux and macOS."}]},{"level":2,"text":"Swift Bindings","anchor":"Swift-Bindings","type":"heading"},{"inlineContent":[{"text":"The Swift language bindings have been generated using","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"code":".gir","type":"codeVoice"},{"type":"text","text":" files from"},{"text":" ","type":"text"},{"identifier":"https:\/\/gi.readthedocs.io\/en\/latest\/","isActive":true,"type":"reference"},{"text":",","type":"text"},{"type":"text","text":" "},{"type":"text","text":"allowing a more “swifty” use of the library than using it"},{"text":" ","type":"text"},{"type":"text","text":"through the low-level C interface."},{"text":" ","type":"text"},{"type":"text","text":"Particularly the collection interfaces, such as"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"https:\/\/rhx.github.io\/SwiftGLib\/GLib\/documentation\/glib\/typedslist"},{"type":"text","text":" and"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"https:\/\/rhx.github.io\/SwiftGLib\/GLib\/documentation\/glib\/typedlist"},{"text":" ","type":"text"},{"type":"text","text":"allow to use templated Swift data types rather than raw"},{"type":"text","text":" "},{"type":"text","text":"pointers."}],"type":"paragraph"},{"text":"Prerequisites","level":2,"anchor":"Prerequisites","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To get the most out of this tutorial, you should be"},{"type":"text","text":" "},{"text":"generally familiar with Linux, macOS, or other UNIX-like","type":"text"},{"type":"text","text":" "},{"text":"environments and know how to use a command-line shell","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"such as "},{"isActive":true,"type":"reference","identifier":"https:\/\/www.gnu.org\/software\/bash\/"},{"text":" or","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/www.zsh.org\/"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"You will need a","type":"text"},{"type":"text","text":" "},{"isActive":true,"identifier":"https:\/\/www.swift.org\/getting-started\/cli-swiftpm\/","type":"reference"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"either by","type":"text"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/developer.apple.com\/support\/xcode\/","isActive":true},{"text":" ","type":"text"},{"text":"if you are running macOS, or","type":"text"},{"type":"text","text":" "},{"text":"by ","type":"text"},{"identifier":"https:\/\/www.swift.org\/install\/","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"type":"text","text":"directly for your Operating System."}]},{"type":"paragraph","inlineContent":[{"text":"You also need to install the GLib development libraries","type":"text"},{"type":"text","text":" "},{"text":"for your system.","type":"text"}]},{"text":"Installing GLib on Linux","anchor":"Installing-GLib-on-Linux","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"Most modern Linux distributions come with the GLib runtime"},{"text":" ","type":"text"},{"type":"text","text":"preinstalled, but you will need to install the headers"},{"type":"text","text":" "},{"type":"text","text":"necessary for development."},{"type":"text","text":" "},{"type":"text","text":"This can be done using the package manager for your system."},{"text":" ","type":"text"},{"text":"For example, on Ubuntu or other Debian-based systems,","type":"text"},{"text":" ","type":"text"},{"text":"you can use the ","type":"text"},{"type":"reference","identifier":"https:\/\/wiki.debian.org\/Apt","isActive":true},{"type":"text","text":" package"},{"text":" ","type":"text"},{"type":"text","text":"manager using the following commands:"}],"type":"paragraph"},{"type":"codeListing","syntax":null,"code":["sudo apt update","sudo apt install libglib2.0-dev glib-networking gobject-introspection libgirepository1.0-dev libxml2-dev jq"]},{"inlineContent":[{"type":"text","text":"Depending on your Linux distributions, the names of the"},{"type":"text","text":" "},{"text":"packages and package management tools will vary.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"You should be able to find this in the documentation for"},{"text":" ","type":"text"},{"type":"text","text":"your Linux distribution."}],"type":"paragraph"},{"name":"Tip","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Some more examples can also be found in the"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/rhx\/SwiftGLib\/blob\/main\/README.md"},{"text":".","type":"text"}]}],"style":"tip","type":"aside"},{"anchor":"Installing-GLib-on-macOS","text":"Installing GLib on macOS","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"For macOS, there are multiple package management tools","type":"text"},{"type":"text","text":" "},{"type":"text","text":"that you can use."},{"text":" ","type":"text"},{"identifier":"http:\/\/brew.sh\/","isActive":true,"type":"reference"},{"text":" is one example.","type":"text"},{"type":"text","text":" "},{"text":"After you have installed HomeBrew, you can install","type":"text"},{"type":"text","text":" "},{"type":"text","text":"GLib using:"}]},{"type":"codeListing","code":["brew update","brew install glib glib-networking gobject-introspection pkg-config jq"],"syntax":null},{"type":"heading","text":"Compiling SwiftGLib programs","anchor":"Compiling-SwiftGLib-programs","level":2},{"inlineContent":[{"type":"text","text":"The easiest way to compile programs and libraries using"},{"text":" ","type":"text"},{"type":"text","text":"SwiftGLib is through projects using the"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"https:\/\/swift.org\/package-manager\/"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Here is an example for a simple program that uses a"},{"type":"text","text":" "},{"identifier":"https:\/\/rhx.github.io\/SwiftGLib\/GLib\/documentation\/glib\/typedlist","isActive":true,"overridingTitle":"type list","overridingTitleInlineContent":[{"text":"type list","type":"text"}],"type":"reference"},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"First, create a directory (folder) for your project, then"},{"type":"text","text":" "},{"text":"create the project inside the folder:","type":"text"}],"type":"paragraph"},{"syntax":null,"code":["mkdir swift-glist","cd swift-glist","swift package init --type=executable"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"This will create a simple “Hello World” executable that","type":"text"},{"type":"text","text":" "},{"type":"text","text":"you can test using "},{"type":"codeVoice","code":"swift run"},{"type":"text","text":" – the program will run"},{"text":" ","type":"text"},{"text":"and print “Hello world”.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"If you look at the files generated by "},{"code":"swift package init","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"text":"you will find a file named ","type":"text"},{"code":"Package.swift","type":"codeVoice"},{"type":"text","text":" that represents"},{"text":" ","type":"text"},{"text":"the project and its compilation targets.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Overall, if you run"}]},{"code":["find * -type f"],"syntax":null,"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"you should see two files, the aforementioned "},{"code":"Package.swift","type":"codeVoice"},{"text":" ","type":"text"},{"text":"and a ","type":"text"},{"code":"main.swift","type":"codeVoice"},{"text":" in ","type":"text"},{"type":"codeVoice","code":"Sources\/swift-glist"},{"type":"text","text":":"}]},{"code":["Package.swift","Sources\/swift-glist\/main.swift"],"syntax":null,"type":"codeListing"},{"style":"warning","type":"aside","name":"Warning","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Some versions of the Swift Package manager create"},{"type":"text","text":" "},{"type":"text","text":"a flat structure when using "},{"code":"swift package init","type":"codeVoice"},{"text":" that puts","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the "},{"code":"main.swift","type":"codeVoice"},{"text":" directly in the ","type":"text"},{"code":"Sources","type":"codeVoice"},{"text":" folder.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"This will cause the Swift compiler to exit with an error if"},{"type":"text","text":" "},{"text":"you try to use ","type":"text"},{"code":"swift run","type":"codeVoice"},{"text":".","type":"text"}]}]},{"type":"paragraph","inlineContent":[{"text":"Such a faulty structure that places your ","type":"text"},{"type":"codeVoice","code":"main.swift"},{"text":" ","type":"text"},{"type":"text","text":"directly in the "},{"code":"Sources","type":"codeVoice"},{"text":" folder would look like this:","type":"text"}]},{"type":"codeListing","syntax":null,"code":["Package.swift","Sources\/main.swift"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In this case, your program won’t compile or run."},{"type":"text","text":" "},{"type":"text","text":"To fix this, you need to move the "},{"code":"main.swift","type":"codeVoice"},{"text":" file","type":"text"},{"type":"text","text":" "},{"type":"text","text":"into a "},{"code":"swift-glist","type":"codeVoice"},{"type":"text","text":" subfolder:"}]},{"syntax":null,"code":["mkdir Sources\/swift-glist","mv Sources\/main.swift Sources\/swift-glist\/"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Now you should be able to build your project."}]},{"inlineContent":[{"text":"Let us now change the ","type":"text"},{"code":"Package.swift","type":"codeVoice"},{"type":"text","text":" file so that it"},{"text":" ","type":"text"},{"type":"text","text":"reads:"}],"type":"paragraph"},{"syntax":"Swift","code":["\/\/ swift-tools-version: 5.7","","import PackageDescription","","let package = Package(","    name: \"swift-glist\",","    dependencies: [","        .package(url: \"https:\/\/github.com\/rhx\/gir2swift.git\", branch: \"main\"),","        .package(url: \"https:\/\/github.com\/rhx\/SwiftGLib.git\", branch: \"main\"),","    ],","    targets: [","        .executableTarget(","            name: \"swift-glist\",","            dependencies: [","                .product(name: \"GLib\", package: \"SwiftGLib\"),","            ]","        ),","    ]",")"],"type":"codeListing"},{"inlineContent":[{"text":"This will add the relevant dependencies for SwiftGLib","type":"text"},{"type":"text","text":" "},{"text":"to the project.  We can now change the code in our","type":"text"},{"type":"text","text":" "},{"code":"Sources\/swift-glist\/main.swift","type":"codeVoice"},{"type":"text","text":" so that it reads:"}],"type":"paragraph"},{"syntax":"Swift","type":"codeListing","code":["import GLib","","let list: TypedList = [\"Hello\", \"world\"]","","print(list.length())  \/\/ Prints: 2","","list.forEach { element in","    print(element)    \/\/ Prints: \"hello\" and \"world\"","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Compile and run the code using:"}]},{"code":["swift run"],"type":"codeListing","syntax":null},{"inlineContent":[{"type":"text","text":"After some compiler output (and potentially"},{"text":" ","type":"text"},{"type":"text","text":"some warnings that you can ignore), you should get the"},{"type":"text","text":" "},{"type":"text","text":"following output:"}],"type":"paragraph"},{"syntax":null,"code":["2","Hello","world"],"type":"codeListing"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"role":"article","roleHeading":"Article","title":"Using GLib with Swift","modules":[{"name":"GLib"}]},"references":{"https://docs.gtk.org/glib/":{"type":"link","titleInlineContent":[{"type":"text","text":"GL
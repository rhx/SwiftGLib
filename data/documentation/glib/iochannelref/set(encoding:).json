{"kind":"symbol","schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"symbolKind":"method","role":"symbol","title":"set(encoding:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"set"},{"kind":"text","text":"("},{"text":"encoding","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier","text":"gchar"},{"text":">?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"c:@EA@GIOStatus","text":"GIOStatus","kind":"typeIdentifier"}],"extendedModule":"GLib","externalID":"s:4GLib17IOChannelProtocolPAAE3set8encodingSo9GIOStatusaSPys4Int8VGSg_tKF::SYNTHESIZED::s:4GLib12IOChannelRefV","roleHeading":"Instance Method","modules":[{"name":"GLib"}]},"abstract":[{"type":"text","text":"Sets the encoding for the input\/output of the channel."},{"text":" ","type":"text"},{"type":"text","text":"The internal encoding is always UTF-8. The default encoding"},{"text":" ","type":"text"},{"text":"for the external file is UTF-8.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"set","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"encoding"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"kind":"text","text":">? = nil) "},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"c:@EA@GIOStatus","text":"GIOStatus","kind":"typeIdentifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"inlineContent":[{"text":"The encoding ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" is safe to use with binary data.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The encoding can only be set if one of the following conditions","type":"text"},{"text":" ","type":"text"},{"text":"is true:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"The channel was just created, and has not been written to or read from yet."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The channel is write-only."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The channel is a file, and the file pointer was just repositioned"},{"text":" ","type":"text"},{"type":"text","text":"by a call to "},{"code":"g_io_channel_seek_position()","type":"codeVoice"},{"text":". (This flushes all the","type":"text"},{"type":"text","text":" "},{"text":"internal buffers.)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The current encoding is ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" or UTF-8.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"One of the (new API) read functions has just returned "},{"type":"codeVoice","code":"eof"},{"text":" ","type":"text"},{"text":"(or, in the case of ","type":"text"},{"code":"g_io_channel_read_to_end()","type":"codeVoice"},{"type":"text","text":", "},{"code":"normal","type":"codeVoice"},{"type":"text","text":")."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"One of the functions "},{"code":"g_io_channel_read_chars()","type":"codeVoice"},{"text":" or","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_io_channel_read_unichar()"},{"type":"text","text":" has returned "},{"code":"again","type":"codeVoice"},{"type":"text","text":" or"},{"text":" ","type":"text"},{"type":"codeVoice","code":"error"},{"text":". This may be useful in the case of","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"illegalSequence"},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Returning one of these statuses from "},{"type":"codeVoice","code":"g_io_channel_read_line()"},{"text":",","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_io_channel_read_line_string()"},{"type":"text","text":", or "},{"code":"g_io_channel_read_to_end()","type":"codeVoice"},{"text":" ","type":"text"},{"text":"does not guarantee that the encoding can be changed.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"Channels which do not meet one of the above conditions cannot call"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_io_channel_seek_position()"},{"text":" with an offset of ","type":"text"},{"type":"codeVoice","code":"cur"},{"type":"text","text":", and, if"},{"type":"text","text":" "},{"type":"text","text":"they are “seekable”, cannot call "},{"type":"codeVoice","code":"g_io_channel_write_chars()"},{"text":" after","type":"text"},{"type":"text","text":" "},{"type":"text","text":"calling one of the API “read” functions."}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/IOChannelRef","doc:\/\/GLib\/documentation\/GLib\/IOChannelRef\/IOChannelProtocol-Implementations"]]},"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/IOChannelRef\/set(encoding:)"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/iochannelref\/set(encoding:)"]}],"references":{"doc://GLib/documentation/GLib/IOChannelRef/IOChannelProtocol-Implementations":{"kind":"article","type":"topic","url":"\/documentation\/glib\/iochannelref\/iochannelprotocol-implementations","role":"collectionGroup","title":"IOChannelProtocol Implementations","identifier":"doc:\/\/GLib\/documentat
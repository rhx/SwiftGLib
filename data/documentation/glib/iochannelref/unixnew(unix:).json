o this function happens to be both a"},{"type":"text","text":" "},{"type":"text","text":"valid file descriptor and socket. If that happens a warning is"},{"type":"text","text":" "},{"text":"issued, and GLib assumes that it is the file descriptor you mean.","type":"text"}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/IOChannelRef"]]},"sections":[],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/IOChannelRef\/unixNew(unix:)","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/iochannelref\/unixnew(unix:)"]}],"references":{"doc://GLib/documentation/GLib/MainContext":{"navigatorTitle":[{"text":"MainContext","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/glib\/maincontext","role":"symbol","type":"topic","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MainContext","kind":"identifier"}],"abstract":[{"type":"text","text":"The "},{"code":"GMainContext","type":"codeVoice"},{"text":" struct is an opaque data","type":"text"},{"type":"text","text":" "},{"type":"text","text":"type representing a set of sources to be handled in a main loop."}],"title":"MainContext","identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext"},"doc://GLib/documentation/GLib/IOChannelRef/unixNew(unix:)":{"title":"unixNew(unix:)","kind":"symbol","abstract":[{"type":"text","text":"Creates a new "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel","type":"reference"},{"type":"text","text":" given a file descriptor. On UNIX systems"},{"type":"text","text":" "},{"text":"this works for plain files, pipes, and sockets.","type":"text"}],"url":"\/documentation\/glib\/iochannelref\/unixnew(unix:)","role":"symbol","type":"topic","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"uni
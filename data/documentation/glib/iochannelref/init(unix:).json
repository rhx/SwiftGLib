{"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"init","kind":"keyword"},{"kind":"text","text":"("},{"text":"unix","kind":"externalParam"},{"kind":"text","text":" "},{"text":"fd","kind":"internalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":")"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"inlineContent":[{"text":"The returned ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel","isActive":true},{"type":"text","text":" has a reference count of 1."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The default encoding for "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel"},{"text":" is UTF-8. If your application","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is reading output from a command using via pipe, you may need to set"},{"text":" ","type":"text"},{"type":"text","text":"the encoding to the encoding of the current locale (see"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_get_charset()"},{"text":") with the ","type":"text"},{"code":"g_io_channel_set_encoding()","type":"codeVoice"},{"text":" function.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"By default, the fd passed will not be closed when the final reference"},{"text":" ","type":"text"},{"text":"to the ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel","isActive":true,"type":"reference"},{"type":"text","text":" data structure is dropped."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If you want to read raw binary data without interpretation, then"},{"type":"text","text":" "},{"text":"call the ","type":"text"},{"code":"g_io_channel_set_encoding()","type":"codeVoice"},{"text":" function with ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" for the","type":"text"},{"type":"text","text":" "},{"text":"encoding argument.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This function is available in GLib on Windows, too, but you should","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"avoid using it on Windows. The domain of file descriptors and"},{"text":" ","type":"text"},{"type":"text","text":"sockets overlap. There is no way for GLib to know which one you mean"},{"type":"text","text":" "},{"type":"text","text":"in case the argument you pass to this function happens to be both a"},{"text":" ","type":"text"},{"type":"text","text":"valid file descriptor and socket. If that happens a warning is"},{"text":" ","type":"text"},{"type":"text","text":"issued, and GLib assumes that it is the file descriptor you mean."}],"type":"paragraph"}]}],"sections":[],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/IOChannelRef\/init(unix:)","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/glib\/iochannelref\/init(unix:)"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"Creates a new "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel"},{"type":"text","text":" given a file descriptor. On UNIX systems"},{"type":"text","text":" "},{"type":"text","text":"this works for plain files, pipes, and sockets."}],"metadata":{"modules":[{"name":"GLib"}],"symbolKind":"init","extendedModule":"GLib","roleHeading":"Initializer","role":"symbol","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"text":"unix","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":")","kind":"text"}],"externalID":"s:4GLib12IOChannelRefV4unixACSi_tcfc","title":"init(unix:)"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/IOChannelRef"]]},"references":{"doc://GLib/documentation/GLib/IOChannel":{"kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"IOChannel","kind":"identifier"}],"title":"IOChannel","role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel","abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"GIOChannel"},{"text":" data type aims to provide a portable method for","type":"text"},{"text":" ","type":"text"},{"text":"using file descriptors, pipes, and sockets, and integrating them","type":"text"},{"text":" ","type":"text"},{"text":"into the main event loop (see [struct","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MainContext","isActive":true,"type":"reference"},{"type":"text","text":"]). Currently,"},{"type":"text","text":" "},{"type":"text","text":"full support is available on UNIX platforms; support for Windows"},{"type":"text","text":" "},{"type":"text","text":"is only partially complete."}],"navigatorTitle":[{"kind":"identifier","text":"IOChannel"}],"url":"\/documentation\/glib\/iochannel","type":"topic"},"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"doc://GLib/documentation/GLib/IOChannelRef/init(unix:)":{"title":"init(unix:)","abstract":[{"text":"Creates a new ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/IOChannel","isActive":true},{"text":" given a file descriptor. On UNIX systems","type":"text"},{"type":"text","text":" "},{"type":"text","text":"this works for plain files, pipes, and sockets."}],"type":"topic","url":"\/documentation\/glib\/iochannelref\/init(unix:)","role":"symbol","fragments":[{"text":"init","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"unix"},{"kind":"text","text":": "},{"t
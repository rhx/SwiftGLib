de":"month"},{"type":"text","text":" between 1 and 12 and "},{"type":"codeVoice","code":"day"},{"text":" ","type":"text"},{"text":"between 1 and 28, 29, 30 or 31 depending on the month and the year.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"hour"},{"type":"text","text":" must be between 0 and 23 and "},{"type":"codeVoice","code":"minute"},{"text":" must be between 0 and 59.","type":"text"}]},{"inlineContent":[{"code":"seconds","type":"codeVoice"},{"type":"text","text":" must be at least 0.0 and must be strictly less than 60.0."},{"text":" ","type":"text"},{"type":"text","text":"It will be rounded down to the nearest microsecond."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If the given time is not representable in the given time zone (for","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"example, 02:30 on March 14th 2010 in Toronto, due to daylight savings"},{"text":" ","type":"text"},{"text":"time) then the time will be rounded up to the nearest existing time","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"(in this case, 03:00).  If this matters to you then you should verify"},{"type":"text","text":" "},{"text":"the return value for containing the same as the numbers you gave.","type":"text"}]},{"inlineContent":[{"text":"In the case that the given time is ambiguous in the given time zone","type":"text"},{"type":"text","text":" "},{"text":"(for example, 01:30 on November 7th 2010 in Toronto, due to daylight","type":"text"},{"type":"text","text":" "},{"text":"savings time) then the time falling within standard (ie:","type":"text"},{"type":"text","text":" "},{"text":"non-daylight) time is taken.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It not considered a programmer error for the values to this function"},{"type":"text","text":" "},{"text":"to be out of range, but in the case that they are, the function will","type":"text"},{"text":" ","type":"text"},{"text":"return ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You should release the return value by calling "},{"type":"codeVoice","code":"g_date_time_unref()"},{"text":" ","type":"text"},{"text":"when you are done with it.","type":"text"}]}]}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/DateTime\/init(tz:year:month:day:hour:minute:seconds:)","interfaceLanguage":"swift"},"kind":"symbol","variants":[{"paths":["\/documentation\/glib\/datetime\/init(tz:year:month:day:hour:minute:seconds:)"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://GLib/documentation/GLib/TimeZoneProtocol":{"abstract":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"GTimeZone"},{"text":" represents a time zone, at no particular point in time.","type":"text"}],"url":"\/documentation\/glib\/timezoneprotocol","kind":"symbol","role":"symbol","type":"topic","title":"TimeZoneProtocol","navigatorTitle":[{"kind":"identifier","text":"TimeZoneProtocol"}],"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"TimeZoneProtocol"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZoneProtocol"},"doc://GLib/documentation/GLib/DateTime":{"title":"DateTime","navigatorTitle":[{"kind":"identifier","text":"DateTime"}],"abstract":[{"code":"GDateTime","type":"codeVoice"},{"type":"text","text":" is a structure that combines a Gregorian date and time"},{"text":" ","type":"text"},{"type":"text","text":"into a single structure."}],"kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"DateTime","kind":"identifier"}],"url":"\/documentation\/glib\/datetime","identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTime","type":"topic","role":"symbol"},"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role
{"kind":"symbol","sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"getWeekNumberingYear"},{"kind":"text","text":"() -> "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"languages":["swift"]}]},{"content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"inlineContent":[{"text":"This function, taken together with ","type":"text"},{"code":"g_date_time_get_week_of_year()","type":"codeVoice"},{"type":"text","text":" and"},{"type":"text","text":" "},{"code":"g_date_time_get_day_of_week()","type":"codeVoice"},{"text":" can be used to determine the full ISO","type":"text"},{"type":"text","text":" "},{"text":"week date on which ","type":"text"},{"type":"codeVoice","code":"datetime"},{"text":" falls.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This is usually equal to the normal Gregorian year (as returned by","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_date_time_get_year()"},{"text":"), except as detailed below:","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"For Thursday, the week-numbering year is always equal to the usual","type":"text"},{"type":"text","text":" "},{"text":"calendar year.  For other days, the number is such that every day","type":"text"},{"type":"text","text":" "},{"text":"within a complete week (Monday to Sunday) is contained within the","type":"text"},{"type":"text","text":" "},{"text":"same week-numbering year.","type":"text"}]},{"inlineContent":[{"type":"text","text":"For Monday, Tuesday and Wednesday occurring near the end of the year,"},{"text":" ","type":"text"},{"type":"text","text":"this may mean that the week-numbering year is one greater than the"},{"text":" ","type":"text"},{"text":"calendar year (so that these days have the same week-numbering year","type":"text"},{"type":"text","text":" "},{"text":"as the Thursday occurring early in the next year).","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For Friday, Saturday and Sunday occurring near the start of the year,"},{"text":" ","type":"text"},{"type":"text","text":"this may mean that the week-numbering year is one less than the"},{"type":"text","text":" "},{"text":"calendar year (so that these days have the same week-numbering year","type":"text"},{"text":" ","type":"text"},{"text":"as the Thursday occurring late in the previous year).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"An equivalent description is that the week-numbering year is equal to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the calendar year containing the majority of the days in the current"},{"type":"text","text":" "},{"text":"week (Monday to Sunday).","type":"text"}]},{"inlineContent":[{"type":"text","text":"Note that January 1 0001 in the proleptic Gregorian calendar is a"},{"type":"text","text":" "},{"text":"Monday, so this function never returns 0.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/glib\/datetime\/getweeknumberingyear()"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"role":"symbol","roleHeading":"Instance Method","modules":[{"name":"GLib"}],"title":"getWeekNumberingYear()","symbolKind":"method","externalID":"s:4GLib16DateTimeProtocolPAAE20getWeekNumberingYearSiyF::SYNTHESIZED::s:4GLib8DateTimeC","extendedModule":"GLib","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"getWeekNumberingYear","kind":"identifier"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}]},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/DateTime","doc:\/\/GLib\/documentation\/GLib\/DateTime\/DateTimeProtocol-Implementations"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/DateTime\/getWeekNumberingYear()","interfaceLanguage":"swift"},"abstract":[{"text":"Returns the ISO 8601 week-numbering year in which the week containing","type":"text"},{"text":" ","type":"text"},{"code":"datetime","type":"codeVoice"},{"type":"text","text":" falls."}],"references":{"doc://GLib/documentation/GLib/DateTime":{"title":"DateTime","navigatorTitle":[{"kind":"identifier","text":"DateTime"}],"abstract":[{"code":"GDateTime","type":"codeVoice"},{"type":"text","text":" is a structure that combines a Gregorian date and time"},{"text":" ","type":"text"},{"type":"text","text":"into a single structure."}],"kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"DateTime","kind":"identifier"}],"url":"\/documentation\/glib\/datetime","identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTime","type":"topic","role":"symbol"},"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"doc://GLib/documentation/GLib/DateTime/DateTimeProtocol-Implementations":{"role":"collectionGroup","kind":"article","title":"DateTimeProtocol Implementations","type":"topic","url":"\/documentation\/glib\/datetime\/datetimeprotocol-implementations","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTime\/DateTimeProtocol-Implementations"},"doc://GLib/documentation/GLib/DateTime/getWeekNumberingYear()":{"role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTime\/getWeekNumberingYear()","type":"topic","abstract":[{"type":"text","text":"Returns the ISO 8601 week-numbering year in which the week containing"},{"type":"text","text":" "},{"code":"datetime","type":"codeVoice"},{"text":" falls.","type":"text"}],"url":"\/documentation\/glib\/datetime\/getweeknumberingyear()","title":"getWeekNumberingYear()","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"getWeekNumberingYear","kind":"identifier"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"kind":"symbol"}}}
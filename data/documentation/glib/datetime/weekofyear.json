{"metadata":{"externalID":"s:4GLib16DateTimeProtocolPAAE10weekOfYearSivp::SYNTHESIZED::s:4GLib8DateTimeC","role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"weekOfYear"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}],"extendedModule":"GLib","roleHeading":"Instance Property","modules":[{"name":"GLib"}],"title":"weekOfYear","symbolKind":"property"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/DateTime","doc:\/\/GLib\/documentation\/GLib\/DateTime\/DateTimeProtocol-Implementations"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/DateTime\/weekOfYear","interfaceLanguage":"swift"},"kind":"symbol","abstract":[{"type":"text","text":"Returns the ISO 8601 week number for the week containing "},{"code":"datetime","type":"codeVoice"},{"text":".","type":"text"},{"type":"text","text":" "},{"text":"The ISO 8601 week number is the same for every day of the week (from","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Moday through Sunday).  That can produce some unusual results"},{"text":" ","type":"text"},{"text":"(described below).","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"kind":"identifier","text":"weekOfYear"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}]}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"inlineContent":[{"text":"The first week of the year is week 1.  This is the week that contains","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the first Thursday of the year.  Equivalently, this is the first week"},{"type":"text","text":" "},{"type":"text","text":"that has more than 4 of its days falling within the calendar year."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The value 0 is never returned by this function.  Days contained"},{"type":"text","text":" "},{"text":"within a year but occurring before the first ISO 8601 week of that","type":"text"},{"type":"text","text":" "},{"type":"text","text":"year are considered as being contained in the last week of the"},{"type":"text","text":" "},{"text":"previous year.  Similarly, the final days of a calendar year may be","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"considered as being part of the first ISO 8601 week of the next year"},{"text":" ","type":"text"},{"text":"if 4 or more days of that week are contained within the new year.","type":"text"}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/datetime\/weekofyear"]}],"sections":[],"references":{"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"doc://GLib/documentation/GLib/DateTime":{"title":"DateTime","navigatorTitle":[{"kind":"identifier","text":"DateTime"}],"abstract":[{"code":"GDateTime","type":"codeVoice"},{"type":"text","text":" is a structure that combines a Gregorian date and time"},{"text":" ","type":"text"},{"type":"text","text":"into a single structure."}],"kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"DateTime","kind":"identifier"}],"url":"\/documentation\/glib\/datetime","identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTime","type":"topic","role":"symbol"},"doc://GLib/documentation/GLib/DateTime/weekOfYear":{"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTime\/weekOfYear","title":"weekOfYear","kind":"symbol","abstract":[{"text":"Returns the ISO 8601 week number for the week containing ","type":"text"},{"code":"datetime","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"The ISO 8601 week number is the same for every day of the week (from","type":"text"},{"type":"text","text":" "},{"text":"Moday through Sunday).  That can produce some unusual results","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"(described below)."}],"url":"\/documentation\/glib\/datetime\/weekofyear","role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"weekOfYear","kind":"identifier"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}]},"doc://GLib/documentation/GLib/DateTime/DateTimeProtocol-Implementations":{"role":"collectionGroup","kind":"article","title":"DateTimeProtocol Implementations","type":"topic","url":"\/documentation\/glib\/datetime\/datetimeprotocol-implementations","abstract":[],"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTime\/DateTimeProtocol-Implementations"}}}
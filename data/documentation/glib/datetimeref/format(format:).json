{"sections":[],"schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/DateTimeRef\/format(format:)"},"metadata":{"roleHeading":"Instance Method","symbolKind":"method","title":"format(format:)","externalID":"s:4GLib16DateTimeProtocolPAAE6formatADSSSgSPys4Int8VGSg_tF::SYNTHESIZED::s:4GLib11DateTimeRefV","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"format","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"format"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"text":">!) -> ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"kind":"text","text":"!"}],"role":"symbol","extendedModule":"GLib","modules":[{"name":"GLib"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"format"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"format"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier","text":"gchar"},{"text":">!) -> ","kind":"text"},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"inlineContent":[{"type":"text","text":"The format strings understood by this function are a subset of the"},{"type":"text","text":" "},{"code":"strftime()","type":"codeVoice"},{"type":"text","text":" format language as specified by C99.  The "},{"type":"codeVoice","code":"D"},{"type":"text","text":", "},{"type":"codeVoice","code":"U"},{"text":" and ","type":"text"},{"code":"W","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"conversions are not supported, nor is the "},{"type":"codeVoice","code":"E"},{"type":"text","text":" modifier.  The GNU"},{"text":" ","type":"text"},{"text":"extensions ","type":"text"},{"code":"k","type":"codeVoice"},{"text":", ","type":"text"},{"code":"l","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"s"},{"text":" and ","type":"text"},{"code":"P","type":"codeVoice"},{"type":"text","text":" are supported, however, as are the"},{"text":" ","type":"text"},{"code":"0","type":"codeVoice"},{"type":"text","text":", "},{"code":"_","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"-"},{"type":"text","text":" modifiers. The Python extension "},{"type":"codeVoice","code":"f"},{"text":" is also supported.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In contrast to "},{"type":"codeVoice","code":"strftime()"},{"text":", this function always produces a UTF-8","type":"text"},{"type":"text","text":" "},{"text":"string, regardless of the current locale.  Note that the rendering of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"many formats is locale-dependent and may not match the "},{"code":"strftime()","type":"codeVoice"},{"type":"text","text":" "},{"text":"output exactly.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The following format specifiers are supported:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"a"},{"type":"text","text":": the abbreviated weekday name according to the current locale"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"A"},{"type":"text","text":": the full weekday name according to the current locale"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"b","type":"codeVoice"},{"type":"text","text":": the abbreviated month name according to the current locale"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"B","type":"codeVoice"},{"text":": the full month name according to the current locale","type":"text"}]}]},{"content":[{"inlineContent":[{"code":"c","type":"codeVoice"},{"type":"text","text":": the preferred date and time representation for the current locale"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"C"},{"text":": the century number (year\/100) as a 2-digit integer (00-99)","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"d"},{"text":": the day of the month as a decimal number (range 01 to 31)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"identifier":"doc:\/\/GLib\/documentation\/GLib\/e-3m6a4","isActive":true,"type":"reference"},{"type":"text","text":": the day of the month as a decimal number (range 1 to 31);"},{"type":"text","text":" "},{"type":"text","text":"single digits are preceded by a figure space (U+2007)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"F"},{"type":"text","text":": equivalent to "},{"code":"Y-","type":"codeVoice"},{"text":"m-","type":"text"},{"code":"d","type":"codeVoice"},{"type":"text","text":" (the ISO 8601 date format)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"g","type":"codeVoice"},{"text":": the last two digits of the ISO 8601 week-based year as a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"decimal number (00-99). This works well with "},{"type":"codeVoice","code":"V"},{"type":"text","text":" and "},{"type":"codeVoice","code":"u"},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"G","type":"codeVoice"},{"text":": the ISO 8601 week-based year as a decimal number. This works","type":"text"},{"type":"text","text":" "},{"type":"text","text":"well with "},{"type":"codeVoice","code":"V"},{"type":"text","text":" and "},{"type":"codeVoice","code":"u"},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"h","type":"codeVoice"},{"text":": equivalent to ","type":"text"},{"type":"codeVoice","code":"b"}]}]},{"content":[{"inlineContent":[{"code":"H","type":"codeVoice"},{"type":"text","text":": the hour as a decimal number using a 24-hour clock (range 00 to 23)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"I"},{"type":"text","text":": the hour as a decimal number using a 12-hour clock (range 01 to 12)"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"j"},{"text":": the day of the year as a decimal number (range 001 to 366)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"k"},{"text":": the hour (24-hour clock) as a decimal number (range 0 to 23);","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"single digits are preceded by a figure space (U+2007)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"l"},{"type":"text","text":": the hour (12-hour clock) as a decimal number (range 1 to 12);"},{"text":" ","type":"text"},{"type":"text","text":"single digits are preceded by a figure space (U+2007)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"m","type":"codeVoice"},{"type":"text","text":": the month as a decimal number (range 01 to 12)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"M","type":"codeVoice"},{"text":": the minute as a decimal number (range 00 to 59)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"f"},{"type":"text","text":": the microsecond as a decimal number (range 000000 to 999999)"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"p"},{"type":"text","text":": either ‘AM’ or ‘PM’ according to the given time value, or the"},{"text":" ","type":"text"},{"text":"corresponding  strings for the current locale.  Noon is treated as","type":"text"},{"type":"text","text":" "},{"type":"text","text":"‘PM’ and midnight as ‘AM’. Use of this format specifier is discouraged, as"},{"text":" ","type":"text"},{"type":"text","text":"many locales have no concept of AM\/PM formatting. Use "},{"type":"codeVoice","code":"c"},{"text":" or ","type":"text"},{"code":"X","type":"codeVoice"},{"type":"text","text":" instead."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"P"},{"text":": like ","type":"text"},{"code":"p","type":"codeVoice"},{"text":" but lowercase: ‘am’ or ‘pm’ or a corresponding string for","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the current locale. Use of this format specifier is discouraged, as"},{"type":"text","text":" "},{"text":"many locales have no concept of AM\/PM formatting. Use ","type":"text"},{"type":"codeVoice","code":"c"},{"text":" or ","type":"text"},{"code":"X","type":"codeVoice"},{"type":"text","text":" instead."}]}]},{"content":[{"inlineContent":[{"code":"r","type":"codeVoice"},{"type":"text","text":": the time in a.m. or p.m. notation. Use of this format specifier is"},{"type":"text","text":" "},{"text":"discouraged, as many locales have no concept of AM\/PM formatting. Use ","type":"text"},{"type":"codeVoice","code":"c"},{"text":" ","type":"text"},{"text":"or ","type":"text"},{"type":"codeVoice","code":"X"},{"text":" instead.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"R","type":"codeVoice"},{"type":"text","text":": the time in 24-hour notation ("},{"type":"codeVoice","code":"H:"},{"text":"M``)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"s","type":"codeVoice"},{"text":": the number of seconds since the Epoch, that is, since 1970-01-01","type":"text"},{"type":"text","text":" "},{"type":"text","text":"00:00:00 UTC"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"S"},{"type":"text","text":": the second as a decimal number (range 00 to 60)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"t","type":"codeVoice"},{"type":"text","text":": a tab character"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"T","type":"codeVoice"},{"type":"text","text":": the time in 24-hour notation with seconds ("},{"code":"H:","type":"codeVoice"},{"text":"M:","type":"text"},{"code":"S","type":"codeVoice"},{"type":"text","text":")"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"u"},{"type":"text","text":": the ISO 8601 standard day of the week as a decimal, range 1 to 7,"},{"text":" ","type":"text"},{"text":"Monday being 1. This works well with ","type":"text"},{"code":"G","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"V"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"V"},{"text":": the ISO 8601 standard week number of the current year as a decimal","type":"text"},{"type":"text","text":" "},{"text":"number, range 01 to 53, where week 1 is the first week that has at","type":"text"},{"text":" ","type":"text"},{"text":"least 4 days in the new year. See ","type":"text"},{"type":"codeVoice","code":"g_date_time_get_week_of_year()"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"This works well with "},{"code":"G","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"u"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"w","type":"codeVoice"},{"text":": the day of the week as a decimal, range 0 to 6, Sunday being 0.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"This is not the ISO 8601 standard format — use "},{"type":"codeVoice","code":"u"},{"text":" instead.","type":"text"}]}]},{"content":[{"inlineContent":[{"code":"x","type":"codeVoice"},{"text":": the preferred date representation for the current locale without","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the time"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"X"},{"text":": the preferred time representation for the current locale without","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the date"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"y"},{"text":": the year as a decimal number without the century","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"Y"},{"text":": the year as a decimal number including the century","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"z"},{"type":"text","text":": the time zone as an offset from UTC ("},{"code":"+hhmm","type":"codeVoice"},{"text":")","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":":z"},{"text":": the time zone as an offset from UTC (","type":"text"},{"type":"codeVoice","code":"+hh:mm"},{"type":"text","text":")."},{"type":"text","text":" "},{"text":"This is a gnulib ","type":"text"},{"code":"strftime()","type":"codeVoice"},{"text":" extension. Since: 2.38","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"::z","type":"codeVoice"},{"type":"text","text":": the time zone as an offset from UTC ("},{"code":"+hh:mm:ss","type":"codeVoice"},{"type":"text","text":"). This is a"},{"type":"text","text":" "},{"type":"text","text":"gnulib "},{"code":"strftime()","type":"codeVoice"},{"text":" extension. Since: 2.38","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":":::z"},{"type":"text","text":": the time zone as an offset from UTC, with "},{"type":"codeVoice","code":":"},{"type":"text","text":" to necessary"},{"text":" ","type":"text"},{"type":"text","text":"precision (e.g., "},{"code":"-04","type":"codeVoice"},{"text":", ","type":"text"},{"type":"codeVoice","code":"+05:30"},{"text":"). This is a gnulib ","type":"text"},{"type":"codeVoice","code":"strftime()"},{"type":"text","text":" extension. Since: 2.38"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"Z"},{"text":": the time zone or name or abbreviation","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"``````: a literal ```` character"}],"type":"paragraph"}]}]},{"inlineContent":[{"type":"text","text":"Some conversion specifications can be modified by preceding the"},{"type":"text","text":" "},{"text":"conversion specifier by one or more modifier characters.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The following modifiers are supported for many of the numeric","type":"text"},{"type":"text","text":" "},{"type":"text","text":"conversions:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"code":"O","type":"codeVoice"},{"type":"text","text":": Use alternative numeric symbols, if the current locale supports those."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"_","type":"codeVoice"},{"type":"text","text":": Pad a numeric result with spaces. This overrides the default padding"},{"text":" ","type":"text"},{"text":"for the specifier.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"-"},{"type":"text","text":": Do not pad a numeric result. This overrides the default padding"},{"type":"text","text":" "},{"type":"text","text":"for the specifier."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"0","type":"codeVoice"},{"text":": Pad a numeric result with zeros. This overrides the default padding","type":"text"},{"text":" ","type":"text"},{"text":"for the specifier.","type":"text"}]}]}]},{"inlineContent":[{"type":"text","text":"The following modifiers are supported for many of the alphabetic conversions:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"^","type":"codeVoice"},{"type":"text","text":": Use upper case if possible. This is a gnulib "},{"code":"strftime()","type":"codeVoice"},{"type":"text","text":" extension."},{"type":"text","text":" "},{"type":"text","text":"Since: 2.80"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"#"},{"type":"text","text":": Use opposite case if possible. This is a gnulib "},{"code":"strftime()","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"extension. Since: 2.80"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Additionally, when "},{"type":"codeVoice","code":"O"},{"type":"text","text":" is used with "},{"type":"codeVoice","code":"B"},{"text":", ","type":"text"},{"type":"codeVoice","code":"b"},{"type":"text","text":", or "},{"code":"h","type":"codeVoice"},{"text":", it produces the alternative","type":"text"},{"type":"text","text":" "},{"type":"text","text":"form of a month name. The alternative form should be used when the month"},{"type":"text","text":" "},{"text":"name is used without a day number (e.g., standalone). It is required in","type":"text"},{"type":"text","text":" "},{"type":"text","text":"some languages (Baltic, Slavic, Greek, and more) due to their grammatical"},{"type":"text","text":" "},{"type":"text","text":"rules. For other languages there is no difference. "},{"type":"codeVoice","code":"OB"},{"type":"text","text":" is a GNU and BSD"},{"type":"text","text":" "},{"type":"codeVoice","code":"strftime()"},{"text":" extension expected to be added to the future POSIX specification,","type":"text"},{"type":"text","text":" "},{"code":"Ob","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"Oh"},{"type":"text","text":" are GNU "},{"type":"codeVoice","code":"strftime()"},{"type":"text","text":" extensions. Since: 2.56"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Since GLib 2.80, when "},{"code":"E","type":"codeVoice"},{"type":"text","text":" is used with "},{"type":"codeVoice","code":"c"},{"type":"text","text":", "},{"type":"codeVoice","code":"C"},{"type":"text","text":", "},{"code":"x","type":"codeVoice"},{"text":", ","type":"text"},{"type":"codeVoice","code":"X"},{"type":"text","text":", "},{"type":"codeVoice","code":"y"},{"text":" or ","type":"text"},{"code":"Y","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the date is formatted using an alternate era representation specific to the"},{"text":" ","type":"text"},{"text":"locale. This is typically used for the Thai solar calendar or Japanese era","type":"text"},{"text":" ","type":"text"},{"text":"names, for example.","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"Ec","type":"codeVoice"},{"text":": the preferred date and time representation for the current locale,","type":"text"},{"text":" ","type":"text"},{"text":"using the alternate era representation","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"EC","type":"codeVoice"},{"text":": the name of the era","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"Ex"},{"text":": the preferred date representation for the current locale without","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the time, using the alternate era representation"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"EX"},{"type":"text","text":": the preferred time representation for the current locale without"},{"text":" ","type":"text"},{"text":"the date, using the alternate era representation","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"Ey","type":"codeVoice"},{"type":"text","text":": the year since the beginning of the era denoted by the "},{"code":"EC","type":"codeVoice"},{"text":" ","type":"text"},{"text":"specifier","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"EY"},{"text":": the full alternative year representation","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/datetimeref\/format(format:)"]}],"abstract":[{"text":"Creates a newly allocated string representing the requested ","type":"text"},{"type":"codeVoice","code":"format"},{"text":".","type":"text"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/DateTimeRef","doc:\/\/GLib\/documentation\/GLib\/DateTimeRef\/DateTimeProtocol-Implementations"]]},"kind":"symbol","references":{"doc://GLib/documentation/GLib/DateTimeRef/format(format:)":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeRef\/format(format:)","type":"topic","title":"format(format:)","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"format","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"format"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">!) -> "},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"abstract":[{"text":"Creates a newly allocated string representing the requested ","type":"text"},{"code":"format","type":"codeVoice"},{"type":"text","text":"."}],"kind":"symbol","url":"\/documentation\/glib\/datetimeref\/format(format:)"},"doc://GLib/documentation/GLib/DateTimeRef":{"url":"\/documentation\/glib\/datetimeref","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"DateTimeRef"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeRef","abstract":[{"code":"GDateTime","type":"codeVoice"},{"type":"text","text":" is a structure that combines a Gregorian date and time"},{"type":"text","text":" "},{"type":"text","text":"into a single structure."}],"title":"DateTimeRef","navigatorTitle":[{"text":"DateTimeRef","kind":"identifier"}],"kind":"symbol","type":"topic"},"doc://GLib/documentation/GLib/DateTimeRef/DateTimeProtocol-Implementations":{"type":"topic","title":"DateTimeProtocol Implementations","identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeRef\/DateTimeProtocol-Implementations","kind":"article","abstract":[],"role":"collectionGroup","url":"\/documentation\/glib\/datetimeref\/datetimeprotocol-implementations"},"doc://GLib/documentation/GLib/e-3m6a4":{"type":"topic","kind":"symbol","role":"symbol","title":"e","identifier":"doc:\/\/GLib\/documentation\/GLib\/e-3m6a4","url":"\/documentation\/glib\/e-3m6a4","abstract":[{"type":"text","text":"The base of natural logarithms."}],"fragments":[{"kind":"keyword","text":"let"},{"text":" ","kind":"text"},{"text":"e","kind":"identifier"},{"kind":"text","text":": "},{"text":"Double","preciseIdentifier":"s:Sd","kind":"typeIdentifier"}]},"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]}}}
{"text":"The ","type":"text"},{"code":"year","type":"codeVoice"},{"text":" must be between 1 and 9999, ","type":"text"},{"type":"codeVoice","code":"month"},{"text":" between 1 and 12 and ","type":"text"},{"type":"codeVoice","code":"day"},{"text":" ","type":"text"},{"text":"between 1 and 28, 29, 30 or 31 depending on the month and the year.","type":"text"}]},{"inlineContent":[{"code":"hour","type":"codeVoice"},{"type":"text","text":" must be between 0 and 23 and "},{"code":"minute","type":"codeVoice"},{"type":"text","text":" must be between 0 and 59."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"code":"seconds","type":"codeVoice"},{"text":" must be at least 0.0 and must be strictly less than 60.0.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"It will be rounded down to the nearest microsecond."}]},{"type":"paragraph","inlineContent":[{"text":"If the given time is not representable in the given time zone (for","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"example, 02:30 on March 14th 2010 in Toronto, due to daylight savings"},{"type":"text","text":" "},{"type":"text","text":"time) then the time will be rounded up to the nearest existing time"},{"type":"text","text":" "},{"text":"(in this case, 03:00).  If this matters to you then you should verify","type":"text"},{"text":" ","type":"text"},{"text":"the return value for containing the same as the numbers you gave.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In the case that the given time is ambiguous in the given time zone"},{"text":" ","type":"text"},{"type":"text","text":"(for example, 01:30 on November 7th 2010 in Toronto, due to daylight"},{"text":" ","type":"text"},{"text":"savings time) then the time falling within standard (ie:","type":"text"},{"type":"text","text":" "},{"text":"non-daylight) time is taken.","type":"text"}]},{"inlineContent":[{"type":"text","text":"It not considered a programmer error for the values to this function"},{"text":" ","type":"text"},{"text":"to be out of range, but in the case that they are, the function will","type":"text"},{"text":" ","type":"text"},{"text":"return ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You should release the return value by calling "},{"code":"g_date_time_unref()","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"when you are done with it."}],"type":"paragraph"}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"paths":["\/documentation\/glib\/datetimeref\/init(tz:year:month:day:hour:minute:seconds:)"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"doc://GLib/documentation/GLib/DateTimeRef/init(tz:year:month:day:hour:minute:seconds:)":{"title":"init(tz:year:month:day:hour:minute:seconds:)","kind":"symbol","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"TimeZoneT"},{"kind":"text","text":">("},{"kind":"externalParam","text":"tz"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"TimeZoneT"},{"text":", ","kind":"text"},{"text":"year","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"month","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"day","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":", "},{"text":"hour","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"te
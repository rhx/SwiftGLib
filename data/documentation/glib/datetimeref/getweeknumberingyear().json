{"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/DateTimeRef\/getWeekNumberingYear()","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Returns the ISO 8601 week-numbering year in which the week containing"},{"text":" ","type":"text"},{"code":"datetime","type":"codeVoice"},{"type":"text","text":" falls."}],"metadata":{"role":"symbol","extendedModule":"GLib","title":"getWeekNumberingYear()","modules":[{"name":"GLib"}],"externalID":"s:4GLib16DateTimeProtocolPAAE20getWeekNumberingYearSiyF::SYNTHESIZED::s:4GLib11DateTimeRefV","roleHeading":"Instance Method","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"getWeekNumberingYear"},{"kind":"text","text":"() -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}]},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/DateTimeRef","doc:\/\/GLib\/documentation\/GLib\/DateTimeRef\/DateTimeProtocol-Implementations"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"getWeekNumberingYear","kind":"identifier"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"This function, taken together with ","type":"text"},{"type":"codeVoice","code":"g_date_time_get_week_of_year()"},{"type":"text","text":" and"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_date_time_get_day_of_week()"},{"text":" can be used to determine the full ISO","type":"text"},{"type":"text","text":" "},{"text":"week date on which ","type":"text"},{"type":"codeVoice","code":"datetime"},{"text":" falls.","type":"text"}]},{"inlineContent":[{"text":"This is usually equal to the normal Gregorian year (as returned by","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_date_time_get_year()"},{"type":"text","text":"), except as detailed below:"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For Thursday, the week-numbering year is always equal to the usual"},{"text":" ","type":"text"},{"text":"calendar year.  For other days, the number is such that every day","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"within a complete week (Monday to Sunday) is contained within the"},{"text":" ","type":"text"},{"type":"text","text":"same week-numbering year."}]},{"type":"paragraph","inlineContent":[{"text":"For Monday, Tuesday and Wednesday occurring near the end of the year,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"this may mean that the week-numbering year is one greater than the"},{"text":" ","type":"text"},{"text":"calendar year (so that these days have the same week-numbering year","type":"text"},{"type":"text","text":" "},{"type":"text","text":"as the Thursday occurring early in the next year)."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For Friday, Saturday and Sunday occurring near the start of the year,"},{"text":" ","type":"text"},{"text":"this may mean that the week-numbering year is one less than the","type":"text"},{"type":"text","text":" "},{"text":"calendar year (so that these days have the same week-numbering year","type":"text"},{"text":" ","type":"text"},{"text":"as the Thursday occurring late in the previous year).","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"An equivalent description is that the week-numbering year is equal to","type":"text"},{"type":"text","text":" "},{"text":"the calendar year containing the majority of the days in the current","type":"text"},{"text":" ","type":"text"},{"text":"week (Monday to Sunday).","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that January 1 0001 in the proleptic Gregorian calendar is a"},{"text":" ","type":"text"},{"text":"Monday, so this function never returns 0.","type":"text"}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/datetimeref\/getweeknumberingyear()"]}],"references":{"doc://GLib/documentation/GLib/DateTimeRef/DateTimeProtocol-Implementations":{"type":"topic","title":"DateTimeProtocol Implementations","identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeRef\/DateTimeProtocol-Implementations","kind":"article","abstract":[],"role":"collectionGroup","url":"\/documentation\/glib\/datetimeref\/datetimeprotocol-implementations"},"doc://GLib/documentation/GLib/DateTimeRef":{"url":"\/documentation\/glib\/datetimeref","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"DateTimeRef"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeRef","abstract":[{"code":"GDateTime","type":"codeVoice"},{"type":"text","text":" is a structure that combines a Gregorian date and time"},{"type":"text","text":" "},{"type":"text","text":"into a single structure."}],"title":"DateTimeRef","navigatorTitle":[{"text":"DateTimeRef","kind":"identifier"}],"kind":"symbol","type":"topic"},"doc://GLib/documentation/GLib/DateTimeRef/getWeekNumberingYear()":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/DateTimeRef\/getWeekNumberingYear()","type":"topic","title":"getWeekNumberingYear()","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"getWeekNumberingYear"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"abstract":[{"text":"Returns the ISO 8601 week-numbering year in which the week containing","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"datetime"},{"type":"text","text":" falls."}],"kind":"symbol","url":"\/documentation\/glib\/datetimeref\/getweeknumberingyear()"},"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]}}}
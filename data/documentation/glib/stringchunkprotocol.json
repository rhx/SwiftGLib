{"text":"!","kind":"text"}],"url":"\/documentation\/glib\/stringchunkprotocol\/insert(string:)","abstract":[{"text":"Adds a copy of ","type":"text"},{"type":"codeVoice","code":"string"},{"type":"text","text":" to the "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StringChunk","isActive":true,"type":"reference"},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"It returns a pointer to the new copy of the string","type":"text"},{"type":"text","text":" "},{"text":"in the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/StringChunk","type":"reference"},{"type":"text","text":". The characters in the string"},{"type":"text","text":" "},{"type":"text","text":"can be changed, if necessary, though you should not"},{"type":"text","text":" "},{"type":"text","text":"change anything after the end of the string."}],"kind":"symbol","role":"symbol","type":"topic"},"doc://GLib/documentation/GLib/StringChunkProtocol/insertConst(string:)":{"role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/StringChunkProtocol\/insertConst(string:)","abstract":[{"text":"Adds a copy of ","type":"text"},{"code":"string","type":"codeVoice"},{"type":"text","text":" to the "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/StringChunk","isActive":true},{"text":", unless the same","type":"text"},{"type":"text","text":" "},{"type":"text","text":"string has already been added to the "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/StringChunk","isActive":true,"type":"reference"},{"type":"text","text":" with"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_string_chunk_insert_const()"},{"text":".","type":"text"}],"title":"insertConst(string:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"insertConst","kind":"identifier"},{"kind":"text","text":"("},{"text":"string","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"
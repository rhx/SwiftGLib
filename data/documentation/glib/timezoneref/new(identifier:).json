{"kind":"symbol","sections":[],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef\/new(identifier:)","interfaceLanguage":"swift"},"abstract":[{"text":"Creates a ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone","isActive":true},{"type":"text","text":" corresponding to "},{"type":"codeVoice","code":"identifier"},{"type":"text","text":". If "},{"code":"identifier","type":"codeVoice"},{"text":" cannot be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"parsed or loaded, "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" is returned."}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef"]]},"variants":[{"paths":["\/documentation\/glib\/timezoneref\/new(identifier:)"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"static","kind":"keyword"},{"kind":"text","text":" "},{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"new","kind":"identifier"},{"kind":"text","text":"("},{"text":"identifier","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier","text":"gchar"},{"kind":"text","text":">? = nil) -> "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef","text":"TimeZoneRef","kind":"typeIdentifier","preciseIdentifier":"s:4GLib11TimeZoneRefV"},{"text":"!","kind":"text"}]}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"code":"identifier","type":"codeVoice"},{"text":" can either be an RFC3339\/ISO 8601 time offset or","type":"text"},{"text":" ","type":"text"},{"text":"something that would pass as a valid value for the ","type":"text"},{"code":"TZ","type":"codeVoice"},{"text":" environment","type":"text"},{"type":"text","text":" "},{"type":"text","text":"variable (including "},{"type":"codeVoice","code":"nil"},{"text":").","type":"text"}]},{"inlineContent":[{"type":"text","text":"In Windows, "},{"code":"identifier","type":"codeVoice"},{"text":" can also be the unlocalized name of a time","type":"text"},{"text":" ","type":"text"},{"text":"zone for standard time, for example “Pacific Standard Time”.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Valid RFC3339 time offsets are ","type":"text"},{"code":"\"Z\"","type":"codeVoice"},{"type":"text","text":" (for UTC) or"},{"text":" ","type":"text"},{"type":"codeVoice","code":"\"±hh:mm\""},{"type":"text","text":".  ISO 8601 additionally specifies"},{"text":" ","type":"text"},{"code":"\"±hhmm\"","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"\"±hh\""},{"type":"text","text":".  Offsets are"},{"text":" ","type":"text"},{"type":"text","text":"time values to be added to Coordinated Universal Time (UTC) to get"},{"type":"text","text":" "},{"text":"the local time.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In UNIX, the "},{"code":"TZ","type":"codeVoice"},{"type":"text","text":" environment variable typically corresponds"},{"text":" ","type":"text"},{"text":"to the name of a file in the zoneinfo database, an absolute path to a file","type":"text"},{"type":"text","text":" "},{"text":"somewhere else, or a string in","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"“std offset [dst [offset],start[\/time],end[\/time]]” (POSIX) format."},{"type":"text","text":" "},{"type":"text","text":"There  are  no spaces in the specification. The name of standard"},{"type":"text","text":" "},{"type":"text","text":"and daylight savings time zone must be three or more alphabetic"},{"type":"text","text":" "},{"type":"text","text":"characters. Offsets are time values to be added to local time to"},{"text":" ","type":"text"},{"text":"get Coordinated Universal Time (UTC) and should be","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"\"[±]hh[[:]mm[:ss]]\""},{"type":"text","text":".  Dates are either"},{"type":"text","text":" "},{"code":"\"Jn\"","type":"codeVoice"},{"text":" (Julian day with n between 1 and 365, leap","type":"text"},{"text":" ","type":"text"},{"text":"years not counted), ","type":"text"},{"type":"codeVoice","code":"\"n\""},{"text":" (zero-based Julian day","type":"text"},{"type":"text","text":" "},{"type":"text","text":"with n between 0 and 365) or "},{"type":"codeVoice","code":"\"Mm.w.d\""},{"type":"text","text":" (day d"},{"text":" ","type":"text"},{"text":"(0 <= d <= 6) of week w (1 <= w <= 5) of month m (1 <= m <= 12), day","type":"text"},{"type":"text","text":" "},{"text":"0 is a Sunday).  Times are in local wall clock time, the default is","type":"text"},{"type":"text","text":" "},{"text":"02:00:00.","type":"text"}]},{"inlineContent":[{"text":"In Windows, the “tzn[+|–]hh","type":"text"},{"identifier":"#dzn","isActive":true,"type":"reference"},{"type":"text","text":"” format is used, but also"},{"text":" ","type":"text"},{"type":"text","text":"accepts POSIX format.  The Windows format uses US rules for all time"},{"type":"text","text":" "},{"text":"zones; daylight savings time is 60 minutes behind the standard time","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"with date and time of change taken from Pacific Standard Time."},{"text":" ","type":"text"},{"type":"text","text":"Offsets are time values to be added to the local time to get"},{"type":"text","text":" "},{"text":"Coordinated Universal Time (UTC).","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"g_time_zone_new_local()"},{"type":"text","text":" calls this function with the value of the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"TZ"},{"type":"text","text":" environment variable. This function itself is independent of"},{"text":" ","type":"text"},{"text":"the value of ","type":"text"},{"code":"TZ","type":"codeVoice"},{"type":"text","text":", but if "},{"type":"codeVoice","code":"identifier"},{"text":" is ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" then "},{"type":"codeVoice","code":"\/etc\/localtime"},{"text":" ","type":"text"},{"text":"will be consulted to discover the correct time zone on UNIX and the","type":"text"},{"text":" ","type":"text"},{"text":"registry will be consulted or ","type":"text"},{"type":"codeVoice","code":"GetTimeZoneInformation()"},{"text":" will be used","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to get the local time zone on Windows."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If intervals are not available, only time zone rules from ","type":"text"},{"type":"codeVoice","code":"TZ"},{"text":" ","type":"text"},{"text":"environment variable or other means, then they will be computed","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"from year 1900 to 2037.  If the maximum year for the rules is"},{"type":"text","text":" "},{"type":"text","text":"available and it is greater than 2037, then it will followed"},{"text":" ","type":"text"},{"type":"text","text":"instead."}]},{"inlineContent":[{"text":"See","type":"text"},{"type":"text","text":" "},{"identifier":"http:\/\/tools.ietf.org\/html\/rfc3339#section-5.6","type":"reference","isActive":true},{"text":" ","type":"text"},{"type":"text","text":"for a precise definition of valid RFC3339 time offsets"},{"type":"text","text":" "},{"type":"text","text":"(the "},{"code":"time-offset","type":"codeVoice"},{"text":" expansion) and ISO 8601 for the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"full list of valid time offsets.  See"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"http:\/\/www.gnu.org\/s\/libc\/manual\/html_node\/TZ-Variable.html"},{"type":"text","text":" "},{"text":"for an explanation of the possible","type":"text"},{"type":"text","text":" "},{"type":"text","text":"values of the "},{"code":"TZ","type":"codeVoice"},{"text":" environment variable. See","type":"text"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"http:\/\/msdn.microsoft.com\/en-us\/library\/ms912391%28v=winembedded.11%29.aspx"},{"type":"text","text":" "},{"type":"text","text":"for the list of time zones on Windows."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You should release the return value by calling "},{"type":"codeVoice","code":"g_time_zone_unref()"},{"type":"text","text":" "},{"text":"when you are done with it.","type":"text"}],"type":"paragraph"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"extendedModule":"GLib","role":"symbol","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"new"},{"kind":"text","text":"("},{"text":"identifier","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"text":">?) -> ","kind":"text"},{"text":"TimeZoneRef","kind":"typeIdentifier","preciseIdentifier":"s:4GLib11TimeZoneRefV"},{"text":"!","kind":"text"}],"modules":[{"name":"GLib"}],"externalID":"s:4GLib11TimeZoneRefV3new10identifierACSgSPys4Int8VGSg_tFZ","roleHeading":"Type Method","title":"new(identifier:)","symbolKind":"method"},"references":{"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"http://www.gnu.org/s/libc/manual/html_node/TZ-Variable.html":{"title":"The GNU C Library manual","type":"link","url":"http:\/\/www.gnu.org\/s\/li
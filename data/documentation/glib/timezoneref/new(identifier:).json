on-5.6":{"title":"RFC3339 §5.6","type":"link","url":"http:\/\/tools.ietf.org\/html\/rfc3339#section-5.6","identifier":"http:\/\/tools.ietf.org\/html\/rfc3339#section-5.6","titleInlineContent":[{"type":"text","text":"RFC3339 §5.6"}]},"doc://GLib/documentation/GLib/TimeZoneRef":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZoneRef","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"TimeZoneRef"}],"type":"topic","abstract":[{"text":"A ","type":"text"},{"code":"GTimeZone","type":"codeVoice"},{"text":" represents a time zone, at no particular point in time.","type":"text"}],"title":"TimeZoneRef","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"TimeZoneRef"}],"url":"\/documentation\/glib\/timezoneref"},"#dzn":{"title":":mm[:ss]","type":"link","url":"#dzn","identifier":"#dzn","titleInlineContent":[{"text":":mm[:ss]","type":"text"}]},"doc://GLib/documentation/GLib/TimeZone":{"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"TimeZone"}],"kind":"symbol","title":"TimeZone","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"TimeZone"}],"url":"\/documentation\/glib\/timezone","abstract":[{"type":"text","text":"A "},{"type":"codeVoice","code":"GTimeZone"},{"text":" represents a time zone, at no particular point in time.","type":"text"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/TimeZone"}}}
int and the caller will not need to unreference it.  This"},{"text":" ","type":"text"},{"type":"text","text":"makes certain common styles of programming much easier while still"},{"type":"text","text":" "},{"text":"maintaining normal refcounting semantics in situations where values","type":"text"},{"type":"text","text":" "},{"text":"are not floating.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://GLib/documentation/GLib/Variant":{"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","kind":"symbol","navigatorTitle":[{"text":"Variant","kind":"identifier"}],"role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Variant","kind":"identifier"}],"url":"\/documentation\/glib\/variant","abstract":[{"type":"codeVoice","code":"GVariant"},{"type":"text","text":" is a variant datatype; it can contain one or more values"},{"type":"text","text":" "},{"text":"along with information about the type of the values.","type":"text"}],"title":"Variant"},"doc://GLib/documentation/GLib/VariantRef/VariantProtocol-Implementations":{"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef\/VariantProtocol-Implementations","kind":"article","role":"collectionGroup","url":"\/documentation\/glib\/variantref\/variantprotocol-implementations","abstract":[],"title":"VariantProtocol Implementations"},"doc://GLib/documentation/GLib/VariantRef/refSink()":{"title":"refSink()","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"refSink","kind":"identifier"},{"kind":"text","text":"() -> "},{"preciseIdentifier":"s:4GLib10VariantRefV","kind":"typeIdentifier","text":"VariantRef"},{"text":"!","kind":"text"}],"abstract":[{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"type":"text","text":" uses a floating reference count system.  All functions with"},{"type":"text","text":" "},{"text":"names starting with ","type":"text"},
 an"},{"text":" ","type":"text"},{"type":"text","text":"array of bytes."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The return value remains valid as long as "},{"code":"value","type":"codeVoice"},{"text":" exists.","type":"text"}]}]}],"metadata":{"role":"symbol","roleHeading":"Instance Method","modules":[{"name":"GLib"}],"extendedModule":"GLib","externalID":"s:4GLib15VariantProtocolPAAE13getBytestringSSSgyF::SYNTHESIZED::s:4GLib10VariantRefV","symbolKind":"method","title":"getBytestring()","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"getBytestring","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":"!","kind":"text"}]},"kind":"symbol","identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/VariantRef\/getBytestring()","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"patch":0,"major":0},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/VariantRef","doc:\/\/GLib\/documentation\/GLib\/VariantRef\/VariantProtocol-Implementations"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/variantref\/getbytestring()"]}],"references":{"doc://GLib/documentation/GLib/Variant":{"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","kind":"symbol","navigatorTitle":[{"text":"Variant","kind":"identifier"}],"role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Variant","kind":"identifier"}],"url":"\/documentation\/glib\/variant","abstract":[{"type":"codeVoice","code":"GVariant"},{"type":"text","text":" is a variant datatype; it can contain one or more values"},{"type":"text","text":" "},{"text":"along with information about the type of the values.","type":"text"}],"title":"Variant"},"doc://GLib/documentation/GLib/VariantRef/getBytestring()":{"title":"getBytestring()","identifier":
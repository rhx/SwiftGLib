{"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"text":"isPartialMatch","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"kind":"text","text":" { "},{"text":"get","kind":"keyword"},{"kind":"text","text":" }"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"inlineContent":[{"type":"text","text":"Consider, for example, an application where a human is required to"},{"text":" ","type":"text"},{"type":"text","text":"type in data for a field with specific formatting requirements. An"},{"text":" ","type":"text"},{"type":"text","text":"example might be a date in the form ddmmmyy, defined by the pattern"},{"text":" ","type":"text"},{"type":"codeVoice","code":"\"^\\d?\\d(jan|feb|mar|apr|may|jun|jul|aug|sep|oct|nov|dec)"},{"type":"text","text":"\\d\\d$”."},{"type":"text","text":" "},{"text":"If the application sees the user’s keystrokes one by one, and can","type":"text"},{"type":"text","text":" "},{"type":"text","text":"check that what has been typed so far is potentially valid, it is"},{"text":" ","type":"text"},{"type":"text","text":"able to raise an error as soon as a mistake is made."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"GRegex supports the concept of partial matching by means of the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"partialSoft"},{"type":"text","text":" and "},{"type":"codeVoice","code":"partialHard"},{"text":" flags.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"When they are used, the return code for"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_regex_match()"},{"text":" or ","type":"text"},{"code":"g_regex_match_full()","type":"codeVoice"},{"type":"text","text":" is, as usual, "},{"type":"codeVoice","code":"true"},{"text":" ","type":"text"},{"type":"text","text":"for a complete match, "},{"code":"false","type":"codeVoice"},{"text":" otherwise. But, when these functions","type":"text"},{"text":" ","type":"text"},{"text":"return ","type":"text"},{"code":"false","type":"codeVoice"},{"type":"text","text":", you can check if the match was partial calling"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_match_info_is_partial_match()"},{"text":".","type":"text"}]},{"inlineContent":[{"text":"The difference between ","type":"text"},{"code":"partialSoft","type":"codeVoice"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"code":"partialHard","type":"codeVoice"},{"text":" is that when a partial match is encountered","type":"text"},{"type":"text","text":" "},{"text":"with ","type":"text"},{"code":"partialSoft","type":"codeVoice"},{"text":", matching continues to search for a","type":"text"},{"type":"text","text":" "},{"text":"possible complete match, while with ","type":"text"},{"type":"codeVoice","code":"partialHard"},{"type":"text","text":" matching"},{"type":"text","text":" "},{"type":"text","text":"stops at the partial match."},{"type":"text","text":" "},{"type":"text","text":"When both "},{"type":"codeVoice","code":"partialSoft"},{"text":" and ","type":"text"},{"code":"partialHard","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"are set, the latter takes precedence."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"There were formerly some restrictions on the pattern for partial matching."},{"type":"text","text":" "},{"text":"The restrictions no longer apply.","type":"text"}]},{"inlineContent":[{"type":"text","text":"See "},{"type":"codeVoice","code":"pcrepartial(3)"},{"type":"text","text":" for more information on partial matching."}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/MatchInfoProtocol"]]},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/MatchInfoProtocol\/isPartialMatch","interfaceLanguage":"swift"},"sections":[],"abstract":[{"type":"text","text":"Usually if the string passed to g_regex_match*() matches as far as"},{"text":" ","type":"text"},{"type":"text","text":"it goes, but is too short to match the entire pattern, "},{"type":"codeVoice","code":"false"},{"type":"text","text":" is"},{"type":"text","text":" "},{"text":"returned. There are circumstances where it might be helpful to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"distinguish this case from other cases in which there is no match."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/matchinfoprotocol\/ispartialmatch"]}],"metadata":{"title":"isPartialMatch","symbolKind":"property","modules":[{"name":"GLib"}],"fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"isPartialMatch","kind":"identifier"},{"kind":"text","text":": "},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"extendedModule":"GLib","roleHeading":"Instance Property","role":"symbol","externalID":"s:4GLib17MatchInfoProtocolPAAE09isPartialB0Sbvp"},"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"references":{"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"doc://GLib/documentation/GLib/MatchInfoProtocol":{"role":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfoProtocol","abstract":[{"type":"text","text":"A GMatchInfo is an opaque struct used to return information about"},{"text":" ","type":"text"},{"text":"matches.","type":"text"}],"title":"MatchInfoProtocol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"MatchInfoProtocol"}],"type":"topic","url":"\/documentation\/glib\/matchinfoprotocol","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"MatchInfoProtocol"}]},"doc://GLib/documentation/GLib/MatchInfoProtocol/isPartialMatch":{"title":"isPartialMatch","abstract":[{"type":"text","text":"Usually if the string passed to g_regex_match*() matches as far as"},{"text":" ","type":"text"},{"text":"it goes, but is too short to match the entire pattern, ","type":"text"},{"type":"codeVoice","code":"false"},{"type":"text","text":" is"},{"type":"text","text":" "},{"text":"returned. There are circumstances where it might be helpful to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"distinguish this case from other cases in which there is no match."}],"url":"\/documentation\/glib\/matchinfoprotocol\/ispartialmatch","kind":"symbol","role":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"kind":"identifier","text":"isPartialMatch"},{"kind":"text","text":": "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"identifier":"doc:\/\/GLib\/documentation\/GLib\/MatchInfoProtocol\/isPartialMatch"}}}
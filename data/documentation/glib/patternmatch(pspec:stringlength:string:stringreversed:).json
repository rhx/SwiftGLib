{"abstract":[{"text":"Matches a string against a compiled pattern.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/patternmatch(pspec:stringlength:string:stringreversed:)"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"patternMatch","kind":"identifier"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"PatternSpecT"},{"text":">(","kind":"text"},{"text":"pspec","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"PatternSpecT"},{"kind":"text","text":", "},{"text":"stringLength","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"text":", ","kind":"text"},{"text":"string","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">!, ","kind":"text"},{"text":"stringReversed","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"gchar","preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier"},{"text":">? = nil) -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"text":" ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"typeIdentifier","text":"PatternSpecT"},{"text":" : ","kind":"text"},{"text":"PatternSpecProtocol","identifier":"doc:\/\/GLib\/documentation\/GLib\/PatternSpecProtocol","kind":"typeIdentifier","preciseIdentifier":"s:4GLib19PatternSpecProtocolP"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"text":"Passing the correct","type":"text"},{"text":" ","type":"text"},{"text":"length of the string given is mandatory. The reversed string can be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"omitted by passing "},{"code":"NULL","type":"codeVoice"},{"text":", this is more efficient if the reversed","type":"text"},{"type":"text","text":" "},{"type":"text","text":"version of the string to be matched is not at hand, as"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_pattern_match()"},{"type":"text","text":" will only construct it if the compiled pattern"},{"text":" ","type":"text"},{"text":"requires reverse matches.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Note that, if the user code will (possibly) match a string against a"},{"type":"text","text":" "},{"type":"text","text":"multitude of patterns containing wildcards, chances are high that"},{"text":" ","type":"text"},{"type":"text","text":"some patterns will require a reversed string. In this case, it’s"},{"type":"text","text":" "},{"text":"more efficient to provide the reversed string to avoid multiple","type":"text"},{"type":"text","text":" "},{"type":"text","text":"constructions thereof in the various calls to "},{"type":"codeVoice","code":"g_pattern_match()"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note also that the reverse of a UTF-8 encoded string can in general"},{"type":"text","text":" "},{"type":"text","text":"not be obtained by [func"},{"type":"codeVoice","code":"GLib.strreverse"},{"text":"]. This works only if the string","type":"text"},{"type":"text","text":" "},{"type":"text","text":"does not contain any multibyte characters. GLib offers the"},{"type":"text","text":" "},{"text":"[func","type":"text"},{"code":"GLib.utf8_strreverse","type":"codeVoice"},{"type":"text","text":"] function to reverse UTF-8 encoded strings."}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"pattern_match is deprecated:"}],"type":"strong"},{"text":" ","type":"text"},{"type":"text","text":"Use [method@GLib.PatternSpec.match] instead"}]}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/patternMatch(pspec:stringLength:string:stringReversed:)"},"metadata":{"platforms":[],"roleHeading":"Function","role":"symbol","externalID":"s:4GLib12patternMatch5pspec12stringLength0E00E8ReversedSbx_SiSPys4Int8VGSgAJtAA19PatternSpecProtocolRzlF","title":"patternMatch(pspec:stringLength:string:stringReversed:)","modules":[{"name":"GLib"}],"symbolKind":"func","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"patternMatch"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"PatternSpecT"},{"kind":"text","text":">("},{"text":"pspec","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"PatternSpecT","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"stringLength"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"string"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier","text":"gchar"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"stringReversed"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier","text":"gchar"},{"text":">?) -> ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}]},"kind":"symbol","sections":[],"references":{"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib"
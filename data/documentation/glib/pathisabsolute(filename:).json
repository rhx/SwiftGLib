{"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"paths":["\/documentation\/glib\/pathisabsolute(filename:)"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib"]]},"abstract":[{"type":"text","text":"Returns "},{"type":"codeVoice","code":"true"},{"text":" if the given ","type":"text"},{"type":"codeVoice","code":"fileName"},{"type":"text","text":" is an absolute file name."},{"text":" ","type":"text"},{"text":"Note that this is a somewhat vague concept on Windows.","type":"text"}],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/pathIsAbsolute(fileName:)","interfaceLanguage":"swift"},"kind":"symbol","primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"pathIsAbsolute","kind":"identifier"},{"kind":"text","text":"("},{"text":"fileName","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"text":"<","kind":"text"},{"text":"gchar","preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier"},{"text":">!) -> ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"On POSIX systems, an absolute file name is well-defined. It always","type":"text"},{"type":"text","text":" "},{"type":"text","text":"starts from the single root directory. For example “\/usr\/local”."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On Windows, the concepts of current drive and drive-specific"},{"type":"text","text":" "},{"type":"text","text":"current directory introduce vagueness. This function interprets as"},{"text":" ","type":"text"},{"text":"an absolute file name one that either begins with a directory","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"separator such as “\\Users\\tml” or begins with the root on a drive,"},{"type":"text","text":" "},{"text":"for example “C:\\Windows”. The first case also includes UNC paths","type":"text"},{"text":" ","type":"text"},{"text":"such as “\\\\myserver\\docs\\foo”. In all cases, either slashes or","type":"text"},{"type":"text","text":" "},{"type":"text","text":"backslashes are accepted."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that a file name relative to the current drive root does not"},{"type":"text","text":" "},{"type":"text","text":"truly specify a file uniquely over time and across processes, as"},{"type":"text","text":" "},{"type":"text","text":"the current drive is a per-process value and can be changed."}]},{"inlineContent":[{"type":"text","text":"File names relative the current directory on some specific drive,"},{"text":" ","type":"text"},{"text":"such as “D:foo\/bar”, are not interpreted as absolute by this","type":"text"},{"type":"text","text":" "},{"type":"text","text":"function, but they obviously are not relative to the normal current"},{"text":" ","type":"text"},{"type":"text","text":"directory as returned by "},{"code":"getcwd()","type":"codeVoice"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"g_get_current_dir()"},{"text":" ","type":"text"},{"type":"text","text":"either. Such paths should be avoided, or need to be handled using"},{"type":"text","text":" "},{"type":"text","text":"Windows-specific code."}],"type":"paragraph"}]}],"metadata":{"roleHeading":"Function","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"pathIsAbsolute","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"fileName"},{"kind":"text","text":": "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier","text":"gchar"},{"text":">!) -> ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"symbolKind":"func","externalID":"s:4GLib14pathIsAbsolute8fileNameSbSPys4Int8VGSg_tF","title":"pathIsAbsolute(fileName:)","role":"symbol","modules":[{"name":"GLib"}]},"references":{"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"doc://GLib/documentation/GLib/pathIsAbsolute(fileName:)":{"url":"\/documentation\/glib\/pathisabsolute(filename:)","identifier":"doc:\/\/GLib\/documentation\/GLib\/pathIsAbsolute(fileName:)","title":"pathIsAbsolute(fileName:)","abstract":[{"type":"text","text":"Returns "},{"type":"codeVoice","code":"true"},{"type":"text","text":" if the given "},{"type":"codeVoice","code":"fileName"},{"type":"text","text":" is an absolute file name."},{"type":"text","text":" "},{"type":"text","text":"Note that this is a somewhat vague concept on Windows."}],"role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"pathIsAbsolute","kind":"identifier"},{"kind":"text","text":"("},{"text":"fileName","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"kind":"text","text":">!) -> "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"type":"topic","kind":"symbol"}}}
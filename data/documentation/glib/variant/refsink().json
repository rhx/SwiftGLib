{"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"refSink"},{"kind":"text","text":"() -> "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef","preciseIdentifier":"s:4GLib10VariantRefV","kind":"typeIdentifier","text":"VariantRef"},{"kind":"text","text":"!"}]}],"kind":"declarations"},{"content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Calling ","type":"text"},{"code":"g_variant_ref_sink()","type":"codeVoice"},{"type":"text","text":" on a "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","type":"reference"},{"type":"text","text":" with a floating reference"},{"type":"text","text":" "},{"text":"will convert the floating reference into a full reference.  Calling","type":"text"},{"text":" ","type":"text"},{"code":"g_variant_ref_sink()","type":"codeVoice"},{"type":"text","text":" on a non-floating "},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","type":"reference"},{"type":"text","text":" results in an"},{"type":"text","text":" "},{"type":"text","text":"additional normal reference being added."}]},{"type":"paragraph","inlineContent":[{"text":"In other words, if the ","type":"text"},{"type":"codeVoice","code":"value"},{"type":"text","text":" is floating, then this call “assumes"},{"type":"text","text":" "},{"type":"text","text":"ownership” of the floating reference, converting it to a normal"},{"type":"text","text":" "},{"text":"reference.  If the ","type":"text"},{"type":"codeVoice","code":"value"},{"type":"text","text":" is not floating, then this call adds a"},{"text":" ","type":"text"},{"type":"text","text":"new normal reference increasing the reference count by one."}]},{"inlineContent":[{"text":"All calls that result in a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","type":"reference"},{"type":"text","text":" instance being inserted into a"},{"type":"text","text":" "},{"type":"text","text":"container will call "},{"code":"g_variant_ref_sink()","type":"codeVoice"},{"type":"text","text":" on the instance.  This means"},{"type":"text","text":" "},{"text":"that if the value was just created (and has only its floating","type":"text"},{"type":"text","text":" "},{"text":"reference) then the container will assume sole ownership of the value","type":"text"},{"type":"text","text":" "},{"text":"at that point and the caller will not need to unreference it.  This","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"makes certain common styles of programming much easier while still"},{"type":"text","text":" "},{"type":"text","text":"maintaining normal refcounting semantics in situations where values"},{"text":" ","type":"text"},{"type":"text","text":"are not floating."}],"type":"paragraph"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/variant\/refsink()"]}],"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/Variant","doc:\/\/GLib\/documentation\/GLib\/Variant\/VariantProtocol-Implementations"]]},"metadata":{"extendedModule":"GLib","externalID":"s:4GLib15VariantProtocolPAAE7refSinkAA0B3RefVSgyF::SYNTHESIZED::s:4GLib7VariantC","roleHeading":"Instance Method","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"refSink"},{"kind":"text","text":"() -> "},{"text":"VariantRef","kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV"},{"text":"!","kind":"text"}],"role":"symbol","title":"refSink()","modules":[{"name":"GLib"}],"symbolKind":"method"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/Variant\/refSink()"},"sections":[],"abstract":[{"isActive":
{"kind":"symbol","sections":[],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/Variant\/getChildValue(index:)","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Reads a child item out of a container "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true,"type":"reference"},{"text":" instance.  This","type":"text"},{"type":"text","text":" "},{"type":"text","text":"includes variants, maybes, arrays, tuples and dictionary"},{"type":"text","text":" "},{"text":"entries.  It is an error to call this function on any other type of","type":"text"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"type":"text","text":"."}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/Variant","doc:\/\/GLib\/documentation\/GLib\/Variant\/VariantProtocol-Implementations"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/variant\/getchildvalue(index:)"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"getChildValue","kind":"identifier"},{"kind":"text","text":"("},{"text":"index","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":") -> ","kind":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef","kind":"typeIdentifier","text":"VariantRef","preciseIdentifier":"s:4GLib10VariantRefV"},{"kind":"text","text":"!"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"It is an error if "},{"code":"index","type":"codeVoice"},{"type":"text","text":" is greater than the number of child items"},{"text":" ","type":"text"},{"type":"text","text":"in the container.  See "},{"type":"codeVoice","code":"g_variant_n_children()"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The returned value is never floating.  You should free it with"},{"type":"text","text":" "},{"code":"g_variant_unref()","type":"codeVoice"},{"text":" when you’re done with it.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that values borrowed from the returned child are not guaranteed to"},{"type":"text","text":" "},{"type":"text","text":"still be valid after the child is freed even if you still hold a reference"},{"type":"text","text":" "},{"type":"text","text":"to "},{"type":"codeVoice","code":"value"},{"type":"text","text":", if "},{"type":"codeVoice","code":"value"},{"type":"text","text":" has not been serialized at the time this function is"},{"text":" ","type":"text"},{"type":"text","text":"called. To avoid this, you can serialize "},{"type":"codeVoice","code":"value"},{"text":" by calling","type":"text"},{"text":" ","type":"text"},{"code":"g_variant_get_data()","type":"codeVoice"},{"text":" and optionally ignoring the return value.","type":"text"}]},{"inlineContent":[{"text":"There may be implementation specific restrictions on deeply nested values,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"which would result in the unit tuple being returned as the child value,"},{"type":"text","text":" "},{"text":"instead of further nested children. ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"text":" is guaranteed to handle","type":"text"},{"type":"text","text":" "},{"type":"text","text":"nesting up to at least 64 levels."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function is "},{"type":"codeVoice","code":"O(1)"},{"type":"text","text":"."}]}],"kind":"content"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"externalID":"s:4GLib15VariantProtocolPAAE13getChildVa
:"text"}]},{"inlineContent":[{"type":"codeVoice","code":"data"},{"type":"text","text":" is not modified by this function and must remain valid with an"},{"text":" ","type":"text"},{"type":"text","text":"unchanging value until such a time as "},{"code":"notify","type":"codeVoice"},{"type":"text","text":" is called with"},{"text":" ","type":"text"},{"code":"userData","type":"codeVoice"},{"text":".  If the contents of ","type":"text"},{"type":"codeVoice","code":"data"},{"text":" change before that time then","type":"text"},{"text":" ","type":"text"},{"text":"the result is undefined.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"data"},{"type":"text","text":" is trusted to be serialized data in normal form then"},{"text":" ","type":"text"},{"code":"trusted","type":"codeVoice"},{"type":"text","text":" should be "},{"type":"codeVoice","code":"true"},{"text":".  This applies to serialized data created","type":"text"},{"type":"text","text":" "},{"text":"within this process or read from a trusted location on the disk (such","type":"text"},{"text":" ","type":"text"},{"text":"as a file installed in \/usr\/lib alongside your application).  You","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"should set trusted to "},{"code":"false","type":"codeVoice"},{"type":"text","text":" if "},{"code":"data","type":"codeVoice"},{"text":" is read from the network, a","type":"text"},{"type":"text","text":" "},{"text":"file in the user’s home directory, etc.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"data","type":"codeVoice"},{"type":"text","text":" was not stored in this machine’s native endianness, any multi-byte"},{"type":"text","text":" "},{"text":"numeric values in the returned variant will also be in non-native","type":"text"},{"type":"text","text":" "},{"text":"endianness. ","type":"text"},{"code":"g_variant_byteswap()","type":"codeVoice"},{"type":"text","text":" can be used to recover the original values."}]},{"inlineContent":[{"code":"notify","type":"codeVoice"},{"text":" will be called with ","type":"text"},{"type":"codeVoice","code":"userData"},{"text":" when ","type":"text"},{"type":"codeVoice","code":"data"},{"type":"text","text":" is no longer"},{"text":" ","type":"text"},{"type":"text","text":"needed.  The exact time of this call is unspecified and might even be"},{"type":"text","text":" "},{"type":"text","text":"before this function returns."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Note: "},{"type":"codeVoice","code":"data"},{"type":"text","text":" must be backed by memory that is aligned appropriately for the"},{"text":" ","type":"text"},{"code":"type","type":"codeVoice"},{"type":"text","text":" being loaded. Otherwise this function will internally create a copy of"},{"text":" ","type":"text"},{"type":"text","text":"the memory (since GLib 2.60) or (in older versions) fail and exit the"},{"type":"text","text":" "},{"type":"text","text":"process."}],"type":"paragraph"}]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/Variant\/init(data:data:size:trusted:notify:userData:)","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/glib\/variant\/init(data:data:size:trusted:notify:userdata:)"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://GLib/documentation/GLib/Variant":{"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","kind":"symbol","navigatorTitle":[{"text":"Variant","kind":"identifier"}],"role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Variant","kind":"identifier"}],"url":"\/documentation\/glib\/variant","abstract":[{"type":"codeVoice","code":"GVariant"},{"type":"text","text":" is a variant datatype; it can contain one or more values"},{"type":"text","text":" "},{"text":"along with information about the type
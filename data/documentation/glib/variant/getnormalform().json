xt":" is not already trusted, then it is scanned to check if it","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is in normal form.  If it is found to be in normal form then it is"},{"type":"text","text":" "},{"type":"text","text":"marked as trusted and a new reference to it is returned."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"value","type":"codeVoice"},{"type":"text","text":" is found not to be in normal form then a new trusted"},{"text":" ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true,"type":"reference"},{"text":" is created with the same value as ","type":"text"},{"code":"value","type":"codeVoice"},{"type":"text","text":". The non-normal parts of"},{"text":" ","type":"text"},{"code":"value","type":"codeVoice"},{"text":" will be replaced with default values which are guaranteed to be in","type":"text"},{"type":"text","text":" "},{"type":"text","text":"normal form."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It makes sense to call this function if you’ve received "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"type":"text","text":"data from untrusted sources and you want to ensure your serialized"},{"type":"text","text":" "},{"text":"output is definitely in normal form.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"value","type":"codeVoice"},{"text":" is already in normal form, a new reference will be returned","type":"text"},{"text":" ","type":"text"},{"text":"(which will be floating if ","type":"text"},{"type":"codeVoice","code":"value"},{"type":"text","text":" is floating). If it is not in normal form,"},{"type":"text","text":" "},{"text":"the newly created ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant"},{"text":" will be returned with a single non-floating
{"kind":"symbol","sections":[],"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/Variant\/takeRef()","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"If "},{"code":"value","type":"codeVoice"},{"text":" is floating, sink it.  Otherwise, do nothing.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/Variant","doc:\/\/GLib\/documentation\/GLib\/Variant\/VariantProtocol-Implementations"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/variant\/takeref()"]}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"takeRef","kind":"identifier"},{"kind":"text","text":"() -> "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef","kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef"},{"text":"!","kind":"text"}]}],"kind":"declarations"},{"content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"inlineContent":[{"text":"Typically you want to use ","type":"text"},{"code":"g_variant_ref_sink()","type":"codeVoice"},{"text":" in order to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"automatically do the correct thing with respect to floating or"},{"text":" ","type":"text"},{"text":"non-floating references, but there is one specific scenario where","type":"text"},{"text":" ","type":"text"},{"text":"this function is helpful.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The situation where this function is helpful is when creating an API"},{"type":"text","text":" "},{"type":"text","text":"that allows the user to provide a callback function that returns a"},{"type":"text","text":" "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true,"type":"reference"},{"text":".  We certainly want to allow the user the flexibility to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"return a non-floating reference from this callback (for the case"},{"text":" ","type":"text"},{"type":"text","text":"where the value that is being returned already exists)."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"At the same time, the style of the "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true},{"text":" API makes it likely that","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"for newly-created "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","type":"reference","isActive":true},{"text":" instances, the user can be saved some","type":"text"},{"type":"text","text":" "},{"text":"typing if they are allowed to return a ","type":"text"},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true,"type":"reference"},{"type":"text","text":" with a floating"},{"text":" ","type":"text"},{"text":"reference.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Using this function on the return value of the user’s callback allows","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the user to do whichever is more convenient for them.  The caller"},{"type":"text","text":" "},{"type":"text","text":"will always receives exactly one full reference to the value: either"},{"type":"text","text":" "},{"text":"the one that was returned in the first place, or a floating reference","type":"text"},{"text":" ","type":"text"},{"text":"that has been converted to a full reference.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function has an odd interaction when combined with"},{"text":" ","type":"text"},{"code":"g_variant_ref_sink()","type":"codeVoice"},{"text":" running at the same time in another thread on","type":"text"},{"text":" ","type":"text"},{"text":"the same ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","isActive":true},{"text":" instance.  If ","type":"text"},{"code":"g_variant_ref_sink()","type":"codeVoice"},{"type":"text","text":" runs first then"},{"type":"text","text":" "},{"text":"the result will be that the floating reference is converted to a hard","type":"text"},{"type":"text","text":" "},{"text":"reference.  If ","type":"text"},{"code":"g_variant_take_ref()","type":"codeVoice"},{"type":"text","text":" runs first then the result will"},{"type":"text","text":" "},{"type":"text","text":"be that the floating reference is converted to a hard reference and"},{"text":" ","type":"text"},{"text":"an additional reference on top of that one is added.  It is best to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"avoid this situation."}]}],"kind":"content"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"symbolKind":"method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"takeRef","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"VariantRef","kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV"},{"kind":"text","text":"!"}],"extendedModule":"GLib","role":"symbol","externalID":"s:4GLib15VariantProtocolPAAE7takeRefAA0bE0VSgyF::SYNTHESIZED::s:4GLib7VariantC","title":"takeRef()","modules":[{"name":"GLib"}],"roleHeading":"Instance Method"},"references":{"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"doc://GLib/documentation/GLib/Variant/VariantProtocol-Implementations":{"title":"VariantProtocol Implementations","abstract":[],"kind":"article","url":"\/documentation\/glib\/variant\/variantprotocol-implementations","type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant\/VariantProtocol-Implementations","role":"collectionGroup"},"doc://GLib/documentation/GLib/VariantRef":{"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/VariantRef","kind":"symbol","navigatorTitle":[{"text":"VariantRef","kind":"identifier"}],"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"VariantRef","kind":"identifier"}],"url":"\/documentation\/glib\/variantref","abstract":[{"type":"codeVoice","code":"GVariant"},{"type":"text","text":" is a variant datatype; it can contain one or more values"},{"type":"text","text":" "},{"text":"along with information about the type of the values.","type":"text"}],"title":"VariantRef"},"doc://GLib/documentation/GLib/Variant":{"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant","kind":"symbol","navigatorTitle":[{"text":"Variant","kind":"identifier"}],"role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Variant","kind":"identifier"}],"url":"\/documentation\/glib\/variant","abstract":[{"type":"codeVoice","code":"GVariant"},{"type":"text","text":" is a variant datatype; it can contain one or more values"},{"type":"text","text":" "},{"text":"along with information about the type of the values.","type":"text"}],"title":"Variant"},"doc://GLib/documentation/GLib/Variant/takeRef()":{"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"takeRef"},{"kind":"text","text":"() -> "},{"preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"title":"takeRef()","url":"\/documentation\/glib\/variant\/takeref()","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/Variant\/takeRef()","abstract":[{"type":"text","text":"If "},{"type":"codeVoice","code":"value"},{"type":"text","text":" is floating, sink it.  Otherwise, do nothing."}],"type":"topic","role":"symbol"}}}
{"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/PatternSpec","doc:\/\/GLib\/documentation\/GLib\/PatternSpec\/PatternSpecProtocol-Implementations"]]},"metadata":{"extendedModule":"GLib","roleHeading":"Instance Method","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"match"},{"text":"(","kind":"text"},{"text":"stringLength","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"string","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">!, "},{"text":"stringReversed","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"text":"gchar","preciseIdentifier":"c:@T@gchar","kind":"typeIdentifier"},{"text":">?) -> ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"role":"symbol","modules":[{"name":"GLib"}],"title":"match(stringLength:string:stringReversed:)","externalID":"s:4GLib19PatternSpecProtocolPAAE5match12stringLength0F00F8ReversedSbSi_SPys4Int8VGSgAKtF::SYNTHESIZED::s:4GLib11PatternSpecC","symbolKind":"method"},"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLib\/documentation\/GLib\/PatternSpec\/match(stringLength:string:stringReversed:)"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/patternspec\/match(stringlength:string:stringreversed:)"]}],"kind":"symbol","abstract":[{"text":"Matches a string against a compiled pattern.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"match","kind":"identifier"},{"text":"(","kind":"text"},{"text":"stringLength","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"string","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gchar","text":"gchar","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"text":"stringReversed","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">? = nil) -> "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"platforms":["macOS"]}]},{"content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Passing the correct"},{"text":" ","type":"text"},{"type":"text","text":"length of the string given is mandatory. The reversed string can be"},{"text":" ","type":"text"},{"text":"omitted by passing ","type":"text"},{"type":"codeVoice","code":"NULL"},{"type":"text","text":", this is more efficient if the reversed"},{"text":" ","type":"text"},{"type":"text","text":"version of the string to be matched is not at hand, as"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.PatternSpec.match"},{"type":"text","text":"] will only construct it if the compiled pattern"},{"text":" ","type":"text"},{"type":"text","text":"requires reverse matches."}]},{"inlineContent":[{"type":"text","text":"Note that, if the user code will (possibly) match a string against a"},{"type":"text","text":" "},{"text":"multitude of patterns containing wildcards, chances are high that","type":"text"},{"type":"text","text":" "},{"text":"some patterns will require a reversed string. In this case, it’s","type":"text"},{"text":" ","type":"text"},{"text":"more efficient to provide the reversed string to avoid multiple","type":"text"},{"type":"text","text":" "},{"type":"text","text":"constructions thereof in the various calls to [method"},{"type":"codeVoice","code":"GLib.PatternSpec.match"},{"type":"text","text":"]."}],"type":"paragraph"},{"inlineContent":[{"text":"Note also that the reverse of a UTF-8 encoded string can in general","type":"text"},{"type":"text","text":" "},{"type":"text","text":"not be obtained by [func"},{"type":"codeVoice","code":"GLib.strreverse"},{"text":"]. This works only if the string","type":"text"},{"type":"text","text":" "},{"type":"text","text":"does not contain any multibyte characters. GLib offers the"},{"text":" ","type":"text"},{"text":"[func","type":"text"},{"type":"codeVoice","code":"GLib.utf8_strreverse"},{"text":"] function to reverse UTF-8 encoded strings.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"sections":[],"references":{"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"doc://GLib/documentation/GLib/PatternSpec/match(stringLength:string:stringReversed:)":{"url":"\/documentation\/glib\/patternspec\/match(stringlength:string:stringreversed:)","type":"topic","kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"match"},{"text":"(","kind":"text"},{"text":"stringLength","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":", "},{"text":"string","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"kind":"typeIden
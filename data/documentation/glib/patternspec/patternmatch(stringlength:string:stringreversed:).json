":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"string","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar","text":"gchar"},{"kind":"text","text":">!, "},{"text":"stringReversed","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">? = nil) -> "},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Passing the correct"},{"text":" ","type":"text"},{"type":"text","text":"length of the string given is mandatory. The reversed string can be"},{"text":" ","type":"text"},{"text":"omitted by passing ","type":"text"},{"code":"NULL","type":"codeVoice"},{"type":"text","text":", this is more efficient if the reversed"},{"text":" ","type":"text"},{"text":"version of the string to be matched is not at hand, as","type":"text"},{"text":" ","type":"text"},{"code":"g_pattern_match()","type":"codeVoice"},{"type":"text","text":" will only construct it if the compiled pattern"},{"type":"text","text":" "},{"type":"text","text":"requires reverse matches."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that, if the user code will (possibly) match a string against a"},{"type":"text","text":" "},{"type":"text","text":"multitude of patterns containing wildcards, chances are high that"},{"type":"text","text":" "},{"type":"text","text":"some patterns will require a reversed string. In this case, it’s"},{"type":"text","text":" "},{"text":"more efficient to provide the reversed string to avoid multiple","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"constructions thereof in the various calls to "},{"code":"g_pattern_match()","type":"codeVoice"},{"type":"text","text":"."}]},{"inlineContent":[{"text":"Note also that the reverse of a UTF-8 encoded string can in general","type":"text"},{"type":"text","text":" "},{"text":"not be obtained by [func","type":"text"},{"type":"codeVoice","code":"GLib.strreverse"},{"type":"text","text":"]. This works only if the string"},{"text":" ","type":"text"},{"type":"text","text":"does not contain any multibyte characters. GLib offers the"},{"type":"text","text":" "},{"text":"[func","type":"text"},{"type":"codeVoice","code":"GLib.utf8_strreverse"},{"text":"] function to reverse UTF-8 encoded strings.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"pattern_match is deprecated:","type":"text"}],"type":"strong"},{"type":"text","text":" "},{"type":"text","text":"Use [method@GLib.PatternSpec.match] instead"}]}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"paths":["\/documentation\/glib\/patternspec\/patternmatch(stringlength:string:stringreversed:)"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://GLib/documentation/GLib/PatternSpec":{"title":"PatternSpec","navigatorTitle":[{"text":"PatternSpec","kind":"identifier"}],"abstract":[{"type":"text","text":"A "},{"type":"codeVoice","code":"GPatternSpec"},{"text":" struct is the ‘compiled’ form of a glob-style pattern.","type":"text"}],"kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PatternSpec","kind":"identifier"}],"url":"\/documentation\/glib\/patternspec","identifier":"doc:\/\/GLib\/documentation\/GLib\/PatternSpec","type":"topic","role":"symbol"},"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","
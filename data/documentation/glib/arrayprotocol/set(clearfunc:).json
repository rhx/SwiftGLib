{"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/arrayprotocol\/set(clearfunc:)"]}],"metadata":{"role":"symbol","extendedModule":"GLib","title":"set(clearFunc:)","modules":[{"name":"GLib"}],"roleHeading":"Instance Method","externalID":"s:4GLib13ArrayProtocolPAAE3set9clearFuncyySvSgXCSg_tF","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"set","kind":"identifier"},{"text":"(","kind":"text"},{"text":"clearFunc","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GDestroyNotify","text":"GDestroyNotify"},{"kind":"text","text":"?)"}]},"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/ArrayProtocol\/set(clearFunc:)","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/ArrayProtocol"]]},"sections":[],"abstract":[{"type":"text","text":"Sets a function to clear an element of "},{"type":"codeVoice","code":"array"},{"text":".","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"set","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"clearFunc"},{"kind":"text","text":": "},{"text":"GDestroyNotify","preciseIdentifier":"c:@T@GDestroyNotify","kind":"typeIdentifier"},{"text":"? = nil)","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"clearFunc","type":"codeVoice"},{"text":" will be called when an element in the array","type":"text"},{"text":" ","type":"text"},{"text":"data segment is removed and when the array is freed and data","type":"text"},{"type":"text","text":" "},{"type":"text","text":"segment is deallocated as well. "},{"code":"clearFunc","type":"codeVoice"},{"text":" will be passed a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"pointer to the element to clear, rather than the element itself."}]},{"inlineContent":[{"type":"text","text":"Note that in contrast with other uses of [callback"},{"isActive":true,"identifier":"doc:\/\/GLib\/documentation\/GLib\/DestroyNotify","type":"reference"},{"text":"]","type":"text"},{"text":" ","type":"text"},{"text":"functions, ","type":"text"},{"code":"clearFunc","type":"codeVoice"},{"type":"text","text":" is expected to clear the contents of"},{"text":" ","type":"text"},{"type":"text","text":"the array element it is given, but not free the element itself."}],"type":"paragraph"},{"type":"codeListing","syntax":"c","code":["typedef struct","{","  gchar *str;","  GObject *obj;","} ArrayElement;","","static void","array_element_clear (ArrayElement *element)","{","  g_clear_pointer (&element->str, g_free);","  g_clear_object (&element->obj);","}","","\/\/ main code","GArray *garray = g_array_new (FALSE, FALSE, sizeof (ArrayElement));","g_array_set_clear_func (garray, (GDestroyNotify) array_element_clear);","\/\/ assign data to the structure","g_array_free (garray, TRUE);"]}]}],"references":{"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"doc://GLib/documentation/GLib/DestroyNotify":{"abstract":[{"type":"text","text":"Specifies the type of function which is called when a data element"},{"type":"text","text":" "},{"type":"text","text":"is destroyed. It is passed the pointer to the data element and"},{"text":" ","type":"text"},{"type":"text","text":"should free any memory and resources allocated for it."}],"title":"DestroyNotify","fragments":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DestroyNotify","kind":"identifier"}],"url":"\/documentation\/glib\/destroynotify","kind":"symbol","role":"symbol","navigatorTitle":[{"text":"DestroyNotify","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/GLib\/documentation\/GLib\/DestroyNotify"},"doc://GLib/documentation/GLib/ArrayProtocol":{"url":"\/documentation\/glib\/arrayprotocol","type":"topic","abstract":[{"type":"text","text":"Contains the public fields of a "},{"type":"codeVoice","code":"GArray"},{"text":".","type":"text"}],"navigatorTitle":[{"text":"ArrayProtocol","kind":"identifier"}],"kind":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"text":"ArrayProtocol","kind":"identifier"}],"role":"symbol","title":"ArrayProtocol","identifier":"doc:\/\/GLib\/documentation\/GLib\/ArrayProtocol"},"doc://GLib/documentation/GLib/ArrayProtocol/set(clearFunc:)":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/ArrayProtocol\/set(clearFunc:)","kind":"symbol","url":"\/documentation\/glib\/arrayprotocol\/set(clearfunc:)","type":"topic","title":"set(clearFunc:)","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"set"},{"kind":"text","text":"("},{"text":"clearFunc","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"GDestroyNotify","preciseIdentifier":"c:@T@GDestroyNotify"},{"text":"?)","kind":"text"}],"abstract":[{"text":"Sets a function to clear an element of ","type":"text"},{"type":"codeVoice","code":"array"},{"type":"text","text":"."}]}}}
Entry entries","...","\/\/ now sort it with","sort_mode = SORT_NAME;","g_ptr_array_sort_with_data (file_list,","                            sort_filelist,","                            GINT_TO_POINTER (sort_mode));"],"syntax":"c"},{"type":"paragraph","inlineContent":[{"text":"This is guaranteed to be a stable sort since version 2.32.","type":"text"}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/ptrarrayref\/sortwithdata(comparefunc:userdata:)"]}],"references":{"doc://GLib/documentation/GLib/PtrArrayRef":{"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"PtrArrayRef","kind":"identifier"}],"type":"topic","navigatorTitle":[{"kind":"identifier","text":"PtrArrayRef"}],"role":"symbol","url":"\/documentation\/glib\/ptrarrayref","kind":"symbol","identifier":"doc:\/\/GLib\/documentation\/GLib\/PtrArrayRef","title":"PtrArrayRef","abstract":[{"type":"text","text":"Contains the public fields of a "},{"type":"codeVoice","code":"GPtrArray"},{"type":"text","text":"."}]},"doc://GLib/documentation/GLib":{"identifier":"doc:\/\/GLib\/documentation\/GLib","title":"GLib","kind":"symbol","role":"collection","type":"topic","url":"\/documentation\/glib","abstract":[]},"doc://GLib/documentation/GLib/PtrArrayRef/PtrArrayProtocol-Implementations":{"url":"\/documentation\/glib\/ptrarrayref\/ptrarrayprotocol-implementations","abstract":[],"type":"topic","title":"PtrArrayProtocol Implementations","kind":"article","role":"collectionGroup","identifier":"doc:\/\/GLib\/documentation\/GLib\/PtrArrayRef\/PtrArrayProtocol-Implementations"},"doc://GLib/documentation/GLib/CompareDataFunc":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/CompareDataFunc","fragments":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CompareDataFunc","kind":"identifier"}],"url":"\/documentation\/glib\/comparedatafunc","type":"topic","navigatorTitle":[{"kind":"identifier","text":"CompareDataFunc"}],"kind":"symbol","abstr
{"identifier":{"url":"doc:\/\/GLib\/documentation\/GLib\/CondProtocol\/waitUntil(mutex:endTime:)","interfaceLanguage":"swift"},"sections":[],"kind":"symbol","metadata":{"modules":[{"name":"GLib"}],"role":"symbol","title":"waitUntil(mutex:endTime:)","symbolKind":"method","roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"waitUntil","kind":"identifier"},{"kind":"text","text":"<"},{"text":"MutexT","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"mutex","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"MutexT"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"endTime"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gint64","text":"gint64"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"externalID":"s:4GLib12CondProtocolPAAE9waitUntil5mutex7endTimeSbqd___s5Int64VtAA05MutexC0Rd__lF","extendedModule":"GLib"},"hierarchy":{"paths":[["doc:\/\/GLib\/documentation\/GLib","doc:\/\/GLib\/documentation\/GLib\/CondProtocol"]]},"abstract":[{"type":"text","text":"Waits until either "},{"code":"cond","type":"codeVoice"},{"type":"text","text":" is signalled or "},{"code":"endTime","type":"codeVoice"},{"type":"text","text":" has passed."}],"schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glib\/condprotocol\/waituntil(mutex:endtime:)"]}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"waitUntil","kind":"identifier"},{"text":"<","kind":"text"},{"text":"MutexT","kind":"genericParameter"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"mutex"},{"text":": ","kind":"text"},{"text":"MutexT","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"endTime"},{"text":": ","kind":"text"},{"text":"gint64","kind":"typeIdentifier","preciseIdentifier":"c:@T@gint64"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"kind":"text","text":" "},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MutexT","kind":"typeIdentifier"},{"kind":"text","text":" : "},{"identifier":"doc:\/\/GLib\/documentation\/GLib\/MutexProtocol","preciseIdentifier":"s:4GLib13MutexProtocolP","kind":"typeIdentifier","text":"MutexProtocol"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"inlineContent":[{"text":"As with ","type":"text"},{"type":"codeVoice","code":"g_cond_wait()"},{"text":" it is possible that a spurious or stolen wakeup","type":"text"},{"type":"text","text":" "},{"text":"could occur.  For that reason, waiting on a condition variable should","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"always be in a loop, based on an explicitly-checked predicate."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"true"},{"text":" is returned if the condition variable was signalled (or in the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"case of a spurious wakeup).  "},{"type":"codeVoice","code":"false"},{"type":"text","text":" is returned if "},{"code":"endTime","type":"codeVoice"},{"type":"text","text":" has"},{"text":" ","type":"text"},{"type":"text","text":"passed."}]},{"inlineContent":[{"type":"text","text":"The following code shows how to correctly perform a timed wait on a"},{"text":" ","type":"text"},{"type":"text","text":"condition variable (extending the example presented in the"},{"text":" ","type":"text"},{"type":"text","text":"documentation for "},{"type":"reference","identifier":"doc:\/\/GLib\/documentation\/GLib\/Cond","isActive":true},{"text":"):","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"code":["gpointer","pop_data_timed (void)","{","  gint64 end_time;","  gpointer data;","","  g_mutex_lock (&data_mutex);","","  end_time = g_get_monotonic_time () + 5 * G_TIME_SPAN_SECOND;","  while (!current_data)","    if (!g_cond_wait_until (&data_cond, &data_mutex, end_time))","      {","        \/\/ timeout has passed.","        g_mutex_unlock (&data_mutex);","        return NULL;","      }","","  \/\/ there is data for us","  data = current_data;","  current_data = NULL;","","  g_mutex_unlock (&data_mutex);","","  return data;","}"],"type":"codeListing","syntax":"C"},{"inlineContent":[{"text":"Notice that the end time is calculated once, before entering the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"loop and reused.  This is the motivation behind the use of absolute"},{"type":"text","text":" "},{"type":"text","text":"time on this API – if a relative time of 5 seconds were passed"},{"text":" ","type":"text"},{"type":"text","text":"directly to the call and a spurious wakeup occurred, the program would"},{"text":" ","type":"text"},{"text":"have to start over waiting again (which would lead to a total wait","type":"text"},{"type":"text","text":" "},{"text":"time of more than 5 seconds).","type":"text"}],"type":"paragraph"}]}],"references":{"doc://GLib/documentation/GLib/CondProtocol/waitUntil(mutex:endTime:)":{"identifier":"doc:\/\/GLib\/documentation\/GLib\/CondProtocol\/waitUntil(mutex:endTime:)","abstract":[{"type":"text","text":"Waits until either "},{"code":"cond","type":"codeVoice"},{"text":" is signalled or ","type":"text"},{"code":"endTime","type":"codeVoice"},{"type":"text","text":" has passed."}],"role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"waitUntil"},{"kind":"text","text":"<"},{"text":"MutexT","kind":"genericParameter"},{"kind":"text","text":">("},{"kind":"externalParam","text":"mutex"},{"text":": ","kind":"te